e(num_blocks, consolidated):\n108\t    mgr = BlockManager()\n109\t\n110\t    for dtype in [int, float]:\n111\t        for idx in range(num_blocks):\n112\t            col = mk.TensorColumn(np.arange(10, dtype=dtype) * idx)\n113\t            mgr.add_column(col, f\"col{idx}_{dtype}\")\n114\t    if consolidated:\n115\t        mgr.consolidate()\n116\t\n117\t    for slc in [\n118\t        slice(2, 6, 1),\n119\t        slice(0, 1, 1),\n120\t        slice(2, 8, 3),\n121\t        np.array([1, 4, 6]),\n122\t        np.array([True, False] * 5),\n123\t    ]:\n124\t        new_mgr = mgr.apply(method_name=\"_get\", index=slc)\n125\t        assert isinstance(new_mgr, BlockManager)\n126\t        for dtype in [int, float]:\n127\t            for idx in range(num_blocks):\n128\t                # check it's equivalent to applying the slice to each column in turn\n129\t                assert (\n130\t                    new_mgr[f\"col{idx}_{dtype}\"].data\n131\t                    == mgr[f\"col{idx}_{dtype}\"][slc].data\n132\t                ).all()\n133\t\n134\t                # check that the base is the same (since we're just slicing)\n135\t                assert (\n136\t                    new_mgr[f\"col{idx}_{dtype}\"].data.base\n137\t                    is mgr[f\"col{idx}_{dtype}\"][slc].data.base\n138\t                ) == isinstance(slc, slice)\n139\t\n140\t\n141\t@pytest.mark.parametrize(\n142\t    \"num_blocks, consolidated\",\n143\t    product([1, 2, 3], [True, False]),\n144\t)\n145\tdef test_apply_get_single(num_blocks, consolidated):\n146\t    mgr = BlockManager()\n147\t\n148\t    for dtype in [int, float]:\n149\t        for idx in range(num_blocks):\n150\t            col = mk.TensorColumn(np.arange(10, dtype=dtype) * idx)\n151\t            mgr.add_column(col, f\"col{idx}_{dtype}\")\n152\t    if consolidated:\n153\t        mgr.consolidate()\n154\t\n155\t    for slc in [0, 8]:\n156\t        result_dict = mgr.apply(method_name=\"_get\", index=slc)\n157\t        assert isinstance(result_dict, dict)\n158\t        for dtype in [int, float]:\n159\t            for idx in range(num_blocks):\n160\t                # check it's equivalent to applying the slice to each column in turn\n161\t                assert result_dict[f\"col{idx}_{dtype}\"] == mgr[f\"col{idx}_{dtype}\"][slc]\n162\t\n163\t\n164\t@pytest.fixture()\n165\tdef call_count(monkeypatch):\n166\t    from meerkat import TensorColumn\n167\t    from meerkat.block.numpy_block import NumPyBlock\n168\t\n169\t    calls = {\"count\": 0}\n170\t\n171\t    block_get = NumPyBlock._get\n172\t\n173\t    def patched_get(self, *args, **kwargs):\n174\t        nonlocal calls\n175\t        calls[\"count\"] += 1\n176\t        return block_get(self, *args, **kwargs)\n177\t\n178\t    monkeypatch.setattr(NumPyBlock, \"_get\", patched_get)\n179\t\n180\t    col_get = TensorColumn._get\n181\t\n182\t    def patched_get_col(self, *args, **kwargs):\n183\t        nonlocal calls\n184\t        calls[\"count\"] += 1\n185\t        return col_get(self, *args, **kwargs)\n186\t\n187\t    monkeypatch.setattr(TensorColumn, \"_get\", patched_get_col)\n188\t\n189\t    return calls\n190\t\n191\t\n192\t@product_parametrize({\"consolidated\": [True, False]})\n193\tdef test_apply_get_single_lambda(call_count, consolidated):\n194\t    mgr = BlockManager()\n195\t    base_col = mk.TensorColumn(np.arange(10))\n196\t    mgr.add_column(base_col, \"a\")\n197\t    # lambda_column = base_col.defer(lambda x: x + 2)\n198\t    # mgr.add_column(lambda_column, \"b\")\n199\t\n200\t    if consolidated:\n201\t        mgr.consolidate()\n202\t\n203\t    mgr.apply(method_name=\"_get\", index=1, materialize=True)\n204\t\n205\t    # we should only call NumpyBlock._get once\n206\t    assert call_count[\"count\"] == 1\n207\t\n208\t\n209\t@product_parametrize({\"consolidated\": [True, False]})\n210\tdef test_apply_get_multiple_lambda(call_count, consolidated):\n211\t    mgr = BlockManager()\n212\t\n213\t    base_col = mk.TensorColumn(np.arange(10))\n214