{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_09a3ed7c03874a59aeb6058e","type":"tool_result","content":"1\t# flake8: noqa\n2\tfrom os.path import isfile, expanduser\n3\tfrom unittest.mock import patch\n4\t\n5\tfrom pytest import fixture\n6\t\n7\t# Set up icecream globally for convenience.\n8\tfrom icecream import install as install_icecream\n9\t\n10\tfrom fabric.testing.fixtures import client, remote, sftp, sftp_objs, transfer\n11\t\n12\t\n13\tinstall_icecream()\n14\t\n15\t\n16\t# TODO: does this want to end up in the public fixtures module too?\n17\t@fixture(autouse=True)\n18\tdef no_user_ssh_config():\n19\t    \"\"\"\n20\t    Cowardly refuse to ever load what looks like user SSH config paths.\n21\t\n22\t    Prevents the invoking user's real config from gumming up test results or\n23\t    inflating test runtime (eg if it sets canonicalization on, which will incur\n24\t    DNS lookups for nearly all of this suite's bogus names).\n25\t    \"\"\"\n26\t    # An ugly, but effective, hack. I am not proud. I also don't see anything\n27\t    # that's >= as bulletproof and less ugly?\n28\t    # TODO: ideally this should expand to cover system config paths too, but\n29\t    # that's even less likely to be an issue.\n30\t    def no_config_for_you(path):\n31\t        if path == expanduser(\"~/.ssh/config\"):\n32\t            return False\n33\t        return isfile(path)\n34\t\n35\t    with patch(\"fabric.config.os.path.isfile\", no_config_for_you):\n36\t        yield\n37\t"}]},"parent_tool_use_id":null,"session_id":"d107d9ad-27cd-4683-96d4-27822778ea12","uuid":"b530ccca-365e-4344-ae9a-fcd3d8eebb57","timestamp":"2026-04-07T10:30:23.993Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tests/conftest.py","content":"# flake8: noqa\nfrom os.path import isfile, expanduser\nfrom unittest.mock import patch\n\nfrom pytest import fixture\n\n# Set up icecream globally for convenience.\nfrom icecream import install as install_icecream\n\nfrom fabric.testing.fixtures import client, remote, sftp, sftp_objs, transfer\n\n\ninstall_icecream()\n\n\n# TODO: does this want to end up in the public fixtures module too?\n@fixture(autouse=True)\ndef no_user_ssh_config():\n    \"\"\"\n    Cowardly refuse to ever load what looks like user SSH config paths.\n\n    Prevents the invoking user's real config from gumming up test results or\n    inflating test runtime (eg if it sets canonicalization on, which will incur\n    DNS lookups for nearly all of this suite's bogus names).\n    \"\"\"\n    # An ugly, but effective, hack. I am not proud. I also don't see anything\n    # that's >= as bulletproof and less ugly?\n    # TODO: ideally this should expand to cover system config paths too, but\n    # that's even less likely to be an issue.\n    def no_config_for_you(path):\n        if path == expanduser(\"~/.ssh/config\"):\n            return False\n        return isfile(path)\n\n    with patch(\"fabric.config.os.path.isfile\", no_config_for_you):\n        yield\n","numLines":37,"startLine":1,"totalLines":37}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_51eb9c311f8d418ab839ce08","type":"tool_result","content":"1\timport os\n2\timport time\n3\t\n4\tfrom io import StringIO\n5\t\n6\tfrom invoke import pty_size, CommandTimedOut\n7\tfrom invocations.environment import in_ci\n8\tfrom pytest import skip, raises\n9\tfrom pytest_relaxed import trap\n10\t\n11\tfrom fabric import Connection, Config\n12\t\n13\t\n14\t# TODO: use pytest markers\n15\tdef skip_outside_ci():\n16\t    if not in_ci():\n17\t        skip()\n18\t\n19\t\n20\tclass Connection_:\n21\t    class ssh_connections:\n22\t        def open_method_generates_real_connection(self):\n23\t            c = Connection(\"localhost\")\n24\t            c.open()\n25\t            assert c.client.get_transport().active is True\n26\t            assert c.is_connected is True\n27\t            return c\n28\t\n29\t        def close_method_closes_connection(self):\n30\t            # Handy shortcut - open things up, then return Connection for us to\n31\t            # close\n32\t            c = self.open_method_generates_real_connection()\n33\t            c.close()\n34\t            assert c.client.get_transport() is None\n35\t            assert c.is_connected is False\n36\t\n37\t    class run:\n38\t        def simple_command_on_host(self):\n39\t            \"\"\"\n40\t            Run command on localhost\n41\t            \"\"\"\n42\t            result = Connection(\"localhost\").run(\"echo foo\", hide=True)\n43\t            assert result.stdout == \"foo\\n\"\n44\t            assert result.exited == 0\n45\t            assert result.ok is True\n46\t\n47\t        def simple_command_with_pty(self):\n48\t            \"\"\"\n49\t            Run command under PTY on localhost\n50\t            \"\"\"\n51\t            # Most Unix systems should have stty, which asplodes when not run\n52\t            # under a pty, and prints useful info otherwise\n53\t            result = Connection(\"localhost\").run(\n54\t                \"stty size\", hide=True, pty=True\n55\t            )\n56\t            found = result.stdout.strip().split()\n57\t            cols, rows = pty_size()\n58\t            assert tuple(map(int, found)), rows == cols\n59\t            # PTYs use \\r\\n, not \\n, line separation\n60\t            assert \"\\r\\n\" in result.stdout\n61\t            assert result.pty is True\n62\t\n63\t    class shell:\n64\t        @trap\n65\t        def base_case(self):\n66\t            result = Connection(\"localhost\").shell(\n67\t                # Some extra newlines to make sure it doesn't get split up by\n68\t                # motd/prompt\n69\t                in_stream=StringIO(\"\\n\\nexit\\n\")\n70\t            )\n71\t            assert result.command is None\n72\t            assert \"exit\" in result.stdout\n73\t            assert result.stderr == \"\"\n74\t            assert result.exited == 0\n75\t            assert result.pty is True\n76\t\n77\t    class local:\n78\t        def wraps_invoke_run(self):\n79\t            # NOTE: most of the interesting tests about this are in\n80\t            # invoke.runners / invoke.integration.\n81\t            cxn = Connection(\"localhost\")\n82\t            result = cxn.local(\"echo foo\", hide=True)\n83\t            assert result.stdout == \"foo\\n\"\n84\t            assert not cxn.is_connected  # meh way of proving it didn't use SSH\n85\t\n86\t    def mixed_use_of_local_and_run(self):\n87\t        \"\"\"\n88\t        Run command truly locally, and over SSH via localhost\n89\t        \"\"\"\n90\t        cxn = Connection(\"localhost\")\n91\t        result = cxn.local(\"echo foo\", hide=True)\n92\t        assert result.stdout == \"foo\\n\"\n93\t        assert not cxn.is_connected  # meh way of proving it didn't use SSH yet\n94\t        result = cxn.run(\"echo foo\", hide=True)\n95\t        assert cxn.is_connected  # NOW it's using SSH\n96\t        assert result.stdout == \"foo\\n\"\n97\t\n98\t    class sudo:\n99\t        def setup(self):\n100\t            # NOTE: assumes a user configured for passworded (NOT\n101\t            # passwordless)_sudo, whose password is 'mypass', is executing the\n102\t            # test suite. I.e. our travis-ci setup.\n103\t            config = Config(\n104\t                {\"sudo\": {\"password\": \"mypass\"}, \"run\": {\"hide\": True}}\n105\t            )\n106\t            self.cxn = Connection(\"localhost\", config=config)\n107\t\n108\t        def sudo_command(self):\n109\t            \"\"\"\n110\t            Run command via sudo on host localhost\n111\t            \"\"\"\n112\t            skip_outside_ci()\n113\t            assert self.cxn.sudo(\"whoami\").stdout.strip() == \"root\"\n114\t\n115\t        def mixed_sudo_and_normal_commands(self):\n116\t            \"\"\"\n117\t            Run command via sudo, and not via sudo, on localhost\n118\t            \"\"\"\n119\t            skip_outside_ci()\n120\t            logname = os.environ[\"LOGNAME\"]\n121\t            assert self.cxn.run(\"whoami\").stdout.strip() == logname\n122\t            assert self.cxn.sudo(\"whoami\").stdout.strip() == \"root\"\n123\t\n124\t    def large_remote_commands_finish_cleanly(self):\n125\t        # Guards against e.g. cleanup finishing before actually reading all\n126\t        # data from the remote end. Which is largely an issue in Invoke-level\n127\t        # code but one that only really manifests when doing stuff over the\n128\t        # network. Yay computers!\n129\t        path = \"/usr/share/dict/words\"\n130\t        cxn = Connection(\"localhost\")\n131\t        with open(path) as fd:\n132\t            words = [x.strip() for x in fd.readlines()]\n133\t        stdout = cxn.run(\"cat {}\".format(path), hide=True).stdout\n134\t        lines = [x.strip() for x in stdout.splitlines()]\n135\t        # When bug present, # lines received is significantly fewer than the\n136\t        # true count in the file (by thousands).\n137\t        assert len(lines) == len(words)\n138\t\n139\t    class command_timeout:\n140\t        def setup(self):\n141\t            self.cxn = Connection(\"localhost\")\n142\t\n143\t        def does_not_raise_exception_when_under_timeout(self):\n144\t            assert self.cxn.run(\"sleep 1\", timeout=3)\n145\t\n146\t        def raises_exception_when_over_timeout(self):\n147\t            with raises(CommandTimedOut) as info:\n148\t                start = time.time()\n149\t                self.cxn.run(\"sleep 5\", timeout=1)\n150\t            elapsed = time.time() - start\n151\t            assert info.value.timeout == 1\n152\t            # Catch scenarios where we except but don't actually shut down\n153\t            # early (w/ a bit of fudge time for overhead)\n154\t            assert elapsed <= 2\n155\t"}]},"parent_tool_use_id":null,"session_id":"d107d9ad-27cd-4683-96d4-27822778ea12","uuid":"49ce62b6-c65a-4bd3-8316-65dbd29f2f64","timestamp":"2026-04-07T10:30:23.994Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/integration/connection.py","content":"import os\nimport time\n\nfrom io import StringIO\n\nfrom invoke import pty_size, CommandTimedOut\nfrom invocations.environment import in_ci\nfrom pytest import skip, raises\nfrom pytest_relaxed import trap\n\nfrom fabric import Connection, Config\n\n\n# TODO: use pytest markers\ndef skip_outside_ci():\n    if not in_ci():\n        skip()\n\n\nclass Connection_:\n    class ssh_connections:\n        def open_method_generates_real_connection(self):\n            c = Connection(\"localhost\")\n            c.open()\n            assert c.client.get_transport().active is True\n            assert c.is_connected is True\n            return c\n\n        def close_method_closes_connection(self):\n            # Handy shortcut - open things up, then return Connection for us to\n            # close\n            c = self.open_method_generates_real_connection()\n            c.close()\n            assert c.client.get_transport() is None\n            assert c.is_connected is False\n\n    class run:\n        def simple_command_on_host(self):\n            \"\"\"\n            Run command on localhost\n            \"\"\"\n            result = Connection(\"localhost\").run(\"echo foo\", hide=True)\n            assert result.stdout == \"foo\\n\"\n            assert result.exited == 0\n            assert result.ok is True\n\n        def simple_command_with_pty(self):\n            \"\"\"\n            Run command under PTY on localhost\n            \"\"\"\n            # Most Unix systems should have stty, which asplodes when not run\n            # under a pty, and prints useful info otherwise\n            result = Connection(\"localhost\").run(\n                \"stty size\", hide=True, pty=True\n            )\n            found = result.stdout.strip().split()\n            cols, rows = pty_size()\n            assert tuple(map(int, found)), rows == cols\n            # PTYs use \\r\\n, not \\n, line separation\n            assert \"\\r\\n\" in result.stdout\n            assert result.pty is True\n\n    class shell:\n        @trap\n        def base_case(self):\n            result = Connection(\"localhost\").shell(\n                # Some extra newlines to make sure it doesn't get split up by\n                # motd/prompt\n                in_stream=StringIO(\"\\n\\nexit\\n\")\n            )\n            assert result.command is None\n            assert \"exit\" in result.stdout\n            assert result.stderr == \"\"\n            assert result.exited == 0\n            assert result.pty is True\n\n    class local:\n        def wraps_invoke_run(self):\n            # NOTE: most of the interesting tests about this are in\n            # invoke.runners / invoke.integration.\n            cxn = Connection(\"localhost\")\n            result = cxn.local(\"echo foo\", hide=True)\n            assert result.stdout == \"foo\\n\"\n            assert not cxn.is_connected  # meh way of proving it didn't use SSH\n\n    def mixed_use_of_local_and_run(self):\n        \"\"\"\n        Run command truly locally, and over SSH via localhost\n        \"\"\"\n        cxn = Connection(\"localhost\")\n        result = cxn.local(\"echo foo\", hide=True)\n        assert result.stdout == \"foo\\n\"\n        assert not cxn.is_connected  # meh way of proving it didn't use SSH yet\n        result = cxn.run(\"echo foo\", hide=True)\n        assert cxn.is_connected  # NOW it's using SSH\n        assert result.stdout == \"foo\\n\"\n\n    class sudo:\n        def setup(self):\n            # NOTE: assumes a user configured for passworded (NOT\n            # passwordless)_sudo, whose password is 'mypass', is executing the\n            # test suite. I.e. our travis-ci setup.\n            config = Config(\n                {\"sudo\": {\"password\": \"mypass\"}, \"run\": {\"hide\": True}}\n            )\n            self.cxn = Connection(\"localhost\", config=config)\n\n        def sudo_command(self):\n            \"\"\"\n            Run command via sudo on host localhost\n            \"\"\"\n            skip_outside_ci()\n            assert self.cxn.sudo(\"whoami\").stdout.strip() == \"root\"\n\n        def mixed_sudo_and_normal_commands(self):\n            \"\"\"\n            Run command via sudo, and not via sudo, on localhost\n            \"\"\"\n            skip_outside_ci()\n            logname = os.environ[\"LOGNAME\"]\n            assert self.cxn.run(\"whoami\").stdout.strip() == logname\n            assert self.cxn.sudo(\"whoami\").stdout.strip() == \"root\"\n\n    def large_remote_commands_finish_cleanly(self):\n        # Guards against e.g. cleanup finishing before actually reading all\n        # data from the remote end. Which is largely an issue in Invoke-level\n        # code but one that only really manifests when doing stuff over the\n        # network. Yay computers!\n        path = \"/usr/share/dict/words\"\n        cxn = Connection(\"localhost\")\n        with open(path) as fd:\n            words = [x.strip() for x in fd.readlines()]\n        stdout = cxn.run(\"cat {}\".format(path), hide=True).stdout\n        lines = [x.strip() for x in stdout.splitlines()]\n        # When bug present, # lines received is significantly fewer than the\n        # true count in the file (by thousands).\n        assert len(lines) == len(words)\n\n    class command_timeout:\n        def setup(self):\n            self.cxn = Connection(\"localhost\")\n\n        def does_not_raise_exception_when_under_timeout(self):\n            assert self.cxn.run(\"sleep 1\", timeout=3)\n\n        def raises_exception_when_over_timeout(self):\n            with raises(CommandTimedOut) as info:\n                start = time.time()\n                self.cxn.run(\"sleep 5\", timeout=1)\n            elapsed = time.time() - start\n            assert info.value.timeout == 1\n            # Catch scenarios where we except but don't actually shut down\n            # early (w/ a bit of fudge time for overhead)\n            assert elapsed <= 2\n","numLines":155,"startLine":1,"totalLines":155}}}
