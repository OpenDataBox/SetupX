"pandas >= 2.0.0\",\n70\t]\n71\t\n72\t[project.urls]\n73\t\"Homepage\" = \"https://github.com/EMI-Group/evox\"\n74\t\"Bug Tracker\" = \"https://github.com/EMI-Group/evox/issues\"\n75\t\n76\t[tool.ruff]\n77\t# Allow lines to be as long as 128. (default: 88)\n78\tline-length = 128\n79\t# Use `\\n` line endings for all files\n80\tformat.line-ending = \"lf\"\n81\t# F: Pyflakes / E, W: pycodestyle / I: isort / NPY: numpy\n82\tlint.select = [\"F\", \"E\", \"W\", \"I\", \"NPY\"]\n83\tlint.ignore = [\"E501\"] # Ignore line length error\n84\tlint.per-file-ignores = {\"*.ipynb\" = [\"I001\"], \"src/evox/__init__.py\" = [\"I001\"], \"src/evox_ext/autoload_ext.py\" = [\"I001\"]}"}]},"parent_tool_use_id":null,"session_id":"d3836cae-35d2-4f23-a394-cd5635739d01","uuid":"4ea0016a-15ca-438d-948f-c532a57320a6","timestamp":"2026-04-07T04:38:29.000Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pyproject.toml","content":"[build-system]\nrequires = [\"setuptools>=61.0\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"evox\"\nversion = \"1.3.0\"\nauthors = [\n  { name = \"Bill Huang\", email = \"bill.huang2001@gmail.com\" },\n  { name = \"Boqing Xu\", email = \"xuboqing123@gmail.com\" },\n  { name = \"Christina Lee\", email = \"1315552992@qq.com\" },\n  { name = \"Kevin Sun\", email = \"skk7757@163.com\" },\n  { name = \"Yanchen Li\", email = \"48726053+liyc5929@users.noreply.github.com\" },\n  { name = \"Zhenyu Liang\", email = \"zhenyuliang97@gmail.com\" },\n]\ndescription = \"evox\"\nreadme = \"README.md\"\nlicense = \"GPL-3.0-or-later\"\nrequires-python = \">=3.10\"\nclassifiers = [\n  \"Programming Language :: Python :: 3\",\n  \"Intended Audience :: Science/Research\",\n  \"Topic :: Scientific/Engineering :: Artificial Intelligence\",\n]\n\ndependencies = [\n  \"torch >= 2.6.0\",\n  \"numpy >= 2.0.0\",\n]\n\n[project.optional-dependencies]\nvis = [\n  \"plotly >= 5.0.0\",\n  \"pandas >= 2.0.0\",\n]\n\nneuroevolution = [\n  \"torchvision >= 0.16.0\",\n  \"brax >= 0.12.0\",\n  \"playground >= 0.0.4\",\n  \"imageio >= 2.0.0\",\n]\n\ntest = [\n  \"torchvision >= 0.16.0\",\n  \"brax >= 0.12.0\",\n  \"plotly >= 5.0.0\",\n  \"playground >= 0.0.4\",\n  \"imageio >= 2.0.0\",\n]\n\ndocs = [\n  \"shibuya\",\n  \"sphinx-autodoc2\",\n  \"sphinx\",\n  \"nbsphinx\",\n  \"myst-nb\",\n  \"ipython\",\n  \"myst-parser[linkify]\",\n  \"sphinx_copybutton\",\n  \"sphinx_design\",\n  \"sphinx-favicon\",\n  \"sphinxcontrib-mermaid\",\n  \"polib\",\n]\n\ndefault = [\n  \"plotly >= 5.0.0\",\n  \"pandas >= 2.0.0\",\n]\n\n[project.urls]\n\"Homepage\" = \"https://github.com/EMI-Group/evox\"\n\"Bug Tracker\" = \"https://github.com/EMI-Group/evox/issues\"\n\n[tool.ruff]\n# Allow lines to be as long as 128. (default: 88)\nline-length = 128\n# Use `\\n` line endings for all files\nformat.line-ending = \"lf\"\n# F: Pyflakes / E, W: pycodestyle / I: isort / NPY: numpy\nlint.select = [\"F\", \"E\", \"W\", \"I\", \"NPY\"]\nlint.ignore = [\"E501\"] # Ignore line length error\nlint.per-file-ignores = {\"*.ipynb\" = [\"I001\"], \"src/evox/__init__.py\" = [\"I001\"], \"src/evox_ext/autoload_ext.py\" = [\"I001\"]}","numLines":84,"startLine":1,"totalLines":84}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_9af2e682fb014908a84aa59e","type":"tool_result","content":"1\t# EvoX Installation Guide\n2\t\n3\t## Install EvoX\n4\t\n5\tEvoX is available at PyPI and can be installed via:\n6\t\n7\t```bash\n8\t# install pytorch first\n9\t# for example:\n10\tpip install torch\n11\t\n12\t# then install EvoX\n13\tpip install \"evox[default]\"\n14\t```\n15\t\n16\tYou can also assign extra options during the installation, currently available extras are `vis`, `neuroevolution`, `test`, `docs`, `default`. For example, to install EvoX with all features, run the following command:\n17\t\n18\t```bash\n19\tpip install \"evox[vis,neuroevolution]\"\n20\t```\n21\t\n22\t## Install PyTorch with accelerator support\n23\t\n24\t`evox` relies on `torch` to provide hardware acceleration.\n25\tThe overall architecture of these Python packages looks like this:\n26\t\n27\t```{mermaid}\n28\tstateDiagram-v2\n29\t    torch : torch\n30\t    nv_gpu : NVIDIA GPU\n31\t    amd_gpu : AMD GPU\n32\t    cpu : CPU\n33\t\n34\t    direction LR\n35\t\n36\t    evox --> torch\n37\t    torch --> nv_gpu\n38\t    torch --> amd_gpu\n39\t    torch --> cpu\n40\t```\n41\t\n42\tTo summarize, whether `evox` has CPU support or Nvidia GPU support (CUDA) or AMD GPU support (ROCm) depends on the installed PyTorch version. Please refer to the PyTorch official website for more installation help: [`torch`](https://pytorch.org/)\n43\t\n44\t\n45\t## Nvidia GPU support on Windows\n46\t\n47\tEvoX support GPU acceleration through PyTorch.\n48\tThere are two ways to use PyTorch with GPU acceleration on Windows:\n49\t\n50\t1. Using WSL 2 (Windows Subsystem for Linux) and install PyTorch on the Linux side.\n51\t2. Directly install PyTorch on Windows.\n52\t\n53\tFor option 2, we provide a [one-click script](/_static/win-install.bat) for fast deployment on fresh installed windows 10/11 64bit with Nvidia GPUs. The script will not use WSL 2 and will install the native Pytorch version on Windows. It will automatically install related applications like VSCode, Git and MiniForge3.\n54\t\n55\t* Ensure the [Nvidia driver](https://www.nvidia.com/Download/index.aspx?lang=en-us) is properly installed first. Otherwise the script will fall back to cpu mode.\n56\t* When running the script, ensure a stable network (accessible to `github.com` etc.).\n57\t* If the script is failed due to network failure, close and reopen it to continue the installation.\n58\t\n59\t### Manual installation on Windows\n60\t\n61\tIf you prefer to install PyTorch directly on Windows manually, you can follow the steps below:\n62\t1. Install Nvidia driver as mentioned above.\n63\t2. Install Python 3.10 or above from [python.org](https://www.python.org/downloads/).\n64\t3. Install PyTorch.\n65\t4. (Optional) Install [`triton-windows`](https://github.com/woct0rdho/triton-windows) for `torch.compile` support on Windows.\n66\t5. Install EvoX.\n67\t\n68\t### Windows WSL 2\n69\t\n70\tDownload the [latest NVIDIA Windows GPU Driver](https://www.nvidia.com/Download/index.aspx?lang=en-us) and install it. Then your WSL 2 will support Nvidia GPUs in its Linux environments.\n71\t\n72\t```{warning}\n73\tDo **NOT** install any NVIDIA GPU Linux driver within WSL 2. Install the driver on the Windows side.\n74\t```\n75\t\n76\t```{seealso}\n77\tNVIDIA has a detailed [CUDA on WSL User Guide](https://docs.nvidia.com/cuda/wsl-user-guide/index.html)\n78\t```\n79\t\n80\t## AMD GPU (ROCm) support\n81\t\n82\tWe recommend using a Docker container from [`rocm/pytorch`](https://hub.docker.com/r/rocm/pytorch).\n83\t\n84\t```shell\n85\tdocker run -it --network=host --device=/dev/kfd --device=/dev/dri --group-add=video --ipc=host --cap-add=SYS_PTRACE --security-opt seccomp=unconfined --shm-size 8G -v $HOME/dockerx:/dockerx -w /dockerx rocm/pytorch​:latest\n86\t```\n87\t\n88\t## Verify the installation\n89\t\n90\tOpen a Python terminal, and run the following:\n91\t\n92\t```python\n93\tfrom torch.utils.collect_env import get_pretty_env_info\n94\timport evox\n95\t\n96\tprint(get_pretty_env_info())\n97\t```\n98\t"}]},"parent_tool_use_id":null,"session_id":"d3836cae-35d2-4f23-a394-cd5635739d01","uuid":"57803cef-74f0-4abb-b138-13cccea99ebd","timestamp":"2026-04-07T04:38:29.001Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/source/guide/install/torch_and_evox.md","content":"# EvoX Installation Guide\n\n## Install EvoX\n\nEvoX is available at PyPI and can be installed via:\n\n```bash\n# install pytorch first\n# for example:\npip install torch\n\n# then install EvoX\npip install \"evox[default]\"\n```\n\nYou can also assign extra options during the installation, currently available extras are `vis`, `neuroevolution`, `test`, `docs`, `default`. For example, to install EvoX with all features, run the following command:\n\n```bash\npip install \"evox[vis,neuroevolution]\"\n```\n\n## Install PyTorch with accelerator support\n\n`evox` relies on `torch` to provide hardware acceleration.\nThe overall architecture of these Python packages looks like this:\n\n```{mermaid}\nstateDiagram-v2\n    torch : torch\n    nv_gpu : NVIDIA GPU\n    amd_gpu : AMD GPU\n    cpu : CPU\n\n    direction LR\n\n    evox --> torch\n    torch --> nv_gpu\n    torch --> amd_gpu\n    torch --> cpu\n```\n\nTo summarize, whether `evox` has CPU support or Nvidia GPU support (CUDA) or AMD GPU support (ROCm) depends on the installed PyTorch version. Please refer to the PyTorch official website for more installation help: [`torch`](https://pytorch.org/)\n\n\n## Nvidia GPU support on Windows\n\nEvoX support GPU acceleration through PyTorch.\nThere are two ways to use PyTorch with GPU acceleration on Windows:\n\n1. Using WSL 2 (Windows Subsystem for Linux) and install PyTorch on the Linux side.\n2. Directly install PyTorch on Windows.\n\nFor option 2, we provide a [one-click script](/_static/win-install.bat) for fast deployment on fresh installed windows 10/11 64bit with Nvidia GPUs. The script will not use WSL 2 and will install the native Pytorch version on Windows. It will automatically install related applications like VSCode, Git and MiniForge3.\n\n* Ensure the [Nvidia driver](https://www.nvidia.com/Download/index.aspx?lang=en-us) is properly installed first. Otherwise the script will fall back to cpu mode.\n* When running the script, ensure a stable network (accessible to `github.com` etc.).\n* If the script is failed due to network failure, close and reopen it to continue the installation.\n\n### Manual installation on Windows\n\nIf you prefer to install PyTorch directly on Windows manually, you can follow the steps below:\n1. Install Nvidia driver as mentioned above.\n2. Install Python 3.10 or above from [python.org](https://www.python.org/downloads/).\n3. Install PyTorch.\n4. (Optional) Install [`triton-windows`](https://github.com/woct0rdho/triton-windows) for `torch.compile` support on Windows.\n5. Install EvoX.\n\n### Windows WSL 2\n\nDownload the [latest NVIDIA Windows GPU Driver](https://www.nvidia.com/Download/index.aspx?lang=en-us) and install it. Then your WSL 2 will support Nvidia GPUs in its Linux environments.\n\n```{warning}\nDo **NOT** install any NVIDIA GPU Linux driver within WSL 2. Install the driver on the Windows side.\n```\n\n```{seealso}\nNVIDIA has a detailed [CUDA on WSL User Guide](https://docs.nvidia.com/cuda/wsl-user-guide/index.html)\n```\n\n## AMD GPU (ROCm) support\n\nWe recommend using a Docker container from [`rocm/pytorch`](https://hub.docker.com/r/rocm/pytorch).\n\n```shell\ndocker run -it --network=host --device=/dev/kfd --device=/dev/dri --group-add=video --ipc=host --cap-add=SYS_PTRACE --security-opt seccomp=unconfined --shm-size 8G -v $HOME/dockerx:/dockerx -w /dockerx rocm/pytorch​:latest\n```\n\n## Verify the installation\n\nOpen a Python terminal, and run the following:\n\n```python\nfrom torch.utils.collect_env import get_pretty_env_info\nimport evox\n\nprint(get_pretty_env_info())\n```\n","numLines":98,"startLine":1,"totalLines":98}}}
