{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_79ee779f56b54d99ac7ba528","type":"tool_result","content":"1\timport os\n2\t\n3\timport torch\n4\tfrom torch.profiler import ProfilerActivity, profile\n5\t\n6\tfrom evox.core import Algorithm, Problem, compile, use_state, vmap\n7\tfrom evox.workflows import EvalMonitor, StdWorkflow\n8\t\n9\t\n10\tclass Sphere(Problem):\n11\t    def __init__(self):\n12\t        super().__init__()\n13\t\n14\t    def evaluate(self, pop: torch.Tensor):\n15\t        return (pop**2).sum(-1)\n16\t\n17\t\n18\tdef test(\n19\t    algo: Algorithm,\n20\t    print_path: str | None = None,\n21\t    profiling: bool = True,\n22\t    test_compile: bool = True,\n23\t):\n24\t    print(\"Current device: \", torch.get_default_device())\n25\t\n26\t    monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n27\t    prob = Sphere()\n28\t    workflow = StdWorkflow(algo, prob, monitor)\n29\t    workflow.init_step()\n30\t    # test compile step\n31\t    if test_compile:\n32\t        state_step = use_state(workflow.step)\n33\t        compile_step = compile(workflow.step)\n34\t        vmap_state_step = vmap(state_step, randomness=\"different\")\n35\t        vmap_state_step = compile(vmap_state_step, fullgraph=True)\n36\t    else:\n37\t        compile_step = workflow.step\n38\t    # print\n39\t    if print_path is not None:\n40\t        with open(os.path.join(print_path, \"compile.md\"), \"w\") as ff:\n41\t            ff.write(torch._dynamo.explain(compile_step)().__str__())\n42\t        if test_compile:\n43\t            with open(os.path.join(print_path, \"compile_vmap.md\"), \"w\") as ff:\n44\t                state = torch.func.stack_module_state([workflow] * 3)\n45\t                state = state[0] | state[1]\n46\t                ff.write(\n47\t                    torch._dynamo.explain(vmap_state_step)(state).__str__()\n48\t                )\n49\t    # profile\n50\t    print(\"Initial best fitness:\", workflow.monitor.topk_fitness)\n51\t    compile_step()\n52\t    if profiling:\n53\t        with profile(\n54\t            activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n55\t        ) as prof:\n56\t            for _ in range(1000):\n57\t                compile_step()\n58\t        print(prof.key_averages().table(), flush=True)\n59\t    else:\n60\t        for _ in range(1000):\n61\t            compile_step()\n62\t    print(\"Final best fitness:\", workflow.monitor.topk_fitness)\n63\t    torch.cuda.synchronize()\n64\t    if test_compile:\n65\t        state = torch.func.stack_module_state([workflow] * 3)\n66\t        state = state[0] | state[1]\n67\t        vmap_state_step(state)\n68\t        print(\"Initial best fitness:\", state[\"monitor.topk_fitness\"])\n69\t        if profiling:\n70\t            with profile(\n71\t                activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n72\t            ) as prof:\n73\t                for _ in range(1000):\n74\t                    state = vmap_state_step(state)\n75\t            print(prof.key_averages().table(), flush=True)\n76\t        else:\n77\t            for _ in range(1000):\n78\t                state = vmap_state_step(state)\n79\t        print(\"Final best fitness:\", state[\"monitor.topk_fitness\"])\n80\t        torch.cuda.synchronize()\n81\t\n82\t\n83\tif __name__ == \"__main__\":\n84\t    torch.set_default_device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n85\t\n86\t    from evox.algorithms import PSO\n87\t\n88\t    test(PSO(pop_size=1000, lb=-10 * torch.ones(50), ub=10 * torch.ones(50)))\n89\t"}]},"parent_tool_use_id":null,"session_id":"d3836cae-35d2-4f23-a394-cd5635739d01","uuid":"38c04eb1-4a6e-4f45-9e21-47977412a806","timestamp":"2026-04-07T04:38:42.007Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/benchmarks/test_base.py","content":"import os\n\nimport torch\nfrom torch.profiler import ProfilerActivity, profile\n\nfrom evox.core import Algorithm, Problem, compile, use_state, vmap\nfrom evox.workflows import EvalMonitor, StdWorkflow\n\n\nclass Sphere(Problem):\n    def __init__(self):\n        super().__init__()\n\n    def evaluate(self, pop: torch.Tensor):\n        return (pop**2).sum(-1)\n\n\ndef test(\n    algo: Algorithm,\n    print_path: str | None = None,\n    profiling: bool = True,\n    test_compile: bool = True,\n):\n    print(\"Current device: \", torch.get_default_device())\n\n    monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n    prob = Sphere()\n    workflow = StdWorkflow(algo, prob, monitor)\n    workflow.init_step()\n    # test compile step\n    if test_compile:\n        state_step = use_state(workflow.step)\n        compile_step = compile(workflow.step)\n        vmap_state_step = vmap(state_step, randomness=\"different\")\n        vmap_state_step = compile(vmap_state_step, fullgraph=True)\n    else:\n        compile_step = workflow.step\n    # print\n    if print_path is not None:\n        with open(os.path.join(print_path, \"compile.md\"), \"w\") as ff:\n            ff.write(torch._dynamo.explain(compile_step)().__str__())\n        if test_compile:\n            with open(os.path.join(print_path, \"compile_vmap.md\"), \"w\") as ff:\n                state = torch.func.stack_module_state([workflow] * 3)\n                state = state[0] | state[1]\n                ff.write(\n                    torch._dynamo.explain(vmap_state_step)(state).__str__()\n                )\n    # profile\n    print(\"Initial best fitness:\", workflow.monitor.topk_fitness)\n    compile_step()\n    if profiling:\n        with profile(\n            activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n        ) as prof:\n            for _ in range(1000):\n                compile_step()\n        print(prof.key_averages().table(), flush=True)\n    else:\n        for _ in range(1000):\n            compile_step()\n    print(\"Final best fitness:\", workflow.monitor.topk_fitness)\n    torch.cuda.synchronize()\n    if test_compile:\n        state = torch.func.stack_module_state([workflow] * 3)\n        state = state[0] | state[1]\n        vmap_state_step(state)\n        print(\"Initial best fitness:\", state[\"monitor.topk_fitness\"])\n        if profiling:\n            with profile(\n                activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n            ) as prof:\n                for _ in range(1000):\n                    state = vmap_state_step(state)\n            print(prof.key_averages().table(), flush=True)\n        else:\n            for _ in range(1000):\n                state = vmap_state_step(state)\n        print(\"Final best fitness:\", state[\"monitor.topk_fitness\"])\n        torch.cuda.synchronize()\n\n\nif __name__ == \"__main__\":\n    torch.set_default_device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n    from evox.algorithms import PSO\n\n    test(PSO(pop_size=1000, lb=-10 * torch.ones(50), ub=10 * torch.ones(50)))\n","numLines":89,"startLine":1,"totalLines":89}}}
