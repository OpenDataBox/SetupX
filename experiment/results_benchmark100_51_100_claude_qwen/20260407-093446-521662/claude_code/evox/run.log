{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_b8db82b54da4411abbd02922","type":"tool_result","content":"1\tfrom unittest import TestCase\n2\t\n3\timport torch\n4\t\n5\tfrom evox.core import Algorithm, Problem, use_state, vmap\n6\tfrom evox.workflows import EvalMonitor, StdWorkflow\n7\t\n8\t\n9\tdef transform_getitem_args(x: torch.Tensor, index_args):\n10\t    print(x, index_args)\n11\t    if isinstance(index_args, tuple):\n12\t        return (x, list(index_args))\n13\t    elif not isinstance(index_args, (list, tuple)):\n14\t        return (x, [index_args])\n15\t    return (x, index_args)\n16\t\n17\t\n18\tclass Sphere(Problem):\n19\t    def __init__(self):\n20\t        super().__init__()\n21\t\n22\t    def evaluate(self, pop: torch.Tensor):\n23\t        return (pop**2).sum(-1)\n24\t\n25\t\n26\tclass TestBase(TestCase):\n27\t    def run_algorithm(self, algo: Algorithm):\n28\t        state_dict = algo.state_dict()\n29\t        monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n30\t        prob = Sphere()\n31\t        workflow = StdWorkflow(algo, prob, monitor)\n32\t        workflow.init_step()\n33\t        self.assertIsNotNone(workflow.get_submodule(\"monitor\").topk_fitness)\n34\t        for _ in range(3):\n35\t            workflow.step()\n36\t        # reset state\n37\t        algo.load_state_dict(state_dict)\n38\t\n39\t    def run_compiled_algorithm(self, algo: Algorithm):\n40\t        state_dict = algo.state_dict()\n41\t        monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n42\t        prob = Sphere()\n43\t        workflow = StdWorkflow(algo, prob, monitor)\n44\t        workflow.init_step()\n45\t        jit_state_step = torch.compile(workflow.step)\n46\t        for _ in range(3):\n47\t            jit_state_step()\n48\t        # reset state\n49\t        algo.load_state_dict(state_dict)\n50\t\n51\t    def run_vmap_algorithm(self, algo: Algorithm):\n52\t        prob = Sphere()\n53\t        workflow = StdWorkflow(algo, prob)\n54\t        params, buffers = torch.func.stack_module_state([workflow] * 3)\n55\t        state = params | buffers\n56\t\n57\t        vmap_state_init_step = vmap(use_state(workflow.init_step), randomness=\"different\")\n58\t        vmap_state_init_step = torch.compile(vmap_state_init_step)\n59\t        vmap_state_step = vmap(use_state(workflow.step), randomness=\"different\")\n60\t        vmap_state_step = torch.compile(vmap_state_step)\n61\t        state = vmap_state_init_step(state)\n62\t        for _ in range(3):\n63\t            state = vmap_state_step(state)\n64\t\n65\t    def run_all(self, algo: Algorithm):\n66\t        self.run_algorithm(algo)\n67\t        self.run_compiled_algorithm(algo)\n68\t        self.run_vmap_algorithm(algo)\n69\t"}]},"parent_tool_use_id":null,"session_id":"d3836cae-35d2-4f23-a394-cd5635739d01","uuid":"4fa7de05-83e5-41d8-9ed9-6debb0a076aa","timestamp":"2026-04-07T04:52:00.454Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/unit_test/algorithms/test_base.py","content":"from unittest import TestCase\n\nimport torch\n\nfrom evox.core import Algorithm, Problem, use_state, vmap\nfrom evox.workflows import EvalMonitor, StdWorkflow\n\n\ndef transform_getitem_args(x: torch.Tensor, index_args):\n    print(x, index_args)\n    if isinstance(index_args, tuple):\n        return (x, list(index_args))\n    elif not isinstance(index_args, (list, tuple)):\n        return (x, [index_args])\n    return (x, index_args)\n\n\nclass Sphere(Problem):\n    def __init__(self):\n        super().__init__()\n\n    def evaluate(self, pop: torch.Tensor):\n        return (pop**2).sum(-1)\n\n\nclass TestBase(TestCase):\n    def run_algorithm(self, algo: Algorithm):\n        state_dict = algo.state_dict()\n        monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n        prob = Sphere()\n        workflow = StdWorkflow(algo, prob, monitor)\n        workflow.init_step()\n        self.assertIsNotNone(workflow.get_submodule(\"monitor\").topk_fitness)\n        for _ in range(3):\n            workflow.step()\n        # reset state\n        algo.load_state_dict(state_dict)\n\n    def run_compiled_algorithm(self, algo: Algorithm):\n        state_dict = algo.state_dict()\n        monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n        prob = Sphere()\n        workflow = StdWorkflow(algo, prob, monitor)\n        workflow.init_step()\n        jit_state_step = torch.compile(workflow.step)\n        for _ in range(3):\n            jit_state_step()\n        # reset state\n        algo.load_state_dict(state_dict)\n\n    def run_vmap_algorithm(self, algo: Algorithm):\n        prob = Sphere()\n        workflow = StdWorkflow(algo, prob)\n        params, buffers = torch.func.stack_module_state([workflow] * 3)\n        state = params | buffers\n\n        vmap_state_init_step = vmap(use_state(workflow.init_step), randomness=\"different\")\n        vmap_state_init_step = torch.compile(vmap_state_init_step)\n        vmap_state_step = vmap(use_state(workflow.step), randomness=\"different\")\n        vmap_state_step = torch.compile(vmap_state_step)\n        state = vmap_state_init_step(state)\n        for _ in range(3):\n            state = vmap_state_step(state)\n\n    def run_all(self, algo: Algorithm):\n        self.run_algorithm(algo)\n        self.run_compiled_algorithm(algo)\n        self.run_vmap_algorithm(algo)\n","numLines":69,"startLine":1,"totalLines":69}}}
