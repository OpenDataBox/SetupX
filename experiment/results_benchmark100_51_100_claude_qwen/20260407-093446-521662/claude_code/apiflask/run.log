{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_64add9a8778840e1be3f8e8c","type":"tool_result","content":"1\tfrom __future__ import annotations\n2\t\n3\timport typing as t\n4\timport warnings\n5\t\n6\tfrom flask import current_app\n7\tfrom flask import g\n8\tfrom flask import request\n9\tfrom flask_httpauth import HTTPBasicAuth as BaseHTTPBasicAuth\n10\tfrom flask_httpauth import HTTPTokenAuth as BaseHTTPTokenAuth\n11\tfrom flask_httpauth import MultiAuth as BaseMultiAuth\n12\tfrom werkzeug.datastructures import Authorization\n13\t\n14\tfrom .exceptions import HTTPError\n15\tfrom .types import ErrorCallbackType\n16\tfrom .types import HTTPAuthType\n17\tfrom .types import ResponseReturnValueType\n18\tfrom .types import SecurityScheme\n19\t\n20\t\n21\tclass _AuthBase:\n22\t    \"\"\"Base class for `HTTPBasicAuth` and `HTTPBasicAuth`.\"\"\"\n23\t\n24\t    def __init__(\n25\t        self,\n26\t        description: str | None = None,\n27\t        security_scheme_name: str | None = None,\n28\t    ) -> None:\n29\t        self.description = description\n30\t        self.security_scheme_name = security_scheme_name\n31\t        self.error_handler(self._auth_error_handler)  # type: ignore\n32\t\n33\t    @property\n34\t    def current_user(self) -> None | t.Any:\n35\t        return g.get('flask_httpauth_user', None)\n36\t\n37\t    @staticmethod\n38\t    def _auth_error_handler(status_code: int) -> ResponseReturnValueType:\n39\t        \"\"\"The default error handler for Flask-HTTPAuth.\n40\t\n41\t        This handler will return JSON response when setting `APIFlask(json_errors=True)` (default).\n42\t\n43\t        *Version changed: 0.9.0*\n44\t\n45\t        - The default reason phrase is used for auth errors.\n46\t        - It will call the `app.error_callback` for auth errors.\n47\t        \"\"\"\n48\t        error = HTTPError(status_code)\n49\t        if current_app.json_errors:  # type: ignore\n50\t            return current_app.error_callback(error)  # type: ignore\n51\t        return error.message, status_code  # type: ignore\n52\t\n53\t    def error_processor(self, f: ErrorCallbackType) -> None:\n54\t        \"\"\"A decorator to register an error callback function for auth errors (401/403).\n55\t\n56\t        The error callback function will be called when authentication errors happened.\n57\t        It should accept an `HTTPError` instance and return a valid response. APIFlask will pass\n58\t        the callback function you decorated to Flask-HTTPAuth's `error_handler` method internally.\n59\t\n60\t        Example:\n61\t\n62\t        ```python\n63\t        from apiflask import APIFlask, HTTPTokenAuth\n64\t\n65\t        app = APIFlask(__name__)\n66\t        auth = HTTPTokenAuth()\n67\t\n68\t        @auth.error_processor\n69\t        def my_auth_error_processor(error):\n70\t            return {\n71\t                'status_code': error.status_code,\n72\t                'message': error.message\n73\t            }, error.status_code\n74\t        ```\n75\t\n76\t        See more details of the error object in\n77\t        [APIFlask.error_processor][apiflask.APIFlask.error_processor].\n78\t\n79\t        *Version added: 0.9.0*\n80\t        \"\"\"\n81\t        self.error_handler(lambda status_code: f(HTTPError(status_code)))  # type: ignore\n82\t\n83\t\n84\tclass HTTPBasicAuth(_AuthBase, BaseHTTPBasicAuth, SecurityScheme):\n85\t    \"\"\"Flask-HTTPAuth's HTTPBasicAuth with some modifications.\n86\t\n87\t    - Add an authentication error handler that returns JSON response.\n88\t    - Expose the `auth.current_user` as a property.\n89\t    - Add a `description` attribute for OpenAPI Spec.\n90\t    - Add a `name` attribute for OpenAPI Spec.\n91\t    - Add the `get_security_scheme` method for OpenAPI Spec.\n92\t\n93\t    Examples:\n94\t\n95\t    ```python\n96\t    from apiflask import APIFlask, HTTPBasicAuth\n97\t\n98\t    app = APIFlask(__name__)\n99\t    auth = HTTPBasicAuth()\n100\t    ```\n101\t\n102\t    *Version changed: 3.0.0*\n103\t\n104\t    - Add parameter `name`.\n105\t\n106\t    *Version changed: 1.3.0*\n107\t\n108\t    - Add `security_scheme_name` parameter.\n109\t    \"\"\"\n110\t\n111\t    def __init__(\n112\t        self,\n113\t        name: str = 'BasicAuth',\n114\t        scheme: str = 'Basic',\n115\t        realm: str | None = None,\n116\t        description: str | None = None,\n117\t        security_scheme_name: str | None = None,\n118\t    ) -> None:\n119\t        \"\"\"Initialize an `HTTPBasicAuth` object.\n120\t\n121\t        Arguments:\n122\t            name: The security scheme name, default to `BasicAuth`.\n123\t            scheme: The authentication scheme used in the `WWW-Authenticate`\n124\t                header. Defaults to `'Basic'`.\n125\t            realm: The realm used in the `WWW-Authenticate` header to indicate\n126\t                a scope of protection, defaults to use `'Authentication Required'`.\n127\t            description: The description of the OpenAPI security scheme.\n128\t            security_scheme_name: The name of the OpenAPI security scheme, default to `BasicAuth`.\n129\t        \"\"\"\n130\t        BaseHTTPBasicAuth.__init__(self, scheme=scheme, realm=realm)\n131\t        super().__init__(description=description, security_scheme_name=security_scheme_name)\n132\t        self.name = security_scheme_name or name\n133\t\n134\t    def get_security_scheme(self) -> dict[str, t.Any]:\n135\t        security_scheme = {\n136\t            'type': 'http',\n137\t            'scheme': 'basic',\n138\t        }\n139\t\n140\t        if self.description is not None:\n141\t            security_scheme['description'] = self.description\n142\t\n143\t        return security_scheme\n144\t\n145\t\n146\tclass HTTPTokenAuth(_AuthBase, BaseHTTPTokenAuth, SecurityScheme):\n147\t    \"\"\"Flask-HTTPAuth's HTTPTokenAuth with some modifications.\n148\t\n149\t    - Add an authentication error handler that returns JSON response.\n150\t    - Expose the `auth.current_user` as a property.\n151\t    - Add a `description` attribute for OpenAPI Spec.\n152\t    - Add a `name` attribute for OpenAPI Spec.\n153\t    - Add the `get_security_scheme` method for OpenAPI Spec.\n154\t\n155\t    Examples:\n156\t\n157\t    ```python\n158\t    from apiflask import APIFlask, HTTPTokenAuth\n159\t\n160\t    app = APIFlask(__name__)\n161\t    auth = HTTPTokenAuth()\n162\t    ```\n163\t    \"\"\"\n164\t\n165\t    def __init__(\n166\t        self,\n167\t        scheme: str = 'Bearer',\n168\t        name: str = 'BearerAuth',\n169\t        realm: str | None = None,\n170\t        header: str | None = None,\n171\t        description: str | None = None,\n172\t        security_scheme_name: str | None = None,\n173\t    ) -> None:\n174\t        \"\"\"Initialize a `HTTPTokenAuth` object.\n175\t\n176\t        Arguments:\n177\t            scheme: The authentication scheme used in the `WWW-Authenticate`\n178\t                header. One of `'Bearer'` and `'ApiKey'`, defaults to `'Bearer'`.\n179\t            name: The security scheme name, default to `BearerAuth`.\n180\t            realm: The realm used in the `WWW-Authenticate` header to indicate\n181\t                 a scope of protection, defaults to use `'Authentication Required'`.\n182\t            header: The custom header where to obtain the token (instead\n183\t                of from `Authorization` header). If a custom header is used,\n184\t                the scheme should not be included. Example:\n185\t\n186\t                ```\n187\t                X-API-Key: this-is-my-token\n188\t                ```\n189\t\n190\t            description: The description of the OpenAPI security scheme.\n191\t            security_scheme_name: The name of the OpenAPI security scheme,\n192\t                defaults to `BearerAuth` or `ApiKeyAuth`.\n193\t\n194\t        *Version changed: 3.0.0*\n195\t\n196\t        - Add parameter `name`.\n197\t\n198\t        *Version changed: 1.3.0*\n199\t\n200\t        - Add `security_scheme_name` parameter.\n201\t        \"\"\"\n202\t        BaseHTTPTokenAuth.__init__(self, scheme=scheme, realm=realm, header=header)\n203\t        super().__init__(description=description, security_scheme_name=security_scheme_name)\n204\t        if not self.scheme.lower() == 'bearer' or self.header is not None:\n205\t            name = 'ApiKeyAuth'\n206\t            warnings.warn(\n207\t                'The API key authorization by HTTPTokenAuth is deprecated and will be removed in '\n208\t                'APIFlask 4.0.0. Use '\n209\t                'APIKeyHeaderAuth, APIKeyCookieAuth, or APIKeyQueryAuth instead.',\n210\t                DeprecationWarning,\n211\t                stacklevel=2,\n212\t            )\n213\t\n214\t        self.name = security_scheme_name or name\n215\t\n216\t    def get_security_scheme(self) -> dict[str, t.Any]:\n217\t        if not self.scheme.lower() == 'bearer' or self.header is not None:\n218\t            security_scheme = {\n219\t                'type': 'apiKey',\n220\t                'name': self.header,\n221\t                'in': 'header',\n222\t            }\n223\t        else:\n224\t            security_scheme = {\n225\t                'type': 'http',\n226\t                'scheme': 'bearer',\n227\t            }\n228\t\n229\t        if self.description is not None:\n230\t            security_scheme['description'] = self.description\n231\t\n232\t        return security_scheme\n233\t\n234\t\n235\tclass _BaseAPIKeyAuth(_AuthBase, BaseHTTPTokenAuth):\n236\t    \"\"\"Base class for `APIKeyHeaderAuth` `APIKeyCookieAuth` `APIKeyQueryAuth`.\"\"\"\n237\t\n238\t    def __init__(\n239\t        self,\n240\t        name: str = 'ApiKeyAuth',\n241\t        scheme: str = 'ApiKey',\n242\t        realm: str | None = None,\n243\t        param_name: str | None = 'X-API-Key',\n244\t        description: str | None = None,\n245\t        security_scheme_name: str | None = None,\n246\t    ) -> None:\n247\t        BaseHTTPTokenAuth.__init__(self, sc