None = None,\n347\t        security_scheme_name: str | None = None,\n348\t    ) -> None:\n349\t        \"\"\"Initialize a `APIKeyCookieAuth` object.\n350\t\n351\t        Arguments:\n352\t            name: The security scheme name, default to `ApiKeyAuth`.\n353\t            scheme: The authentication scheme used in the `WWW-Authenticate`\n354\t                header. defaults to `'ApiKey'`.\n355\t            realm: The realm used in the `WWW-Authenticate` header to indicate\n356\t                 a scope of protection, defaults to use `'Authentication Required'`.\n357\t            param_name: The name of API Key paramter. defaults to `'ApiKey'`.\n358\t            description: The description of the OpenAPI security scheme.\n359\t            security_scheme_name: The name of the OpenAPI security scheme,\n360\t                defaults to `ApiKeyAuth`.\n361\t\n362\t        *Version added: 3.0.0*\n363\t        \"\"\"\n364\t        super().__init__(\n365\t            name=name,\n366\t            scheme=scheme,\n367\t            realm=realm,\n368\t            param_name=param_name,\n369\t            description=description,\n370\t            security_scheme_name=security_scheme_name,\n371\t        )\n372\t        self._location = 'cookie'\n373\t\n374\t    def is_compatible_auth(self, headers):\n375\t        return self.param_name in request.cookies\n376\t\n377\t    def get_auth(self) -> Authorization:\n378\t        auth = Authorization('apiKey')\n379\t        auth.token = request.cookies.get(self.param_name, '')  # type: ignore\n380\t        return auth\n381\t\n382\t\n383\tclass APIKeyQueryAuth(_BaseAPIKeyAuth):\n384\t    \"\"\"Flask-HTTPAuth's HTTPTokenAuth with some modifications to implement query parameter APIKey authentication.\n385\t\n386\t    - Add an authentication error handler that returns JSON response.\n387\t    - Expose the `auth.current_user` as a property.\n388\t    - Add a `description` attribute for OpenAPI Spec.\n389\t    - Add a `name` attribute for Open