g\nimport aj.entry\nimport aj.log\nimport aj.plugins\n\n\nclass TestConfig(aj.config.BaseConfig):\n    def __init__(self):\n        aj.config.BaseConfig.__init__(self)\n        self.data = {\n            'bind': {\n                'mode': 'tcp',\n                'host': '0.0.0.0',\n                'port': 8000,\n            },\n            'color': 'blue',\n            'name': 'test',\n            'ssl': {\n                'enable': False\n            },\n            'email': {\n                'enable': False\n            },\n        }\n\n    def load(self):\n        pass\n\n    def save(self):\n        pass\n\n\naj.log.init_console(logging.WARN)\n\n# Ensure tree for secret key and logs\nos.makedirs('/workspace/etc/ajenti', exist_ok=True)\nos.makedirs('/workspace/logs/ajenti', exist_ok=True)\n\n# Set config path and log directory\nos.environ['AJENTI_CONFIG'] = '/workspace/etc/ajenti/config.yml'\naj.log.LOG_DIR = '/workspace/logs/ajenti'\naj.log.LOG_FILE = '/workspace/logs/ajenti/ajenti.log'\n\n# Create log file\nwith open(aj.log.LOG_FILE, 'w') as f:\n    pass\n\naj.entry.start(\n    config=TestConfig(),\n    dev_mode=False,\n    debug_mode=True,\n    autologin=True,\n    product_name='ajenti',\n    daemonize=False,\n    plugin_providers=[aj.plugins.DirectoryPluginProvider('../plugins')],\n)\n","structuredPatch":[{"oldStart":49,"oldLines":10,"newStart":49,"newLines":6,"lines":[" aj.log.LOG_DIR = '/workspace/logs/ajenti'"," aj.log.LOG_FILE = '/workspace/logs/ajenti/ajenti.log'"," ","-# Create log file","-with open(aj.log.LOG_FILE, 'w') as f:","-    pass","-"," aj.entry.start(","     config=TestConfig(),","     dev_mode=False,"]}],"userModified":false,"replaceAll":false}}
