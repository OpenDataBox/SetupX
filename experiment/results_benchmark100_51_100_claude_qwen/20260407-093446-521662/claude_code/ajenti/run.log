{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0e514200d4394df5a750d02f","type":"tool_result","content":"The file /workspace/ajenti-core/aj/log.py has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"f881cebb-6592-4c40-a00f-2bdf7c835e8c","uuid":"820658ab-a85b-48a1-8cb7-3b3d12c737a6","timestamp":"2026-04-07T09:20:07.719Z","tool_use_result":{"filePath":"/workspace/ajenti-core/aj/log.py","oldString":"def init_log_file(log_level=logging.INFO):\n    #sys.stderr = sys.stdout = LoggerWriter()\n    if not os.path.isfile(LOG_FILE):\n        # Use open() instead of mknod for non-root users\n        open(LOG_FILE, 'a').close()\n    os.chmod(LOG_FILE, 0o640)","newString":"def init_log_file(log_level=logging.INFO):\n    #sys.stderr = sys.stdout = LoggerWriter()\n    if not os.path.isfile(LOG_FILE):\n        # Use open() instead of mknod for non-root users\n        with open(LOG_FILE, 'w') as f:\n            pass\n    # Use 0o644 instead of 0o640 for non-root users\n    os.chmod(LOG_FILE, 0o644)","originalFile":"import logging\nimport logging.handlers\nimport os\nimport sys\nfrom termcolor import colored\nfrom datetime import datetime\n\nimport aj\n\nLOG_DIR = '/var/log/ajenti'\nLOG_NAME = 'ajenti.log'\nLOG_FILE = os.path.join(LOG_DIR, LOG_NAME)\nLOG_PARAMS = {\n    'master_pid': None,\n    'tag': 'master',\n}\n\n\nclass ConsoleHandler(logging.StreamHandler):\n    def __init__(self, stream):\n        logging.StreamHandler.__init__(self, stream)\n\n    def handle(self, record):\n        if not self.stream.isatty():\n            return logging.StreamHandler.handle(self, record)\n\n        s = ''\n        d = datetime.fromtimestamp(record.created)\n        s += colored(d.strftime(\"%d.%m.%Y %H:%M:%S  \"), 'white')\n\n        params = {\n            'tag': getattr(record, 'tag', 'master'),\n            'pid': getattr(record, 'pid', os.getpid()),\n        }\n\n        process_tag = ''\n        padding = ''\n        if params['tag'] == 'master':\n            if os.getpid() == LOG_PARAMS['master_pid']:\n                process_tag = colored('master', 'yellow')\n            else:\n                params['tag'] = None\n        if params['tag'] == 'restricted':\n            process_tag = colored('rstrct', 'red')\n            padding = '  '\n        if params['tag'] == 'worker':\n            process_tag = colored('worker', 'green')\n            padding = '  '\n        if params['tag'] == 'task':\n            process_tag = colored('task  ', 'blue')\n            padding = '    '\n        if params['tag'] is None:\n            process_tag = colored('...   ', 'blue')\n            padding = '  '\n        s += colored('[', 'white')\n        s += process_tag\n        s += colored(' %5i]  ' % params['pid'], 'white')\n\n        if aj.debug:\n            s += colored(\n                ('%15s:%-4s  ' % (record.filename[-15:], record.lineno)),\n                'magenta',\n                attrs=['bold']\n            )\n\n        l = ''\n        if record.levelname == 'DEBUG':\n            l = colored('DEBUG', 'white')\n        if record.levelname == 'INFO':\n            l = colored('INFO ', 'green', attrs=['bold'])\n        if record.levelname == 'WARNING':\n            l = colored('WARN ', 'yellow', attrs=['bold'])\n        if record.levelname == 'ERROR':\n            l = colored('ERROR', 'red', attrs=['bold'])\n        s += l + '  '\n\n        s += padding\n\n        try:\n            s += record.msg % record.args\n        except TypeError:\n            # Not enough arguments can be caused by encoded URL\n            s += record.msg\n        s += '\\n'\n        self.stream.write(s)\n\n\ndef init_console(log_level=logging.INFO):\n    log = logging.getLogger()\n    log.setLevel(logging.DEBUG)\n    stdout = ConsoleHandler(sys.stdout)\n    stdout.setLevel(log_level)\n    log.handlers = [stdout]\n\n\nclass LoggerWriter:\n    def write(self, message):\n        if message != '\\n':\n            message = message.strip(\"\\n\")\n            logging.warning(f'stdout: {message}')\n\n    def flush(self):\n        pass\n\n\ndef init_log_directory():\n    if not os.path.exists(LOG_DIR):\n        os.mkdir(LOG_DIR)\n    # Use 0o755 instead of 0o640 to allow non-root users to create files\n    os.chmod(LOG_DIR, 0o755)\n\n\ndef init_log_file(log_level=logging.INFO):\n    #sys.stderr = sys.stdout = LoggerWriter()\n    if not os.path.isfile(LOG_FILE):\n        # Use open() instead of mknod for non-root users\n        open(LOG_FILE, 'a').close()\n    os.chmod(LOG_FILE, 0o640)\n    log = logging.getLogger()\n    try:\n        handler = logging.handlers.TimedRotatingFileHandler(\n            LOG_FILE,\n            when='midnight',\n            backupCount=7\n        )\n        handler.setLevel(log_level)\n        handler.setFormatter(logging.Formatter('%(asctime)s %(levelname)-8s: %(message)s'))\n        log.handlers = [handler]\n    except IOError:\n        pass\n\n    return log\n\n\ndef init_log_forwarding(fx):\n    methods = ['info', 'warn', 'debug', 'error', 'critical']\n    for method in methods:\n        setattr(\n            logging,\n            method,\n            (lambda method: lambda message, *args: fx(\n                method,\n                message,\n                tag=LOG_PARAMS['tag'],\n                pid=os.getpid(),\n                *args\n            ))(method)\n        )\n\n\ndef set_log_params(**kwargs):\n    LOG_PARAMS.update(kwargs)\n","structuredPatch":[{"oldStart":114,"oldLines":8,"newStart":114,"newLines":10,"lines":["     #sys.stderr = sys.stdout = LoggerWriter()","     if not os.path.isfile(LOG_FILE):","         # Use open() instead of mknod for non-root users","-        open(LOG_FILE, 'a').close()","-    os.chmod(LOG_FILE, 0o640)","+        with open(LOG_FILE, 'w') as f:","+            pass","+    # Use 0o644 instead of 0o640 for non-root users","+    os.chmod(LOG_FILE, 0o644)","     log = logging.getLogger()","     try:","         handler = logging.handlers.TimedRotatingFileHandler("]}],"userModified":false,"replaceAll":false}}
