ss_tag\n57\t        s += colored(' %5i]  ' % params['pid'], 'white')\n58\t\n59\t        if aj.debug:\n60\t            s += colored(\n61\t                ('%15s:%-4s  ' % (record.filename[-15:], record.lineno)),\n62\t                'magenta',\n63\t                attrs=['bold']\n64\t            )\n65\t\n66\t        l = ''\n67\t        if record.levelname == 'DEBUG':\n68\t            l = colored('DEBUG', 'white')\n69\t        if record.levelname == 'INFO':\n70\t            l = colored('INFO ', 'green', attrs=['bold'])\n71\t        if record.levelname == 'WARNING':\n72\t            l = colored('WARN ', 'yellow', attrs=['bold'])\n73\t        if record.levelname == 'ERROR':\n74\t            l = colored('ERROR', 'red', attrs=['bold'])\n75\t        s += l + '  '\n76\t\n77\t        s += padding\n78\t\n79\t        try:\n80\t            s += record.msg % record.args\n81\t        except TypeError:\n82\t            # Not enough arguments can be caused by encoded URL\n83\t            s += record.msg\n84\t        s += '\\n'\n85\t        self.stream.write(s)\n86\t\n87\t\n88\tdef init_console(log_level=logging.INFO):\n89\t    log = logging.getLogger()\n90\t    log.setLevel(logging.DEBUG)\n91\t    stdout = ConsoleHandler(sys.stdout)\n92\t    stdout.setLevel(log_level)\n93\t    log.handlers = [stdout]\n94\t\n95\t\n96\tclass LoggerWriter:\n97\t    def write(self, message):\n98\t        if message != '\\n':\n99\t            message = message.strip(\"\\n\")\n100\t            logging.warning(f'stdout: {message}')\n101\t\n102\t    def flush(self):\n103\t        pass\n104\t\n105\t\n106\tdef init_log_directory():\n107\t    if not os.path.exists(LOG_DIR):\n108\t        os.mkdir(LOG_DIR)\n109\t    os.chmod(LOG_DIR, 0o640)\n110\t\n111\t\n112\tdef init_log_file(log_level=logging.INFO):\n113\t    #sys.stderr = sys.stdout = LoggerWriter()\n114\t    if not os.path.isfile(LOG_FILE):\n115\t        os.mknod(LOG_FILE)\n116\t    os.chmod(LOG_FILE, 0o640)\n117\t    log = logging.getLogger()\n118\t    t