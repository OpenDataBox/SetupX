{"type":"user","uuid":"e5c6ca7b-f99d-445d-80bd-ff8cb463d83e","session_id":"9337dcc6-0830-49bc-888a-99e194bc5266","parent_tool_use_id":null,"message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_12353b2ccb4b4b6e8544fe35","is_error":false,"content":"#!/usr/bin/env python3\nfrom setuptools import setup, find_packages\nimport platform\n\n__requires = list(filter(None, open('requirements.txt').read().splitlines()))\nif platform.python_implementation() == 'PyPy':\n    __requires.append('git+git://github.com/schmir/gevent@pypy-hacks')\n    __requires.append('git+git://github.com/gevent-on-pypy/pypycore ')\nelse:\n    __requires.append('gevent>=1')\n\nsetup(\n    name='aj',\n    version='2.2.15',\n    python_requires='>=3',\n    install_requires=__requires,\n    description='Web UI base toolkit',\n    author='Eugene Pankov',\n    author_email='e@ajenti.org',\n    url='https://ajenti.org/',\n    packages=find_packages(),\n    include_package_data=True,\n    package_data={\n        \"aj\": [\n            \"aj/static/images/*\",\n        ],\n    },\n)\n"}]}}
