sting\n    \"pytest\",\n    \"pytest-cov\",\n    \"coverage [toml]\",\n    # code style\n    \"ruff==0.11.*\",\n    \"mypy\",\n    \"types-docutils\",\n    \"scipy-stubs\",\n    \"typos\",\n    # docs\n    \"mkdocs\",\n    \"mkdocs-material\",\n    \"mkdocs-exclude\",\n    \"mkdocs-redirects\",\n    \"mkdocstrings-python\",\n    \"mike\",\n    \"mkdocs-jupyter\",\n    \"black\",\n    # release\n    \"bump-my-version\",\n]\npublishing = [\"build\", \"twine\", \"wheel\"]\nrl = [\"stable-baselines3>=2.3.2\", \"sb3-contrib\"]\nnotebooks = [\"nbmake\", \"tensorflow\"]\n\n[project.urls]\nRepository = \"https://github.com/neurogym/neurogym\"\nIssues = \"https://github.com/neurogym/neurogym\"\nDocumentation = \"https://neurogym.github.io/neurogym\"\nChangelog = \"https://github.com/neurogym/neurogym/CHANGELOG.md\"\n\n[tool.pytest.ini_options]\ntestpaths = [\"tests\"]\n\n[tool.coverage.run]\nbranch = true\nsource = [\"neurogym\"]\ncommand_line = \"-m pytest\"\n\n# For completeness, until we move to an src-based layouts\n[tool.setuptools.packages.find]\ninclude = [\"neurogym*\"]\nexclude = [\"tests*\"]\n\n[tool.mypy]\npython_version = \"3.11\"\nwarn_return_any = true\nwarn_unused_configs = true\nshow_error_codes = true\nexclude = \"build/.*\"\n\n[[tool.mypy.overrides]]\nmodule = \"psychopy\"\nignore_missing_imports = true\n\n[tool.coverage.report]\nexclude_also = [\n    \"if TYPE_CHECKING:\",\n    \"def __repr__\",\n    \"def __str__\",\n    \"raise NotImplementedError\",\n]\n\n[tool.typos]\ndefault.extend-ignore-words-re = [\n    \"arange\", # common numpy function\n]\nfiles.ignore-hidden = false\nfiles.extend-exclude = [\".git/*\"]\n"}]}}
