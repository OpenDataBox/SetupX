{"type":"user","uuid":"0564685f-8ace-4910-a85d-75aa19c39849","session_id":"f8a35bb2-02f9-481e-9baf-1ad4e79a157a","parent_tool_use_id":null,"message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_432957226e394821877f1fda","is_error":false,"content":"# gpp, nbp, rh, ra, mrro, tws, hfss, hfls, snw, tsl, rsus, rsds, tas\n\n\n[h1: Ecosystem and Carbon Cycle]\nbgcolor = \"#ECFFE6\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Gross Primary Productivity]\nvariable       = \"gpp\"\ncmap           = \"Greens\"\nweight         = 5\nmass_weighting = True\n\n[Fluxnet]\nsource     = \"Test-Data/DATA/gpp.nc\"\nweight     = 9\ntable_unit = \"g m-2 d-1\"\nplot_unit  = \"g m-2 d-1\"\nskip_iav   = False\n\n[GBAF]\nsource        = \"Test-Data/DATA/gpp_0.5x0.5.nc\"\nweight        = 15\ntable_unit    = \"Pg yr-1\"\nplot_unit     = \"g m-2 d-1\"\nspace_mean    = False\nrelationships = \"SurfaceAirTemperature/CRU\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Global Net Ecosystem Carbon Balance]\nvariable = \"nbp\"\nweight   = 5\nctype    = \"ConfNBP\"\n\n[Hoffman]\nsource   = \"Test-Data/DATA/nbp_1850-2010.nc\"\nweight   = 20\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Net Ecosystem Exchange]\nvariable       = \"nee\"\nderived        = \"gpp-ra-rh\"\nweight         = 5\nmass_weighting = True\n\n[GBAF]\nsource     = \"Test-Data/DATA/nee_0.5x0.5.nc\"\nweight     = 4\ntable_unit = \"Pg yr-1\"\nplot_unit  = \"g m-2 d-1\"\nspace_mean = False\n\n###########################################################################\n\n[h1: Hydrology Cycle]\nbgcolor = \"#E6F9FF\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Runoff]\nvariable       = \"runoff\"\nalternate_vars = \"mrro\"\nweight         = 5\n\n[Dai]\nctype          = \"ConfRunoff\"\nsource         = \"Test-Data/DATA/runoff.nc\"\nweight         = 15\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Terrestrial Water Storage Anomaly]\nvariable       = \"twsa\"\nalternate_vars = \"tws\"\ncmap           = \"Blues\"\nweight         = 5\nctype          = \"ConfTWSA\"\n\n[GRACE]\nsource   = \"Test-Data/DATA/twsa_0.5x0.5.nc\"\nweight   = 25\nbasin_source = \"Test-Data/mrro/Dai/basins_0.5x0.5.nc\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Permafrost]\nvariable = \"tsl\"\n\n[NSIDC]\nctype    = \"ConfPermafrost\"\nsource   = \"Test-Data/DATA/Brown2002.nc\"\ny0       = 1970.\nyf       = 2000.\nTeps     = 273.15\ndmax     = 3.5\n\n###########################################################################\n\n[h1: Radiation and Energy Cycle]\nbgcolor = \"#FFECE6\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Albedo]\nvariable = \"albedo\"\nderived  = \"rsus/rsds\"\nweight   = 1\n\n[MODIS]\nsource   = \"Test-Data/DATA/albedo_0.5x0.5.nc\"\nweight   = 20\n\n###########################################################################\n\n[h1: Forcings]\nbgcolor = \"#EDEDED\"\n\n#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n[h2: Surface Air Temperature]\nvariable = \"tas\"\nweight   = 2\n\n[CRU]\nsource   = \"Test-Data/DATA/tas_0.5x0.5.nc\"\nweight   = 25\n"}]}}
