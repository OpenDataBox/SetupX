{"type":"user","uuid":"219d9094-0323-4539-9456-a2d05339ee6f","session_id":"409358c9-8c8d-46c1-8bd5-e973db58fba8","parent_tool_use_id":null,"message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ad539f2c8bb04ba3bc36df65","is_error":false,"content":"[tox]\nenvlist =\n    py3{14,13,12,11,10,9}\n    pypy310\n    minimal\n    style\n    typing\n    docs\n    min-versions\nskip_missing_interpreters = True\n\n[testenv]\ndeps =\n    -r requirements/tests.txt\n    -r requirements/examples.txt\ncommands =\n    pytest -v\n\n# test with minimal dependencies\n# make sure no extra dependencies are introduced\n[testenv:minimal]\ndeps =\n    -e .\ncommands =\n    python -c \"from apiflask import APIFlask\"\n\n[testenv:style]\ndeps = pre-commit\nskip_install = true\ncommands =\n    pre-commit run --all-files\n\n[testenv:docs]\ndeps = -r requirements/docs.txt\nwhitelist_externals = mkdocs\ncommands = mkdocs build\n\n[testenv:typing]\ndeps = -r requirements/typing.txt\ncommands = mypy\n\n[testenv:min-versions]\ndeps =\n    -r requirements/tests.txt\n    -r requirements/min-versions.txt\ncommands =\n    pytest -v\n\n[testenv:pypy311]\ndeps =\n    -r requirements/tests.txt\n    -r requirements/examples.txt\ncommands_pre =\n    python -m pip uninstall -y backports-datetime-fromisoformat\ncommands =\n    pytest -v\n"}]}}
