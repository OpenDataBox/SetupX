{"type":"session_message","session_id":"ses_28a93ff61ffe5C1qrtu8sHfb59","role":"assistant","message_id":"msg_d756c1159001B2s27LseSUbIyJ","parts":[{"id":"prt_d756c1ce7001gELtWOKVq8NVle","messageID":"msg_d756c1159001B2s27LseSUbIyJ","sessionID":"ses_28a93ff61ffe5C1qrtu8sHfb59","type":"tool","tool":"read","callID":"call_07ca31b96b264c2296ff4b0f","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [tool.poetry]\n2: \n3: name = \"memegen\"\n4: version = \"11.2\"\n5: description = \"The free and open source API to generate memes.\"\n6: authors = [\"Jace Browning <support@maketested.com>\"]\n7: license = \"MIT\"\n8: \n9: packages = [{ include = \"app\" }]\n10: \n11: [tool.poetry.dependencies]\n12: \n13: python = \"^3.13\"\n14: \n15: # Sanic\n16: sanic = \"~25.12\" # run 'poetry update sanic-ext sanic-testing' when changing this\n17: sanic-ext = \"*\"\n18: \n19: # Markdown\n20: markdown = \"~3.10\"\n21: pymdown-extensions = \"^10.21\"\n22: pygments = \"^2.20.0\"\n23: \n24: # Images\n25: pillow = \"~12.1\"\n26: pilmoji = { git = \"https://github.com/jay3332/pilmoji\", branch = \"2.0\" }\n27: spongemock = \"~1.0.0\"\n28: \n29: # Utilities\n30: aiocache = \"~0.12.3\"\n31: aiohttp = \"^3.13.4\"\n32: anyio = \"^4.12.1\"\n33: datafiles = \"^2.3.4\"\n34: furl = \"^2.1.4\"\n35: webp = \"~0.4\"\n36: \n37: # Production\n38: bugsnag = \"^4.8\"\n39: gunicorn = \"^25.1\"\n40: uvicorn = \"~0.40.0\"\n41: \n42: [tool.poetry.group.dev.dependencies]\n43: \n44: # Formatting\n45: isort = \"^7.0\"\n46: black = \"^26.3\"\n47: \n48: # Type Checking\n49: mypy = \"^1.19.1\"\n50: autoflake = \"^2.3\"\n51: types-aiofiles = \"*\"\n52: types-requests = \"*\"\n53: types-setuptools = \"*\"\n54: \n55: # Testing\n56: pytest = \"^9.0.2\"\n57: pytest-asyncio = \"*\"\n58: pytest-describe = \"^3.0\"\n59: pytest-expecter = \"^3.0\"\n60: pytest-random = \"*\"\n61: pytest-cov = \"^7.0\"\n62: sanic-testing = \"*\"\n63: aioresponses = \"*\"\n64: locust = \"^2.42.2\"\n65: \n66: # Coverage\n67: coveragespace = \"^6.1\"\n68: \n69: # Documentation\n70: mkdocs = \"^1.2.3\"\n71: \n72: # Utilities\n73: honcho = \"^2.0\"\n74: ipdb = \"*\"\n75: rope = \"^1.14\"\n76: watchdog = { version = \"^6.0\", extras = [\"watchmedo\"] }\n77: \n78: [tool.black]\n79: \n80: quiet = true\n81: \n82: [tool.isort]\n83: \n84: profile = \"black\"\n85: \n86: [tool.mypy]\n87: \n88: ignore_missing_imports = true\n89: no_implicit_optional = true\n90: check_untyped_defs = true\n91: \n92: plugins = \"datafiles.plugins:mypy\"\n93: \n94: cache_dir = \".cache/mypy/\"\n95: \n96: [tool.pytest.ini_options]\n97: \n98: testpaths = \"app\"\n99: \n100: addopts = \"\"\"\n101: --no-header \\\n102: --random \\\n103: --show-capture=log \\\n104: -rxX \\\n105: --cov=app --cov-report=term-missing:skip-covered --cov-report=html:.cache/htmlcov --no-cov-on-fail\n106: \"\"\"\n107: \n108: cache_dir = \".cache/pytest/\"\n109: \n110: markers = \"slow\"\n111: \n112: asyncio_mode = \"strict\"\n113: \n114: filterwarnings = [\n115:     \"ignore::DeprecationWarning:websockets.legacy\",\n116:     \"ignore::DeprecationWarning:sanic.logging.deprecation\",\n117: ]\n118: \n119: [build-system]\n120: \n121: requires = [\"poetry-core>=1.0.0\"]\n122: build-backend = \"poetry.core.masonry.api\"\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"[tool.poetry]\n\nname = \"memegen\"\nversion = \"11.2\"\ndescription = \"The free and open source API to generate memes.\"\nauthors = [\"Jace Browning <support@maketested.com>\"]\nlicense = \"MIT\"\n\npackages = [{ include = \"app\" }]\n\n[tool.poetry.dependencies]\n\npython = \"^3.13\"\n\n# Sanic\nsanic = \"~25.12\" # run 'poetry update sanic-ext sanic-testing' when changing this\nsanic-ext = \"*\"\n\n# Markdown\nmarkdown = \"~3.10\"","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775791513243,"end":1775791513247}}}]}
