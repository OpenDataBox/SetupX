{"type":"session_message","session_id":"ses_28a9dcf52ffervxvqxBuMVL5jF","role":"assistant","message_id":"msg_d7562896c001TkORwZQ3xYq1i6","parts":[{"id":"prt_d75629465002R2E2jotjuhnqiq","messageID":"msg_d7562896c001TkORwZQ3xYq1i6","sessionID":"ses_28a9dcf52ffervxvqxBuMVL5jF","type":"tool","tool":"read","callID":"call_5f4a204ce6ef41ffb48fe6a3","state":{"status":"completed","input":{"filePath":"/workspace/custom_components/waste_collection_schedule/waste_collection_schedule/test/test_sources.py"},"output":"<path>/workspace/custom_components/waste_collection_schedule/waste_collection_schedule/test/test_sources.py</path>\n<type>file</type>\n<content>1: #!/usr/bin/env python3\n2: \n3: import argparse\n4: import datetime\n5: import importlib\n6: import re\n7: import site\n8: import traceback\n9: from pathlib import Path\n10: \n11: import yaml\n12: \n13: SECRET_FILENAME = Path(__file__).resolve().parent / \"secrets.yaml\"\n14: SECRET_REGEX = re.compile(r\"!secret\\s(\\w+)\")\n15: \n16: \n17: def main():\n18:     parser = argparse.ArgumentParser(description=\"Test sources.\")\n19:     parser.add_argument(\n20:         \"-s\", \"--source\", action=\"append\", help=\"Test given source file\"\n21:     )\n22:     parser.add_argument(\n23:         \"-l\", \"--list\", action=\"store_true\", help=\"List retrieved entries\"\n24:     )\n25:     parser.add_argument(\n26:         \"-d\",\n27:         \"--double\",\n28:         action=\"store_true\",\n29:         help=\"Run the fetch method twice and check that the second result is the same as the first one, should be run if fetching modifies the source object\",\n30:     )\n31:     parser.add_argument(\n32:         \"-i\", \"--icon\", action=\"store_true\", help=\"Show waste type icon\"\n33:     )\n34:     parser.add_argument(\"--sorted\", action=\"store_true\", help=\"Sort output by date\")\n35:     parser.add_argument(\"--weekday\", action=\"store_true\", help=\"Show weekday\")\n36:     parser.add_argument(\n37:         \"-t\",\n38:         \"--traceback\",\n39:         action=\"store_true\",\n40:         help=\"Print exception information and stack trace\",\n41:     )\n42:     parser.add_argument(\n43:         \"-I\", \"--ics\", action=\"store_true\", help=\"Test all .yaml file for ICS source\"\n44:     )\n45:     parser.add_argument(\n46:         \"-y\", \"--yaml\", action=\"append\", help=\"Test given .yaml file for ICS source\"\n47:     )\n48:     args = parser.parse_args()\n49: \n50:     # read secrets.yaml\n51:     secrets = {}\n52:     try:\n53:         with open(SECRET_FILENAME) as stream:\n54:             try:\n55:                 secrets = yaml.safe_load(stream)\n56:             except yaml.YAMLError as exc:\n57:                 print(exc)\n58:     except FileNotFoundError:\n59:         # ignore missing secrets.yaml\n60:         pass\n61: \n62:     package_dir = Path(__file__).resolve().parents[2]\n63:     source_dir = package_dir / \"waste_collection_schedule\" / \"source\"\n64: \n65:     # add module directory to path\n66:     site.addsitedir(str(package_dir))\n67: \n68:     # find all source files for testing\n69:     if args.source is not None:\n70:         # source file(s) given\n71:         source_files = args.source\n72:     elif not args.ics and args.yaml is None:\n73:         # no ICS yaml files given --> test all source files\n74:         source_files = filter(\n75:             lambda x: x != \"__init__\",\n76:             map(lambda x: x.stem, source_dir.glob(\"*.py\")),\n77:         )\n78:     else:\n79:         # ICS yaml file(s) given\n80:         source_files = []\n81: \n82:     for f in sorted(source_files):\n83:         # iterate through all *.py files in waste_collection_schedule/source\n84:         print(f\"Testing source {f} ...\")\n85:         module = importlib.import_module(f\"waste_collection_schedule.source.{f}\")\n86: \n87:         # get all names within module\n88:         names = set(dir(module))\n89: \n90:         # test if all mandatory names exist\n91:         assert \"TITLE\" in names\n92:         assert \"DESCRIPTION\" in names\n93:         assert \"URL\" in names\n94:         assert \"TEST_CASES\" in names\n95: \n96:         # run through all test-cases\n97:         for name, tc in module.TEST_CASES.items():\n98:             # replace secrets in arguments\n99:             replace_secret(secrets, tc)\n100: \n101:             test_fetch(module, name, tc, args)\n102: \n103:     # find all ICS yaml files for testing\n104:     ics_yaml_dir = Path(__file__).resolve().parents[4] / \"doc\" / \"ics\" / \"yaml\"\n105:     if args.ics:\n106:         # test all ICS yaml files\n107:         yaml_files = ics_yaml_dir.glob(\"*.yaml\")\n108:     elif args.yaml:\n109:         # ICS yaml files specified\n110:         yaml_files = [Path(ics_yaml_dir, f).with_suffix(\".yaml\") for f in args.yaml]\n111:     elif args.source is None:\n112:         # neither source nor ICS yaml files specified --> test all yaml files\n113:         yaml_files = ics_yaml_dir.glob(\"*.yaml\")\n114:     else:\n115:         # source files given --> don't test ICS yaml files\n116:         yaml_files = []\n117: \n118:     # run through all .yaml files for ICS source\n119:     module = importlib.import_module(\"waste_collection_schedule.source.ics\")\n120:     for f in sorted(yaml_files):\n121:         print(f\"Testing ICS {f.stem}\")\n122:         with open(f) as stream:\n123:             # read yaml file\n124:             data = yaml.safe_load(stream)\n125: \n126:             # run through all test-cases\n127:             for name, tc in data[\"test_cases\"].items():\n128:                 test_fetch(module, name, tc, args)\n129: \n130: \n131: def test_fetch(module, name, tc, args):\n132:     # create source\n133:     try:\n134:         source = module.Source(**tc)\n135:         result = source.fetch()\n136:         if args.double:\n137:             result2 = source.fetch()\n138:             if result != result2:\n139:                 print(\n140:                     f\"{bcolors.FAIL}  ERROR: source.fetch() does not return the same result on second call\"\n141:                 )\n142:                 for collection in result:\n143:                     try:\n144:                         idx = result2.index(collection)\n145:                         result2.pop(idx)\n146:                     except ValueError:\n147:                         print(f\"  {collection} not in second result\")\n148:                 for collection in result2:\n149:                     print(f\"  {collection} not in first result\")\n150:                 print(bcolors.ENDC, end=\"\")\n151: \n152:         count = len(result)\n153:         if count > 0:\n154:             print(f\"  found {bcolors.OKGREEN}{count}{bcolors.ENDC} entries for {name}\")\n155:         else:\n156:             print(f\"  found {bcolors.WARNING}0{bcolors.ENDC} entries for {name}\")\n157: \n158:         # test if source is returning the correct date format\n159:         if len(list(filter(lambda x: type(x.date) is not datetime.date, result))) > 0:\n160:             print(\n161:                 f\"{bcolors.FAIL}  ERROR: source returns invalid date format (datetime.datetime instead of datetime.date?){bcolors.ENDC}\"\n162:             )\n163: \n164:         if args.list:\n165:             result = sorted(result, key=lambda x: x.date) if args.sorted else result\n166:             for x in result:\n167:                 icon_str = f\" [{x.icon}]\" if args.icon else \"\"\n168:                 weekday_str = x.date.strftime(\"%a \") if args.weekday else \"\"\n169:                 print(f\"    {x.date.isoformat()} {weekday_str}: {x.type}{icon_str}\")\n170:     except KeyboardInterrupt:\n171:         exit()\n172:     except Exception as exc:\n173:         print(f\"  {name} {bcolors.FAIL}failed{bcolors.ENDC}: {exc}\")\n174:         if args.traceback:\n175:             print(indent(traceback.format_exc(), 4))\n176: \n177: \n178: def replace_secret(secrets, d):\n179:     for key in d.keys():\n180:         value = d[key]\n181:         if isinstance(value, dict):\n182:             replace_secret(secrets, value)\n183:         elif isinstance(value, str):\n184:             match = SECRET_REGEX.fullmatch(value)\n185:             if match is not None:\n186:                 id = match.group(1)\n187:                 if id in secrets:\n188:                     d[key] = secrets[id]\n189:                 else:\n190:                     print(f\"identifier '{id}' not found in {SECRET_FILENAME}\")\n191: \n192: \n193: def indent(s, count):\n194:     indent = \" \" * count\n195:     return \"\\n\".join([indent + line for line in s.split(\"\\n\")])\n196: \n197: \n198: class bcolors:\n199:     HEADER = \"\\033[95m\"\n200:     OKBLUE = \"\\033[94m\"\n201:     OKCYAN = \"\\033[96m\"\n202:     OKGREEN = \"\\033[92m\"\n203:     WARNING = \"\\033[93m\"\n204:     FAIL = \"\\033[91m\"\n205:     ENDC = \"\\033[0m\"\n206:     BOLD = \"\\033[1m\"\n207:     UNDERLINE = \"\\033[4m\"\n208: \n209: \n210: if __name__ == \"__main__\":\n211:     main()\n\n(End of file - total 211 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\nimport argparse\nimport datetime\nimport importlib\nimport re\nimport site\nimport traceback\nfrom pathlib import Path\n\nimport yaml\n\nSECRET_FILENAME = Path(__file__).resolve().parent / \"secrets.yaml\"\nSECRET_REGEX = re.compile(r\"!secret\\s(\\w+)\")\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Test sources.\")\n    parser.add_argument(\n        \"-s\", \"--source\", action=\"append\", help=\"Test given source file\"","truncated":false,"loaded":[]},"title":"custom_components/waste_collection_schedule/waste_collection_schedule/test/test_sources.py","time":{"start":1775790888687,"end":1775790888694}}}]}
