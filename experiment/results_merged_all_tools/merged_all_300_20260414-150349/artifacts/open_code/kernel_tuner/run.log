{"type":"session_message","session_id":"ses_288963eb6ffeaPeCtB5dMDgj3X","role":"assistant","message_id":"msg_d7769e47a001Fb6MQ7VXG7Himy","parts":[{"id":"prt_d7769f1d9001kwCzQPvcgzLA6D","messageID":"msg_d7769e47a001Fb6MQ7VXG7Himy","sessionID":"ses_288963eb6ffeaPeCtB5dMDgj3X","type":"tool","tool":"read","callID":"call_cb1f35e15e9b41d5854d3795","state":{"status":"completed","input":{"filePath":"/workspace/noxfile.py"},"output":"<path>/workspace/noxfile.py</path>\n<type>file</type>\n<content>1: \"\"\"Configuration file for the Nox test runner.\n2: \n3: This instantiates the specified sessions in isolated environments and runs the tests.\n4: This allows for locally mirroring the testing occuring with GitHub-actions.\n5: Be careful that the general setup of tests is left to pyproject.toml.\n6: \"\"\"\n7: \n8: \n9: import platform\n10: import re\n11: from pathlib import Path\n12: \n13: import nox\n14: from nox_poetry import Session, session\n15: \n16: # set the test parameters\n17: verbose = False\n18: python_versions_to_test = [\"3.11\", \"3.12\", \"3.13\", \"3.14\"]\n19: nox.options.stop_on_first_error = True\n20: nox.options.error_on_missing_interpreters = True\n21: nox.options.default_venv_backend = 'virtualenv'\n22: \n23: # workspace level settings\n24: settings_file_path = Path(\"./noxsettings.toml\")\n25: venvbackend_values = ('none', 'virtualenv', 'conda', 'mamba', 'venv')  # from https://nox.thea.codes/en/stable/usage.html#changing-the-sessions-default-backend\n26: \n27: # TODO remove this from a session function, session is only needed to receive trigger argument\n28: @session    # to only run on the current python interpreter\n29: def create_settings(session: Session) -> None:\n30:     \"\"\"One-time creation of noxsettings.toml.\"\"\"\n31:     arg_trigger = False\n32:     if session.posargs:\n33:         # check if the trigger argument was used\n34:         arg_trigger = any(arg.lower() == \"create-settings-file\" for arg in session.posargs)\n35:     # create settings file if the trigger is used or old settings exist\n36:     noxenv_file_path = Path(\"./noxenv.txt\")\n37:     if arg_trigger or (noxenv_file_path.exists() and not settings_file_path.exists()):\n38:         # default values\n39:         venvbackend = nox.options.default_venv_backend\n40:         envdir = \"\"\n41:         # conversion from old notenv.txt\n42:         if noxenv_file_path.exists(): \n43:             venvbackend = noxenv_file_path.read_text().strip()\n44:             noxenv_file_path.unlink()\n45:         # write the settings\n46:         assert venvbackend in venvbackend_values, f\"{venvbackend=}, must be one of {','.join(venvbackend_values)}\"\n47:         settings = (f'venvbackend = \"{venvbackend}\"\\n'\n48:                     f'envdir = \"{envdir}\"\\n')\n49:         settings_file_path.write_text(settings)\n50:         # exit to make sure the user checks the settings are correct\n51:         if arg_trigger:\n52:             session.warn(f\"Settings file '{settings_file_path}' created, exiting. Please check settings are correct before running Nox again.\")\n53:             exit(1)\n54: \n55: # obtain workspace level settings from the 'noxsettings.toml' file\n56: if settings_file_path.exists():\n57:     with settings_file_path.open(mode=\"rb\") as fp:\n58:         import tomli\n59:         nox_settings = tomli.load(fp)\n60:         venvbackend = nox_settings['venvbackend']\n61:         envdir = nox_settings['envdir']\n62:         assert venvbackend in venvbackend_values, f\"File '{settings_file_path}' has {venvbackend=}, must be one of {','.join(venvbackend_values)}\"\n63:         nox.options.default_venv_backend = venvbackend\n64:         nox.options.venvbackend = venvbackend\n65:         if envdir is not None and len(envdir) > 0:\n66:             nox.options.envdir = envdir\n67: \n68: # @session    # to only run on the current python interpreter\n69: # def lint(session: Session) -> None:\n70: #     \"\"\"Ensure the code is formatted as expected.\"\"\"\n71: #     session.install(\"ruff\")\n72: #     session.run(\"ruff\", \"--output-format=github\", \"--config=pyproject.toml\", \".\")\n73: \n74: @session    # to only run on the current python interpreter\n75: def check_poetry(session: Session) -> None:\n76:     \"\"\"Check whether Poetry is correctly configured.\"\"\"\n77:     session.run(\"poetry\", \"check\", \"--no-interaction\", external=True)\n78: \n79: @session    # to only run on the current python interpreter\n80: def check_development_environment(session: Session) -> None:\n81:     \"\"\"Check whether the development environment is up to date with the dependencies, and try to update if necessary.\"\"\"\n82:     if session.posargs:\n83:         if 'github-action' in session.posargs:\n84:             session.log(\"Skipping development environment check on the GitHub Actions runner, as this is always up to date.\")\n85:             return None\n86:     output: str = session.run(\"poetry\", \"install\", \"--sync\", \"--dry-run\", \"--with\", \"test\", silent=True, external=True)\n87:     match = re.search(r\"Package operations: (\\d+) (?:install|installs), (\\d+) (?:update|updates), (\\d+) (?:removal|removals), \\d+ skipped\", output)\n88:     assert match is not None, f\"Could not check development environment, reason: {output}\"\n89:     groups = match.groups()\n90:     installs, updates, removals = int(groups[0]), int(groups[1]), int(groups[2])\n91:     if installs > 0 or updates > 0:\n92:         # packages = re.findall(r\"• Installing .* | • Updating .*\", output, flags=re.MULTILINE)\n93:         # assert packages is not None\n94:         session.warn(f\"\"\"\n95:             Your development environment is out of date ({installs} installs, {updates} updates). \n96:             Update with 'poetry install --sync', using '--with' and '-E' for optional dependencies, extras respectively.\n97:             Note: {removals} packages are not in the specification (i.e. installed manually) and may be removed.\n98:             To preview changes, run 'poetry install --sync --dry-run' (with optional dependencies and extras).\"\"\")\n99: \n100: @session(python=python_versions_to_test)  # missing versions can be installed with `pyenv install ...`\n101: # do not forget check / set the versions with `pyenv global`, or `pyenv local` in case of virtual environment\n102: def tests(session: Session) -> None:\n103:     \"\"\"Run the tests for the specified Python versions.\"\"\"\n104:     session.log(f\"Testing on Python {session.python}\")\n105:     # check if optional dependencies have been disabled by user arguments (e.g. `nox -- skip-gpu`, `nox -- skip-cuda`)\n106:     install_cuda = True\n107:     install_hip = True\n108:     install_opencl = True\n109:     install_additional_tests = False\n110:     small_disk = False\n111:     if session.posargs:\n112:         for arg in session.posargs:\n113:             if arg.lower() == \"skip-gpu\":\n114:                 install_cuda = False\n115:                 install_hip = False\n116:                 install_opencl = False\n117:                 break\n118:             elif arg.lower() == \"skip-cuda\":\n119:                 install_cuda = False\n120:             elif arg.lower() == \"skip-hip\":\n121:                 install_hip = False\n122:             elif arg.lower() == \"skip-opencl\":\n123:                 install_opencl = False\n124:             elif arg.lower() == \"additional-tests\":\n125:                 install_additional_tests = True\n126:             elif arg.lower() == \"small-disk\":\n127:                 small_disk = True\n128:             else:\n129:                 raise ValueError(f\"Unrecognized argument {arg}\")\n130: \n131:     # check if there are optional dependencies that can not be installed\n132:     if install_hip:\n133:         if platform.system().lower() != 'linux':\n134:             session.warn(\"HIP is only available on Linux, disabling dependency and tests\")\n135:             install_hip = False\n136:     full_install = install_cuda and install_hip and install_opencl and install_additional_tests\n137: \n138:     # if the user has a small disk, remove the other environment caches before each session is ran\n139:     if small_disk:\n140:         try:\n141:             session_folder = session.name.replace('.', '*').strip()\n142:             folders_to_delete: str = session.run(\n143:                 \"find\", \"./.nox\", \"-mindepth\", \"1\", \"-maxdepth\", \"1\", \"-type\", \"d\", \"-not\", \"-name\", session_folder,\n144:                 silent=True, external=True)\n145:             folders_to_delete: list[str] = folders_to_delete.split('\\n')\n146:             for folder_to_delete in folders_to_delete:\n147:                 if len(folder_to_delete) > 0:\n148:                     session.warn(f\"Removing environment cache {folder_to_delete} because of 'small-disk' argument\")\n149:                     session.run(\"rm\", \"-rf\", folder_to_delete, external=True)\n150:         except Exception as error:\n151:             session.warn(\"Could not delete Nox caching directories, reason:\")\n152:             session.warn(error)\n153: \n154:     # remove temporary files leftover from the previous session\n155:     session.run(\"rm\", \"-f\", \"temp_*.c\", external=True)\n156: \n157:     # set extra arguments based on optional dependencies\n158:     extras_args = []\n159:     if install_cuda:\n160:         extras_args.extend([\"-E\", \"cuda\"])\n161:     if install_hip:\n162:         extras_args.extend([\"-E\", \"hip\"])\n163:     if install_opencl:\n164:         extras_args.extend([\"-E\", \"opencl\"])\n165: \n166:     # separately install optional dependencies with weird dependencies / build process\n167:     install_warning = \"\"\"Installation failed, this likely means that the required hardware or drivers are missing.\n168:                   Run with `-- skip-gpu` or one of the more specific options (e.g. `-- skip-cuda`) to avoid this.\"\"\"\n169:     if install_cuda:\n170:         # use NVCC to get the CUDA version\n171:         import re\n172:         nvcc_output: str = session.run(\"nvcc\", \"--version\", silent=True, external=True)\n173:         nvcc_output = \"\".join(nvcc_output.splitlines())  # convert to single string for easier REGEX\n174:         cuda_version = re.match(r\"^.*release ([0-9]+.[0-9]+).*$\", nvcc_output, flags=re.IGNORECASE).group(1).strip()\n175:         session.warn(f\"Detected CUDA version: {cuda_version}\")\n176:         # if we need to install the CUDA extras, first install pycuda seperately, reason:\n177:         #   since version 2022.2 it has `oldest-supported-numpy` as a build dependency which doesn't work with Poetry\n178:         if \" not found: \" in session.run(\"pip\", \"show\", \"pycuda\", external=True, silent=True, success_codes=[0,1]):\n179:             # if PyCUDA is not installed, install it\n180:             session.warn(\"PyCUDA not installed\")\n181:             try:\n182:                 session.install(\"pycuda\", \"--no-cache-dir\", \"--force-reinstall\") # Attention: if changed, check `pycuda` in pyproject.toml as well\n183:             except Exception as error:\n184:                 session.log(error)\n185:                 session.warn(install_warning)\n186:         else:\n187:             session.warn(\"PyCUDA installed\")\n188:             # if PyCUDA is already installed, check whether the CUDA version PyCUDA was installed with matches the current CUDA version\n189:             session.install(\"numpy\")    # required by pycuda.driver\n190:             pycuda_version = session.run(\"python\", \"-c\", \"import pycuda.driver as drv; drv.init(); print('.'.join(list(str(d) for d in drv.get_version())))\", silent=True)\n191:             shortest_string, longest_string = (pycuda_version, cuda_version) if len(pycuda_version) < len(cuda_version) else (cuda_version, pycuda_version)\n192:             if longest_string[:len(shortest_string)] != shortest_string:\n193:                 session.warn(f\"PyCUDA was compiled with a version of CUDA ({pycuda_version}) that does not match the current version ({cuda_version}). Re-installing.\")\n194:                 try:\n195:                     session.install(\"pycuda\", \"--no-cache-dir\", \"--force-reinstall\")  # Attention: if changed, check `pycuda` in pyproject.toml as well\n196:                 except Exception as error:\n197:                     session.log(error)\n198:                     session.warn(install_warning)\n199: \n200:     # finally, install the dependencies, optional dependencies and the package itself\n201:     poetry_env = Path(session.run_always(\"poetry\", \"env\", \"info\", \"--executable\", silent=not verbose, external=True).splitlines()[-1].strip()).resolve()\n202:     session_env = Path(session.bin, \"python/\").resolve()\n203:     assert poetry_env.exists(), f\"{poetry_env=} does not exist\"\n204:     assert session_env.exists(), f\"{session_env=} does not exist\"\n205:     # if the poetry virtualenv is not set to the session env, use requirements file export instead of Poetry install\n206:     if poetry_env != session_env:\n207:         session.warn(f\"Poetry env ({str(poetry_env)}) is not session env ({str(session_env)}), falling back to install via requirements export\")\n208:         requirements_file = Path(f\"tmp_test_requirements_{session.name}.txt\")\n209:         if requirements_file.exists():\n210:             requirements_file.unlink()\n211:         if verbose:\n212:             print(session.run_always('conda', 'list'))\n213:         session.run_always('poetry', 'export', '-f', 'requirements.txt', '-o', requirements_file.name, '--with=test', '--without-hashes', *extras_args, external=True, silent=not verbose)\n214:         session.install('-r', requirements_file.name)\n215:         session.install('.')\n216:         requirements_file.unlink()\n217:         if verbose:\n218:             print(session.run_always('conda', 'list'))\n219:     else:\n220:         try:\n221:             session.run_always(\"poetry\", \"install\", \"--with\", \"test\", *extras_args, external=True, silent=False)\n222:         except Exception as error:\n223:             session.warn(install_warning)\n224:             raise error\n225: \n226:     # if applicable, install the dependencies for additional tests\n227:     if install_additional_tests and install_cuda:\n228:         install_additional_warning = \"\"\"\n229:                 Installation failed, this likely means that the required hardware or drivers are missing.\n230:                 Run without `-- additional-tests` to avoid this.\"\"\"\n231:         # install cuda-python\n232:         try:\n233:             session.install(\"cuda-python\")\n234:         except Exception as error:\n235:             session.log(error)\n236:             session.warn(install_additional_warning)\n237:         # install cupy\n238:         try:\n239:             try:\n240:                 # based on the CUDA version, try installing the exact prebuilt cupy version\n241:                 cuda_cupy_version = f\"cupy-cuda{''.join(cuda_version.split('.'))}\"\n242:                 session.install(cuda_cupy_version)\n243:             except Exception:\n244:                 # if the exact prebuilt is not available, try the more general prebuilt\n245:                 cuda_cupy_version_x = f\"cupy-cuda{cuda_version.split('.')[0]}x\"\n246:                 session.warn(f\"CuPy exact prebuilt not available for {cuda_version}, trying {cuda_cupy_version_x}\")\n247:                 session.install(cuda_cupy_version_x)\n248:         except Exception:\n249:             # if no compatible prebuilt wheel is found, try building CuPy ourselves\n250:             session.warn(f\"No prebuilt CuPy found for CUDA {cuda_version}, building from source...\")\n251:             session.install(\"cupy\")\n252: \n253:     # for the last Python version session if all optional dependencies are enabled:\n254:     if session.python == python_versions_to_test[-1] and full_install:\n255:         # run pytest on the package to generate the correct coverage report\n256:         session.run(\"pytest\", external=False)\n257:     else:\n258:         # for the other Python version sessions:\n259:         # run pytest without coverage reporting\n260:         session.run(\"pytest\", \"--no-cov\", external=False)\n261: \n262:     # warn if no coverage report\n263:     if not full_install:\n264:         session.warn(\"\"\"\n265:                      Tests ran successfully, but only a subset.\n266:                      Coverage file not generated.\n267:                      Run with 'additional-tests' and without 'skip-gpu', 'skip-cuda' etc. to avoid this.\n268:                     \"\"\")\n\n(End of file - total 268 lines)\n</content>","metadata":{"preview":"\"\"\"Configuration file for the Nox test runner.\n\nThis instantiates the specified sessions in isolated environments and runs the tests.\nThis allows for locally mirroring the testing occuring with GitHub-actions.\nBe careful that the general setup of tests is left to pyproject.toml.\n\"\"\"\n\n\nimport platform\nimport re\nfrom pathlib import Path\n\nimport nox\nfrom nox_poetry import Session, session\n\n# set the test parameters\nverbose = False\npython_versions_to_test = [\"3.11\", \"3.12\", \"3.13\", \"3.14\"]\nnox.options.stop_on_first_error = True\nnox.options.error_on_missing_interpreters = True","truncated":false,"loaded":[]},"title":"noxfile.py","time":{"start":1775824925432,"end":1775824925437}}}]}
