{"type":"session_message","session_id":"ses_288963eb6ffeaPeCtB5dMDgj3X","role":"assistant","message_id":"msg_d7769d5c4001c5f7q7zqR5z5T4","parts":[{"id":"prt_d7769e2c1001dyovKqhDsQuMt8","messageID":"msg_d7769d5c4001c5f7q7zqR5z5T4","sessionID":"ses_288963eb6ffeaPeCtB5dMDgj3X","type":"tool","tool":"read","callID":"call_af7f0fc2f6814480ba60de4a","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: requires = [\"poetry-core>=1.7.0\", \"setuptools>=67.7.2\"]\n3: build-backend = \"poetry.core.masonry.api\"\n4: \n5: [project]\n6: name = \"kernel_tuner\"\n7: description = \"An easy to use CUDA/OpenCL kernel tuner in Python\"\n8: version = \"1.3.1\" # adhere to PEP440 versioning: https://packaging.python.org/en/latest/guides/distributing-packages-using-setuptools/#id55\n9: readme = \"README.md\"\n10: license = \"Apache-2.0\"\n11: authors = [\n12:     { name = \"Ben van Werkhoven\", email = \"b.vanwerkhoven@esciencecenter.nl\"},\n13:     { name = \"Alessio Sclocco\", email = \"a.sclocco@esciencecenter.nl\" },\n14:     { name = \"Stijn Heldens\", email = \"s.heldens@esciencecenter.nl\" },\n15:     { name = \"Floris-Jan Willemsen\", email = \"f.j.Willemsen@esciencecenter.nl\" },\n16:     { name = \"Willem-Jan Palenstijn\", email = \"w.j.palenstijn@liacs.leidenuniv.nl\" },\n17:     { name = \"Bram Veenboer\", email = \"veenboer@astron.nl\" },\n18:     { name = \"Richard Schoonhoven\", email = \"Richard.Schoonhoven@cwi.nl\"  },\n19:     { name = \"Leon Oostrum\", email = \"l.oostrum@esciencecenter.nl\" },\n20: ]\n21: keywords = [\n22:     \"auto-tuning\",\n23:     \"gpu\",\n24:     \"computing\",\n25:     \"pycuda\",\n26:     \"cuda\",\n27:     \"pyopencl\",\n28:     \"opencl\",\n29: ]\n30: classifiers = [\n31:     \"Environment :: Console\",\n32:     \"Environment :: GPU\",\n33:     \"Development Status :: 5 - Production/Stable\",\n34:     \"Intended Audience :: Developers\",\n35:     \"Intended Audience :: Education\",\n36:     \"Intended Audience :: Science/Research\",\n37:     \"License :: OSI Approved :: Apache Software License\",\n38:     \"Natural Language :: English\",\n39:     \"Operating System :: MacOS :: MacOS X\",\n40:     \"Operating System :: POSIX :: Linux\",\n41:     \"Topic :: Scientific/Engineering\",\n42:     \"Topic :: Software Development\",\n43:     \"Topic :: System :: Distributed Computing\",\n44:     \"Programming Language :: Python :: 3.10\",\n45:     \"Programming Language :: Python :: 3.11\",\n46:     \"Programming Language :: Python :: 3.12\",\n47:     \"Programming Language :: Python :: 3.13\"\n48: ]\n49: \n50: # ATTENTION: if anything is changed here, run `poetry update`\n51: requires-python = \">=3.10,<4\" # <4 is because of hip-python  # NOTE when changing the Python versions, also change the test versions in the Noxfile and GitHub Actions\n52: dependencies = [\n53:     \"numpy>=2.0.0\",\n54:     \"scipy>=1.14.1\",    # Python >=3.13 needs scipy >=1.14\n55:     \"packaging\",        # required by file_utils\n56:     \"jsonschema\",\n57:     \"python-constraint2>=2.4.0\",\n58:     \"xmltodict\",\n59:     \"pandas>=2.0.0\",\n60:     \"scikit-learn>=1.0.2\",\n61: ]\n62: # NOTE Torch can be used with Kernel Tuner, but is not a dependency, should be up to the user to use it\n63: \n64: [project.urls]\n65: homepage = \"https://KernelTuner.github.io/kernel_tuner/\"\n66: documentation = \"https://KernelTuner.github.io/kernel_tuner/\"\n67: repository = \"https://github.com/KernelTuner/kernel_tuner\"\n68: changelog = \"https://github.com/KernelTuner/kernel_tuner/blob/master/CHANGELOG.md\"\n69: issues = \"https://github.com/KernelTuner/kernel_tuner/issues\"\n70: \n71: [project.scripts]\n72: kernel_tuner = \"kernel_tuner.interface:entry_point\"\n73: \n74: [tool.poetry]\n75: packages = [{ include = \"kernel_tuner\", from = \".\" }]\n76: include = [\n77:     { path = \"test\" },\n78: ] # this ensures that people won't have to clone the whole repo to include notebooks, they can just do `pip install kernel_tuner[tutorial,cuda]`\n79: \n80: # List of optional dependencies for user installation, e.g. `pip install kernel_tuner[cuda]`, used in the below `extras`.\n81: # Please note that this is different from the dependency groups below, e.g. `docs` and `test`, those are for development.\n82: # ATTENTION: if anything is changed here, run `poetry update`\n83: # CUDA\n84: # cupy-cuda11x = { version = \"*\", optional = true }    # NOTE: these are completely optional dependencies as described in CONTRIBUTING.rst\n85: # cupy-cuda12x = { version = \"*\", optional = true }\n86: # cuda-python = { version = \"*\", optional = true }\n87: \n88: [[tool.poetry.source]]\n89: name = \"testpypi\"\n90: url = \"https://test.pypi.org/simple/\"\n91: priority = \"explicit\"\n92: \n93: [tool.poetry.dependencies]\n94: hip-python = { version = \"^6.3.3.540.31\", source = \"testpypi\", optional = true }  # Note: when released, switch this package to pypi and remove tool.poetry.source and move this to [project.optional-dependencies]\n95: \n96: [project.optional-dependencies]\n97: cuda = [\"pycuda>=2025.1\", \"nvidia-ml-py>=12.535.108\", \"pynvml>=11.4.1\"] # Attention: if pycuda is changed here, also change `session.install(\"pycuda\")` in the Noxfile\n98: opencl = [\"pyopencl\"]                                                   # Attention: if pyopencl is changed here, also change `session.install(\"pyopencl\")` in the Noxfile\n99: cuda_opencl = [\"pycuda>=2024.1\", \"pyopencl\"]                            # Attention: if pycuda is changed here, also change `session.install(\"pycuda\")` in the Noxfile\n100: hip = [\"hip-python\"]\n101: tutorial = [\"jupyter>=1.0.0\", \"matplotlib>=3.5.0\", \"nvidia-ml-py>=12.535.108\"]\n102: \n103: # ATTENTION: if anything is changed here, run `poetry update` and `poetry export --with docs --without-hashes --format=requirements.txt --output doc/requirements.txt`\n104: # Please note that there is overlap with the `dev` group\n105: [tool.poetry.group.docs]\n106: optional = true\n107: [tool.poetry.group.docs.dependencies]\n108: sphinx = \"^7.3.7\"\n109: sphinx_rtd_theme = \"^2.0.0\"\n110: sphinx-pyproject = \"^0.3\"\n111: nbsphinx = \"^0.9\"\n112: ipython = \"*\"\n113: pytest = \"^8.2.0\"           # TODO why do we need pytest here?\n114: markupsafe = \"^2.0.1\"       # TODO why do we need markupsafe here?\n115: # sphinx-autodoc-typehints = \"^1.24.0\"\n116: \n117: # ATTENTION: if anything is changed here, run `poetry update`\n118: # Please also run `poetry export -f requirements.txt --output doc/requirements_test.txt --with test`\n119: [tool.poetry.group.test]\n120: optional = true\n121: [tool.poetry.group.test.dependencies]\n122: pytest = \"^8.2.0\"\n123: pytest-timeout = \"^2.3.1\"\n124: pytest-cov = \"^5.0.0\"\n125: mock = \"^5.1.0\"\n126: nox = \"^2024.4.15\"\n127: nox-poetry = \"^1.0.3\"\n128: ruff = \"^0.4.8\"\n129: pep440 = \"^0.1.2\"\n130: tomli = \"^2.0.1\"          # held back by Python <= 3.10, can be replaced by built-in [tomllib](https://docs.python.org/3.11/library/tomllib.html) from Python 3.11 onwards\n131: scikit-optimize = \"0.10.2\"\n132: \n133: # development dependencies are unused for now, as this is already covered by test and docs\n134: # # ATTENTION: if anything is changed here, run `poetry update`\n135: # [tool.poetry.group.dev.dependencies]\n136: \n137: [tool.pytest.ini_options]\n138: minversion = \"7.4\"\n139: pythonpath = [\n140:     \"kernel_tuner\",\n141: ] # necessary to get coverage reports without installing with `-e`\n142: addopts = \"--cov --cov-config=.coveragerc --cov-report=html --cov-report=term-missing --cov-fail-under=60\"\n143: testpaths = [\"test\"]\n144: \n145: [tool.black]\n146: line-length = 120\n147: [tool.ruff]\n148: line-length = 120\n149: respect-gitignore = true\n150: exclude = [\"doc\", \"examples\"]\n151: select = [\n152:     \"E\", # pycodestyle\n153:     \"F\", # pyflakes,\n154:     \"D\", # pydocstyle,\n155: ]\n156: [tool.ruff.pydocstyle]\n157: convention = \"google\"\n158: [tool.ruff.lint]\n159: select = [\"NPY201\"]\n\n(End of file - total 159 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"poetry-core>=1.7.0\", \"setuptools>=67.7.2\"]\nbuild-backend = \"poetry.core.masonry.api\"\n\n[project]\nname = \"kernel_tuner\"\ndescription = \"An easy to use CUDA/OpenCL kernel tuner in Python\"\nversion = \"1.3.1\" # adhere to PEP440 versioning: https://packaging.python.org/en/latest/guides/distributing-packages-using-setuptools/#id55\nreadme = \"README.md\"\nlicense = \"Apache-2.0\"\nauthors = [\n    { name = \"Ben van Werkhoven\", email = \"b.vanwerkhoven@esciencecenter.nl\"},\n    { name = \"Alessio Sclocco\", email = \"a.sclocco@esciencecenter.nl\" },\n    { name = \"Stijn Heldens\", email = \"s.heldens@esciencecenter.nl\" },\n    { name = \"Floris-Jan Willemsen\", email = \"f.j.Willemsen@esciencecenter.nl\" },\n    { name = \"Willem-Jan Palenstijn\", email = \"w.j.palenstijn@liacs.leidenuniv.nl\" },\n    { name = \"Bram Veenboer\", email = \"veenboer@astron.nl\" },\n    { name = \"Richard Schoonhoven\", email = \"Richard.Schoonhoven@cwi.nl\"  },\n    { name = \"Leon Oostrum\", email = \"l.oostrum@esciencecenter.nl\" },\n]","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775824921576,"end":1775824921579}}}]}
