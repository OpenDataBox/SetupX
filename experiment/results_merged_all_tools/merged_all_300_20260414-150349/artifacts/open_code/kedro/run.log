{"type":"session_message","session_id":"ses_278b59d75ffeHdT4rN4BayaROP","role":"assistant","message_id":"msg_d874a7577001p4qeGJX2HxUfEG","parts":[{"id":"prt_d874a7f6500186MwMAmQP1C6Fu","messageID":"msg_d874a7577001p4qeGJX2HxUfEG","sessionID":"ses_278b59d75ffeHdT4rN4BayaROP","type":"tool","tool":"read","callID":"call_74c2024e536541b687f8b3cb","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: # PEP-518 https://peps.python.org/pep-0518/\n2: [build-system]\n3: # Minimum requirements for the build system to execute.\n4: requires = [\"setuptools>=65.5.1\"]  # PEP 518 specifications\n5: build-backend = \"setuptools.build_meta\"\n6: \n7: [project]\n8: name = \"kedro\"\n9: authors = [\n10:     {name = \"Kedro\"}\n11: ]\n12: description = \"Kedro helps you build production-ready data and analytics pipelines\"\n13: requires-python = \">=3.10\"\n14: dependencies = [\n15:     \"attrs>=21.3\",\n16:     \"build>=0.7.0\",\n17:     \"click>=8.2\",\n18:     \"cookiecutter>=2.1.1,<3.0\",\n19:     \"dynaconf>=3.1.2,<4.0\",\n20:     \"fsspec>=2021.4\",\n21:     \"gitpython>=3.0\",\n22:     \"kedro-telemetry>=0.5.0\",\n23:     \"more_itertools>=8.14.0\",\n24:     \"omegaconf>=2.1.1\",\n25:     \"parse>=1.19.0\",\n26:     \"pluggy>=1.0\",\n27:     \"PyYAML>=4.2,<7.0\",\n28:     \"rich>=12.0,<15.0\",\n29:     \"tomli>=1.1.0;python_version<'3.11'\",  # tomllib is part of the standard library in Python 3.11+\n30:     \"tomli-w\",\n31:     \"typing_extensions>=4.0\",\n32: ]\n33: keywords = [\n34:     \"pipelines\",\n35:     \"machine learning\",\n36:     \"data pipelines\",\n37:     \"data science\",\n38:     \"data engineering\",\n39: ]\n40: license = {text = \"Apache Software License (Apache 2.0)\"}\n41: classifiers = [\n42:     \"Development Status :: 5 - Production/Stable\",\n43:     \"Programming Language :: Python :: 3.10\",\n44:     \"Programming Language :: Python :: 3.11\",\n45:     \"Programming Language :: Python :: 3.12\",\n46:     \"Programming Language :: Python :: 3.13\",\n47: ]\n48: dynamic = [\"readme\", \"version\"]\n49: \n50: [project.optional-dependencies]\n51: test = [\n52:     \"behave>=1.2.6,<2.0\",\n53:     \"chardet<6\",  # Temporary: remove once requests supports chardet 6 (causes RequestsDependencyWarning)\n54:     \"coverage[toml]\",\n55:     \"detect-secrets~=1.5.0\",\n56:     \"import-linter>=2.5.2,<3.0\",\n57:     \"ipylab>=1.0.0\",\n58:     \"ipython>=8.10,<10.0\",\n59:     \"jupyterlab_server>=2.11.1\",\n60:     \"jupyterlab>=3,<5\",\n61:     \"jupyter~=1.0\",\n62:     \"kedro-datasets\",\n63:     \"mypy~=1.0\",\n64:     \"pandas>=2.0,<4.0\",\n65:     \"pluggy>=1.0\",\n66:     \"pre-commit>=2.9.2,<5.0\",  # The hook `mypy` requires pre-commit version 2.9.2.\n67:     \"pydantic\",\n68:     \"pytest-cov>=3,<8\",\n69:     \"pytest-mock>=1.7.1,<4.0\",\n70:     \"pytest-xdist[psutil]>=2.2.1,<4.0\",\n71:     \"pytest>=7.2,<10.0\",\n72:     \"requests_mock\",\n73:     \"s3fs>=2021.4,<2026.5\",\n74:     # mypy related dependencies\n75:     \"pandas-stubs\",\n76:     \"types-PyYAML\",\n77:     \"types-requests\",\n78: ]\n79: docs = [\n80:     \"mkdocs>=1.6.1,<2.0\",\n81:     \"mkdocs-material>=9.6.11\",\n82:     \"mkdocs-material-extensions>=1.3.1\",\n83:     \"mkdocs-mermaid2-plugin>=1.2.1\",\n84:     \"mkdocs-autorefs>=1.4.1\",\n85:     \"mkdocs-get-deps>=0.2.0\",\n86:     \"mkdocstrings>=0.29.1\",\n87:     \"mkdocstrings-python>=0.29.1\",\n88:     \"mkdocs-click\",\n89:     \"mkdocs-redirects\",\n90:     \"griffe\",  # Required by mkdocstrings-python for API documentation generation.\n91:     \"mkdocs-llmstxt\" # Required to generate the llm.txt file\n92: ]\n93: jupyter = [\n94:     \"ipylab>=1.0.0\",\n95:     \"notebook>=7.0.0\"  # requires the new share backend of notebook and labs\"\n96: ]\n97: benchmark = [\n98:     \"asv\"\n99: ]\n100: all = [ \"kedro[test,docs,jupyter,benchmark]\" ]\n101: \n102: [project.urls]\n103: Homepage = \"https://kedro.org\"\n104: Source = \"https://github.com/kedro-org/kedro\"\n105: Documentation = \"https://docs.kedro.org\"\n106: Tracker = \"https://github.com/kedro-org/kedro/issues\"\n107: \n108: [project.scripts]\n109: kedro = \"kedro.framework.cli:main\"\n110: \n111: [tool.setuptools]\n112: zip-safe = false\n113: \n114: [tool.setuptools.packages.find]\n115: include = [\"kedro*\"]\n116: \n117: [tool.setuptools.package-data]\n118: kedro = [\"py.typed\"]\n119: \n120: [tool.setuptools.dynamic]\n121: readme = {file = \"README.md\", content-type = \"text/markdown\"}\n122: version = {attr = \"kedro.__version__\"}\n123: \n124: [tool.ruff.format]\n125: exclude = [\"**/templates\", \"features/test_starter\"]\n126: docstring-code-format = true\n127: \n128: [tool.coverage.report]\n129: fail_under = 100\n130: show_missing = true\n131: omit = [\n132:     \"kedro/templates/*\",\n133:     \"kedro/extras/logging/color_logger.py\",\n134:     \"kedro/extras/extensions/ipython.py\",\n135:     \"kedro/framework/cli/hooks/specs.py\",\n136:     \"kedro/framework/hooks/specs.py\",\n137:     \"tests/*\",\n138:     \"kedro/runner/parallel_runner.py\",\n139:     \"*/site-packages/*\",\n140: ]\n141: exclude_also = [\"raise NotImplementedError\", \"if TYPE_CHECKING:\", \"class CatalogProtocol\"]\n142: \n143: [tool.coverage.run]\n144: concurrency = [\"multiprocessing\", \"thread\"]\n145: parallel = true\n146: sigterm = true\n147: \n148: [tool.pytest.ini_options]\n149: addopts=\"\"\"\n150: --cov-context test  \\\n151: --cov-config pyproject.toml \\\n152: --cov-report xml:coverage.xml \\\n153: --cov-report term-missing \\\n154: --cov kedro \\\n155: --cov tests \\\n156: --ignore tests/template/fake_repo \\\n157: --ignore features \\\n158: --ignore kedro/templates \\\n159: --no-cov-on-fail \\\n160: -ra \\\n161: -W ignore\"\"\"\n162: testpaths = [\n163:   \"tests\"\n164: ]\n165: \n166: [tool.importlinter]\n167: root_package = \"kedro\"\n168: \n169: [[tool.importlinter.contracts]]\n170: name = \"CLI > Context > Library, Runner > Extras > IO & Pipeline\"\n171: type = \"layers\"\n172: containers = \"kedro\"\n173: layers = [\n174:     \"framework.cli\",\n175:     \"framework.session\",\n176:     \"framework.context\",\n177:     \"framework.project\",\n178:     \"runner\",\n179:     \"io\",\n180:     \"pipeline\",\n181:     \"config\"\n182: ]\n183: ignore_imports = [\n184:     \"kedro.runner.task -> kedro.framework.project\",\n185:     \"kedro.framework.hooks.specs -> kedro.framework.context\",\n186:     \"kedro -> kedro.ipython\"\n187: ]\n188: \n189: [[tool.importlinter.contracts]]\n190: name = \"Pipeline and IO are independent\"\n191: type = \"independence\"\n192: modules = [\n193:     \"kedro.pipeline\",\n194:     \"kedro.io\"\n195: ]\n196: ignore_imports = [\n197:     \"kedro -> kedro.ipython\"\n198: ]\n199: \n200: [[tool.importlinter.contracts]]\n201: name = \"Config cannot import Runner et al\"\n202: type = \"forbidden\"\n203: source_modules = [\n204:     \"kedro.config\"\n205: ]\n206: forbidden_modules = [\n207:     \"kedro.runner\",\n208:     \"kedro.io\",\n209:     \"kedro.pipeline\",\n210: ]\n211: \n212: [[tool.importlinter.contracts]]\n213: name = \"Runner et al cannot import Config\"\n214: type = \"forbidden\"\n215: source_modules = [\n216:     \"kedro.runner\",\n217:     \"kedro.io\",\n218:     \"kedro.pipeline\",\n219: ]\n220: forbidden_modules = [\n221:     \"kedro.config\"\n222: ]\n223: ignore_imports = [\n224:     \"kedro.framework.context.context -> kedro.config\",\n225:     \"kedro.framework.session.session -> kedro.config\",\n226: ]\n227: \n228: [tool.ruff]\n229: line-length = 88\n230: show-fixes = true\n231: lint.select = [\n232:     \"F\",    # Pyflakes\n233:     \"W\",    # pycodestyle\n234:     \"E\",    # pycodestyle\n235:     \"I\",    # isort\n236:     \"UP\",   # pyupgrade\n237:     \"PL\",   # Pylint\n238:     \"T201\", # Print Statement\n239:     \"S\",    # flake8-bandit\n240:     \"TCH\",  # flake8-type-checking\n241:     \"RUF\",  # Ruff-specific rules\n242: ]\n243: lint.ignore = [\"E501\"]\n244: \n245: [tool.ruff.lint.isort]\n246: known-first-party = [\"kedro\"]\n247: \n248: [tool.ruff.lint.per-file-ignores]\n249: \"{tests,docs}/*\" = [\"PLR2004\",\"PLR0913\"]\n250: \"{tests,docs,tools,static,features,docs}/*\" = [\"T201\", \"S101\", \"S108\"]  # Check print statement for kedro/ only\n251: \n252: [tool.mypy]\n253: ignore_missing_imports = true\n254: disable_error_code = [\"misc\", \"untyped-decorator\"]\n255: exclude = [\"^kedro/templates/\", \"^docs/\", \"^features/test_starter/\"]\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"# PEP-518 https://peps.python.org/pep-0518/\n[build-system]\n# Minimum requirements for the build system to execute.\nrequires = [\"setuptools>=65.5.1\"]  # PEP 518 specifications\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"kedro\"\nauthors = [\n    {name = \"Kedro\"}\n]\ndescription = \"Kedro helps you build production-ready data and analytics pipelines\"\nrequires-python = \">=3.10\"\ndependencies = [\n    \"attrs>=21.3\",\n    \"build>=0.7.0\",\n    \"click>=8.2\",\n    \"cookiecutter>=2.1.1,<3.0\",\n    \"dynaconf>=3.1.2,<4.0\",\n    \"fsspec>=2021.4\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1776091300117,"end":1776091300121}}}]}
