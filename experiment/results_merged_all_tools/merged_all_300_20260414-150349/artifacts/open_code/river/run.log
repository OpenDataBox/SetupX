ominate\",\n54:     \"flask\",\n55:     \"ipykernel\",\n56:     \"jupyter-client\",\n57:     \"mike @ git+https://github.com/squidfunk/mike.git\",\n58:     \"pygments<2.20\",\n59:     \"zensical\",\n60:     \"nbconvert\",\n61:     \"numpydoc\",\n62:     \"plotly>=6.3.0\",\n63:     \"python-slugify\",\n64:     \"spacy\",\n65:     \"tabulate\",\n66:     \"watermark\",\n67:     \"notebook<7\",\n68:     \"jupyter-contrib-nbextensions>=0.7.0,<0.8\",\n69: ]\n70: benchmark = [\n71:     \"asv\",\n72:     \"virtualenv\",\n73: ]\n74: \n75: [tool.poetry.build]\n76: generate-setup-file = true\n77: script = \"build.py\"\n78: \n79: [tool.poetry.dependencies]\n80: python = \"^3.10\"\n81: numpy = \">=1.23.0\"\n82: scipy = \"^1.14.1\"\n83: pandas = \"^2.2.3\"\n84: \n85: [tool.poetry.group.dev.dependencies]\n86: graphviz = \"^0.20.1\"\n87: gymnasium = \"^0.29.0\"\n88: matplotlib = \"^3.8.4\"\n89: mypy = \"^1.11.1\"\n90: pre-commit = \"^3.5.0\"\n91: pytest = \"^7.4.2\"\n92: ruff = \"^0.4.10\"\n93: scikit-learn = \"^1.5.1\"\n94: sqlalchemy = \"^2.0.22\"\n95: sympy = \"^1.12.1\"\n96: pytest-xdist = { extras = [\"psutil\"], version = \"^3.3.1\" }\n97: ipykernel = \"^6.26.0\"\n98: ipython = \"^8.17.2\"\n99: rich = \"^13.6.0\"\n100: jupyter = \"^1.0.0\"\n101: mike = { git = \"https://github.com/squidfunk/mike.git\" }\n102: polars = \"^1.1.0\"\n103: \n104: [tool.poetry.group.compat]\n105: optional = true\n106: \n107: [tool.poetry.group.compat.dependencies]\n108: scikit-learn = \"^1.5.1\"\n109: sqlalchemy = \"^2.0.0\"\n110: \n111: [tool.poetry.group.docs]\n112: optional = true\n113: \n114: [tool.poetry.group.docs.dependencies]\n115: \"dominate\" = \"*\"\n116: \"flask\" = \"*\"\n117: \"ipykernel\" = \"*\"\n118: \"jupyter-client\" = \"*\"\n119: \"jupyter-contrib-nbextensions\" = \"^0.7.0\"\n120: \"mike\" = { git = \"https://github.com/squidfunk/mike.git\" }\n121: \"zensical\" = \"*\"\n122: \"nbconvert\" = \"*\"\n123: \"notebook\" = \"<7\"\n124: \"numpydoc\" = \"*\"\n125: \"plotly\" = \">6.3.0\"\n126: \"python-slugify\" = \"*\"\n127: \"spacy\" = \"*\"\n128: \"tabulate\" = \"*\"\n129: \"watermark\" = \"*\"\n130: \n131: [tool.poetry.group.benchmark]\n132: optional = true\n133: \n134: \n135: \n136: \n137: \n138: [tool.setuptools]\n139: packages = [\"river\"]\n140: \n141: [tool.uv]\n142: default-groups = [\n143:     \"dev\",\n144:     \"compat\",\n145:     \"docs\",\n146:     \"benchmark\",\n147: ]\n148: \n149: [tool.cibuildwheel]\n150: build-frontend = \"build[uv]\"\n151: skip = \"*-musllinux_i686\"\n152: enable = [\"cpython-freethreading\"]\n153: test-command = \"python -c \\\"import river\\\"\"\n154: \n155: [tool.cibuildwheel.environment]\n156: PATH = \"$HOME/.cargo/bin:$PATH\"\n157: \n158: [tool.cibuildwheel.linux.environment]\n159: PATH = \"$HOME/.cargo/bin:$PATH\"\n160: CARGO_NET_GIT_FETCH_WITH_CLI = \"true\"\n161: \n162: [[tool.cibuildwheel.overrides]]\n163: select = \"*-linux_*\"\n164: before-build = \"\"\"curl https://sh.rustup.rs -sSf | sh -s -- --default-toolchain=nightly --profile=minimal -y && rustup show\"\"\"\n165: \n166: [[tool.cibuildwheel.overrides]]\n167: select = [\"*-macosx_*\"]\n168: before-build = \"rustup default nightly && rustup target add aarch64-apple-darwin && rustup target add x86_64-apple-darwin && rustup show\"\n169: \n170: [[tool.cibuildwheel.overrides]]\n171: select = [\"*-win_*\", \"*-win32\"]\n172: before-build = \"rustup default nightly && rustup toolchain install nightly-i686-pc-windows-msvc && rustup target add i686-pc-windows-msvc && rustup show\"\n173: \n174: [tool.hatch.build.targets.sdist]\n175: include = [\n176:     \"**/*.cpp\",\n177:     \"**/*.pyx\",\n178:     \"**/*.pxd\",\n179:     \"river/datasets/*.csv\",\n180:     \"river/datasets/*.gz\",\n181:     \"river/datasets/*.zip\",\n182:     \"river/stream/*.zip\",\n183:     \"Cargo.toml\",\n184:     \"rust_src/**/*\",\n185: ]\n186: \n187: [tool.hatch.build.targets.wheel]\n188: include = [\n189:     \"**/*.cpp\",\n190:     \"**/*.pyx\",\n191:     \"**/*.pxd\",\n192:     \"river/datasets/*.csv\",\n193:     \"river/datasets/*.gz\",\n194:     \"river/datasets/*.zip\",\n195:     \"river/stream/*.zip\",\n196:     \"Cargo.toml\",\n197:     \"rust_src/**/*\",\n198: ]\n199: \n200: [tool.pytest.ini_options]\n201: addopts = [\n202:     \"--doctest-modules\",\n203:     \"--doctest-glob=README.md\",\n204:     \"--ignore=build.py\",\n205:     \"--ignore=benchmarks\",\n206:     \"--ignore=docs/scripts\",\n207:     \"--verbose\",\n208:     \"-ra\",\n209:     \"-m not datasets and not slow\",\n210:     \"--color=yes\",\n211: ]\n212: filterwarnings = [\n213:     \"ignore:A single label was found in 'y_true' and 'y_pred':UserWarning:sklearn\",\n214: ]\n215: doctest_optionflags = \"NORMALIZE_WHITESPACE NUMBER ELLIPSIS\"\n216: norecursedirs = [\n217:     \"build\",\n218:     \"docs\",\n219:     \"node_modules\",\n220:     \".eggs\",\n221:     \"scikit-multiflow\",\n222:     \"site\",\n223:     \"benchmarks\",\n224: ]\n225: markers = [\n226:     \"datasets: tests that pertain to the datasets module\",\n227:     \"slow: tests that take a long time to run\",\n228: ]\n229: \n230: [tool.ruff]\n231: line-length = 100\n232: target-version = 'py310'\n233: extend-include = [\"*.ipynb\"]\n234: \n235: [tool.ruff.lint]\n236: select = [\n237:     # pycodestyle\n238:     \"E\",\n239:     # Pyflakes\n240:     \"F\",\n241:     # pyupgrade\n242:     \"UP\",\n243:     # isort\n244:     \"I\",\n245: ]\n246: ignore = [\"E501\"]\n247: fixable = [\"ALL\"]\n248: \n249: [tool.ruff.lint.isort]\n250: required-imports = [\"from __future__ import annotations\"]\n251: \n252: [tool.ruff.format]\n253: quote-style = \"double\"\n254: indent-style = \"space\"\n255: \n256: [tool.mypy]\n257: files = \"river\"\n258: strict = true\n259: \n260: [[tool.mypy.overrides]]\n261: module = [\n262:     \"mmh3.*\",\n263:     \"numpy.*\",\n264:     \"sklearn.*\",\n265:     \"pytest.*\",\n266:     \"pandas.*\",\n267:     \"scipy.*\",\n268:     \"graphviz.*\",\n269:     \"vaex.*\",\n270:     \"torch.*\",\n271:     \"sqlalchemy.*\",\n272:     \"requests.*\",\n273:     \"gymnasium.*\",\n274:     \"sympy.*\",\n275:     \"polars.*\",\n276: ]\n277: ignore_missing_imports = true\n278: \n279: [[tool.mypy.overrides]]\n280: # Disable strict mode for all non fully-typed modules\n281: module = [\n282:     \"river.metrics.*\",\n283:     \"river.stats.*\",\n284:     \"river.optim.*\",\n285:     \"river.datasets.*\",\n286:     \"river.tree.*\",\n287:     \"river.preprocessing.*\",\n288:     \"river.stream.*\",\n289:     \"river.linear_model.*\",\n290:     \"river.evaluate.*\",\n291:     \"river.drift.*\",\n292:     \"river.compose.*\",\n293:     \"river.bandit.*\",\n294:     \"river.cluster.*\",\n295:     \"river.anomaly.*\",\n296:     \"river.time_series.*\",\n297:     \"river.feature_extraction.*\",\n298:     \"river.ensemble.*\",\n299:     \"river.proba.*\",\n300:     \"river.multioutput.*\",\n301:     \"river.naive_bayes.*\",\n302:     \"river.checks.*\",\n303:     \"river.rules.*\",\n304:     \"river.model_selection.*\",\n305:     \"river.forest.*\",\n306:     \"river.neighbors.*\",\n307:     \"river.sketch.*\",\n308:     \"river.facto.*\",\n309:     \"river.covariance.*\",\n310:     \"river.compat.*\",\n311:     \"river.multiclass.*\",\n312:     \"river.reco.*\",\n313:     \"river.imblearn.*\",\n314:     \"river.feature_selection.*\",\n315:     \"river.active.*\",\n316:     \"river.neural_net.*\",\n317:     \"river.test_estimators\",\n318: ]\n319: # The strict option is global, the checks must be disabled one by one\n320: warn_unused_ignores = false\n321: check_untyped_defs = false\n322: allow_subclassing_any = true\n323: allow_any_generics = true\n324: allow_untyped_calls = true\n325: allow_incomplete_defs = true\n326: allow_untyped_defs = true\n327: warn_return_any = false\n\n(End of file - total 327 lines)\n</content>","metadata":{"preview":"[project]\nname = \"river\"\nversion = \"0.23.0\"\ndescription = \"Online machine learning in Python\"\nauthors = [{ name 