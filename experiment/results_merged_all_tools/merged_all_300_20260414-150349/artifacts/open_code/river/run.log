\ndrwxr-xr-x  8 root root   4096 Apr  9 20:13 .git\n-rw-r--r--  1 root root     79 Apr  9 20:13 .gitattributes\ndrwxr-xr-x  4 root root   4096 Apr  9 20:13 .github\n-rw-r--r--  1 root root   1383 Apr  9 20:13 .gitignore\n-rw-r--r--  1 root root    842 Apr  9 20:13 .pre-commit-config.yaml\n-rw-r--r--  1 root root      7 Apr  9 20:13 .python-version\n-rw-r--r--  1 root root    335 Apr  9 20:13 CITATION.bib\n-rw-r--r--  1 root root   2456 Apr  9 20:13 CLAUDE.md\n-rw-r--r--  1 root root   3354 Apr  9 20:13 CODE_OF_CONDUCT.md\n-rw-r--r--  1 root root   7126 Apr  9 20:13 CONTRIBUTING.md\n-rw-r--r--  1 root root    696 Apr  9 20:13 Cargo.toml\n-rw-r--r--  1 root root   1528 Apr  9 20:13 LICENSE\n-rw-r--r--  1 root root   1166 Apr  9 20:13 Makefile\n-rw-r--r--  1 root root   7805 Apr  9 20:13 README.md\ndrwxr-xr-x  2 root root   4096 Apr  9 20:13 benches\ndrwxr-xr-x  3 root root   4096 Apr  9 20:13 benchmarks\ndrwxr-xr-x 16 root root   4096 Apr  9 20:13 docs\n-rw-r--r--  1 root root  82964 Apr  9 20:13 mkdocs.yml\n-rw-r--r--  1 root root   6989 Apr  9 20:13 pyproject.toml\ndrwxr-xr-x 41 root root   4096 Apr  9 20:13 river\ndrwxr-xr-x  2 root root   4096 Apr  9 20:13 rust_src\n-rw-r--r--  1 root root   1424 Apr  9 20:13 setup.py\n-rw-r--r--  1 root root 730173 Apr  9 20:13 uv.lock\n","exit":0,"description":"List workspace directory contents","truncated":false},"title":"List workspace directory contents","time":{"start":1775765626777,"end":1775765626829}}}]}
