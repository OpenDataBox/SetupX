{"type":"session_message","session_id":"ses_2889c783affeUIX3gr9Z6cf87u","role":"assistant","message_id":"msg_d7763a5dd001TfWDwKVVxzZNda","parts":[{"id":"prt_d7763b19b001G37gXOlqts30Vt","messageID":"msg_d7763a5dd001TfWDwKVVxzZNda","sessionID":"ses_2889c783affeUIX3gr9Z6cf87u","type":"tool","tool":"read","callID":"call_d379e1cf87234d6fa6b929ce","state":{"status":"completed","input":{"filePath":"/workspace/tasks.py"},"output":"<path>/workspace/tasks.py</path>\n<type>file</type>\n<content>1: \"\"\"Deployment file to facilitate releases of monty.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import datetime\n6: import glob\n7: import json\n8: import os\n9: import re\n10: from typing import TYPE_CHECKING\n11: \n12: import requests\n13: from invoke import task\n14: \n15: from monty import __version__ as ver\n16: from monty.os import cd\n17: \n18: if TYPE_CHECKING:\n19:     from invoke import Context\n20: \n21: __author__ = \"Shyue Ping Ong\"\n22: __copyright__ = \"Copyright 2012, The Materials Project\"\n23: __version__ = \"0.1\"\n24: __maintainer__ = \"Shyue Ping Ong\"\n25: __email__ = \"shyue@mit.edu\"\n26: __date__ = \"Apr 29, 2012\"\n27: \n28: NEW_VER = datetime.datetime.today().strftime(\"%Y.%-m.%-d\")\n29: \n30: \n31: @task\n32: def make_doc(ctx: Context) -> None:\n33:     with cd(\"docs\"):\n34:         ctx.run(\"rm monty.*.rst\", warn=True)\n35:         ctx.run(\"sphinx-apidoc --separate -P -M -d 6 -o . -f ../src/monty\")\n36:         # ctx.run(\"rm monty*.html\", warn=True)\n37:         # ctx.run(\"sphinx-build -b html . ../docs\")  # HTML building.\n38:         ctx.run(\"sphinx-build -M markdown . .\")\n39:         ctx.run(\"rm *.rst\", warn=True)\n40:         ctx.run(\"cp markdown/monty*.md .\")\n41:         for fn in glob.glob(\"monty*.md\"):\n42:             with open(fn, encoding=\"utf-8\") as f:\n43:                 lines = [line.rstrip() for line in f if \"Submodules\" not in line]\n44:             if fn == \"monty.md\":\n45:                 preamble = [\n46:                     \"---\",\n47:                     \"layout: default\",\n48:                     \"title: API Documentation\",\n49:                     \"nav_order: 5\",\n50:                     \"---\",\n51:                     \"\",\n52:                 ]\n53:             else:\n54:                 preamble = [\n55:                     \"---\",\n56:                     \"layout: default\",\n57:                     f\"title: {fn}\",\n58:                     \"nav_exclude: true\",\n59:                     \"---\",\n60:                     \"\",\n61:                 ]\n62:             with open(fn, \"w\", encoding=\"utf-8\") as f:\n63:                 f.write(\"\\n\".join(preamble + lines))\n64: \n65:         ctx.run(\"rm -r markdown\", warn=True)\n66:         ctx.run(\"cp ../*.md .\")\n67:         ctx.run(\"mv README.md index.md\")\n68:         ctx.run(\"rm -rf *.orig doctrees\", warn=True)\n69: \n70:         with open(\"index.md\", encoding=\"utf-8\") as f:\n71:             contents = f.read()\n72:         with open(\"index.md\", \"w\", encoding=\"utf-8\") as f:\n73:             contents = re.sub(\n74:                 r\"\\n## Official Documentation[^#]*\",\n75:                 \"{: .no_toc }\\n\\n## Table of contents\\n{: .no_toc .text-delta }\\n* TOC\\n{:toc}\\n\\n\",\n76:                 contents,\n77:             )\n78:             contents = (\n79:                 \"---\\nlayout: default\\ntitle: Home\\nnav_order: 1\\n---\\n\\n\" + contents\n80:             )\n81: \n82:             f.write(contents)\n83: \n84: \n85: @task\n86: def update_doc(ctx: Context) -> None:\n87:     ctx.run(\"git pull\", warn=True)\n88:     make_doc(ctx)\n89:     ctx.run(\"git add .\", warn=True)\n90:     ctx.run('git commit -a -m \"Update dev docs\"', warn=True)\n91:     ctx.run(\"git push\", warn=True)\n92: \n93: \n94: @task\n95: def test(ctx: Context) -> None:\n96:     ctx.run(\"pytest\")\n97: \n98: \n99: @task\n100: def setver(ctx: Context) -> None:\n101:     ctx.run(f'sed s/version=.*,/version=\\\\\"{ver}\\\\\",/ setup.py > newsetup')\n102:     ctx.run(\"mv newsetup setup.py\")\n103: \n104: \n105: @task\n106: def release_github(ctx: Context) -> None:\n107:     with open(\"docs/changelog.md\", encoding=\"utf-8\") as f:\n108:         contents = f.read()\n109:     toks = re.split(\"##\", contents)\n110:     desc = toks[1].strip()\n111:     payload = {\n112:         \"tag_name\": f\"v{NEW_VER}\",\n113:         \"target_commitish\": \"master\",\n114:         \"name\": f\"v{NEW_VER}\",\n115:         \"body\": desc,\n116:         \"draft\": False,\n117:         \"prerelease\": False,\n118:     }\n119: \n120:     response = requests.post(\n121:         \"https://api.github.com/repos/materialsvirtuallab/monty/releases\",\n122:         data=json.dumps(payload),\n123:         headers={\"Authorization\": \"token \" + os.environ[\"GITHUB_RELEASES_TOKEN\"]},\n124:     )\n125:     print(response.text)\n126: \n127: \n128: @task\n129: def commit(ctx: Context) -> None:\n130:     ctx.run(f'git commit -a -m \"v{NEW_VER} release\"', warn=True)\n131:     ctx.run(\"git push\", warn=True)\n132: \n133: \n134: @task\n135: def set_ver(ctx: Context, version: str = NEW_VER) -> None:\n136:     with open(\"pyproject.toml\", encoding=\"utf-8\") as f:\n137:         contents = f.read()\n138:         contents = re.sub(r\"version = ([\\.\\d\\\"]+)\", f'version = \"{version}\"', contents)\n139: \n140:     with open(\"pyproject.toml\", \"w\", encoding=\"utf-8\") as f:\n141:         f.write(contents)\n142: \n143: \n144: @task\n145: def release(ctx: Context, notest: bool = False, version: str = NEW_VER) -> None:\n146:     set_ver(ctx, version)\n147:     if not notest:\n148:         test(ctx)\n149:     # update_doc(ctx)\n150:     commit(ctx)\n151:     release_github(ctx)\n152:     ctx.run(\"python -m build\", warn=True)\n153:     ctx.run(\"python -m build --wheel\", warn=True)\n154:     ctx.run(\"twine upload --skip-existing dist/*.whl\", warn=True)\n155:     ctx.run(\"twine upload --skip-existing dist/*.tar.gz\", warn=True)\n\n(End of file - total 155 lines)\n</content>","metadata":{"preview":"\"\"\"Deployment file to facilitate releases of monty.\"\"\"\n\nfrom __future__ import annotations\n\nimport datetime\nimport glob\nimport json\nimport os\nimport re\nfrom typing import TYPE_CHECKING\n\nimport requests\nfrom invoke import task\n\nfrom monty import __version__ as ver\nfrom monty.os import cd\n\nif TYPE_CHECKING:\n    from invoke import Context\n","truncated":false,"loaded":[]},"title":"tasks.py","time":{"start":1775824515632,"end":1775824515640}}}]}
