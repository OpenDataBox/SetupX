{"type":"session_message","session_id":"ses_289c4bb43ffeh1fAUGyexNPYoK","role":"assistant","message_id":"msg_d763b59580015wWuNtVtTddMlI","parts":[{"id":"prt_d763b6205001sXY1xbZt3ikVnr","messageID":"msg_d763b59580015wWuNtVtTddMlI","sessionID":"ses_289c4bb43ffeh1fAUGyexNPYoK","type":"tool","tool":"read","callID":"call_7e8b8e6d5d8a427f923b6332","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: requires = [\"setuptools>=64.0.0\", \"setuptools-scm\", \"wheel\"]\n3: build-backend = \"setuptools.build_meta\"\n4: \n5: [project]\n6: authors = [\n7:     { name = \"Giulia Crocioni\", email = \"g.crocioni@esciencecenter.nl\" },\n8:     { name = \"Dani Bodor\", email = \"d.bodor@esciencecenter.nl\" },\n9:     { name = \"Nathan Cloos\", email = \"cloosnathan@gmail.com\" },\n10:     { name = \"Alexander Hadjiivanov\", email = \"a.hadjiivanov@esciencecenter.nl\" },\n11:     { name = \"Guangyu Robert Yang\", email = \"gyyang.neuro@gmail.com\" },\n12:     { name = \"Jorge Mejias\", email = \"j.f.mejias@uva.nl\" },\n13:     { name = \"Manuel Molano Mazon\", email = \"manuelmolanomazon@gmail.com\" },\n14: ]\n15: classifiers = [\n16:     \"License :: OSI Approved :: Apache Software License\",\n17:     \"Natural Language :: English\",\n18:     \"Programming Language :: Python :: 3.10\",\n19:     \"Programming Language :: Python :: 3.11\",\n20:     \"Programming Language :: Python :: 3.12\",\n21:     \"Programming Language :: Python :: 3.13\",\n22:     \"Programming Language :: Python :: 3.14\",\n23: ]\n24: dependencies = [\n25:     \"pydantic-settings\",\n26:     \"loguru\",\n27:     \"tqdm\",\n28:     \"tomlkit\",\n29:     \"numpy==2.2.*\",\n30:     \"gymnasium==0.29.*\",\n31:     \"matplotlib==3.10.*\",\n32:     \"scipy\",\n33:     \"natsort\"\n34: ]\n35: description = \"NeuroGym: Gymnasium-style Cognitive Neuroscience Tasks\"\n36: keywords = [\n37:     \"neuroscience\",\n38:     \"neural networks\",\n39:     \"supervised learning\",\n40:     \"reinforcement learning\",\n41:     \"synthetic data\",\n42: ]\n43: license = { text = \"Apache-2.0 License\" }\n44: name = \"neurogym\"\n45: readme = { file = \"README.md\", content-type = \"text/markdown\" }\n46: requires-python = \">=3.10\"\n47: version = \"2.3.1\"\n48: \n49: [project.optional-dependencies]\n50: dev = [\n51:     # testing\n52:     \"pytest\",\n53:     \"pytest-cov\",\n54:     \"coverage [toml]\",\n55:     # code style\n56:     \"ruff==0.11.*\",\n57:     \"mypy\",\n58:     \"types-docutils\",\n59:     \"scipy-stubs\",\n60:     \"typos\",\n61:     # docs\n62:     \"mkdocs\",\n63:     \"mkdocs-material\",\n64:     \"mkdocs-exclude\",\n65:     \"mkdocs-redirects\",\n66:     \"mkdocstrings-python\",\n67:     \"mike\",\n68:     \"mkdocs-jupyter\",\n69:     \"black\",\n70:     # release\n71:     \"bump-my-version\",\n72: ]\n73: publishing = [\"build\", \"twine\", \"wheel\"]\n74: rl = [\"stable-baselines3>=2.3.2\", \"sb3-contrib\"]\n75: notebooks = [\"nbmake\", \"tensorflow\"]\n76: \n77: [project.urls]\n78: Repository = \"https://github.com/neurogym/neurogym\"\n79: Issues = \"https://github.com/neurogym/neurogym\"\n80: Documentation = \"https://neurogym.github.io/neurogym\"\n81: Changelog = \"https://github.com/neurogym/neurogym/CHANGELOG.md\"\n82: \n83: [tool.pytest.ini_options]\n84: testpaths = [\"tests\"]\n85: \n86: [tool.coverage.run]\n87: branch = true\n88: source = [\"neurogym\"]\n89: command_line = \"-m pytest\"\n90: \n91: # For completeness, until we move to an src-based layouts\n92: [tool.setuptools.packages.find]\n93: include = [\"neurogym*\"]\n94: exclude = [\"tests*\"]\n95: \n96: [tool.mypy]\n97: python_version = \"3.11\"\n98: warn_return_any = true\n99: warn_unused_configs = true\n100: show_error_codes = true\n101: exclude = \"build/.*\"\n102: \n103: [[tool.mypy.overrides]]\n104: module = \"psychopy\"\n105: ignore_missing_imports = true\n106: \n107: [tool.coverage.report]\n108: exclude_also = [\n109:     \"if TYPE_CHECKING:\",\n110:     \"def __repr__\",\n111:     \"def __str__\",\n112:     \"raise NotImplementedError\",\n113: ]\n114: \n115: [tool.typos]\n116: default.extend-ignore-words-re = [\n117:     \"arange\", # common numpy function\n118: ]\n119: files.ignore-hidden = false\n120: files.extend-exclude = [\".git/*\"]\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=64.0.0\", \"setuptools-scm\", \"wheel\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nauthors = [\n    { name = \"Giulia Crocioni\", email = \"g.crocioni@esciencecenter.nl\" },\n    { name = \"Dani Bodor\", email = \"d.bodor@esciencecenter.nl\" },\n    { name = \"Nathan Cloos\", email = \"cloosnathan@gmail.com\" },\n    { name = \"Alexander Hadjiivanov\", email = \"a.hadjiivanov@esciencecenter.nl\" },\n    { name = \"Guangyu Robert Yang\", email = \"gyyang.neuro@gmail.com\" },\n    { name = \"Jorge Mejias\", email = \"j.f.mejias@uva.nl\" },\n    { name = \"Manuel Molano Mazon\", email = \"manuelmolanomazon@gmail.com\" },\n]\nclassifiers = [\n    \"License :: OSI Approved :: Apache Software License\",\n    \"Natural Language :: English\",\n    \"Programming Language :: Python :: 3.10\",\n    \"Programming Language :: Python :: 3.11\",\n    \"Programming Language :: Python :: 3.12\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775805096731,"end":1775805096744}}}]}
