CENSE\n-rw-r--r--  1 root root   64 Apr 10 00:50 MANIFEST.in\n-rw-r--r--  1 root root 1631 Apr 10 00:50 Makefile\n-rw-r--r--  1 root root 8856 Apr 10 00:50 README.md\ndrwxr-xr-x 10 root root 4096 Apr 10 00:50 docs\ndrwxr-xr-x  5 root root 4096 Apr 10 00:50 great_tables\n-rw-r--r--  1 root root 3198 Apr 10 00:50 pyproject.toml\n-rw-r--r--  1 root root  187 Apr 10 00:50 pyrightconfig.json\ndrwxr-xr-x  4 root root 4096 Apr 10 00:50 tests\n","exit":0,"description":"List workspace directory contents","truncated":false},"title":"List workspace directory contents","time":{"start":1775782219293,"end":1775782219344}}}]}
