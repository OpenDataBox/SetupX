t :: Libraries :: Python Modules\",\n37:     \"Topic :: Text Processing :: Markup :: HTML\",\n38:     \"Topic :: Scientific/Engineering :: Visualization\"\n39: ]\n40: dependencies = [\n41:     \"commonmark>=0.9.1\",\n42:     \"faicons>=0.2.2\",\n43:     \"htmltools>=0.4.1\",\n44:     \"importlib-metadata\",\n45:     \"typing_extensions>=3.10.0.0\",\n46:     \"Babel>=2.13.1\",\n47:     \"importlib-resources\"\n48: ]\n49: requires-python = \">=3.9\"\n50: \n51: [project.optional-dependencies]\n52: all = [\n53:     \"great_tables[extra]\",\n54:     \"great_tables[dev]\",\n55: ]\n56: \n57: extra = [\n58:     \"css-inline>=0.14.1\",\n59:     \"selenium>=4.18.1\",\n60:     \"Pillow>=10.2.0\",\n61: ]\n62: \n63: dev = [\n64:     \"great_tables[dev-no-pandas]\",\n65:     \"pandas\",\n66:     \"plotnine\",\n67:     \"numpy>=1.22.4\",\n68: \n69: ]\n70: \n71: dev-no-pandas = [\n72:     \"ruff==0.8.0\",\n73:     \"jupyter\",\n74:     \"quartodoc>=0.11.0; python_version >= '3.9'\",\n75:     \"griffe==0.38.1\",\n76:     \"gt-extras>=0.0.7\",\n77:     \"polars\",\n78:     \"pre-commit==2.15.0\",\n79:     \"pyarrow\",\n80:     \"pyright>=1.1.244\",\n81:     \"pytest>=3\",\n82:     \"pytest-cov\",\n83:     \"shiny\",\n84:     \"svg.py\",\n85:     \"syrupy\"\n86: ]\n87: \n88: [project.urls]\n89: homepage = \"https://github.com/posit-dev/great-tables\"\n90: documentation = \"https://posit-dev.github.io/great-tables/\"\n91: \n92: [tool.pytest.ini_options]\n93: minversion = \"6.0\"\n94: addopts = \"-ra -q --cov=great_tables -m 'not no_pandas'\"\n95: asyncio_mode = \"strict\"\n96: testpaths = [\n97:     \"tests\"\n98: ]\n99: \n100: markers = [\n101:     \"extra: marks tests that require extra dependencies to run\",\n102:     \"no_pandas: test meant to run without pandas installed\",\n103: ]\n104: \n105: [tool.ruff]\n106: line-length = 100\n107: \n108: \n109: [tool.ruff.format]\n110: exclude = [\"great_tables/vals.py\"]\n111: \n112: \n113: [tool.ruff.lint]\n114: exclude = [\"docs\", \".venv