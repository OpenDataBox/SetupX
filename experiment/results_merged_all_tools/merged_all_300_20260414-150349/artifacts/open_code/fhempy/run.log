{"type":"session_message","session_id":"ses_2773fa88affexOeDEJZQBK1j1u","role":"assistant","message_id":"msg_d88c06da7001lKmywBlPOK1r0E","parts":[{"id":"prt_d88c078ef0010sqQ534Z33eOy7","messageID":"msg_d88c06da7001lKmywBlPOK1r0E","sessionID":"ses_2773fa88affexOeDEJZQBK1j1u","type":"tool","tool":"read","callID":"call_0c0d0c88c0a148b18b249b25","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: requires = [ \"poetry-core\",]\n3: build-backend = \"poetry.core.masonry.api\"\n4: \n5: [tool.poetry]\n6: name = \"fhempy\"\n7: description = \"Python binding for FHEM to support Python modules\"\n8: version = \"0.1.754\"\n9: authors = [ \"Dominik Karall <dominik.karall@gmail.com>\",]\n10: readme = \"README.md\"\n11: homepage = \"https://github.com/fhempy/fhempy\"\n12: [[tool.poetry.packages]]\n13: include = \"fhempy\"\n14: from = \"FHEM/bindings/python\"\n15: \n16: [tool.semantic_release]\n17: build_command = \"pip install poetry && poetry build\"\n18: version_variables = [ \"FHEM/bindings/python/fhempy/lib/version.py:__version__\",]\n19: version_toml = [ \"pyproject.toml:tool.poetry.version\",]\n20: \n21: [tool.setuptools]\n22: include-package-data = true\n23: script-files = [ \"FHEM/bindings/python/bin/fhempy\",]\n24: \n25: [tool.poetry.urls]\n26: \"Bug Tracker\" = \"https://github.com/fhempy/fhempy/issues\"\n27: Sponsorship = \"https://github.com/sponsors/fhempy\"\n28: \n29: [tool.poetry.scripts]\n30: fhempy = \"fhempy.lib.fhem_pythonbinding:run\"\n31: \n32: [tool.poetry.dependencies]\n33: python = \"^3.9\"\n34: websockets = \"==12.0\"\n35: importlib_metadata = \"7.1.0\"\n36: pycryptodomex = \"3.20.0\"\n37: ifaddr = \"==0.2.0\"\n38: zeroconf = \"==0.132.2\"\n39: markdown2 = \"2.4.13\"\n40: requests = \"2.32.2\"\n41: async-upnp-client = \"0.38.3\"\n42: packaging = \"24.0\"\n43: pexpect = \"==4.9.0\"\n44: aiofiles = \"==23.2.1\"\n45: \n46: [tool.setuptools.package-data]\n47: \"*\" = [ \"README.md\",]\n48: \n49: [tool.poetry.dependencies.aiohttp]\n50: extras = [ \"speedups\",]\n51: version = \"3.9.5\"\n52: \n53: [tool.poetry.group.all]\n54: optional = true\n55: \n56: [tool.setuptools.packages.find]\n57: where = [ \"FHEM/bindings/python\",]\n58: exclude = [ \"tests*\",]\n59: \n60: [tool.poetry.group.all.dependencies]\n61: GitPython = \"==3.1.43\"\n62: aioblescan = \"==0.2.14\"\n63: aiohomekit = \"==2.6.16\"\n64: aionefit = \"==0.14\"\n65: alphaessopenapi = \"==0.0.7\"\n66: async-upnp-client = \"==0.38.3\"\n67: asyncio_mqtt = \"==0.16.2\"\n68: beautifulsoup4 = \"==4.12.3\"\n69: bleak = \"==0.20.2\"\n70: bleparser = \"==3.7.1\"\n71: bluepy = \"==1.3.0\"\n72: bluetooth-adapters = \"==0.16.2\"\n73: bluetooth-auto-recovery = \"==1.4.2\"\n74: bt_proximity = \"==0.2.1\"\n75: btsocket = \"==0.3.0\"\n76: construct = \"==2.10.70\"\n77: cryptography = \"==43.0.0\"\n78: esphome = \"==2024.12.2\"\n79: goodwe = \"==0.4.8\"\n80: greeclimate = \"==1.4.1\"\n81: httpx = \"==0.27.0\"\n82: huawei-solar = \"==2.2.9\"\n83: hyundai_kia_connect_api = \"==3.19.1\"\n84: janus = \"==1.0.0\"\n85: luma_led-matrix = \"==1.7.1\"\n86: lxml = \"==5.2.1\"\n87: meross-iot = \"==0.4.8.0\"\n88: micloud = \"==0.6\"\n89: miflora = \"==0.7.2\"\n90: mitemp-bt = \"==0.0.5\"\n91: mytoyota = \"==1.1.0\"\n92: netifaces = \"==0.11.0\"\n93: opencv-python-headless = \"==4.9.0.80\"\n94: paho-mqtt = \"==1.6.1\"\n95: pexpect = \"==4.9.0\"\n96: pillow = \"==11.1.0\"\n97: playwright = \"==1.43.0\"\n98: # remove pytibber from here as it requires websockets < 12.0\n99: # pyTibber = {version = \"==0.29.0\", python = \"^3.11\" }\n100: # pybluez 0.30 wasn't released yet, we use the github tag\n101: # pybluez = \"==0.30\"\n102: pychromecast = \"==13.1.0\"\n103: pygatt = \"==4.0.5\"\n104: pyit600 = \"==0.5.1\"\n105: pyjwt = \"==2.8.0\"\n106: # pymyenergi fails to resolve by poetry\n107: # pymyenergi = \"==0.1.1\"\n108: pyprusalink = \"==2.1.1\"\n109: pyqrcode = \"==1.2.1\"