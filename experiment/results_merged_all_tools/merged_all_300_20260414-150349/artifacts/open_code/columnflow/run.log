{"type":"session_message","session_id":"ses_27763f7d3ffeGH5F5fsk7eU9xK","role":"assistant","message_id":"msg_d889c1fe8001Xm9ZVlElmzRyGV","parts":[{"id":"prt_d889c2a68001BZpk88Kr0czyUy","messageID":"msg_d889c1fe8001Xm9ZVlElmzRyGV","sessionID":"ses_27763f7d3ffeGH5F5fsk7eU9xK","type":"tool","tool":"read","callID":"call_48a52ab583b445bca2070be0","state":{"status":"completed","input":{"filePath":"/workspace/setup.py"},"output":"<path>/workspace/setup.py</path>\n<type>file</type>\n<content>1: # coding: utf-8\n2: \n3: \n4: import os\n5: from setuptools import setup, find_packages\n6: \n7: \n8: this_dir = os.path.dirname(os.path.abspath(__file__))\n9: \n10: \n11: keywords = [\n12:     \"physics\", \"analysis\", \"experiment\", \"columnar\", \"vectorized\",\n13:     \"law\", \"order\", \"luigi\", \"workflow\", \"automation\", \"lhc\", \"cern\",\n14: ]\n15: \n16: \n17: classifiers = [\n18:     \"Programming Language :: Python\",\n19:     \"Programming Language :: Python :: 3\",\n20:     \"Programming Language :: Python :: 3.7\",\n21:     \"Programming Language :: Python :: 3.8\",\n22:     \"Programming Language :: Python :: 3.9\",\n23:     \"Programming Language :: Python :: 3.10\",\n24:     \"Programming Language :: Python :: 3.11\",\n25:     \"Development Status :: 4 - Beta\",\n26:     \"Operating System :: OS Independent\",\n27:     \"License :: OSI Approved :: BSD License\",\n28:     \"Intended Audience :: Developers\",\n29:     \"Intended Audience :: Science/Research\",\n30:     \"Intended Audience :: Information Technology\",\n31: ]\n32: \n33: \n34: # read the readme file\n35: with open(os.path.join(this_dir, \"README.md\"), \"r\") as f:\n36:     long_description = f.read()\n37: \n38: \n39: # load installation requirements\n40: with open(os.path.join(this_dir, \"sandboxes\", \"cf.txt\"), \"r\") as f:\n41:     install_requires = [line.strip() for line in f.readlines() if line.strip()]\n42: \n43: \n44: # load package infos\n45: pkg = {}\n46: with open(os.path.join(this_dir, \"columnflow\", \"__version__.py\"), \"r\") as f:\n47:     exec(f.read(), pkg)\n48: \n49: \n50: setup(\n51:     name=\"columnflow\",\n52:     version=pkg[\"__version__\"],\n53:     author=pkg[\"__author__\"],\n54:     author_email=pkg[\"__email__\"],\n55:     description=pkg[\"__doc__\"].strip().split(\"\\n\")[0].strip(),\n56:     license=pkg[\"__license__\"],\n57:     url=pkg[\"__contact__\"],\n58:     keywords=keywords,\n59:     classifiers=classifiers,\n60:     long_description=long_description,\n61:     long_description_content_type=\"text/markdown\",\n62:     install_requires=install_requires,\n63:     python_requires=\">=3.7, <=3.11\",\n64:     zip_safe=False,\n65:     packages=find_packages(exclude=[\"tests\"]),\n66: )\n\n(End of file - total 66 lines)\n</content>","metadata":{"preview":"# coding: utf-8\n\n\nimport os\nfrom setuptools import setup, find_packages\n\n\nthis_dir = os.path.dirname(os.path.abspath(__file__))\n\n\nkeywords = [\n    \"physics\", \"analysis\", \"experiment\", \"columnar\", \"vectorized\",\n    \"law\", \"order\", \"luigi\", \"workflow\", \"automation\", \"lhc\", \"cern\",\n]\n\n\nclassifiers = [\n    \"Programming Language :: Python\",\n    \"Programming Language :: Python :: 3\",\n    \"Programming Language :: Python :: 3.7\",","truncated":false,"loaded":[]},"title":"setup.py","time":{"start":1776113429382,"end":1776113429391}}}]}
