s))\n80:         )\n81: \n82:     def test_full_string_toggles_all_true(self):\n83:         toggle_setting_names = []\n84:         for setting in settings_by_name.values():\n85:             if isinstance(setting, Toggle):\n86:                 toggle_setting_names.append(setting.name)\n87: \n88:         settings = SeedSettings()\n89:         for name in toggle_setting_names:\n90:             settings.set(name, True)\n91: \n92:         string = settings.settings_string(include_private=True)\n93: \n94:         for name in toggle_setting_names:\n95:             settings.set(name, False)\n96: \n97:         settings.apply_settings_string(string, include_private=True)\n98: \n99:         for name in toggle_setting_names:\n100:             self.assertTrue(settings.get(name), msg=name)\n101: \n102:     def test_full_string_toggles_all_false(self):\n103:         toggle_setting_names = []\n104:         for setting in settings_by_name.values():\n105:             if isinstance(setting, Toggle):\n106:                 toggle_setting_names.append(setting.name)\n107: \n108:         settings = SeedSettings()\n109:         for name in toggle_setting_names:\n110:             settings.set(name, False)\n111: \n112:         string = settings.settings_string(include_private=True)\n113: \n114:         for name in toggle_setting_names:\n115:             settings.set(name, True)\n116: \n117:         settings.apply_settings_string(string, include_private=True)\n118: \n119:         for name in toggle_setting_names:\n120:             self.assertFalse(settings.get(name), msg=name)\n121: \n122: \n123: if __name__ == '__main__':\n124:     unittest.main()\n\n(End of file - total 124 lines)\n</content>","metadata":{"preview":"import unittest\n\nfrom Class.seedSettings import Toggle, IntSpinner, FloatSpinner, SingleSelect, MultiSelect, SeedSettings, \\\n    SettingGroup, settings_by_name\n\n\nclass Tests(unittest.TestCase):\n\n    def test_toggle(self):\n        setting = Toggle(name='Test', group=Sett