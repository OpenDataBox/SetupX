{"type":"session_message","session_id":"ses_2773301eaffetfGemgzO7tKLl1","role":"assistant","message_id":"msg_d88d2c44a001p5ew87kaeYnkPm","parts":[{"id":"prt_d88d2caf3001mnODEhdsZTssih","messageID":"msg_d88d2c44a001p5ew87kaeYnkPm","sessionID":"ses_2773301eaffetfGemgzO7tKLl1","type":"tool","tool":"read","callID":"call_a594add72b9049168dd382aa","state":{"status":"completed","input":{"filePath":"/workspace/Module/appconfig.py"},"output":"<path>/workspace/Module/appconfig.py</path>\n<type>file</type>\n<content>1: import json\n2: from pathlib import Path\n3: from typing import Optional\n4: \n5: import yaml\n6: \n7: AUTOSAVE_FOLDER = \"auto-save\"\n8: PRESET_FOLDER = \"presets\"\n9: \n10: \n11: def settings_presets_folder() -> Path:\n12:     return Path(PRESET_FOLDER).absolute()\n13: \n14: \n15: def read_app_config() -> dict:\n16:     config_path = Path('randomizer-config.json').absolute()\n17:     if config_path.is_file():\n18:         with open(config_path, encoding='utf-8') as config_file:\n19:             return json.load(config_file)\n20:     else:\n21:         return {}\n22: \n23: \n24: def read_boss_enemy_override_files() -> str:\n25:     result_string = \"\"\n26:     location_override_path = Path('override_enemies.yaml').absolute()\n27:     if location_override_path.is_file():\n28:         with open(location_override_path, encoding='utf-8') as location_override:\n29:             result_string += location_override.read()\n30:     enemy_override_path = Path('override_enemies.yaml').absolute()\n31:     if enemy_override_path.is_file():\n32:         with open(enemy_override_path, encoding='utf-8') as enemy_override:\n33:             result_string += enemy_override.read()\n34:     return result_string\n35: \n36: \n37: def write_app_config(config: dict):\n38:     config_path = Path('randomizer-config.json').absolute()\n39:     with open(config_path, mode='w', encoding='utf-8') as config_file:\n40:         json.dump(config, config_file, indent=4)\n41: \n42: \n43: def update_app_config(key: str, value):\n44:     randomizer_config = read_app_config()\n45:     randomizer_config[key] = value\n46:     write_app_config(randomizer_config)\n47: \n48: \n49: def remove_app_config(key: str):\n50:     randomizer_config = read_app_config()\n51:     if key in randomizer_config:\n52:         del randomizer_config[key]\n53:         write_app_config(randomizer_config)\n54: \n55: \n56: def _read_directory(key: str) -> Optional[Path]:\n57:     randomizer_config = read_app_config()\n58:     value = randomizer_config.get(key, \"to-nowhere\")\n59:     if value is None:\n60:         return None\n61: \n62:     candidate = Path(value)\n63:     if candidate.is_dir():\n64:         return candidate\n65:     else:\n66:         return None\n67: \n68: \n69: def read_last_save_path() -> Optional[Path]:\n70:     return _read_directory(\"last_save_folder\")\n71: \n72: \n73: def write_last_save_path(selected_directory):\n74:     update_app_config(\"last_save_folder\", selected_directory)\n75: \n76: \n77: def read_openkh_path() -> Optional[Path]:\n78:     return _read_directory(\"openkh_folder\")\n79: \n80: \n81: def write_openkh_path(selected_directory):\n82:     update_app_config('openkh_folder', selected_directory)\n83: \n84: \n85: def read_custom_music_path() -> Optional[Path]:\n86:     return _read_directory(\"custom_music_folder\")\n87: \n88: \n89: def write_custom_music_path(selected_directory):\n90:     update_app_config('custom_music_folder', selected_directory)\n91: \n92: \n93: def read_custom_visuals_path() -> Optional[Path]:\n94:     return _read_directory(\"custom_visuals_folder\")\n95: \n96: \n97: def write_custom_visuals_path(selected_directory):\n98:     update_app_config('custom_visuals_folder', selected_directory)\n99: \n100: \n101: def extracted_data_path() -> Optional[Path]:\n102:     \"\"\"Returns the path to extracted game data, or None if not found.\"\"\"\n103:     openkh_path = read_openkh_path()\n104:     if openkh_path is None:\n105:         return None\n106: \n107:     mods_manager_yml_path = openkh_path / \"mods-manager.yml\"\n108:     if not mods_manager_yml_path.is_file():\n109:         return None\n110: \n111:     with open(mods_manager_yml_path, encoding=\"utf-8\") as mod_manager_file:\n112:         mod_manager_yaml = yaml.safe_load(mod_manager_file)\n113:         game_data_path = mod_manager_yaml.get(\"gameDataPath\", \"to-nowhere\")\n114:         if game_data_path is None:\n115:             # Maybe something weird happened in the Mods Manager setup? Should have a gameDataPath.\n116:             # Regardless, nothing we can do here.\n117:             return None\n118: \n119:         extracted_data = Path(game_data_path)\n120:         if extracted_data.is_dir():\n121:             return extracted_data\n122:         else:\n123:             # Has a gameDataPath configured, but it's not being detected as a directory\n124:             return None\n125: \n126: \n127: def extracted_game_path(game: str) -> Optional[Path]:\n128:     \"\"\"Returns the path to extracted game data for the specified game, or None if not found.\"\"\"\n129:     base_extracted_path = extracted_data_path()\n130:     if base_extracted_path is None:\n131:         return None\n132: \n133:     game_path = base_extracted_path / game\n134:     if game_path.is_dir():\n135:         return game_path\n136:     else:\n137:         return None\n138: \n139: \n140: def goa_mod_path() -> Optional[Path]:\n141:     \"\"\"Returns the path to the Garden of Assemblage mod, or None if not found.\"\"\"\n142:     openkh_path = read_openkh_path()\n143:     if openkh_path is None:\n144:         return None\n145: \n146:     kh2_mods_path = openkh_path / \"mods\" / \"kh2\"\n147:     if not kh2_mods_path.is_dir():\n148:         return None\n149: \n150:     # Best effort here to try to find GoA ROM mod. If this doesn't seem good enough, could change to a folder chooser.\n151:     for top_mod_dir in kh2_mods_path.iterdir():\n152:         if not top_mod_dir.is_dir():\n153:             continue\n154: \n155:         if top_mod_dir.name.startswith(\"GoA-ROM-Edition\"):\n156:             return top_mod_dir\n157: \n158:         for second_dir in top_mod_dir.iterdir():\n159:             if second_dir.is_dir() and second_dir.name.startswith(\"GoA-ROM-Edition\"):\n160:                 return second_dir\n161: \n162:     return None\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"import json\nfrom pathlib import Path\nfrom typing import Optional\n\nimport yaml\n\nAUTOSAVE_FOLDER = \"auto-save\"\nPRESET_FOLDER = \"presets\"\n\n\ndef settings_presets_folder() -> Path:\n    return Path(PRESET_FOLDER).absolute()\n\n\ndef read_app_config() -> dict:\n    config_path = Path('randomizer-config.json').absolute()\n    if config_path.is_file():\n        with open(config_path, encoding='utf-8') as config_file:\n            return json.load(config_file)\n    else:","truncated":false,"loaded":[]},"title":"Module/appconfig.py","time":{"start":1776117009463,"end":1776117009472}}}]}
