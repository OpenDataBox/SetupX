{"type":"session_message","session_id":"ses_2773301eaffetfGemgzO7tKLl1","role":"assistant","message_id":"msg_d88ceac08001gya3ZK2XHCfYoD","parts":[{"id":"prt_d88ceb6e90010iDX2o0O13vAje","messageID":"msg_d88ceac08001gya3ZK2XHCfYoD","sessionID":"ses_2773301eaffetfGemgzO7tKLl1","type":"tool","tool":"read","callID":"call_fd6c88ccebf04109860d5e78","state":{"status":"completed","input":{"filePath":"/workspace/tests/test_modifier.py"},"output":"<path>/workspace/tests/test_modifier.py</path>\n<type>file</type>\n<content>1: import unittest\n2: \n3: from List.ItemList import Items\n4: from List.configDict import LevelUpStatBonus\n5: from List.inventory import ability\n6: from List.inventory.growth import (\n7:     HighJump1,\n8:     HighJump2,\n9:     HighJump3,\n10:     HighJumpMax,\n11:     QuickRun1,\n12:     QuickRun2,\n13:     QuickRun3,\n14:     QuickRunMax,\n15:     AerialDodge1,\n16:     AerialDodge2,\n17:     AerialDodge3,\n18:     AerialDodgeMax,\n19:     Glide1,\n20:     Glide2,\n21:     Glide3,\n22:     GlideMax,\n23:     DodgeRoll1,\n24:     DodgeRoll2,\n25:     DodgeRoll3,\n26:     DodgeRollMax,\n27:     GrowthType,\n28: )\n29: from Module.modifier import SeedModifier\n30: \n31: \n32: class Tests(unittest.TestCase):\n33:     def test_default_ability_pool(self):\n34:         all_action = Items.getActionAbilityList()\n35:         all_support = Items.getSupportAbilityList() + Items.getKeybladeAbilityList() + Items.getLevelAbilityList()\n36:         pool = SeedModifier.default_ability_pool(action=all_action, support=all_support)\n37:         self.assertCountEqual(all_action + all_support, pool)\n38: \n39:     def test_random_ability_pool(self):\n40:         all_action = Items.getActionAbilityList()\n41:         all_support = Items.getSupportAbilityList() + Items.getKeybladeAbilityList() + Items.getLevelAbilityList()\n42:         for _ in range(1000):\n43:             pool = SeedModifier.random_ability_pool(\n44:                 action=all_action, support=all_support\n45:             )\n46:             self.assertEqual(len(pool), len(all_action) + len(all_support))\n47:             second_chance = next(\n48:                 (a for a in pool if a.item == ability.SecondChance), None\n49:             )\n50:             self.assertIsNotNone(second_chance)\n51:             once_more = next((a for a in pool if a.item == ability.OnceMore), None)\n52:             self.assertIsNotNone(once_more)\n53: \n54:     def test_random_support_ability_pool(self):\n55:         all_action = Items.getActionAbilityList()\n56:         all_support = Items.getSupportAbilityList() + Items.getKeybladeAbilityList() + Items.getLevelAbilityList()\n57:         for _ in range(1000):\n58:             pool = SeedModifier.random_support_ability_pool(\n59:                 action=all_action, support=all_support\n60:             )\n61:             self.assertEqual(len(pool), len(all_action) + len(all_support))\n62:             second_chance = next(\n63:                 (a for a in pool if a.item == ability.SecondChance), None\n64:             )\n65:             self.assertIsNotNone(second_chance)\n66:             once_more = next((a for a in pool if a.item == ability.OnceMore), None)\n67:             self.assertIsNotNone(once_more)\n68:             for action_ability in all_action:\n69:                 self.assertIn(action_ability, pool)\n70: \n71:     def test_random_stackable_ability_pool(self):\n72:         all_action = Items.getActionAbilityList()\n73:         all_support = Items.getSupportAbilityList() + Items.getKeybladeAbilityList() + Items.getLevelAbilityList()\n74:         for _ in range(1000):\n75:             pool = SeedModifier.random_stackable_ability_pool(\n76:                 action=all_action, support=all_support\n77:             )\n78:             self.assertEqual(len(pool), len(all_action) + len(all_support))\n79:             second_chance = next(\n80:                 (a for a in pool if a.item == ability.SecondChance), None\n81:             )\n82:             self.assertIsNotNone(second_chance)\n83:             once_more = next((a for a in pool if a.item == ability.OnceMore), None)\n84:             self.assertIsNotNone(once_more)\n85: \n86:     def test_level_up_stat_pool_normal(self):\n87:         pool = SeedModifier.level_up_stat_pool(glass_cannon=False)\n88:         bonuses = [bonus for bonus, _ in pool]\n89:         expected = [\n90:             LevelUpStatBonus.STRENGTH,\n91:             LevelUpStatBonus.MAGIC,\n92:             LevelUpStatBonus.DEFENSE,\n93:             LevelUpStatBonus.AP,\n94:         ]\n95:         self.assertCountEqual(expected, bonuses)\n96: \n97:     def test_level_up_stat_pool_glass_cannon(self):\n98:         pool = SeedModifier.level_up_stat_pool(glass_cannon=True)\n99:         bonuses = [bonus for bonus, _ in pool]\n100:         expected = [\n101:             LevelUpStatBonus.STRENGTH,\n102:             LevelUpStatBonus.MAGIC,\n103:             LevelUpStatBonus.AP,\n104:         ]\n105:         self.assertCountEqual(expected, bonuses)\n106: \n107:     def test_level_up_stat_pool_weighted_default(self):\n108:         pool = SeedModifier.level_up_stat_pool_weighted()\n109:         bonuses = [bonus for bonus, _, _ in pool]\n110:         weights = [weight for _, _, weight in pool]\n111:         expected_bonuses = [\n112:             LevelUpStatBonus.STRENGTH,\n113:             LevelUpStatBonus.MAGIC,\n114:             LevelUpStatBonus.DEFENSE,\n115:             LevelUpStatBonus.AP,\n116:         ]\n117:         expected_weights = [\n118:             25,\n119:             25,\n120:             25,\n121:             25,\n122:         ]\n123:         self.assertCountEqual(expected_bonuses, bonuses)\n124:         self.assertCountEqual(expected_weights, weights)\n125: \n126:     def test_level_up_stat_pool_weighted_glass_cannon(self):\n127:         pool = SeedModifier.level_up_stat_pool_weighted(def_rate=0)\n128:         bonuses = [bonus for bonus, _, _ in pool]\n129:         weights = [weight for _, _, weight in pool]\n130:         expected_bonuses = [\n131:             LevelUpStatBonus.STRENGTH,\n132:             LevelUpStatBonus.MAGIC,\n133:             LevelUpStatBonus.AP,\n134:         ]\n135:         expected_weights = [\n136:             34,\n137:             33,\n138:             33,\n139:         ]\n140:         self.assertCountEqual(expected_bonuses, bonuses)\n141:         self.assertCountEqual(expected_weights, weights)\n142: \n143:     def test_level_up_stat_pool_weighted_str_bias(self):\n144:         pool = SeedModifier.level_up_stat_pool_weighted(str_rate=50)\n145:         bonuses = [bonus for bonus, _, _ in pool]\n146:         weights = [weight for _, _, weight in pool]\n147:         expected_bonuses = [\n148:             LevelUpStatBonus.STRENGTH,\n149:             LevelUpStatBonus.MAGIC,\n150:             LevelUpStatBonus.DEFENSE,\n151:             LevelUpStatBonus.AP,\n152:         ]\n153:         expected_weights = [\n154:             40,\n155:             20,\n156:             20,\n157:             20,\n158:         ]\n159:         self.assertCountEqual(expected_bonuses, bonuses)\n160:         self.assertCountEqual(expected_weights, weights)\n161: \n162:     def test_movement_disabled(self):\n163:         specific_growth = {\n164:             GrowthType.HIGH_JUMP: 0,\n165:             GrowthType.QUICK_RUN: 0,\n166:             GrowthType.DODGE_ROLL: 0,\n167:             GrowthType.AERIAL_DODGE: 0,\n168:             GrowthType.GLIDE: 0,\n169:         }\n170:         growths = SeedModifier.starting_growth(specific_growth, random_range=(0, 0))\n171:         self.assertEqual(0, len(growths))\n172: \n173:     def test_movement_level_1(self):\n174:         specific_growth = {\n175:             GrowthType.HIGH_JUMP: 1,\n176:             GrowthType.QUICK_RUN: 1,\n177:             GrowthType.DODGE_ROLL: 1,\n178:             GrowthType.AERIAL_DODGE: 1,\n179:             GrowthType.GLIDE: 1,\n180:         }\n181:         expected = [\n182:             HighJump1,\n183:             QuickRun1,\n184:             AerialDodge1,\n185:             Glide1,\n186:             DodgeRoll1,\n187:         ]\n188:         growths = SeedModifier.starting_growth(specific_growth, random_range=(0, 0))\n189:         self.assertCountEqual(expected, growths)\n190: \n191:     def test_movement_level_2(self):\n192:         specific_growth = {\n193:             GrowthType.HIGH_JUMP: 2,\n194:             GrowthType.QUICK_RUN: 2,\n195:             GrowthType.DODGE_ROLL: 2,\n196:             GrowthType.AERIAL_DODGE: 2,\n197:             GrowthType.GLIDE: 2,\n198:         }\n199:         expected = [\n200:             HighJump1,\n201:             HighJump2,\n202:             QuickRun1,\n203:             QuickRun2,\n204:             AerialDodge1,\n205:             AerialDodge2,\n206:             Glide1,\n207:             Glide2,\n208:             DodgeRoll1,\n209:             DodgeRoll2,\n210:         ]\n211:         growths = SeedModifier.starting_growth(specific_growth, random_range=(0, 0))\n212:         self.assertCountEqual(expected, growths)\n213: \n214:     def test_movement_level_3(self):\n215:         specific_growth = {\n216:             GrowthType.HIGH_JUMP: 3,\n217:             GrowthType.QUICK_RUN: 3,\n218:             GrowthType.DODGE_ROLL: 3,\n219:             GrowthType.AERIAL_DODGE: 3,\n220:             GrowthType.GLIDE: 3,\n221:         }\n222:         expected = [\n223:             HighJump1,\n224:             HighJump2,\n225:             HighJump3,\n226:             QuickRun1,\n227:             QuickRun2,\n228:             QuickRun3,\n229:             AerialDodge1,\n230:             AerialDodge2,\n231:             AerialDodge3,\n232:             Glide1,\n233:             Glide2,\n234:             Glide3,\n235:             DodgeRoll1,\n236:             DodgeRoll2,\n237:             DodgeRoll3,\n238:         ]\n239:         growths = SeedModifier.starting_growth(specific_growth, random_range=(0, 0))\n240:         self.assertCountEqual(expected, growths)\n241: \n242:     def test_movement_level_4(self):\n243:         specific_growth = {\n244:             GrowthType.HIGH_JUMP: 4,\n245:             GrowthType.QUICK_RUN: 4,\n246:             GrowthType.DODGE_ROLL: 4,\n247:             GrowthType.AERIAL_DODGE: 4,\n248:             GrowthType.GLIDE: 4,\n249:         }\n250:         expected = [\n251:             HighJump1,\n252:             HighJump2,\n253:             HighJump3,\n254:             HighJumpMax,\n255:             QuickRun1,\n256:             QuickRun2,\n257:             QuickRun3,\n258:             QuickRunMax,\n259:             AerialDodge1,\n260:             AerialDodge2,\n261:             AerialDodge3,\n262:             AerialDodgeMax,\n263:             Glide1,\n264:             Glide2,\n265:             Glide3,\n266:             GlideMax,\n267:             DodgeRoll1,\n268:             DodgeRoll2,\n269:             DodgeRoll3,\n270:             DodgeRollMax,\n271:         ]\n272:         growths = SeedModifier.starting_growth(specific_growth, random_range=(0, 0))\n273:         self.assertCountEqual(expected, growths)\n274: \n275:     def test_random_3(self):\n276:         specific_growth = {\n277:             GrowthType.HIGH_JUMP: 0,\n278:             GrowthType.QUICK_RUN: 0,\n279:             GrowthType.DODGE_ROLL: 0,\n280:             GrowthType.AERIAL_DODGE: 0,\n281:             GrowthType.GLIDE: 0,\n282:         }\n283:         for _ in range(1000):\n284:             growths = SeedModifier.starting_growth(specific_growth, random_range=(3, 3))\n285:             self.assertEqual(3, len(growths))\n286: \n287:     def test_random_5(self):\n288:         specific_growth = {\n289:             GrowthType.HIGH_JUMP: 0,\n290:             GrowthType.QUICK_RUN: 0,\n291:             GrowthType.DODGE_ROLL: 0,\n292:             GrowthType.AERIAL_DODGE: 0,\n293:             GrowthType.GLIDE: 0,\n294:         }\n295:         for _ in range(1000):\n296:             growths = SeedModifier.starting_growth(specific_growth, random_range=(5, 5))\n297:             self.assertEqual(5, len(growths))\n298: \n299: \n300: if __name__ == \"__main__\":\n301:     unittest.main()\n\n(End of file - total 301 lines)\n</content>","metadata":{"preview":"import unittest\n\nfrom List.ItemList import Items\nfrom List.configDict import LevelUpStatBonus\nfrom List.inventory import ability\nfrom List.inventory.growth import (\n    HighJump1,\n    HighJump2,\n    HighJump3,\n    HighJumpMax,\n    QuickRun1,\n    QuickRun2,\n    QuickRun3,\n    QuickRunMax,\n    AerialDodge1,\n    AerialDodge2,\n    AerialDodge3,\n    AerialDodgeMax,\n    Glide1,\n    Glide2,","truncated":false,"loaded":[]},"title":"tests/test_modifier.py","time":{"start":1776116742103,"end":1776116742107}}}]}
