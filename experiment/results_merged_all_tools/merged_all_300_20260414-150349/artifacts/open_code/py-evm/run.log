g should fit on one line with quotes\n51: # D203 - 1 blank line required before class docstring\n52: # D204 - 1 blank line required after class docstring\n53: # D205 - 1 blank line required between summary line and description\n54: # D212 - Multi-line docstring summary should start at the first line\n55: # D302 - Use u\"\"\" for Unicode docstrings\n56: # D400 - First line should end with a period\n57: # D401 - First line should be in imperative mood\n58: # D404 - First word of the docstring should not be `This`\n59: # D412 - No blank lines allowed between a section header and its content\n60: # D415 - First line should end with a period, question mark, or exclamation point\n61: add-ignore = \"D200,D203,D204,D205,D212,D302,D400,D401,D404,D412,D415\"\n62: \n63: # Explanation:\n64: # D400 - Enabling this error code seems to make it a requirement that the first\n65: # sentence in a docstring is not split across two lines.  It also makes it a\n66: # requirement that no docstring can have a multi-sentence description without a\n67: # summary line.  Neither one of those requirements seem appropriate.\n68: \n69: [tool.pytest.ini_options]\n70: addopts = \"-v --showlocals --durations 10\"\n71: log_date_format = \"%m-%d %H:%M:%S\"\n72: log_format = \"%(levelname)8s  %(asctime)s  %(filename)20s  %(message)s\"\n73: timeout = 300\n74: xfail_strict = true\n75: \n76: [tool.towncrier]\n77: # Read https://github.com/ethereum/py-evm/blob/main/newsfragments/README.md for instructions\n78: directory = \"newsfragments\"\n79: filename = \"docs/release_notes.rst\"\n80: issue_format = \"`#{issue} <https://github.com/ethereum/py-evm/issues/{issue}>`__\"\n81: package = \"eth\"\n82: title_format = \"py-evm v{version} ({project_date})\"\n83: underlines = [\"-\", \"~\", \"^\"]\n84: \n85: [[tool.towncrier.type]]\n86: directory = \"breaking\"\n87: name = \"Breaking Changes\"\n88: showcontent = true\n89: \n90: [[tool.towncrier.type]]\n91: directory = \"bugfix\"\n92: name = \"Bugfixes\"\n93: showcontent = true\n94: \n95: [[tool.towncrier.type]]\n96: directory = \"deprecation\"\n97: name = \"Deprecations\"\n98: showcontent = true\n99: \n100: [[tool.towncrier.type]]\n101: directory = \"docs\"\n102: name = \"Improved Documentation\"\n103: showcontent = true\n104: \n105: [[tool.towncrier.type]]\n106: directory = \"feature\"\n107: name = \"Features\"\n108: showcontent = true\n109: \n110: [[tool.towncrier.type]]\n111: directory = \"internal\"\n112: name = \"Internal Changes - For py-evm Contributors\"\n113: showcontent = true\n114: \n115: [[tool.towncrier.type]]\n116: directory = \"misc\"\n117: name = \"Miscellaneous Changes\"\n118: showcontent = false\n119: \n120: [[tool.towncrier.type]]\n121: directory = \"performance\"\n122: name = \"Performance Improvements\"\n123: showcontent = true\n124: \n125: [[tool.towncrier.type]]\n126: directory = \"removal\"\n127: name = \"Removals\"\n128: showcontent = true\n129: \n130: [tool.bumpversion]\n131: current_version = \"0.12.1-beta.1\"\n132: parse = \"\"\"\n133:     (?P<major>\\\\d+)\n134:     \\\\.(?P<minor>\\\\d+)\n135:     \\\\.(?P<patch>\\\\d+)\n136: \t\t(-\n137: \t\t\t(?P<stage>[^.]*)\n138: \t\t\t\\\\.(?P<devnum>\\\\d+)\n139: \t\t)?\n140: \"\"\"\n141: serialize = [\n142: \t\"{major}.{minor}.{patch}-{stage}.{devnum}\",\n143: \t\"{major}.{minor}.{patch}\",\n144: ]\n145: search = \"{current_version}\"\n146: replace = \"{new_version}\"\n147: regex = false\n148: ignore_missing_version = false\n149: tag = true\n150: sign_tags = true\n151: tag_name = \"v{new_version}\"\n152: tag_message = \"Bump version: {current_version} → {new_version}\"\n153: allow_dirty = false\n154: commit = true\n155: message = \"Bump version: {current_version} → {new_version}\"\n156: \n157: [tool.bumpversion.parts.stage]\n158: optional_value = \"stable\"\n159: first_value = \"stable\"\n160: values = [\n161: \t\"alpha\",\n162: \t\"beta\",\n163: \t\"stable\",\n164: ]\n165: \n166: [tool.bumpversion.part.devnum]\n167: \n168: [[tool.bumpversion.files]]\n169: 