{"type":"session_message","session_id":"ses_2776e44adffeWi2i79hWf80hqu","role":"assistant","message_id":"msg_d8891fbed001F0PbovrXa1t05S","parts":[{"id":"prt_d88921be60010dPHP9D2OtgRe4","messageID":"msg_d8891fbed001F0PbovrXa1t05S","sessionID":"ses_2776e44adffeWi2i79hWf80hqu","type":"tool","tool":"read","callID":"call_de27c59ad06d4a64b6bd6c18","state":{"status":"completed","input":{"filePath":"/workspace/utest/run.py","limit":100},"output":"<path>/workspace/utest/run.py</path>\n<type>file</type>\n<content>1: #!/usr/bin/env python\n2: \n3: \"\"\"Helper script to run all Robot Framework's unit tests.\n4: \n5: usage: utest/run.py [options] [directory]\n6: \n7: options:\n8:     -q, --quiet     Minimal output\n9:     -v, --verbose   Verbose output\n10:     -d, --doc       Show test's doc string instead of name and class\n11:                     (implies verbosity)\n12:     -h, --help      Show help\n13: \n14: `directory` is the path of the directory under the `utest` folder to execute.\n15: If no value is given all tests are run\n16: \n17: examples:\n18: $ utest/run.py -q output\n19: This will run only the unit tests in the subdirectory output\n20: \"\"\"\n21: \n22: import argparse\n23: import os\n24: import re\n25: import sys\n26: import unittest\n27: import warnings\n28: \n29: if not sys.warnoptions:\n30:     warnings.simplefilter(\"always\")\n31:     if sys.version_info >= (3, 10):\n32:         warnings.simplefilter(\"error\", EncodingWarning)  # noqa: F821\n33: \n34: \n35: base = os.path.abspath(os.path.normpath(os.path.split(sys.argv[0])[0]))\n36: for path in [\"../src\", \"../atest/testresources/testlibs\", \"../utest/resources\"]:\n37:     path = os.path.join(base, path.replace(\"/\", os.sep))\n38:     if path not in sys.path:\n39:         sys.path.insert(0, path)\n40: \n41: testfile = re.compile(r\"^test_.*\\.py$\", re.IGNORECASE)\n42: imported = {}\n43: \n44: \n45: def get_tests(directory=None):\n46:     if directory is None:\n47:         directory = base\n48:     else:\n49:         directory = os.path.join(base, directory)\n50:     sys.path.insert(0, directory)\n51:     tests = []\n52:     for name in sorted(os.listdir(directory)):\n53:         if name.startswith(\".\"):\n54:             continue\n55:         fullname = os.path.join(directory, name)\n56:         if os.path.isdir(fullname):\n57:             tests.extend(get_tests(fullname))\n58:         elif testfile.match(name):\n59:             modname = os.path.splitext(name)[0]\n60:             if modname in imported:\n61:                 print(\n62:                     f\"Test module '{modname}' imported both as '{imported[modname]}' \"\n63:                     f\"and '{os.path.join(directory, name)}'. Rename one or fix test \"\n64:                     f\"discovery.\",\n65:                     file=sys.stderr,\n66:                 )\n67:                 sys.exit(1)\n68:             module = __import__(modname)\n69:             imported[modname] = module.__file__\n70:             tests.append(unittest.defaultTestLoader.loadTestsFromModule(module))\n71:     return tests\n72: \n73: \n74: def usage_exit(msg=None):\n75:     print(__doc__)\n76:     if msg is None:\n77:         rc = 251\n78:     else:\n79:         print(\"\\nError:\", msg)\n80:         rc = 252\n81:     sys.exit(rc)\n82: \n83: \n84: if __name__ == \"__main__\":\n85:     parser = argparse.ArgumentParser(add_help=False, description=__doc__)\n86:     parser.add_argument(\"-I\", \"--interpreter\", default=sys.executable)\n87:     parser.add_argument(\"-h\", \"--help\", action=\"store_true\")\n88:     parser.add_argument(\"-q\", \"--quiet\", dest=\"vrbst\", action=\"store_const\", const=0)\n89:     parser.add_argument(\"-v\", \"--verbose\", dest=\"vrbst\", action=\"store_const\", const=2)\n90:     parser.add_argument(\"-d\", \"--doc\", dest=\"docs\", action=\"store_true\")\n91:     parser.add_argument(\"-x\", \"--exit-on-failure\", dest=\"failfast\", action=\"store_true\")\n92:     parser.add_argument(dest=\"directory\", nargs=\"?\", action=\"store\", default=None)\n93:     parser.set_defaults(vrbst=1)\n94: \n95:     args = parser.parse_args()\n96:     if args.docs:\n97:         args.vrbst = 2\n98:     if args.help:\n99:         usage_exit()\n100: \n\n(Showing lines 1-100 of 112. Use offset=101 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python\n\n\"\"\"Helper script to run all Robot Framework's unit tests.\n\nusage: utest/run.py [options] [directory]\n\noptions:\n    -q, --quiet     Minimal output\n    -v, --verbose   Verbose output\n    -d, --doc       Show test's doc string instead of name and class\n                    (implies verbosity)\n    -h, --help      Show help\n\n`directory` is the path of the directory under the `utest` folder to execute.\nIf no value is given all tests are run\n\nexamples:\n$ utest/run.py -q output\nThis will run only the unit tests in the subdirectory output\n\"\"\"","truncated":true,"loaded":[]},"title":"utest/run.py","time":{"start":1776112770635,"end":1776112770641}}}]}
