rectory.\n\n","description":"Check atest/run.py usage"},"status":"running","input":{"command":"source /workspace/venv/bin/activate && python3 /workspace/atest/run.py --help","description":"Check atest/run.py usage"},"time":{"start":1776112876004}}}]}
