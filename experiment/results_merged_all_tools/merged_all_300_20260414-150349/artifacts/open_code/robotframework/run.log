{"type":"session_message","session_id":"ses_2776e44adffeWi2i79hWf80hqu","role":"assistant","message_id":"msg_d8891e60f001LN7rNJ9OJl7D2l","parts":[{"id":"prt_d8891f570001lZKMIy84qzOJ3f","messageID":"msg_d8891e60f001LN7rNJ9OJl7D2l","sessionID":"ses_2776e44adffeWi2i79hWf80hqu","type":"tool","tool":"read","callID":"call_7aa7073aa9ab4338b6a75cd7","state":{"status":"completed","input":{"filePath":"/workspace/tasks.py"},"output":"<path>/workspace/tasks.py</path>\n<type>file</type>\n<content>1: # ruff: noqa: E402\n2: \n3: \"\"\"Tasks to help Robot Framework packaging and other development.\n4: \n5: Executed by Invoke <http://pyinvoke.org>. Install it with `pip install invoke`\n6: and run `invoke --help` and `invoke --list` for details how to execute tasks.\n7: \n8: See `BUILD.rst` for packaging and releasing instructions.\n9: \"\"\"\n10: \n11: import json\n12: import subprocess\n13: import sys\n14: from pathlib import Path\n15: \n16: assert Path.cwd().resolve() == Path(__file__).resolve().parent\n17: sys.path.insert(0, \"src\")\n18: \n19: from invoke import Exit, task\n20: from rellu import initialize_labels, ReleaseNotesGenerator, Version\n21: from rellu.tasks import clean as clean\n22: \n23: from robot.libdoc import libdoc\n24: \n25: REPOSITORY = \"robotframework/robotframework\"\n26: VERSION_PATH = Path(\"src/robot/version.py\")\n27: VERSION_PATTERN = 'VERSION = \"(.*)\"'\n28: SETUP_PATH = Path(\"setup.py\")\n29: RELEASE_NOTES_PATH = Path(\"doc/releasenotes/rf-{version}.rst\")\n30: RELEASE_NOTES_TITLE = \"Robot Framework {version}\"\n31: RELEASE_NOTES_INTRO = \"\"\"\n32: `Robot Framework`_ {version} is a new release with **UPDATE** enhancements\n33: and bug fixes. **MORE intro stuff...**\n34: \n35: **REMOVE reference to tracker if release notes contain all issues.**\n36: All issues targeted for Robot Framework {version.milestone} can be found\n37: from the `issue tracker milestone`_.\n38: \n39: Questions and comments related to the release can be sent to the `#devel`\n40: channel on `Robot Framework Slack`_ and possible bugs submitted to\n41: the `issue tracker`_.\n42: \n43: **REMOVE ``--pre`` from the next command with final releases.**\n44: If you have pip_ installed, just run\n45: \n46: ::\n47: \n48:    pip install --pre --upgrade robotframework\n49: \n50: to install the latest available release or use\n51: \n52: ::\n53: \n54:    pip install robotframework=={version}\n55: \n56: to install exactly this version. Alternatively you can download the package\n57: from PyPI_ and install it manually. For more details and other installation\n58: approaches, see the `installation instructions`_.\n59: \n60: Robot Framework {version} was released on {date}.\n61: \n62: .. _Robot Framework: http://robotframework.org\n63: .. _Robot Framework Foundation: http://robotframework.org/foundation\n64: .. _pip: http://pip-installer.org\n65: .. _PyPI: https://pypi.python.org/pypi/robotframework\n66: .. _issue tracker milestone: https://github.com/robotframework/robotframework/issues?q=milestone%3A{version.milestone}\n67: .. _issue tracker: https://github.com/robotframework/robotframework/issues\n68: .. _robotframework-users: http://groups.google.com/group/robotframework-users\n69: .. _Slack: http://slack.robotframework.org\n70: .. _Robot Framework Slack: Slack_\n71: .. _installation instructions: ../../INSTALL.rst\n72: \"\"\"\n73: \n74: \n75: @task\n76: def format(ctx, targets=\"src atest utest\"):\n77:     \"\"\"Format code.\n78: \n79:     Args:\n80:         targets: Directories or files to format.\n81: \n82:     Formatting is done in multiple phases:\n83: \n84:     1. Lint code using Ruff. If linting fails, the process is stopped.\n85:     2. Format code using Black.\n86:     3. Re-organize multiline imports using isort to use less vertical space.\n87:        Public APIs using redundant import aliases are excluded.\n88: \n89:     Tool configurations are in `pyproject.toml`.\n90:     \"\"\"\n91:     print(\"Linting...\")\n92:     try:\n93:         ctx.run(f\"ruff check --fix --quiet {targets}\")\n94:     except Exception:\n95:         print(\"Linting failed! Fix reported problems.\")\n96:         raise\n97:     print(\"OK\")\n98:     print(\"Formatting...\")\n99:     ctx.run(f\"black --quiet {targets}\")\n100:     ctx.run(f\"isort --quiet {targets}\")\n101:     print(\"OK\")\n102: \n103: \n104: @task\n105: def set_version(ctx, version):\n106:     \"\"\"Set project version in `src/robot/version.py` and `setup.py`.\n107: \n108:     Args:\n109:         version: Project version to set or `dev` to set development version.\n110: \n111:     Following PEP-440 compatible version numbers are supported:\n112:     - Final version like 3.0 or 3.1.2.\n113:     - Alpha, beta or release candidate with `a`, `b` or `rc` postfix,\n114:       respectively, and an incremented number like 3.0a1 or 3.0.1rc1.\n115:     - Development version with `.dev` postfix and an incremented number like\n116:       3.0.dev1 or 3.1a1.dev2.\n117: \n118:     When the given version is `dev`, the existing version number is updated\n119:     to the next suitable development version. For example, 3.0 -> 3.0.1.dev1,\n120:     3.1.1 -> 3.1.2.dev1, 3.2a1 -> 3.2a2.dev1, 3.2.dev1 -> 3.2.dev2.\n121:     \"\"\"\n122:     version = Version(version, VERSION_PATH, VERSION_PATTERN)\n123:     version.write()\n124:     Version(str(version), SETUP_PATH, VERSION_PATTERN).write()\n125:     print(version)\n126: \n127: \n128: @task\n129: def print_version(ctx):\n130:     \"\"\"Print the current project version.\"\"\"\n131:     print(Version(path=VERSION_PATH, pattern=VERSION_PATTERN))\n132: \n133: \n134: @task\n135: def library_docs(ctx, name):\n136:     \"\"\"Generate standard library documentation.\n137: \n138:     Args:\n139:         name:  Name of the library or `all` to generate docs for all libs.\n140:                Name is case-insensitive and can be shortened as long as it\n141:                is a unique prefix. For example, `b` is equivalent to\n142:                `BuiltIn` and `di` equivalent to `Dialogs`.\n143:     \"\"\"\n144:     libraries = [\n145:         \"BuiltIn\",\n146:         \"Collections\",\n147:         \"DateTime\",\n148:         \"Dialogs\",\n149:         \"OperatingSystem\",\n150:         \"Process\",\n151:         \"Screenshot\",\n152:         \"String\",\n153:         \"Telnet\",\n154:         \"XML\",\n155:     ]\n156:     name = name.lower()\n157:     if name != \"all\":\n158:         libraries = [lib for lib in libraries if lib.lower().startswith(name)]\n159:         if len(libraries) != 1:\n160:             raise Exit(f\"'{name}' is not a unique library prefix.\")\n161:     for lib in libraries:\n162:         libdoc(lib, str(Path(f\"doc/libraries/{lib}.html\")))\n163:         libdoc(lib, str(Path(f\"doc/libraries/{lib}.json\")), specdocformat=\"RAW\")\n164: \n165: \n166: @task\n167: def release_notes(ctx, version=None, username=None, password=None, write=False):\n168:     \"\"\"Generate release notes based on issues in the issue tracker.\n169: \n170:     Args:\n171:         version:  Generate release notes for this version. If not given,\n172:                   generated them for the current version.\n173:         username: GitHub username.\n174:         password: GitHub password.\n175:         write:    When set to True, write release notes to a file overwriting\n176:                   possible existing file. Otherwise, just print them to the\n177:                   terminal.\n178: \n179:     Username and password can also be specified using `GITHUB_USERNAME` and\n180:     `GITHUB_PASSWORD` environment variable, respectively. If they aren't\n181:     specified at all, communication with GitHub is anonymous and typically\n182:     pretty slow.\n183:     \"\"\"\n184:     version = Version(version, VERSION_PATH, VERSION_PATTERN)\n185:     file = RELEASE_NOTES_PATH if write else sys.stdout\n186:     generator = ReleaseNotesGenerator(\n187:         REPOSITORY, RELEASE_NOTES_TITLE, RELEASE_NOTES_INTRO\n188:     )\n189:     generator.generate(version, username, password, file)\n190: \n191: \n192: @task\n193: def build_libdoc(ctx):\n194:     \"\"\"Update Libdoc HTML template and language support.\n195: \n196:     Regenerates `libdoc.html`, the static template used by Libdoc.\n197: \n198:     Update the language support by reading the translations file from the Libdoc\n199:     web project and updates the languages that are used in the Libdoc command line\n200:     tool for help and language validation.\n201: \n202:     This task needs to be run if there are any changes to Libdoc.\n203:     \"\"\"\n204:     # FIXME: Use `ctx.run` instead.\n205:     subprocess.run([\"npm\", \"run\", \"build\", \"--prefix\", \"src/web/\"])\n206: \n207:     source = Path(\"src/web/libdoc/i18n/translations.json\")\n208:     data = json.loads(source.read_text(encoding=\"UTF-8\"))\n209:     languages = sorted([key.upper() for key in data])\n210: \n211:     target = Path(\"src/robot/libdocpkg/languages.py\")\n212:     content = target.read_text(encoding=\"UTF-8\")\n213:     in_languages = False\n214:     with target.open(\"w\", encoding=\"UTF-8\") as out:\n215:         for line in content.splitlines():\n216:             if line == \"LANGUAGES = [\":\n217:                 out.write(line + \"\\n\")\n218:                 for lang in languages:\n219:                     out.write(f'    \"{lang}\",\\n')\n220:                 out.write(\"]\\n\")\n221:                 in_languages = True\n222:             elif not in_languages:\n223:                 out.write(line + \"\\n\")\n224:             elif line == \"]\":\n225:                 in_languages = False\n226: \n227: \n228: @task\n229: def init_labels(ctx, username=None, password=None):\n230:     \"\"\"Initialize project by setting labels in the issue tracker.\n231: \n232:     Args:\n233:         username: GitHub username.\n234:         password: GitHub password.\n235: \n236:     Username and password can also be specified using `GITHUB_USERNAME` and\n237:     `GITHUB_PASSWORD` environment variable, respectively.\n238: \n239:     Should only be executed once when taking `rellu` tooling to use or\n240:     when labels it uses have changed.\n241:     \"\"\"\n242:     initialize_labels(REPOSITORY, username, password)\n\n(End of file - total 242 lines)\n</content>","metadata":{"preview":"# ruff: noqa: E402\n\n\"\"\"Tasks to help Robot Framework packaging and other development.\n\nExecuted by Invoke <http://pyinvoke.org>. Install it with `pip install invoke`\nand run `invoke --help` and `invoke --list` for details how to execute tasks.\n\nSee `BUILD.rst` for packaging and releasing instructions.\n\"\"\"\n\nimport json\nimport subprocess\nimport sys\nfrom pathlib import Path\n\nassert Path.cwd().resolve() == Path(__file__).resolve().parent\nsys.path.insert(0, \"src\")\n\nfrom invoke import Exit, task\nfrom rellu import initialize_labels, ReleaseNotesGenerator, Version","truncated":false,"loaded":[]},"title":"tasks.py","time":{"start":1776112760465,"end":1776112760473}}}]}
