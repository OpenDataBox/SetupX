{"type":"session_message","session_id":"ses_28bcc31f9ffe0NQ72LvX19vTUA","role":"assistant","message_id":"msg_d7433e3d7001fYVjzyL5jhi2NB","parts":[{"id":"prt_d7433ee5c001kUeoxM6IuiFUM3","messageID":"msg_d7433e3d7001fYVjzyL5jhi2NB","sessionID":"ses_28bcc31f9ffe0NQ72LvX19vTUA","type":"tool","tool":"read","callID":"call_5894e3282127488db51d1f83","state":{"status":"completed","input":{"filePath":"/workspace/setup.py"},"output":"<path>/workspace/setup.py</path>\n<type>file</type>\n<content>1: # Copyright 2018 DeepMind Technologies Limited. All rights reserved.\n2: #\n3: # Licensed under the Apache License, Version 2.0 (the \"License\");\n4: # you may not use this file except in compliance with the License.\n5: # You may obtain a copy of the License at\n6: #\n7: #     http://www.apache.org/licenses/LICENSE-2.0\n8: #\n9: # Unless required by applicable law or agreed to in writing, software\n10: # distributed under the License is distributed on an \"AS IS\" BASIS,\n11: # WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n12: # See the License for the specific language governing permissions and\n13: # limitations under the License.\n14: \n15: \"\"\"Install script for setuptools.\"\"\"\n16: \n17: import datetime\n18: from importlib import util as import_util\n19: import os\n20: import sys\n21: \n22: from setuptools import find_packages\n23: from setuptools import setup\n24: import setuptools.command.build_py\n25: import setuptools.command.develop\n26: \n27: spec = import_util.spec_from_file_location('_metadata', 'acme/_metadata.py')\n28: _metadata = import_util.module_from_spec(spec)\n29: spec.loader.exec_module(_metadata)\n30: \n31: # TODO(b/184148890): Add a release flag\n32: \n33: \n34: # Any particular version of reverb needs to be pinned against a particular\n35: # version of TF due to how it is built. While the versions below should be the\n36: # most recent stable versions of each library we'll be explicit just make make\n37: # sure this constraint is upheld.\n38: \n39: tensorflow = [\n40:     'tensorflow==2.8.0',\n41:     'tensorflow_probability==0.15.0',\n42:     'tensorflow_datasets==4.6.0',\n43:     'dm-reverb==0.7.2',\n44:     'dm-launchpad==0.5.2',\n45: ]\n46: \n47: core_requirements = [\n48:     'absl-py',\n49:     'dm-env',\n50:     'dm-tree',\n51:     'numpy',\n52:     'pillow',\n53:     'typing-extensions',\n54: ]\n55: \n56: jax_requirements = [\n57:     'jax==0.4.3',\n58:     'jaxlib==0.4.3',\n59:     'chex',\n60:     'dm-haiku',\n61:     'flax',\n62:     'optax',\n63:     'rlax',\n64: ] + tensorflow\n65: \n66: tf_requirements = [\n67:     'dm-sonnet',\n68:     'trfl',\n69: ] + tensorflow\n70: \n71: testing_requirements = [\n72:     'pytype==2021.8.11',  # TODO(b/206926677): update to new version.\n73:     'pytest-xdist',\n74: ]\n75: \n76: envs_requirements = [\n77:     'atari-py',\n78:     'bsuite',\n79:     'dm-control',\n80:     'gym==0.25.0',\n81:     'gym[atari]',\n82:     'pygame==2.1.0',\n83:     'rlds',\n84: ]\n85: \n86: \n87: def generate_requirements_file(path=None):\n88:   \"\"\"Generates requirements.txt file with the Acme's dependencies.\n89: \n90:   It is used by Launchpad GCP runtime to generate Acme requirements to be\n91:   installed inside the docker image. Acme itself is not installed from pypi,\n92:   but instead sources are copied over to reflect any local changes made to\n93:   the codebase.\n94: \n95:   Args:\n96:     path: path to the requirements.txt file to generate.\n97:   \"\"\"\n98:   if not path:\n99:     path = os.path.join(os.path.dirname(__file__), 'acme/requirements.txt')\n100:   with open(path, 'w') as f:\n101:     for package in set(core_requirements + jax_requirements + tf_requirements +\n102:                        envs_requirements):\n103:       f.write(f'{package}\\n')\n104: \n105: \n106: long_description = \"\"\"Acme is a library of reinforcement learning (RL) agents\n107: and agent building blocks. Acme strives to expose simple, efficient,\n108: and readable agents, that serve both as reference implementations of popular\n109: algorithms and as strong baselines, while still providing enough flexibility\n110: to do novel research. The design of Acme also attempts to provide multiple\n111: points of entry to the RL problem at differing levels of complexity.\n112: \n113: For more information see [github repository](https://github.com/deepmind/acme).\"\"\"\n114: \n115: # Get the version from metadata.\n116: version = _metadata.__version__\n117: \n118: # If we're releasing a nightly/dev version append to the version string.\n119: if '--nightly' in sys.argv:\n120:   sys.argv.remove('--nightly')\n121:   version += '.dev' + datetime.datetime.now().strftime('%Y%m%d')\n122: \n123: \n124: class BuildPy(setuptools.command.build_py.build_py):\n125: \n126:   def run(self):\n127:     generate_requirements_file()\n128:     setuptools.command.build_py.build_py.run(self)\n129: \n130: \n131: class Develop(setuptools.command.develop.develop):\n132: \n133:   def run(self):\n134:     generate_requirements_file()\n135:     setuptools.command.develop.develop.run(self)\n136: \n137: cmdclass = {\n138:     'build_py': BuildPy,\n139:     'develop': Develop,\n140: }\n141: \n142: setup(\n143:     name='dm-acme',\n144:     version=version,\n145:     cmdclass=cmdclass,\n146:     description='A Python library for Reinforcement Learning.',\n147:     long_description=long_description,\n148:     long_description_content_type='text/markdown',\n149:     author='DeepMind',\n150:     license='Apache License, Version 2.0',\n151:     keywords='reinforcement-learning python machine learning',\n152:     packages=find_packages(),\n153:     package_data={'': ['requirements.txt']},\n154:     include_package_data=True,\n155:     install_requires=core_requirements,\n156:     extras_require={\n157:         'jax': jax_requirements,\n158:         'tf': tf_requirements,\n159:         'testing': testing_requirements,\n160:         'envs': envs_requirements,\n161:     },\n162:     classifiers=[\n163:         'Development Status :: 3 - Alpha',\n164:         'Environment :: Console',\n165:         'Intended Audience :: Science/Research',\n166:         'License :: OSI Approved :: Apache Software License',\n167:         'Operating System :: POSIX :: Linux',\n168:         'Programming Language :: Python :: 3',\n169:         'Programming Language :: Python :: 3.8',\n170:         'Programming Language :: Python :: 3.9',\n171:         'Topic :: Scientific/Engineering :: Artificial Intelligence',\n172:     ],\n173: )\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"# Copyright 2018 DeepMind Technologies Limited. All rights reserved.\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n\n\"\"\"Install script for setuptools.\"\"\"\n\nimport datetime\nfrom importlib import util as import_util\nimport os\nimport sys","truncated":false,"loaded":[]},"title":"setup.py","time":{"start":1775771054093,"end":1775771054098}}}]}
