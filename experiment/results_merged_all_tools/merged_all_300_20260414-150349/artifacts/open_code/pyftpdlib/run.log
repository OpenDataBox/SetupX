{"type":"session_message","session_id":"ses_28a77699cffeNuNcQOA57Lb5pD","role":"assistant","message_id":"msg_d7588ac06001HyxrmqaiHqMNYh","parts":[{"id":"prt_d7588b8a4001lhh2y2nEjePKtM","messageID":"msg_d7588ac06001HyxrmqaiHqMNYh","sessionID":"ses_28a77699cffeNuNcQOA57Lb5pD","type":"tool","tool":"read","callID":"call_556a0fe28421486ca198b834","state":{"status":"completed","input":{"filePath":"/workspace/Makefile"},"output":"<path>/workspace/Makefile</path>\n<type>file</type>\n<content>1: # Shortcuts for various tasks (UNIX only).\n2: # To use a specific Python version run:\n3: # \t$ make install PYTHON=python3.7\n4: # To run a specific test:\n5: # \t$ make test ARGS=\"-v -s tests/test_functional.py::TestIPv6MixedEnvironment::test_port_v4\"\n6: \n7: # Configurable\n8: PYTHON = python3\n9: ARGS =\n10: \n11: # In not in a virtualenv, add --user options for install commands.\n12: SETUP_INSTALL_ARGS = `$(PYTHON) -c \\\n13: \t\"import sys; print('' if hasattr(sys, 'real_prefix') or hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix else '--user')\"`\n14: PYTHON_ENV_VARS = PYTHONWARNINGS=always PYTHONUNBUFFERED=1 PYTEST_DISABLE_PLUGIN_AUTOLOAD=1\n15: PIP_INSTALL_ARGS = --trusted-host files.pythonhosted.org --trusted-host pypi.org --upgrade\n16: \n17: # if make is invoked with no arg, default to `make help`\n18: .DEFAULT_GOAL := help\n19: \n20: # install git hook\n21: _ := $(shell mkdir -p .git/hooks/ && ln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)\n22: \n23: # ===================================================================\n24: # Install\n25: # ===================================================================\n26: \n27: clean:  ## Remove all build files.\n28: \t@rm -rfv `find . \\\n29: \t\t-type d -name __pycache__ \\\n30: \t\t-o -type f -name \\*.bak \\\n31: \t\t-o -type f -name \\*.orig \\\n32: \t\t-o -type f -name \\*.pyc \\\n33: \t\t-o -type f -name \\*.pyd \\\n34: \t\t-o -type f -name \\*.pyo \\\n35: \t\t-o -type f -name \\*.rej \\\n36: \t\t-o -type f -name \\*.so \\\n37: \t\t-o -type f -name \\*.~ \\\n38: \t\t-o -type f -name \\*\\$testfn`\n39: \t@rm -rfv \\\n40: \t\t*.core \\\n41: \t\t*.egg-info \\\n42: \t\t*\\$testfile* \\\n43: \t\t.coverage \\\n44: \t\t.failed-tests.txt \\\n45: \t\t.pytest_cache \\\n46: \t\t.ruff_cache/ \\\n47: \t\tbuild/ \\\n48: \t\tdist/ \\\n49: \t\tdocs/_build/ \\\n50: \t\thtmlcov/ \\\n51: \t\tpyftpd-tmp-* \\\n52: \t\ttmp/\n53: \n54: install:  ## Install this package.\n55: \t$(PYTHON) -m pip install -e . $(SETUP_INSTALL_ARGS)\n56: \n57: uninstall:  ## Uninstall this package.\n58: \tcd ..; $(PYTHON) -m pip uninstall -y -v pyftpdlib || true\n59: \t$(PYTHON) scripts/internal/purge_installation.py\n60: \n61: install-pip:  ## Install pip (no-op if already installed).\n62: \t$(PYTHON) scripts/internal/install_pip.py\n63: \n64: install-pydeps-test:  ## Install python deps necessary to run unit tests.\n65: \t${MAKE} install-pip\n66: \t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n67: \t$(PYTHON) -c \\\n68: \t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'])\"\n69: \n70: install-pydeps-dev:  ## Install python deps meant for local development.\n71: \t${MAKE} install-git-hooks\n72: \t${MAKE} install-pip\n73: \t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n74: \t$(PYTHON) -c \\\n75: \t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'] + d['dev'])\"\n76: \n77: install-git-hooks:  ## Install GIT pre-commit hook.\n78: \tln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit\n79: \tchmod +x .git/hooks/pre-commit\n80: \n81: # ===================================================================\n82: # Tests\n83: # ===================================================================\n84: \n85: test:  ## Run all tests. To run a specific test: do \"make test ARGS=pyftpdlib.test.test_functional.TestFtpStoreData\"\n86: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS)\n87: \n88: test-parallel:  ## Run all tests in parallel.\n89: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest -n auto --dist loadgroup $(ARGS)\n90: \n91: test-functional:  ## Run functional FTP tests.\n92: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional.py\n93: \n94: test-functional-ssl:  ## Run functional FTPS tests.\n95: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional_ssl.py\n96: \n97: test-servers:  ## Run tests for FTPServer and its subclasses.\n98: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_servers.py\n99: \n100: test-authorizers:  ## Run tests for authorizers.\n101: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_authorizers.py\n102: \n103: test-filesystems:  ## Run filesystem tests.\n104: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_filesystems.py\n105: \n106: test-ioloop:  ## Run IOLoop tests.\n107: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_ioloop.py\n108: \n109: test-cli:  ## Run miscellaneous tests.\n110: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_cli.py\n111: \n112: test-lastfailed:  ## Run previously failed tests\n113: \t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest --last-failed $(ARGS)\n114: \n115: test-coverage:  ## Run test coverage.\n116: \trm -rf .coverage htmlcov\n117: \t$(PYTHON_ENV_VARS) $(PYTHON) -m coverage run -m pytest $(ARGS)\n118: \t$(PYTHON) -m coverage report\n119: \t@echo \"writing results to htmlcov/index.html\"\n120: \t$(PYTHON) -m coverage html\n121: \t$(PYTHON) -m webbrowser -t htmlcov/index.html\n122: \n123: # ===================================================================\n124: # Linters\n125: # ===================================================================\n126: \n127: black:  ## Python files linting (via black)\n128: \t@git ls-files '*.py' | xargs $(PYTHON) -m black --check --safe\n129: \n130: ruff:  ## Run ruff linter.\n131: \t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --output-format=concise\n132: \n133: _pylint:  ## Python pylint (not mandatory, just run it from time to time)\n134: \t@git ls-files '*.py' | xargs $(PYTHON) -m pylint --rcfile=pyproject.toml --jobs=0 $(ARGS)\n135: \n136: lint-rst:  ## Run RsT linter.\n137: \t@git ls-files '*.rst' | xargs rstcheck --config=pyproject.toml\n138: \n139: lint-toml:  ## Linter for pyproject.toml\n140: \t@git ls-files '*.toml' | xargs toml-sort --check\n141: \n142: lint-all:  ## Run all linters\n143: \t${MAKE} black\n144: \t${MAKE} ruff\n145: \t${MAKE} lint-rst\n146: \t${MAKE} lint-toml\n147: \n148: # ===================================================================\n149: # Fixers\n150: # ===================================================================\n151: \n152: fix-black:\n153: \tgit ls-files '*.py' | xargs $(PYTHON) -m black\n154: \n155: fix-ruff:\n156: \t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --fix --output-format=concise $(ARGS)\n157: \n158: fix-toml:  ## Fix pyproject.toml\n159: \t@git ls-files '*.toml' | xargs toml-sort\n160: \n161: fix-all:  ## Run all code fixers.\n162: \t${MAKE} fix-black\n163: \t${MAKE} fix-ruff\n164: \t${MAKE} fix-toml\n165: \n166: # ===================================================================\n167: # Distribution\n168: # ===================================================================\n169: \n170: # --- create\n171: \n172: generate-manifest:  ## Generates MANIFEST.in file.\n173: \t$(PYTHON) scripts/internal/generate_manifest.py > MANIFEST.in\n174: \n175: create-sdist:  ## Create tar.gz source distribution.\n176: \t$(MAKE) generate-manifest\n177: \t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --sdist\n178: \n179: create-wheels:  ## Create .whl distribution.\n180: \t$(MAKE) generate-manifest\n181: \t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --wheel\n182: \n183: create-dist:  ## Create .tar.gz + .whl distribution.\n184: \t$(MAKE) create-sdist\n185: \t$(MAKE) create-wheels\n186: \n187: # --- check\n188: \n189: check-manifest:  ## Check sanity of MANIFEST.in file.\n190: \t$(PYTHON) -m check_manifest -v\n191: \n192: check-pyproject:  ## Check sanity of pyproject.toml file.\n193: \t$(PYTHON) -m validate_pyproject -v pyproject.toml\n194: \n195: check-sdist:  ## Check sanity of source distribution.\n196: \t$(PYTHON_ENV_VARS) $(PYTHON) -m virtualenv --clear --no-wheel --quiet build/venv\n197: \t$(PYTHON_ENV_VARS) build/venv/bin/python -m pip install -v --isolated --quiet dist/*.tar.gz\n198: \t$(PYTHON_ENV_VARS) build/venv/bin/python -c \"import os; os.chdir('build/venv'); import pyftpdlib\"\n199: \t$(PYTHON) -m twine check --strict dist/*.tar.gz\n200: \n201: check-wheels:  ## Check sanity of wheels.\n202: \t$(PYTHON) -m abi3audit --verbose --strict dist/*-abi3-*.whl\n203: \t$(PYTHON) -m twine check --strict dist/*.whl\n204: \n205: check-dist:  ## Run all sanity checks re. to the package distribution.\n206: \t$(MAKE) check-manifest\n207: \t$(MAKE) check-pyproject\n208: \t$(MAKE) check-sdist\n209: \t$(MAKE) check-wheels\n210: \n211: # --- release\n212: \n213: pre-release:  ## Check if we're ready to produce a new release.\n214: \t$(MAKE) clean\n215: \t$(MAKE) create-dist\n216: \t$(MAKE) check-dist\n217: \t$(MAKE) install\n218: \t@$(PYTHON) -c \\\n219: \t\t\"import requests, sys; \\\n220: \t\tfrom packaging.version import parse; \\\n221: \t\tfrom pyftpdlib import __ver__; \\\n222: \t\tres = requests.get('https://pypi.org/pypi/pyftpdlib/json', timeout=5); \\\n223: \t\tversions = sorted(res.json()['releases'], key=parse, reverse=True); \\\n224: \t\tsys.exit('version %r already exists on PYPI' % __ver__) if __ver__ in versions else 0\"\n225: \t@$(PYTHON) -c \\\n226: \t\t\"from pyftpdlib import __ver__ as ver; \\\n227: \t\thistory = open('HISTORY.rst').read(); \\\n228: \t\tassert ver in history, '%r not found in HISTORY.rst' % ver; \\\n229: \t\tassert 'IN DEVELOPMENT' not in history, 'IN DEVELOPMENT found in HISTORY.rst';\"\n230: \n231: release:  ## Upload a new release.\n232: \t$(PYTHON) -m twine upload dist/*.tar.gz\n233: \t$(PYTHON) -m twine upload dist/*.whl\n234: \t$(MAKE) git-tag-release\n235: \n236: git-tag-release:  ## Git-tag a new release.\n237: \tgit tag -a release-`$(PYTHON) -c \"import pyftpdlib; print(pyftpdlib.__ver__)\"` -m `git rev-list HEAD --count`:`git rev-parse --short HEAD`\n238: \tgit push --follow-tags\n239: \n240: print-announce:  ## Print announce of new release.\n241: \t@$(PYTHON) scripts/internal/print_announce.py\n242: \n243: # ===================================================================\n244: # Misc\n245: # ===================================================================\n246: \n247: grep-todos:  ## Look for TODOs in source files.\n248: \tgit grep -EIn \"TODO|FIXME|XXX\"\n249: \n250: check-broken-links:  ## Look for broken links in source files.\n251: \tgit ls-files | xargs $(PYTHON) -Wa scripts/internal/check_broken_links.py\n252: \n253: help: ## Display callable targets.\n254: \t@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = \":.*?## \"}; {printf \"\\033[36m%-20s\\033[0m %s\\n\", $$1, $$2}'\n\n(End of file - total 254 lines)\n</content>","metadata":{"preview":"# Shortcuts for various tasks (UNIX only).\n# To use a specific Python version run:\n# \t$ make install PYTHON=python3.7\n# To run a specific test:\n# \t$ make test ARGS=\"-v -s tests/test_functional.py::TestIPv6MixedEnvironment::test_port_v4\"\n\n# Configurable\nPYTHON = python3\nARGS =\n\n# In not in a virtualenv, add --user options for install commands.\nSETUP_INSTALL_ARGS = `$(PYTHON) -c \\\n\t\"import sys; print('' if hasattr(sys, 'real_prefix') or hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix else '--user')\"`\nPYTHON_ENV_VARS = PYTHONWARNINGS=always PYTHONUNBUFFERED=1 PYTEST_DISABLE_PLUGIN_AUTOLOAD=1\nPIP_INSTALL_ARGS = --trusted-host files.pythonhosted.org --trusted-host pypi.org --upgrade\n\n# if make is invoked with no arg, default to `make help`\n.DEFAULT_GOAL := help\n\n# install git hook","truncated":false,"loaded":[]},"title":"Makefile","time":{"start":1775793387982,"end":1775793387985}}}]}
