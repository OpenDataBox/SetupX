 total 250 lines)\n</content>","metadata":{"preview":"[build-system]\nbuild-backend = \"setuptools.build_meta\"\nrequires = [\"setuptools\"]\n\n[project]\nauthors = [{name = \"Giampaolo Rodola'\", email = \"g.rodola@gmail.com\"}]\nclassifiers = [\n    \"Development Status :: 5 - Production/Stable\",\n    \"Environment :: Console\",\n    \"Intended Audience :: Developers\",\n    \"Intended Audience :: System Administrators\",\n    \"Operating System :: OS Independent\",\n    \"Programming Language :: Python :: 3\",\n    \"Programming Language :: Python\",\n    \"Topic :: Internet :: File Transfer Protocol (FTP)\",\n    \"Topic :: Software Development :: Libraries :: Python Modules\",\n    \"Topic :: System :: Filesystems\",\n]\ndependencies = [\n    \"pyasynchat; python_version >= '3.12'\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775793387401,"end":1775793387408}}}]}
