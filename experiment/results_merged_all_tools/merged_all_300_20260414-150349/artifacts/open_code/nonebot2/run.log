ttpx[http2] >=0.26.0, <1.0.0\",\n39:   \"aiohttp[speedups] >=3.11.0, <4.0.0\",\n40:   \"uvicorn[standard] >=0.20.0, <1.0.0\",\n41: ]\n42: \n43: [dependency-groups]\n44: dev = [\n45:   { include-group = \"test\" },\n46:   { include-group = \"docs\" },\n47:   \"ruff >=0.15.0, <0.16.0\",\n48:   \"nonemoji >=0.1.2, <0.2.0\",\n49:   \"pre-commit >=4.0.0, <5.0.0\",\n50: ]\n51: test = [\n52:   \"trio >=0.27.0\",\n53:   \"nonebug >=0.4.1, <0.5.0\",\n54:   \"wsproto >=1.2.0, <2.0.0\",\n55:   \"werkzeug >=2.3.6, <4.0.0\",\n56:   \"pytest-cov >=7.0.0, <8.0.0\",\n57:   \"pytest-xdist >=3.0.2, <4.0.0\",\n58:   \"coverage-conditional-plugin >=0.9.0, <0.10.0\",\n59: ]\n60: docs = [\"nb-autodoc >=1.0.4, <2.0.0\"]\n61: pydantic-v1 = [\"pydantic >=1.10.0, <2.0.0\"]\n62: pydantic-v2 = [\"pydantic >=2.0.0, <3.0.0\"]\n63: \n64: [project.urls]\n65: Homepage = \"https://nonebot.dev/\"\n66: Repository = \"https://github.com/nonebot/nonebot2\"\n67: Documentation = \"https://nonebot.dev/\"\n68: \"Bug Tracker\" = \"https://github.com/nonebot/nonebot2/issues\"\n69: Changelog = \"https://nonebot.dev/changelog\"\n70: Funding = \"https://afdian.com/@nonebot\"\n71: \n72: [tool.uv]\n73: required-version = \">=0.8.0\"\n74: conflicts = [[{ group = \"pydantic-v1\" }, { group = \"pydantic-v2\" }]]\n75: \n76: [tool.uv.build-backend]\n77: module-name = \"nonebot\"\n78: module-root = \"\"\n79: \n80: [tool.pytest.ini_options]\n81: addopts = \"--cov=nonebot --cov-report=term-missing\"\n82: filterwarnings = [\"error\", \"ignore::DeprecationWarning\"]\n83: \n84: [tool.ruff]\n85: line-length = 88\n86: \n87: [tool.ruff.format]\n88: line-ending = \"lf\"\n89: \n90: [tool.ruff.lint]\n91: select = [\n92:   \"F\",     # Pyflakes\n93:   \"W\",     # pycodestyle warnings\n94:   \"E\",     # pycodestyle errors\n95:   \"I\",     # isort\n96:   \"UP\",    # pyupgrade\n97:   \"ASYNC\", # flake8-async\n98:   \"C4\",    # flake8-comprehensions\n99:   \"T10\",   # flake8-debugger\n100:   \"T20\",   # flake8-print\n101:   \"PYI\",   # flake8-pyi\n102:   \"PT\",    # flake8-pytest-style\n103:   \"Q\",     # flake8-quotes\n104:   \"TID\",   # flake8-tidy-imports\n105:   \"RUF\",   # Ruff-specific rules\n106: ]\n107: ignore = [\n108:   \"E402\",   # module-import-not-at-top-of-file\n109:   \"UP037\",  # quoted-annotation\n110:   \"RUF001\", # ambiguous-unicode-character-string\n111:   \"RUF002\", # ambiguous-unicode-character-docstring\n112:   \"RUF003\", # ambiguous-unicode-character-comment\n113: ]\n114: \n115: [tool.ruff.lint.isort]\n116: force-sort-within-sections = true\n117: known-first-party = [\"nonebot\", \"tests/*\"]\n118: extra-standard-library = [\"typing_extensions\"]\n119: \n120: [tool.ruff.lint.flake8-pytest-style]\n121: fixture-parentheses = false\n122: mark-parentheses = false\n123: \n124: [tool.ruff.lint.pyupgrade]\n125: keep-runtime-typing = true\n126: \n127: [tool.pyright]\n128: pythonVersion = \"3.10\"\n129: pythonPlatform = \"All\"\n130: defineConstant = { PYDANTIC_V2 = true }\n131: executionEnvironments = [\n132:   { root = \"./tests/python_3_12\", pythonVersion = \"3.12\", extraPaths = [\n133:     \"./\",\n134:   ] },\n135:   { root = \"./tests\", extraPaths = [\n136:     \"./\",\n137:   ] },\n138:   { root = \"./\" },\n139: ]\n140: \n141: typeCheckingMode = \"standard\"\n142: reportShadowedImports = false\n143: disableBytesTypePromotions = true\n144: \n145: [build-system]\n146: requires = [\"uv_build >=0.8.3, <0.10.0\"]\n147: build-backend = \"uv_build\"\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"[project]\nname = \"nonebot2\"\nversion = \"2.5.0\"\ndescription = \"An asynchronous python bot framework.\"\nauthors = [{ name = \"yanyongyu\", email = \"yyy@nonebot.dev\" }]\nlicense = \"MIT\"\nreadme = \"README.md\"\nkeywords = [\"bot\", \"qq\", \"qqbot\", \"mirai\", \"coolq\"]\nclassifiers = [\n  \"Development Status :: 5 - Production/Stable\",\n  \"Framework :: Robot Framework\",\n  \"Framework :: Robot Framework :: Library\",\n  \"Operating System :: OS Independent\",\n  \"Programming Language :: Python :: 3\",\n]\nrequires-python = \">=3.10, <4.0\"\ndependencies = [\n  \"yarl >=1.7.2, <2.0.0\",\n  \"anyio >=4.4.0, <5.0.0\",\n  \"loguru >=0.6.0, <1.0.0\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1776098349008,"end":1776098349012}}}]}
