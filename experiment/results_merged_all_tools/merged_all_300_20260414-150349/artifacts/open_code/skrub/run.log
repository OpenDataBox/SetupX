file = \"skrub/VERSION.txt\" }\n46: \n47: [dependency-groups]\n48: dev = [\n49:   \"ipykernel\",\n50:   \"ipython\",\n51:   \"jupyterlab\",\n52: \n53:   # doc\n54:   \"jupyterlite-sphinx\",\n55:   \"jupyterlite-pyodide-kernel\",\n56:   \"numpydoc\",\n57:   \"pydata-sphinx-theme\",\n58:   \"seaborn\",\n59:   # TODO: unpin sphinx when incmpatibility with autosummary-accessors is fixed:\n60:   # https://github.com/xarray-contrib/sphinx-autosummary-accessors/issues/165\n61:   \"sphinx<9\",\n62:   \"sphinx-copybutton\",\n63:   \"sphinx-gallery\",\n64:   \"sphinxext-opengraph\",\n65:   \"sphinx-autosummary-accessors\",\n66:   \"statsmodels\",\n67: \n68:   # lint\n69:   \"ruff==0.15.0\",\n70:   \"pre-commit\",\n71: \n72:   # test\n73:   \"pytest\",\n74:   \"pytest-cov\",\n75:   \"pytest-xdist\",\n76: \n77:   # optional\n78:   \"pyarrow\",\n79:   \"polars\",\n80:   \"plotly\",\n81:   \"optuna\",\n82: ]\n83: transformers = [\"sentence-transformers\"]\n84: \n85: [project.urls]\n86: Homepage = \"https://skrub-data.org/\"\n87: Source = \"https://github.com/skrub-data/skrub\"\n88: Issues = \"https://github.com/skrub-data/skrub/issues\"\n89: \n90: [tool.setuptools]\n91: packages = [\"skrub\"]\n92: \n93: [tool.pixi.workspace]\n94: channels = [\"conda-forge\", \"pytorch\"]\n95: platforms = [\"linux-64\", \"osx-arm64\", \"osx-64\", \"win-64\"]\n96: \n97: [tool.pixi.dependencies]\n98: numpy = \">=1.23.5\"\n99: pandas = \">=1.5.3\"\n100: scikit-learn = \">=1.4.2\"\n101: scipy = \">=1.9.3\"\n102: jinja2 = \">=3.1.2\"\n103: matplotlib = \">=3.4.3\"\n104: pydot = \"*\"\n105: requests = \">=2.27.1\"\n106: \n107: [tool.pixi.feature.doc.dependencies]\n108: jupyterlite-sphinx = \"*\"\n109: jupyterlite-pyodide-kernel = \"*\"\n110: matplotlib = \"*\"\n111: pydot = \"*\"\n112: numpydoc = \"*\"\n113: pydata-sphinx-theme = \"*\"\n114: plotly = \"*\"\n115: memory_profiler = \"*\"\n116: seaborn = \"*\"\n117:   # TODO: unpin sphinx when incmpatibility with autosummary-accessors is fixed:\n118:   # https://github.com/xarray-contrib/sphinx-autosummary-accessors/issues/165\n119: sphinx = \"<9\"\n120: sphinx-copybutton = \"*\"\n121: sphinx-gallery = \"*\"\n122: sphinxext-opengraph = \"*\"\n123: sphinx-autosummary-accessors = \">=2025.3.1,<2026\"\n124: sphinx-sitemap = \"*\"\n125: statsmodels = \"*\"\n126: optuna = \"*\"\n127: skorch = \"*\"\n128: \n129: [tool.pixi.feature.lint.dependencies]\n130: ruff = \"==0.15.0\"\n131: pre-commit = \"*\"\n132: \n133: [tool.pixi.feature.optional.dependencies]\n134: pyarrow = \"*\"\n135: polars = \"*\"\n136: plotly = \"*\"\n137: optuna = \"*\"\n138: \n139: [tool.pixi.feature.transformers]\n140: # pytorch is not anymore released on osx-64 platform\n141: platforms = [\"linux-64\", \"osx-arm64\", \"win-64\"]\n142: \n143: [tool.pixi.feature.transformers.dependencies]\n144: pytorch = { version = \">=2.4.1,<3\" }\n145: transformers = \"*\"\n146: datasets = \"*\"\n147: sentence-transformers = \">=3.0,<6\"\n148: tokenizers = \">=0.22.0,<=0.23.0\"\n149: pyarrow = \"<21\"\n150: \n151: [tool.pixi.feature.test.dependencies]\n152: numpydoc = \"*\"\n153: pytest = \"*\"\n154: pytest-cov = \"*\"\n155: pytest-xdist = \"*\"\n156: \n157: [tool.pixi.feature.dev.dependencies]\n158: ipykernel = \"*\"\n159: ipython = \"*\"\n160: jupyterlab = \"*\"\n161: \n162: [tool.pixi.pypi-dependencies]\n163: skrub = { path = \".\", editable = true }\n164: \n165: [tool.pixi.feature.min-dependencies.dependencies]\n166: numpy = \"==1.23.5\"\n167: pandas = \"==1.5.3\"\n168: scikit-learn = \"==1.4.2\"\n169: scipy = \"==1.9.3\"\n170: jinja2 = \"==3.1.2\"\n171: matplotlib = \"==3.4.3\"\n172: pydot = \"*\"\n173: requests = \"==2.27.1\"\n174: # pinning pyparsing because it raises deprecation warnings in matplotlib\n175: # TODO: unpin when it gets fixed\n176: pyparsing = \"<3.3\"\n177: \n178: [tool.pixi.feature.min-optional-dependencies.dependencies]\n179: pyarrow = \"==15.0.2\"\n180: polars = \"==1.5.0\"\n181: plotly = \"*\"\n182: optuna = \"*\"\n183: \n184: [tool.pixi.feature.nightly-dependencies.pypi-options]\n185: # Get the nightly of as many dependencies as possible\n186: extra-index-urls = [\n187:   # scikit-learn, numpy, pandas...\n188:   \"https://pypi.anaconda.org/scientific-python-nightly-wheels/simple\",\n189:   # pyarrow\n190:   \"https://pypi.fury.io/arrow-nightlies\",\n191: ]\n192: \n193: [tool.pixi.feature.nightly-dependencies.pypi-dependencies]\n194: # Have to repeat dependencies here because otherwise pixi pulls from conda channels\n195: # rather than PyPI indexes\n196: skrub = { path = \".\", editable = true }\n197: numpy = \"*\"\n198: pandas = \"*\"\n199: scikit-learn = \"*\"\n200: scipy = \"*\"\n201: jinja2 = \"*\"\n202: matplotlib = \"*\"\n203: pydot = \"*\"\n204: requests = \"*\"\n205: pyarrow = \"*\"\n206: polars = \"*\"\n207: plotly = \"*\"\n208: \n209: [tool.pixi.feature.polars-without-pyarrow.dependencies]\n210: polars = \"*\"\n211: plotly = \"*\"\n212: optuna = \"*\"\n213: \n214: [tool.pixi.feature.py310.dependencies]\n215: python = \"~=3.10.0\"\n216: \n217: [tool.pixi.feature.py311.dependencies]\n218: python = \"~=3.11.0\"\n219: \n220: [tool.pixi.feature.py314.dependencies]\n221: python = \"~=3.14.0\"\n222: \n223: [tool.pixi.feature.doc.tasks]\n224: build-doc = { cmd = \"make html\", cwd = \"doc\" }\n225: build-doc-quick = { cmd = \"make html-noplot\", cwd = \"doc\" }\n226: clean-doc = { cmd = \"make clean\", cwd = \"doc\" }\n227: linkcheck = { cmd = \"make linkcheck\", cwd = \"doc\" }\n228: linkcheck-quick = { cmd = \"make linkcheck-noplot\", cwd = \"doc\" }\n229: \n230: [tool.pixi.feature.doc.target.win-64.tasks]\n231: build-doc = { cmd = \".\\\\make.bat html\", cwd = \"doc\" }\n232: build-doc-quick = { cmd = \".\\\\make.bat html-noplot\", cwd = \"doc\" }\n233: clean-doc = { cmd = \".\\\\make.bat clean\", cwd = \"doc\" }\n234: linkcheck = { cmd = \".\\\\make.bat linkcheck\", cwd = \"doc\" }\n235: linkcheck-quick = { cmd = \".\\\\make.bat linkcheck-noplot\", cwd = \"doc\" }\n236: \n237: \n238: [tool.pixi.feature.lint.tasks]\n239: lint = { cmd = \"pre-commit install && pre-commit run -v --all-files --show-diff-on-failure\" }\n240: \n241: [tool.pixi.feature.check-pyi-diff.tasks]\n242: # Note: this only works on Unix\n243: check = { cmd = \"python build_tools/generate_data_ops_stub.py | diff - skrub/_data_ops/_data_ops.pyi\" }\n244: \n245: [tool.pixi.feature.test.tasks]\n246: test = { cmd = \"pytest -vsl --cov=skrub --cov-report=xml skrub\" }\n247: test-user-guide = { cmd = \"pytest doc/**/*.rst\" }\n248: \n249: [tool.pixi.environments]\n250: lint = [\"lint\"]\n251: check-pyi-diff = [\"check-pyi-diff\"]\n252: doc = [\"optional\", \"doc\", \"transformers\"]\n253: test = [\"optional\", \"test\"]\n254: dev = [\"dev\", \"optional\", \"doc\", \"lint\", \"test\", \"transformers\"]\n255: ci-py310-min-deps = [\"py310\", \"min-dependencies\", \"test\"]\n256: ci-py310-min-optional-deps = [\n257:   \"py310\",\n258:   \"min-dependencies\",\n259:   \"min-optional-dependencies\",\n260:   \"test\",\n261: ]\n262: ci-py311-transformers = [\"py311\", \"transformers\", \"test\"]\n263: ci-py314-latest-deps = [\"py314\", \"test\"]\n264: ci-py314-polars-without-pyarrow = [\"py314\", \"test\", \"polars-without-pyarrow\"]\n265: ci-py314-latest-optional-deps = [\"py314\", \"optional\", \"test\"]\n266: \n267: # no-default-feature is necessary for pixi to download from nightly PyPI indexes rather than conda channels\n268: ci-nightly-deps = { no-default-feature = true, features = [ \"py314\", \"nightly-dependencies\", \"test\" ] }\n269: \n270: [tool.ruff]\n271: line-length = 88\n272: exclude = [\n273:   \".git\",\n274:   \"__pycache__\",\n275:   \"dist\",\n276:   \"doc/_build\",\n277:   \"doc/auto_examples\",\n278:   \"build\",\n279:   \"pixi.lock\"\n280: ]\n281: \n282: [tool.ruff.lint]\n283: # all rules can be found here: https://beta.ruff.rs/docs/rules/\n284: select = [\"E\", \"F\", \"W\", \"B\", \"C4\", \"I\", \"UP\"]\n285: ignore = [\n286:   # use `is` and `is not` for type comparisons\n287:   \"E721\",\n288:   # do not assign a lambda expression, use a def\n289:   \"E731\",\n290:   # do not use variables named 'l', 'O', or 'I'\n291:   \"E741\",\n292:   \"B004\",\n293:   \"B007\",\n294:   \"B010\",\n295:   \"B017\",\n296:   \"B018\",\n297:   \"B028\",\n298:   \"B904\",\n299:   \"B905\",\n300:   # unnecessary list comprehension (rewrite as a set comprehension)\n301:   \"C403\",\n302:   # unnecessary tuple literal (rewrite as a set literal)\n303:   \"C405\",\n304:   # unnecessary `dict()` call (rewrite as a literal)\n305:   \"C408\",\n306:   # unnecessary list literal passed to `tuple()` (rewrite as a tuple literal)\n307:   \"C409\",\n308: ]\n309: \n310: [tool.ruff.lint.per-file-ignores]\n311: # It's fine not to put the import at the top of the file in the examples\n312: # folder.\n313: \"examples/*\" = [\"E402\"]\n314: \"doc/tutorials/*\" = [\"E402\"]\n315: \"doc/conf.py\" = [\"E402\"]\n316: # Long exception messages in docstrings\n317: \"skrub/_clean_null_strings.py\" = [\"E501\"]\n318: \n319: [tool.pytest.ini_options]\n320: filterwarnings = [\n321:   # Turn deprecation warnings into errors\n322:   \"error::FutureWarning\",\n323:   \"error::DeprecationWarning\",\n324: \n325:   # Ignore warning from np.in1d since the future behavior is already the desired\n326:   # behavior. TODO remove when numpy min version >= 1.25.\n327:   'ignore:elementwise\\ comparison\\ failed:FutureWarning',\n328:   # TODO remove when pandas min version >= 2.2.0\n329:   'ignore:.*utcfromtimestamp\\(\\) is deprecated.*:DeprecationWarning',\n330:   # TODO remove when joblib min version >= 1.4.0\n331:   'ignore:.*ast\\.Num is deprecated.*:DeprecationWarning',\n332:   # TODO remove when joblib min version >= 1.4.0\n333:   'ignore:.*ast\\.NameConstant is deprecated.*:DeprecationWarning',\n334:   # TODO remove when joblib min version >= 1.4.0\n335:   'ignore:.*Attribute n is deprecated.*:DeprecationWarning',\n336:   # FIXME we need to decided what to do with pyarrow that is required by pandas >= 3.0\n337:   'ignore:(?s).*Pyarrow will become a required dependency of pandas.*:DeprecationWarning',\n338:   # Ignore pandas warning about converting Series of length 1 to scalar\n339:   # https://github.com/skrub-data/skrub/pull/1974\n340:   'ignore:Converting a Series or array of length 1 into a scalar is deprecated.*',\n341:   # accessing .values on a pandas dataframe raises this warning after numpy 1.25;\n342:   # should be addressed in pandas\n343:   'ignore:np.find_common_type is deprecated.*:DeprecationWarning',\n344:   'ignore:.*distutils Version classes are deprecated.*',\n345:   'ignore:.*`resume_download` is deprecated.*',\n346:   'ignore:.*`clean_up_tokenization_spaces` was not set.*',\n347:   'ignore:The current process just got forked.*',\n348:   'ignore:.*`clean_up_tokenization_spaces` was not set.*',\n349: ]\n350: log_cli_level = \"INFO\"\n351: xfail_strict = true\n352: addopts = [\n353:   \"--doctest-modules\",\n354:   \"--strict-config\",\n355:   \"--strict-markers\",\n356: ]\n357: doctest_optionflags = \"NORMALIZE_WHITESPACE ELLIPSIS\"\n358: \n359: [tool.codespell]\n360: # Ref: https://github.com/codespell-project/codespell#using-a-config-file\n361: skip = '.git*,*.svg,package-lock.json,*.lock,*.css,*-min.*,pyproject.toml'\n362: check-hidden = true\n363: # ignore-regex = ''\n364: ignore-words-list = 'ans,serie,fulfilment'\n\n(End of file - total 364 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=77.0.3\", \"setuptools_scm[toml]>=8\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"skrub\"\ndynamic = [\"version\"]\ndescription = \"Machine learning with dataframes\"\nreadme = \"README.rst\"\nauthors = [\n  { name = \"Riccardo Cappuzzo\" },\n  { name = \"Jerome Dockes\" },\n  { name = \"Guillaume Lemaitre\" },\n  { name = \"Vincent Maladiere\" },\n  { name = \"Gael Varoquaux\" },\n]\nlicense = \"BSD-3-Clause\"\nlicense-files = [\"LICENSE.txt\"]\nclassifiers = [\n    \"Development Status