{"type":"session_message","session_id":"ses_2775b4fbdffelnzkfcT80UULty","role":"assistant","message_id":"msg_d88ab679a001w3usHgrugoRmOl","parts":[{"id":"prt_d88ab7003001sLrePNCOKteGDS","messageID":"msg_d88ab679a001w3usHgrugoRmOl","sessionID":"ses_2775b4fbdffelnzkfcT80UULty","type":"tool","tool":"read","callID":"call_068ebe9a89a34172ba2d62ce","state":{"status":"completed","input":{"filePath":"/workspace/client/tests/utils.py"},"output":"<path>/workspace/client/tests/utils.py</path>\n<type>file</type>\n<content>1: \n2: # Copyright 2016-2025 Battelle Energy Alliance, LLC\n3: #\n4: # Licensed under the Apache License, Version 2.0 (the \"License\");\n5: # you may not use this file except in compliance with the License.\n6: # You may obtain a copy of the License at\n7: #\n8: #     http://www.apache.org/licenses/LICENSE-2.0\n9: #\n10: # Unless required by applicable law or agreed to in writing, software\n11: # distributed under the License is distributed on an \"AS IS\" BASIS,\n12: # WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: # See the License for the specific language governing permissions and\n14: # limitations under the License.\n15: \n16: from __future__ import unicode_literals, absolute_import\n17: import os, json\n18: from client import BaseClient, INLClient\n19: from ci.tests import utils\n20: from ci import models\n21: \n22: def create_json_response(canceled=False, success=True):\n23:     ret = {'status': 'OK'}\n24:     if canceled:\n25:         ret['command'] = 'cancel'\n26:     else:\n27:         ret['command'] = 'none'\n28:     ret['success'] = success\n29:     return ret\n30: \n31: \n32: def create_step_dict(script_sleep=2, num=1):\n33:     step = {\"environment\": {\"foo\": \"bar\", \"step_var_with_root\": \"BUILD_ROOT/foo\"},\n34:         'script': 'echo test_output1; sleep %s; echo test_output2' % script_sleep,\n35:         'stepresult_id': num,\n36:         'step_num': num,\n37:         'step_name': 'step {}'.format(num),\n38:         'step_id': num,\n39:         'abort_on_failure': True,\n40:         'allowed_to_fail': False,\n41:         }\n42:     return step\n43: \n44: def create_job_dict(num_steps=1, pk=1):\n45:     job = {'environment': {'CIVET_BASE_REPO': 'base repo', \"var_with_root\": \"BUILD_ROOT/bar\"},\n46:       'recipe_name': 'test_job',\n47:       'prestep_sources': ['prestep'],\n48:       'abort_on_failure': True,\n49:       'job_id': pk,\n50:       'steps':[create_step_dict(num=i) for i in range(num_steps)]\n51:       }\n52:     return job\n53: \n54: def default_client_info():\n55:     return {\"url\": \"test_url\",\n56:         \"client_name\": \"client_name\",\n57:         \"server\": \"https:://<server0>\",\n58:         \"servers\": [\"https://<server0>\", \"https://<server1>\"],\n59:         \"build_configs\": [\"linux-gnu\"],\n60:         \"ssl_verify\": False,\n61:         \"ssl_cert\": \"\",\n62:         \"log_file\": \"\",\n63:         \"log_dir\": os.path.abspath(os.path.dirname(__file__)),\n64:         \"build_keys\": [1234],\n65:         \"single_shot\": \"False\",\n66:         \"poll\": 30,\n67:         \"daemon_cmd\": \"\",\n68:         \"request_timeout\": 30,\n69:         \"update_step_time\": 20,\n70:         \"server_update_timeout\": 5,\n71:         \"server_update_interval\": 30,\n72:         \"max_output_size\": 5*1024*1024,\n73:         \"environment\": {}\n74:         }\n75: \n76: def read_json_test_file(fname):\n77:     dirname = os.path.dirname(os.path.realpath(__file__))\n78:     full_name = os.path.join(dirname, fname)\n79:     with open(full_name, \"r\") as f:\n80:         json_data = f.read()\n81:         return json.loads(json_data)\n82: \n83: def in_call_args(mock_obj, pat, idx):\n84:     for call in mock_obj.call_args_list:\n85:         if str(pat) in str(call[0][idx]):\n86:             return True\n87:     return False\n88: \n89: def server_url(stage, client_info, step):\n90:     url_names = {\"start_step\": \"start_step_result\",\n91:         \"update_step\": \"update_step_result\",\n92:         \"complete_step\": \"complete_step_result\",\n93:         }\n94:     url = \"%s/client/%s/%s/%s/%s/\" % (client_info[\"server\"], url_names[stage], client_info[\"build_keys\"][0], client_info[\"client_name\"], step[\"stepresult_id\"])\n95:     return url\n96: \n97: def check_finished(test_obj, claimed_job, client_info, mock_obj):\n98:     finished = \"%s/client/job_finished/%s/%s/%s/\" % (client_info[\"server\"], client_info[\"build_keys\"][0], client_info[\"client_name\"], claimed_job[\"job_info\"][\"job_id\"])\n99:     test_obj.assertTrue(in_call_args(mock_obj, finished, 0))\n100: \n101: def check_step(test_obj, step, client_info, mock_obj):\n102:     start = \"start %s\" % step[\"step_name\"]\n103:     done = \"done %s\" % step[\"step_name\"]\n104:     env_line = \"/foo/bar/global /foo/bar/%s\" % step[\"step_name\"]\n105:     line = \"%s\\\\n%s\\\\n%s\\\\n\" % (env_line, start, done)\n106:     test_obj.assertTrue(in_call_args(mock_obj, server_url(\"start_step\", client_info, step), 0))\n107:     test_obj.assertTrue(in_call_args(mock_obj, server_url(\"update_step\", client_info, step), 0))\n108:     test_obj.assertTrue(in_call_args(mock_obj, server_url(\"complete_step\", client_info, step), 0))\n109:     test_obj.assertTrue(in_call_args(mock_obj, step[\"stepresult_id\"], 1))\n110:     test_obj.assertTrue(in_call_args(mock_obj, env_line, 1))\n111:     test_obj.assertTrue(in_call_args(mock_obj, start, 1))\n112:     test_obj.assertTrue(in_call_args(mock_obj, done, 1))\n113:     test_obj.assertTrue(in_call_args(mock_obj, line, 1))\n114: \n115: def check_calls(test_obj, claimed_job, client_info, mock_obj):\n116:     for step in claimed_job[\"job_info\"][\"steps\"]:\n117:         check_step(test_obj, step, client_info, mock_obj)\n118:     check_finished(test_obj, claimed_job, client_info, mock_obj)\n119: \n120: def create_base_client(log_dir=None, log_file=None):\n121:     client_info = default_client_info()\n122:     if log_dir != None:\n123:         client_info[\"log_dir\"] = log_dir\n124:     if log_file != None:\n125:         client_info[\"log_file\"] = log_file\n126:     BaseClient.setup_logger() # logger on stdout\n127:     return BaseClient.BaseClient(client_info)\n128: \n129: def create_inl_client(log_dir=None, log_file=None):\n130:     client_info = default_client_info()\n131:     BaseClient.setup_logger() # logger on stdout\n132:     return INLClient.INLClient(client_info)\n133: \n134: def create_client_job(recipe_dir, name=\"TestJob\", sleep=1, n_steps=3, extra_script=''):\n135:     user = utils.get_test_user()\n136:     recipe = utils.create_recipe(user=user, name=name)\n137:     test_job = utils.create_job(user=user, recipe=recipe)\n138:     test_job.ready = True\n139:     test_job.client = None\n140:     test_job.status = models.JobStatus.NOT_STARTED\n141:     test_job.save()\n142: \n143:     # create a prestep to make sure sourcing functions work\n144:     prestep0 = utils.create_prestepsource(filename=\"prestep0_{}.sh\".format(name), recipe=recipe)\n145:     with open(os.path.join(recipe_dir, prestep0.filename), \"w\") as f:\n146:         f.write('function start_message()\\n{\\n  echo start \"$*\"\\n}')\n147: \n148:     # create a prestep to make sure sourcing functions work\n149:     prestep1 = utils.create_prestepsource(filename=\"prestep1_{}.sh\".format(name), recipe=recipe)\n150:     with open(os.path.join(recipe_dir, prestep1.filename), \"w\") as f:\n151:         f.write('function end_message()\\n{\\n  echo end \"$*\"\\n}')\n152: \n153:     # create a global environment variable to test env works\n154:     # as well as BUILD_ROOT replacement\n155:     utils.create_recipe_environment(name=\"GLOBAL_NAME\", value=\"BUILD_ROOT/global\", recipe=recipe)\n156:     count = 0\n157:     for s in [f\"step{i}\".format(i) for i in range(n_steps)]:\n158:         step = utils.create_step(name=s, recipe=recipe, position=count)\n159:         # create a step environment variable to test env works\n160:         # as well as BUILD_ROOT replacement\n161:         utils.create_step_environment(name=\"STEP_NAME\", value=\"BUILD_ROOT/%s\" % s, step=step)\n162:         step.filename = \"{}_{}.sh\".format(s, name)\n163:         step.save()\n164:         count += 1\n165:         script_filename = os.path.join(recipe_dir, step.filename)\n166:         job_script = \"echo $GLOBAL_NAME $CIVET_RECIPE_NAME $STEP_NAME\\n\"\n167:         job_script += \"start_message {0}:{1}\\n\".format(recipe.name, s)\n168:         job_script += \"sleep {0}\\n\".format(sleep)\n169:         job_script += \"end_message {0}:{1}\\n\".format(recipe.name, s)\n170:         job_script += extra_script\n171:         with open(script_filename, \"w\") as f:\n172:             f.write(job_script)\n173:     return test_job\n174: \n175: def create_job_with_nested_bash(recipe_dir, name=\"TestJob\", sleep=10):\n176:     user = utils.get_test_user()\n177:     recipe = utils.create_recipe(user=user, name=name)\n178:     test_job = utils.create_job(user=user, recipe=recipe)\n179:     test_job.ready = True\n180:     test_job.client = None\n181:     test_job.status = models.JobStatus.NOT_STARTED\n182:     test_job.save()\n183: \n184:     step = utils.create_step(name=\"step0\", recipe=recipe, position=0)\n185:     step.filename = \"step0.sh\"\n186:     step.save()\n187:     script_filename = os.path.join(recipe_dir, step.filename)\n188:     sub_script_filename = os.path.join(recipe_dir, \"step0_sub.sh\")\n189:     sub_sub_script_filename = os.path.join(recipe_dir, \"step0_sub_sub.sh\")\n190:     with open(script_filename, \"w\") as f:\n191:         f.write(\"#!/bin/bash\\necho 'Launching {0}'\\n{0}\\necho '{0} returned '\".format(sub_script_filename))\n192:     with open(sub_script_filename, \"w\") as f:\n193:         f.write(\"#!/bin/bash\\necho 'Launching {0}'\\n{0}\\necho '{0} returned'\".format(sub_sub_script_filename))\n194: \n195:     import stat\n196:     st = os.stat(sub_script_filename)\n197:     os.chmod(sub_script_filename, st.st_mode | stat.S_IEXEC)\n198: \n199:     with open(sub_sub_script_filename, \"w\") as f:\n200:         f.write(\"#!/bin/bash\\necho 'Sleeping {0}...'\\nsleep {0}\\necho 'Finished sleeping'\".format(sleep))\n201:     st = os.stat(sub_sub_script_filename)\n202:     os.chmod(sub_sub_script_filename, st.st_mode | stat.S_IEXEC)\n203:     return test_job\n204: \n205: def check_complete_step(self, job, client, result, extra_step_msg=''):\n206:     global_var = \"%s/global\" % client.get_environment('BUILD_ROOT')\n207:     step_var = \"%s/%s\" % (client.get_environment('BUILD_ROOT'), result.name)\n208:     output = \"{0} {1} {2}\\nstart {1}:{3}\\nend {1}:{3}\\n{4}\".format(global_var, job.recipe.name, step_var, result.name, extra_step_msg)\n209:     self.assertEqual(result.output, output)\n210: \n211: def check_complete_job(self, job, client, n_steps=3, extra_step_msg=''):\n212:     job.refresh_from_db()\n213:     self.assertEqual(job.step_results.count(), n_steps)\n214:     for result in job.step_results.order_by(\"position\"):\n215:         check_complete_step(self, job, client, result, extra_step_msg)\n216:         self.assertEqual(job.complete, True)\n217:         self.assertEqual(job.status, models.JobStatus.SUCCESS)\n218:         self.assertGreater(job.seconds.total_seconds(), 1)\n219: \n220: def check_canceled_job(self, job, client):\n221:     job.refresh_from_db()\n222:     self.assertEqual(job.step_results.count(), 3)\n223:     found_cancel = False\n224:     for result in job.step_results.order_by(\"position\"):\n225:         if result.status == models.JobStatus.CANCELED:\n226:             self.assertEqual(result.output, \"\")\n227:             self.assertGreater(job.seconds.total_seconds(), 1)\n228:             found_cancel = True\n229:         elif result.status == models.JobStatus.SUCCESS:\n230:             check_complete_step(self, job, client, result)\n231:             self.assertGreater(job.seconds.total_seconds(), 1)\n232: \n233:     self.assertEqual(found_cancel, True)\n234:     self.assertEqual(job.complete, True)\n235:     self.assertEqual(job.status, models.JobStatus.CANCELED)\n236: \n237: def check_stopped_job(self, job):\n238:     job.refresh_from_db()\n239:     self.assertEqual(job.step_results.count(), 0)\n240:     self.assertEqual(job.complete, False)\n241:     self.assertEqual(job.status, models.JobStatus.NOT_STARTED)\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"\n# Copyright 2016-2025 Battelle Energy Alliance, LLC\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n\nfrom __future__ import unicode_literals, absolute_import\nimport os, json\nfrom client import BaseClient, INLClient\nfrom ci.tests import utils\nfrom ci import models","truncated":false,"loaded":[]},"title":"client/tests/utils.py","time":{"start":1776114430295,"end":1776114430298}}}]}
