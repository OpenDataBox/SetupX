{"type":"session_message","session_id":"ses_2775b4fbdffelnzkfcT80UULty","role":"assistant","message_id":"msg_d88ab54ce001p5tPWmKmvdCewa","parts":[{"id":"prt_d88ab5bb3001Fly73eZYLPr6Fm","messageID":"msg_d88ab54ce001p5tPWmKmvdCewa","sessionID":"ses_2775b4fbdffelnzkfcT80UULty","type":"tool","tool":"read","callID":"call_026f51f1f9714c12896b2190","state":{"status":"completed","input":{"filePath":"/workspace/client/tests/test_BaseClient.py"},"output":"<path>/workspace/client/tests/test_BaseClient.py</path>\n<type>file</type>\n<content>1: \n2: # Copyright 2016-2025 Battelle Energy Alliance, LLC\n3: #\n4: # Licensed under the Apache License, Version 2.0 (the \"License\");\n5: # you may not use this file except in compliance with the License.\n6: # You may obtain a copy of the License at\n7: #\n8: #     http://www.apache.org/licenses/LICENSE-2.0\n9: #\n10: # Unless required by applicable law or agreed to in writing, software\n11: # distributed under the License is distributed on an \"AS IS\" BASIS,\n12: # WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: # See the License for the specific language governing permissions and\n14: # limitations under the License.\n15: \n16: from __future__ import unicode_literals, absolute_import\n17: from django.test import SimpleTestCase\n18: from django.test import override_settings\n19: from client import BaseClient\n20: from client.tests import utils\n21: from ci.tests import utils as test_utils\n22: \n23: @override_settings(INSTALLED_GITSERVERS=[test_utils.github_config()])\n24: class Tests(SimpleTestCase):\n25:     def test_log_dir(self):\n26:         c = utils.create_base_client()\n27:         self.assertIn(c.client_info[\"client_name\"], c.client_info[\"log_file\"])\n28:         # dir exists but can't write\n29:         with self.assertRaises(BaseClient.ClientException):\n30:             c.set_log_dir(\"/var\")\n31: \n32:         # dir does not exist\n33:         with self.assertRaises(BaseClient.ClientException):\n34:             c.set_log_dir(\"/var/aafafafaf\")\n35: \n36:         # not set, should just return\n37:         c.set_log_dir(\"\")\n38: \n39:         # test it out from __init__\n40:         with self.assertRaises(BaseClient.ClientException):\n41:             c = utils.create_base_client(log_dir=\"/afafafafa/\")\n42: \n43:         # test it out from __init__\n44:         with self.assertRaises(BaseClient.ClientException):\n45:             c = utils.create_base_client(log_dir=\"\", log_file=\"\")\n46: \n47:     def test_log_file(self):\n48:         c = utils.create_base_client(log_file=\"test_log\")\n49:         self.assertIn('test_log', c.client_info[\"log_file\"])\n50: \n51:         # can't write\n52:         with self.assertRaises(BaseClient.ClientException):\n53:             c.set_log_file(\"/var/foo\")\n54: \n55:         # can't write\n56:         with self.assertRaises(BaseClient.ClientException):\n57:             c.set_log_file(\"/aafafafaf/fo\")\n58: \n59:         # not set, should just return\n60:         c.set_log_file(\"\")\n61: \n62:     def test_get_client_info(self):\n63:         c = utils.create_base_client()\n64: \n65:         with self.assertRaises(BaseClient.ClientException):\n66:             c.get_client_info('foo')\n67: \n68:         self.assertEqual(c.get_client_info('client_name'), c.client_info['client_name'])\n69: \n70:     def test_set_client_info(self):\n71:         c = utils.create_base_client()\n72: \n73:         with self.assertRaises(BaseClient.ClientException):\n74:             c.set_client_info('foo', None)\n75: \n76:         c.set_client_info('client_name', 'foo')\n77:         self.assertEqual(c.get_client_info('client_name'), 'foo')\n78: \n79:     def test_add_config(self):\n80:         with self.assertRaises(BaseClient.ClientException):\n81:             c = utils.create_base_client()\n82:             c.add_config(1)\n83:         with self.assertRaises(BaseClient.ClientException):\n84:             c = utils.create_base_client()\n85:             c.add_config('foo')\n86:             c.add_config('foo')\n87:         c = utils.create_base_client()\n88:         c.add_config('bar')\n89: \n90:     def test_environment(self):\n91:         c = utils.create_base_client()\n92:         self.assertNotIn('FOO', c.get_environment())\n93:         with self.assertRaises(BaseClient.ClientException):\n94:             c.get_environment('FOO')\n95:         c.set_environment('FOO', 'bar')\n96:         self.assertEqual('bar', c.get_environment('FOO'))\n97:         self.assertEqual(c.client_info['environment'], c.get_environment())\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"\n# Copyright 2016-2025 Battelle Energy Alliance, LLC\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n\nfrom __future__ import unicode_literals, absolute_import\nfrom django.test import SimpleTestCase\nfrom django.test import override_settings\nfrom client import BaseClient\nfrom client.tests import utils","truncated":false,"loaded":[]},"title":"client/tests/test_BaseClient.py","time":{"start":1776114425121,"end":1776114425131}}}]}
