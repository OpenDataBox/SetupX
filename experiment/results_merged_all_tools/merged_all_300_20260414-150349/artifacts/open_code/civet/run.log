{"type":"session_message","session_id":"ses_2775b4fbdffelnzkfcT80UULty","role":"assistant","message_id":"msg_d88ab5ded001xrkH080Oap3rCD","parts":[{"id":"prt_d88ab6579001gHp1kuz4UnjyaG","messageID":"msg_d88ab5ded001xrkH080Oap3rCD","sessionID":"ses_2775b4fbdffelnzkfcT80UULty","type":"tool","tool":"read","callID":"call_720356c0f4534965b49462a5","state":{"status":"completed","input":{"filePath":"/workspace/client/BaseClient.py"},"output":"<path>/workspace/client/BaseClient.py</path>\n<type>file</type>\n<content>1: \n2: # Copyright 2016-2025 Battelle Energy Alliance, LLC\n3: #\n4: # Licensed under the Apache License, Version 2.0 (the \"License\");\n5: # you may not use this file except in compliance with the License.\n6: # You may obtain a copy of the License at\n7: #\n8: #     http://www.apache.org/licenses/LICENSE-2.0\n9: #\n10: # Unless required by applicable law or agreed to in writing, software\n11: # distributed under the License is distributed on an \"AS IS\" BASIS,\n12: # WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: # See the License for the specific language governing permissions and\n14: # limitations under the License.\n15: \n16: from __future__ import unicode_literals, absolute_import\n17: import logging, logging.handlers\n18: from client.JobGetter import JobGetter\n19: from client.JobRunner import JobRunner\n20: from client.ServerUpdater import ServerUpdater\n21: from client.InterruptHandler import InterruptHandler\n22: import os, signal, sys\n23: import time\n24: import traceback\n25: from typing import Callable\n26: \n27: import logging\n28: logger = logging.getLogger(\"civet_client\")\n29: \n30: from threading import Thread\n31: try:\n32:     from queue import Queue\n33: except ImportError:\n34:     from Queue import Queue\n35: \n36: def has_handler(handler_type):\n37:     \"\"\"\n38:     Check to see if a handler is already installed.\n39:     Normally this isn't a problem but when running tests it might be.\n40:     \"\"\"\n41:     for h in logger.handlers:\n42:         # Use type instead of isinstance since the types have\n43:         # to match exactly\n44:         if type(h) == handler_type:\n45:             return True\n46:     return False\n47: \n48: def setup_logger(log_file=None):\n49:     \"\"\"\n50:     Setup the \"civet_client\" logger.\n51:     Input:\n52:       log_file: If not None then a RotatingFileHandler is installed. Otherwise a logger to console is used.\n53:     \"\"\"\n54:     formatter = logging.Formatter('%(asctime)-15s:%(levelname)s:%(message)s')\n55:     fhandler = None\n56:     if log_file:\n57:         if has_handler(logging.handlers.RotatingFileHandler):\n58:             return\n59:         fhandler = logging.handlers.RotatingFileHandler(log_file, maxBytes=1024*1024*5, backupCount=5)\n60:     else:\n61:         if has_handler(logging.StreamHandler):\n62:             return\n63:         fhandler = logging.StreamHandler()\n64: \n65:     fhandler.setFormatter(formatter)\n66:     logger.addHandler(fhandler)\n67:     logger.setLevel(logging.DEBUG)\n68: \n69: class ClientException(Exception):\n70:     pass\n71: \n72: class BaseClient(object):\n73:     \"\"\"\n74:     This is the job server client. It polls the server\n75:     for new jobs, requests one, and then runs it.\n76:     While running a job it reports back with output\n77:     from the job. During this operation the server\n78:     can respond with commands to the the client. Mainly\n79:     to cancel the job.\n80:     \"\"\"\n81:     def __init__(self, client_info):\n82:         self.client_info = client_info\n83:         self.command_q = Queue()\n84:         self.runner_error = False\n85:         self.runner_killed = False\n86:         self.thread_join_wait = 2*60*60 # 2 hours\n87: \n88:         if self.client_info[\"log_file\"]:\n89:             self.set_log_file(self.client_info[\"log_file\"])\n90:         elif self.client_info[\"log_dir\"]:\n91:             self.set_log_dir(self.client_info[\"log_dir\"])\n92:         else:\n93:             raise ClientException(\"log file not set\")\n94: \n95:         setup_logger(self.client_info[\"log_file\"])\n96: \n97:         try:\n98:             self.cancel_signal = InterruptHandler(self.command_q, sig=[signal.SIGUSR1, signal.SIGINT])\n99:             self.graceful_signal = InterruptHandler(self.command_q, sig=[signal.SIGUSR2])\n100:         except:\n101:             # On Windows, SIGUSR1, SIGUSR2 are not defined. Signals don't\n102:             # work in general so this is the easiest way to disable\n103:             # them but leave all the code in place.\n104:             self.cancel_signal = InterruptHandler(self.command_q, sig=[])\n105:             self.graceful_signal = InterruptHandler(self.command_q, sig=[])\n106: \n107:         if self.client_info[\"ssl_cert\"]:\n108:             self.client_info[\"ssl_verify\"] = self.client_info[\"ssl_cert\"]\n109: \n110:         self.client_info[\"build_configs\"] = []\n111:         self.client_info['environment'] = {}\n112: \n113:         if 'client_name' in self.client_info:\n114:             self.set_environment('CIVET_CLIENT_NAME', self.client_info['client_name'])\n115: \n116:         # Entry point for running something before each runner step;\n117:         # would be a function that takes an env (the step env) and returns\n118:         # False it it failed\n119:         self._runner_pre_step: Callable[[dict | None], bool] = None\n120:         # Entry point for running something after each runner step;\n121:         # would be a function that takes an env (the step env) and returns\n122:         # False it it failed\n123:         self._runner_post_step: Callable[[dict | None], bool] = None\n124: \n125:     def get_client_info(self, key):\n126:         \"\"\"\n127:         Returns:\n128:           The client information associated with the given key.\n129:         Raises:\n130:           ClientException: If client info is not found with the given key.\n131:         \"\"\"\n132:         if key not in self.client_info:\n133:             raise ClientException('Client info with key {} does not exist'.format(key))\n134:         return self.client_info[key]\n135: \n136:     def set_client_info(self, key, value):\n137:         \"\"\"\n138:         Sets the client info with the given key to the given value.\n139:         \"\"\"\n140:         self.get_client_info(key) # Check for existance\n141:         self.client_info[key] = value\n142: \n143:     def set_log_dir(self, log_dir):\n144:         \"\"\"\n145:         Sets the log dir. If log_dir is set\n146:         the log file name will have a set name of \"civet_client_<name>_<pid>.log\"\n147:         raises Exception if the directory doesn't exist or isn't writable.\n148:         \"\"\"\n149:         if not log_dir:\n150:             return\n151: \n152:         log_dir = os.path.abspath(log_dir)\n153:         self.check_log_dir(log_dir)\n154:         self.client_info[\"log_file\"] = \"%s/civet_client_%s.log\" % (log_dir, self.client_info[\"client_name\"])\n155: \n156:     def check_log_dir(self, log_dir):\n157:         \"\"\"\n158:         Makes sure the log directory exists and is writable\n159:         Input:\n160:           log_dir: The directory to check if we can write a log file\n161:         Raises:\n162:           ClientException if unable to write\n163:         \"\"\"\n164:         if not os.path.isdir(log_dir):\n165:             raise ClientException('Log directory (%s) does not exist!' % log_dir)\n166: \n167:         if not os.access(log_dir, os.W_OK):\n168:             raise ClientException('Log directory (%s) is not writeable!' % log_dir)\n169: \n170:     def set_log_file(self, log_file):\n171:         \"\"\"\n172:         Specify a log file to use.\n173:         Input:\n174:           log_file: The log file to write to\n175:         Raises:\n176:           ClientException if we can't write to the file\n177:         \"\"\"\n178:         if not log_file:\n179:             return\n180: \n181:         log_file = os.path.abspath(log_file)\n182: \n183:         log_dir = os.path.dirname(log_file)\n184:         self.check_log_dir(log_dir)\n185:         self.client_info[\"log_file\"] = log_file\n186: \n187:     def add_config(self, config):\n188:         if not isinstance(config, str):\n189:             raise ClientException('config must be a str')\n190:         if config in self.get_client_info('build_configs'):\n191:             raise ClientException('config {} already exists'.format(config))\n192:         self.client_info['build_configs'].append(config)\n193: \n194:     def get_environment(self, var=None):\n195:         \"\"\"\n196:         Gets the additional environment variables that were set\n197:         for the client via set_environment.\n198:         Input:\n199:           var: The environment variable to get, if not provided, returns the whole environment dict\n200:         Raises:\n201:           ClientException if var is provided and the variable is not in the environment dict\n202:         \"\"\"\n203:         if var:\n204:             if str(var) not in self.get_client_info('environment'):\n205:                 raise ClientException('Variable {} is not in the client environment'.format(var))\n206:             return self.get_client_info('environment')[str(var)]\n207:         return self.get_client_info('environment')\n208: \n209:     def set_environment(self, var, value):\n210:         \"\"\"\n211:         Sets an environment variable to be set when this client\n212:         executes a job.\n213:         Input:\n214:           var: The environment variable\n215:           value: The environment variable value\n216:         \"\"\"\n217:         environment = self.get_client_info('environment')\n218:         environment[str(var)] = str(value)\n219:         self.set_client_info('environment', environment)\n220: \n221:     def run_claimed_job(self, server, servers, claimed, fail: bool = False):\n222:         job_info = claimed[\"job_info\"]\n223:         job_id = job_info[\"job_id\"]\n224:         build_key = claimed[\"build_key\"]\n225:         message_q = Queue()\n226:         runner = JobRunner(self.client_info, job_info, message_q, self.command_q, build_key,\n227:                            pre_step=self._runner_pre_step, post_step=self._runner_post_step)\n228:         self.cancel_signal.set_message({\"job_id\": job_id, \"command\": \"cancel\"})\n229: \n230:         control_q = Queue()\n231:         updater = ServerUpdater(server, self.client_info, message_q, self.command_q, control_q)\n232:         for entry in servers:\n233:             if entry != server:\n234:                 control_q.put({\"server\": entry, \"message\": \"Running job on another server\"})\n235:             else:\n236:                 control_q.put({\"server\": entry, \"message\": \"Job {}: {}\".format(job_id, job_info[\"recipe_name\"])})\n237: \n238:         updater_thread = Thread(target=ServerUpdater.run, args=(updater,))\n239:         updater_thread.start()\n240:         runner.run_job(fail=fail)\n241:         if not runner.stopped and not runner.canceled:\n242:             logger.info(\"Joining message_q\")\n243:             message_q.join()\n244:         control_q.put({\"command\": \"Quit\"}) # Any command will stop the ServerUpdater\n245: \n246:         # We want to wait for a little while here, if necessary.\n247:         # It could be that the server is temporarily down and if\n248:         # we just wait long enough for it to come back we can finish cleanly.\n249:         # However, we don't want to hang forever.\n250:         logger.info(\"Joining ServerUpdater\")\n251:         updater_thread.join(self.thread_join_wait)\n252:         # python >= 3.9 changed Thread.isAlive() -> thread.is_alive()\n253:         old_is_alive = sys.version_info[0] == 3 and sys.version_info[1] < 9\n254:         if updater_thread.isAlive() if old_is_alive else updater_thread.is_alive():\n255:             logger.warning(\"Failed to join ServerUpdater thread. Job {}: '{}' not updated correctly\".format(\n256:                 job_id, job_info[\"recipe_name\"]))\n257:         self.command_q.queue.clear()\n258:         self.runner_error = runner.error\n259:         self.runner_killed = runner.job_killed\n260: \n261:     def run(self):\n262:         \"\"\"\n263:         Main client loop. Polls the server for jobs and runs them.\n264:         \"\"\"\n265: \n266:         while True:\n267:             do_poll = True\n268:             try:\n269:                 getter = JobGetter(self.client_info)\n270:                 claimed = getter.get_job()\n271:                 if claimed:\n272:                     server = self.get_client_info('server')\n273:                     self.run_claimed_job(server, [server], claimed)\n274:                     # finished the job, look for a new one immediately\n275:                     do_poll = False\n276:             except Exception:\n277:                 logger.warning(\"Error: %s\" % traceback.format_exc())\n278: \n279:             if self.cancel_signal.triggered or self.graceful_signal.triggered:\n280:                 logger.info(\"Received signal...exiting\")\n281:                 break\n282: \n283:             if self.runner_error:\n284:                 logger.info(\"Error occurred in runner...exiting\")\n285:                 break\n286: \n287:             if self.client_info[\"single_shot\"]:\n288:                 break\n289: \n290:             if do_poll:\n291:                 time.sleep(self.get_client_info('poll'))\n\n(End of file - total 291 lines)\n</content>","metadata":{"preview":"\n# Copyright 2016-2025 Battelle Energy Alliance, LLC\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n\nfrom __future__ import unicode_literals, absolute_import\nimport logging, logging.handlers\nfrom client.JobGetter import JobGetter\nfrom client.JobRunner import JobRunner\nfrom client.ServerUpdater import ServerUpdater","truncated":false,"loaded":[]},"title":"client/BaseClient.py","time":{"start":1776114427595,"end":1776114427603}}}]}
