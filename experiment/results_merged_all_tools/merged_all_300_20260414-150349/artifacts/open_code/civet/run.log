rs.request',\n93:                 'django.contrib.auth.context_processors.auth',\n94:                 'django.contrib.messages.context_processors.messages',\n95:             ],\n96:         },\n97:     },\n98: ]\n99: \n100: WSGI_APPLICATION = 'civet.wsgi.application'\n101: \n102: \n103: # Database\n104: # https://docs.djangoproject.com/en/1.8/ref/settings/#databases\n105: \n106: # Database used while testing. Just a sqlite DB.\n107: testing_database = {'ENGINE': 'django.db.backends.sqlite3',\n108:         'NAME': os.path.join(BASE_DIR, 'db.sqlite3'),\n109:         }\n110: # PostgreSql configuration\n111: postgresql_database = {'ENGINE': 'django.db.backends.postgresql_psycopg2',\n112:         'NAME': '<db_name>',\n113:         'USER': '<db_username>',\n114:         'PASSWORD': '<password>',\n115:         'HOST': 'localhost',\n116:         'PORT': '',\n117:         'CONN_MAX_AGE': 60,\n118:         }\n119: \n120: DATABASES = {'default': testing_database}\n121: \n122: # Set a database field default (required as of 3.2, or you will start to see warnings)\n123: DEFAULT_AUTO_FIELD = 'django.db.models.AutoField'\n124: \n125: # Internationalization\n126: # https://docs.djangoproject.com/en/1.8/topics/i18n/\n127: \n128: LANGUAGE_CODE = 'en-us'\n129: \n130: TIME_ZONE = 'UTC'\n131: \n132: USE_I18N = True\n133: \n134: USE_L10N = True\n135: \n136: USE_TZ = True\n137: en_formats.DATETIME_FORMAT = 'H:i:s m/d/y e'\n138: \n139: \n140: # Static files (CSS, JavaScript, Images)\n141: # https://docs.djangoproject.com/en/1.8/howto/static-files/\n142: \n143: STATIC_URL = '/static/'\n144: \n145: # directory where all the static files go when\n146: # calling ./manage.py collectstatic\n147: STATIC_ROOT = os.path.join(BASE_DIR, 'static')\n148: \n149: #DEFAULT_AUTHENTICATION_CLASSES = ( 'rest_framework.authentication.OAuth2Authentication',)\n150: \n151: DEFAULT_LOG_LEVEL = \"INFO\"\n152: \n153: rotating_file_handler = {\n154:         'level': DEFAULT_LOG_LEVEL,\n155:         'class': 'logging.handlers.RotatingFileHandler',\n156:         'filename': 'civet.log',\n157:         'maxBytes': 1024*1024*20, # 20M\n158:         'backupCount': 5,\n159:         'formatter': 'simple',\n160:     }\n161: \n162: default_file_handler = {\n163:         'level': DEFAULT_LOG_LEVEL,\n164:         'class': 'logging.FileHandler',\n165:         'filename': 'civet.log',\n166:         'formatter': 'simple',\n167:     }\n168: \n169: LOGGING = {\n170:     'version': 1,\n171:     'disable_existing_loggers': False,\n172:     'formatters': {\n173:         'simple': {\n174:             'format': '%(asctime)s:%(levelname)s:%(message)s',\n175:             'datefmt': \"%Y-%m-%d %H:%M:%S\",\n176:         },\n177:         'verbose': {\n178:             'format': '%(levelname)s %(asctime)s %(module)s %(process)d %(thread)d %(message)s',\n179:             'datefmt': \"%Y-%m-%d %H:%M:%S\",\n180:         },\n181:         'django.server': {\n182:             '()': 'django.utils.log.ServerFormatter',\n183:             'format': '[%(server_time)s] %(message)s',\n184:         },\n185:     },\n186:     'handlers': {\n187:         'file': default_file_handler,\n188:         'console': {\n189:             'level': DEFAULT_LOG_LEVEL,\n190:             'class':'logging.StreamHandler',\n191:             'formatter': 'simple',\n192:         },\n193:         'django.server': {\n194:             'level': DEFAULT_LOG_LEVEL,\n195:             'class': 'logging.StreamHandler',\n196:             'formatter': 'django.server',\n197:         },\n198:     },\n199:     'loggers': {\n200:         'django.request': {\n201:             'handlers': ['console', 'file'],\n202:             'level': DEFAULT_LOG_LEVEL,\n203:             'propagate': True,\n204:         },\n205:         'django': {\n206:             'handlers':['console', 'file'],\n207:             'propagate': True,\n208:             'level': DEFAULT_LOG_LEVEL,\n209:         },\n210:         'ci': {\n211:             'handlers':['console', 'file'],\n212:             'propagate': True,\n213:             'level': DEFAULT_LOG_LEVEL,\n214:         },\n215:         'django.server': {\n216:             'handlers': ['django.server'],\n217:             'level': DEFAULT_LOG_LEVEL,\n218:             'propagate': False,\n219:         },\n220:     },\n221: }\n222: \n223: #SECURE_CONTENT_TYPE_NOSNIFF=True\n224: #SECURE_BROWSER_XSS_FILTER=True\n225: #SECURE_SSL_REDIRECT=True\n226: #SESSION_COOKIE_SECURE=True\n227: #CSRF_COOKIE_SECURE=True\n228: #CSRF_COOKIE_HTTPONLY=True\n229: #X_FRAME_OPTIONS='DENY'\n230: #SECURE_HSTS_SECONDS=\n231: \n232: # location of the recipes directory, relative to the base project directory\n233: RECIPE_BASE_DIR = os.path.join(os.path.dirname(BASE_DIR), 'civet_recipes')\n234: \n235: # all the git servers that we support\n236: GITSERVER_GITHUB = 0\n237: GITSERVER_GITLAB = 1\n238: GITSERVER_BITBUCKET = 2\n239: \n240: # Instead of checking the Git server each time for permissions\n241: # (member of a team, repo visibility, etc), we cache the results\n242: # for this amount of time. Once this has expired then we\n243: # recheck.\n244: PERMISSION_CACHE_TIMEOUT = 60*60\n245: \n246: # The absolute url for the server. This is used\n247: # in places where we need to send links to outside\n248: # sources that will point to the server and we\n249: # don't have access to a HttpRequest object.\n250: ABSOLUTE_BASE_URL = \"https://localhost\"\n251: \n252: # Interval (in milliseconds) in which the browser will do an AJAX call to update.\n253: # Put here so that we can dynamically change these while testing\n254: HOME_PAGE_UPDATE_INTERVAL = 20000\n255: JOB_PAGE_UPDATE_INTERVAL = 20000\n256: EVENT_PAGE_UPDATE_INTERVAL = 20000\n257: \n258: # Internal (in milliseconds) at which to rebuild the cache for available jobs\n259: # 0 means to always update\n260: GET_JOB_UPDATE_INTERVAL = 0\n261: \n262: # This allows for cross origin resource sharing.\n263: # Mainly so that mooseframework.org can have access\n264: # to the mooseframework view.\n265: CORS_ORIGIN_ALLOW_ALL = False\n266: CORS_ORIGIN_WHITELIST = (\n267:     'https://www.mooseframework.org',\n268:     'https://mooseframework.org',\n269:   )\n270: CORS_ALLOW_METHODS = (\n271:     'GET',\n272:   )\n273: \n274: \"\"\"\n275: See the wiki for available options with descriptions and examples.\n276: https://github.com/idaholab/civet/wiki/Settings\n277: \"\"\"\n278: \n279: # Set a default (required as of 3.2, or you will start to see warnings)\n280: # TODO: Understand what it is this actual does, and if its safe for us to use\n281: DEFAULT_AUTO_FIELD = 'django.db.models.AutoField'\n282: \n283: github_repo_settings = {\n284:         \"idaholab/moose\":\n285:             {\n286:                 \"failed_but_allowed_label_name\": \"PR: Failed but allowed\",\n287:                 \"recipe_label_activation\": {\n288:                     \"MOOSE_DOCUMENTATION\": \"^docs/|python/MooseDocs/\",\n289:                     \"MOOSE_TUTORIAL\": \"^tutorials/\",\n290:                     \"MOOSE_EXAMPLES\": \"^examples/\",\n291:                     \"MOOSE_PYTHON\": \"^python/chigger/|python/peacock/|python/mooseutils/\",\n292:                 },\n293:                 \"recipe_label_activation_additive\": {},\n294:                 \"branch_settings\": {\n295:                     \"devel\": {\n296:                         \"auto_cancel_push_events_except_current\": True,\n297:                         \"auto_uncancel_previous_event\": True,\n298:                     },\n299:                     \"next\": {\n300:                         \"auto_cancel_push_events_except_current\": True,\n301:                         \"auto_uncancel_previous_event\": True,\n302:                     },\n303:                 },\n304:                 \"auto_merge_require_review\": True,\n305:                 \"auto_merge_label\": \"PR: Auto Merge\",\n306:                 \"auto_merge_enabled\": False,\n307:                 \"badges\": [{\n308:                     \"recipe\": \"recipes/moosebuild/moose/Test_deprecated.cfg\",\n309:                     \"name\": \"deprecated\",\n310:                     }]\n311:             },\n312:         }\n313: \n314: github_config = {\"type\": GITSERVER_GITHUB,\n315:         \"api_url\": \"https://api.github.com\",\n316:         \"html_url\": \"https://github.com\",\n317:         \"hostname\": \"github.com\",\n318:         \"secret_id\": \"<secret_id>\",\n319:         \"client_id\": \"<client_id>\",\n320:         \"post_event_summary\": False,\n321:         \"post_job_status\": False,\n322:         \"remote_update\": False,\n323:         \"install_webhook\": False,\n324:         \"remove_pr_label_prefix\": [\"PR: [TODO]\",],\n325:         \"pr_wip_prefix\": [\"WIP:\", \"[WIP]\"],\n326:         \"failed_but_allowed_label_name\": None,\n327:         \"recipe_label_activation\": {},\n328:         \"recipe_label_activation_additive\": {},\n329:         \"authorized_users\": ['idaholab'],\n330:         \"request_timeout\": 5,\n331:         \"icon_class\": \"fa fa-github fa-lg\",\n332:         \"civet_base_url\": ABSOLUTE_BASE_URL,\n333:         \"repository_settings\": github_repo_settings,\n334:         \"login_label\": \"External Login\" #modify this to change the text on the login button\n335:     }\n336: \n337: gitlab_config = {\"type\": GITSERVER_GITLAB,\n338:         \"api_url\": \"http://<API_HOSTNAME>\",\n339:         \"html_url\": \"http://<API_HOSTNAME>\",\n340:         \"hostname\": \"<hostname>\",\n341:         \"secret_id\": \"<secret_id>\",\n342:         \"client_id\": \"<client_id>\",\n343:         \"ssl_cert\": False,\n344:         \"post_event_summary\": False,\n345:         \"post_job_status\": False,\n346:         \"remote_update\": False,\n347:         \"install_webhook\": False,\n348:         \"pr_wip_prefix\": [\"WIP:\", \"[WIP]\"],\n349:         \"failed_but_allowed_label_name\": None,\n350:         \"recipe_label_activation\": {},\n351:         \"recipe_label_activation_additive\": {},\