{"type":"session_message","session_id":"ses_2880a7b4dffefwsIe7Zm13KuUr","role":"assistant","message_id":"msg_d77f5985e001OfmInG5gvMM7qV","parts":[{"id":"prt_d77f5a66c001YzmqGH0wrYvOHS","messageID":"msg_d77f5985e001OfmInG5gvMM7qV","sessionID":"ses_2880a7b4dffefwsIe7Zm13KuUr","type":"tool","tool":"read","callID":"call_3053fe8fefc74fb9b2aa0170","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: requires = [\"setuptools>=62.3\"]\n3: build-backend = \"setuptools.build_meta\"\n4: \n5: [project]\n6: name = \"xknx\"\n7: authors = [\n8:   { name = \"Julius Mittenzwei\", email = \"julius@mittenzwei.com\" },\n9:   { name = \"Matthias Alphart\", email = \"farmio@alphart.net\" },\n10:   { name = \"Marvin Wichmann\", email = \"me@marvin-wichmann.de\" },\n11: ]\n12: classifiers = [\n13:   \"Development Status :: 5 - Production/Stable\",\n14:   \"Intended Audience :: Developers\",\n15:   \"Programming Language :: Python :: 3\",\n16:   \"Topic :: Home Automation\",\n17:   \"Topic :: System :: Hardware :: Hardware Drivers\",\n18: ]\n19: dependencies = [\n20:   \"async_timeout>=4.0.0; python_version<'3.11'\",\n21:   \"typing_extensions; python_version<'3.11'\",\n22:   \"cryptography>=35.0.0\",\n23:   \"ifaddr>=0.1.7\",\n24: ]\n25: description = \"An Asynchronous Library for the KNX protocol. Documentation: https://xknx.io/\"\n26: dynamic = [\"version\"]\n27: keywords = [\"KNX\", \"EIB\", \"Home Assistant\", \"home automation\"]\n28: license = \"MIT\"\n29: readme = \"README.md\"\n30: requires-python = \">=3.10.0\"\n31: \n32: [project.urls]\n33: homepage = \"https://xknx.io/\"\n34: repository = \"https://github.com/XKNX/xknx.git\"\n35: \n36: \n37: [tool.setuptools.dynamic]\n38: version = { attr = \"xknx.__version__.__version__\" }\n39: \n40: [tool.setuptools.packages.find]\n41: include = [\"xknx*\"]\n42: \n43: [tool.codespell]\n44: skip = '*.min.js,docs/config-converter/lib/*,*.lock'\n45: ignore-words-list = 'hass'\n46: quiet-level = 2\n47: \n48: \n49: [tool.mypy]\n50: pretty = true\n51: python_version = \"3.10\"\n52: show_error_codes = true\n53: strict = true\n54: # additional flags to strict mode\n55: ignore_missing_imports = true\n56: implicit_reexport = true\n57: warn_unreachable = true\n58: \n59: \n60: [tool.pylint.master]\n61: init-hook = 'import sys; sys.path.append(\".\")'\n62: persistent = \"no\"\n63: reports = \"no\"\n64: allow-reexport-from-package = true\n65: jobs = 0\n66: \n67: [tool.pylint.message_control]\n68: # Reasons disabled:\n69: # too-many-* - are not enforced for the sake of readability\n70: # too-few-* - same as too-many-*\n71: disable = [\n72:   \"declare-non-slot\",               # pylint doesn't account for inherited slots with class based type annotations - mypy should handle it\n73:   \"cyclic-import\",                  # doesn't test if both import on load\n74:   \"duplicate-code\",                 # unavoidable\n75:   \"fixme\",                          # TODO\n76:   \"format\",                         # handled by ruff\n77:   \"inconsistent-return-statements\", # doesn't handle raise\n78:   \"locally-disabled\",               # it spams too much\n79:   \"no-member\",                      # handled by mypy - pylint has false positives sometimes\n80:   \"too-few-public-methods\",\n81:   \"too-many-ancestors\",             # it's too strict.\n82:   \"too-many-arguments\",\n83:   \"too-many-boolean-expressions\",\n84:   \"too-many-branches\",\n85:   \"too-many-instance-attributes\",\n86:   \"too-many-lines\",\n87:   \"too-many-locals\",\n88:   \"too-many-positional-arguments\",\n89:   \"too-many-public-methods\",\n90:   \"too-many-return-statements\",\n91:   \"too-many-statements\",\n92:   \"ungrouped-imports\",              # handled by ruff\n93:   \"unused-argument\",                # generic callbacks and setup methods create a lot of warnings\n94:   \"wrong-import-order\",             # handled by ruff\n95: ]\n96: # disabled for tests via command line options in tox.ini:\n97: #   - protected-access\n98: #   - abstract-class-instantiated\n99: enable = [\"use-symbolic-message-instead\"]\n100: \n101: [tool.pylint.format]\n102: expected-line-ending-format = \"LF\"\n103: \n104: [tool.pylint.reports]\n105: score = \"no\"\n106: output-format = \"colorized\"\n107: \n108: \n109: [tool.pytest]\n110: addopts = [\"--durations=10\"]\n111: testpaths = [\"test\"]\n112: # pytest-asyncio settings\n113: asyncio_mode = \"auto\"\n114: asyncio_default_fixture_loop_scope = \"function\"\n115: \n116: \n117: [tool.ruff]\n118: lint.select = [\n119:   \"A\",     # builtins shadowing\n120:   \"ANN\",   # annotations\n121:   \"ASYNC\", # async\n122:   \"B\",     # bugbear\n123:   \"C4\",    # comprehensions\n124:   \"D\",     # pydocstyle\n125:   \"E\",     # pycodestyle\n126:   \"F\",     # pyflakes\n127:   \"FLY\",   # flynt\n128:   \"FURB\",  # refurb\n129:   \"G\",     # logging\n130:   \"I\",     # isort\n131:   \"LOG\",   # logging\n132:   \"PTH\",   # pathlib\n133:   \"RUF\",   # ruff specific\n134:   \"SLF\",   # private member access\n135:   \"SIM\",   # simplify\n136:   \"T20\",   # print\n137:   \"UP\",    # pyupgrade\n138:   \"W\",     # pydocstyle warning\n139: ]\n140: lint.ignore = [\n141:   \"ANN401\", # any-type - mypy should handle this where necessary\n142:   \"D202\",\n143:   \"D203\",\n144:   \"D212\",\n145:   \"E501\",   # line too long\n146:   \"SIM102\", # collapsible-if\n147:   \"SIM105\", #suppressible-exception\n148: ]\n149: extend-exclude = [\"script\"]\n150: \n151: [tool.ruff.lint.isort]\n152: force-sort-within-sections = true\n153: combine-as-imports = true\n154: \n155: [tool.ruff.lint.per-file-ignores]\n156: \"examples/*\" = [\"T20\"] # print-used\n157: \"test/*\" = [\n158:   \"RUF012\",\n159:   \"SLF\",    # private member access\n160: ] # Mutable class attributes should be annotated with `typing.ClassVar`\n161: \n162: [tool.ruff.lint.flake8-builtins]\n163: builtins-allowed-modules = [\n164:   # been there before ruff check A005 was added - backwards compatibility\n165:   \"datetime\",\n166:   \"io\",\n167:   \"profile\",\n168:   \"typing\",\n169: ]\n\n(End of file - total 169 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=62.3\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"xknx\"\nauthors = [\n  { name = \"Julius Mittenzwei\", email = \"julius@mittenzwei.com\" },\n  { name = \"Matthias Alphart\", email = \"farmio@alphart.net\" },\n  { name = \"Marvin Wichmann\", email = \"me@marvin-wichmann.de\" },\n]\nclassifiers = [\n  \"Development Status :: 5 - Production/Stable\",\n  \"Intended Audience :: Developers\",\n  \"Programming Language :: Python :: 3\",\n  \"Topic :: Home Automation\",\n  \"Topic :: System :: Hardware :: Hardware Drivers\",\n]\ndependencies = [\n  \"async_timeout>=4.0.0; python_version<'3.11'\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775834081164,"end":1775834081167}}}]}
