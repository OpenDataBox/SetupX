{"type":"session_message","session_id":"ses_2788be2d5ffe53nFnIn5eNbziE","role":"assistant","message_id":"msg_d877431e9001d9Kvr6PUMGHCaz","parts":[{"id":"prt_d87743c2f001chnvWHIPvdxNdA","messageID":"msg_d877431e9001d9Kvr6PUMGHCaz","sessionID":"ses_2788be2d5ffe53nFnIn5eNbziE","type":"tool","tool":"read","callID":"call_cbfcc6477a0e47b4ac79c5e8","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [project]\n2: name = \"mopidy\"\n3: description = \"Mopidy is an extensible music server written in Python\"\n4: readme = \"README.rst\"\n5: requires-python = \">= 3.13\"\n6: license = { text = \"Apache-2.0\" }\n7: authors = [{ name = \"Stein Magnus Jodal\", email = \"stein.magnus@jodal.no\" }]\n8: classifiers = [\n9:     \"Development Status :: 5 - Production/Stable\",\n10:     \"Environment :: No Input/Output (Daemon)\",\n11:     \"Intended Audience :: End Users/Desktop\",\n12:     \"License :: OSI Approved :: Apache Software License\",\n13:     \"Operating System :: OS Independent\",\n14:     \"Topic :: Multimedia :: Sound/Audio :: Players\",\n15: ]\n16: dynamic = [\"version\"]\n17: dependencies = [\n18:     \"cyclopts >= 3.12\",\n19:     \"httpx >= 0.28.1\",\n20:     \"platformdirs >= 4.3\",\n21:     \"pydantic >= 2.10\",\n22:     \"pygobject >= 3.50\",\n23:     \"pykka >= 4.1\",\n24:     \"rich >= 13.9\",\n25:     \"tornado >= 6.4\",\n26: ]\n27: \n28: [project.urls]\n29: Homepage = \"https://mopidy.com/\"\n30: Documentation = \"https://docs.mopidy.com/\"\n31: \"Discourse forum\" = \"https://discourse.mopidy.com/\"\n32: \"Zulip chat\" = \"https://mopidy.zulipchat.com/\"\n33: Source = \"https://github.com/mopidy/mopidy\"\n34: Issues = \"https://github.com/mopidy/mopidy/issues\"\n35: \n36: [project.scripts]\n37: mopidy = \"mopidy._app.cli:app.meta\"\n38: \n39: [project.entry-points.\"mopidy.ext\"]\n40: file = \"mopidy._exts.file:Extension\"\n41: http = \"mopidy._exts.http:Extension\"\n42: m3u = \"mopidy._exts.m3u:Extension\"\n43: softwaremixer = \"mopidy._exts.softwaremixer:Extension\"\n44: stream = \"mopidy._exts.stream:Extension\"\n45: \n46: \n47: [build-system]\n48: requires = [\"setuptools >= 78\", \"setuptools-scm >= 8.2\"]\n49: build-backend = \"setuptools.build_meta\"\n50: \n51: \n52: [dependency-groups]\n53: dev = [\n54:     \"tox >= 4.25\",\n55:     { include-group = \"docs\" },\n56:     { include-group = \"rumdl\" },\n57:     { include-group = \"ruff\" },\n58:     { include-group = \"tests\" },\n59:     { include-group = \"typing\" },\n60: ]\n61: docs = [\n62:     \"mkdocstrings-python>=2.0.3\",\n63:     \"zensical>=0.0.24\",\n64: ]\n65: rumdl = [\"rumdl\"]\n66: ruff = [\"ruff == 0.15.0\"]\n67: tests = [\n68:     \"dirty-equals >= 0.9\",\n69:     \"polyfactory >= 3.1\",\n70:     \"pytest >= 8.3\",\n71:     \"pytest-cov >= 5.0\",\n72:     \"pytest-httpx >= 0.35\",\n73:     \"pytest-mock >= 3.14\",\n74: ]\n75: typing = [\n76:     \"pygobject-stubs >= 2.14.0, != 2.15.0\",\n77:     \"pyright == 1.1.408\",\n78:     \"ty == 0.0.14\",\n79: ]\n80: \n81: \n82: [tool.coverage.paths]\n83: source = [\"src/\", \"*/site-packages/\"]\n84: \n85: [tool.coverage.run]\n86: source_pkgs = [\"mopidy\"]\n87: \n88: [tool.coverage.report]\n89: show_missing = true\n90: exclude_also = ['if TYPE_CHECKING:', 'raise NotImplementedError']\n91: \n92: \n93: [tool.pyright]\n94: pythonVersion = \"3.13\"\n95: # Use venv from parent directory, to share it with any extensions:\n96: venvPath = \"../\"\n97: venv = \".venv\"\n98: typeCheckingMode = \"standard\"\n99: # Not all dependencies have type hints:\n100: reportMissingTypeStubs = false\n101: # Already covered by flake8-self:\n102: reportPrivateImportUsage = false\n103: \n104: \n105: [tool.pytest.ini_options]\n106: filterwarnings = [\n107:     \"error::DeprecationWarning:mopidy[.*]\",\n108:     \"ignore::PendingDeprecationWarning:mopidy[.*]\",\n109:     \"ignore::DeprecationWarning:mopidy[.*]\",\n110: ]\n111: \n112: \n113: [tool.ruff]\n114: target-version = \"py313\"\n115: \n116: [tool.ruff.lint]\n117: select = [\"ALL\"]\n118: ignore = [\n119:     \"A002\",    # builtin-argument-shadowing  # TODO\n120:     \"A003\",    # builtin-attribute-shadowing\n121:     \"A005\",    # stdlib-module-shadowing\n122:     \"ANN401\",  # any-type\n123:     \"D100\",    # undocumented-public-module  # TODO\n124:     \"D101\",    # undocumented-public-class  # TODO\n125:     \"D102\",    # undocumented-public-method  # TODO\n126:     \"D103\",    # undocumented-public-function  # TODO\n127:     \"D104\",    # undocumented-public-package  # TODO\n128:     \"D105\",    # undocumented-magic-method\n129:     \"D107\",    # undocumented-public-init  # TODO\n130:     \"FBT001\",  # boolean-positional-arg-in-function-definition  # TODO\n131:     \"FBT002\",  # boolean-default-value-in-function-definition  # TODO\n132:     \"FBT003\",  # boolean-positional-value-in-function-call  # TODO\n133:     \"FIX002\",  # line-contains-todo\n134:     \"FIX003\",  # line-contains-fixme\n135:     \"FIX004\",  # line-contains-hack\n136:     \"G004\",    # logging-f-string\n137:     \"PLR2004\", # magic-value-comparison\n138:     \"PLW2901\", # redefined-loop-name\n139:     \"RET504\",  # unnecessary-assign\n140:     \"S101\",    # assert  # TODO\n141:     \"S314\",    # suspicious-xml-element-tree-usage -- ElementTree is safe given expat >= 2.6.1\n142:     \"SLF001\",  # private-member-access  # TODO\n143:     \"TD002\",   # missing-todo-author\n144:     \"TD003\",   # missing-todo-link\n145:     \"TC003\",   # typing-only-standard-library-import\n146:     \"TC006\",   # runtime-cast-value\n147:     \"TRY003\",  # raise-vanilla-args\n148:     \"TRY400\",  # error-instead-of-exception\n149:     #\n150:     # Conflicting with `ruff format`\n151:     \"COM812\", # missing-trailing-comma\n152:     \"ISC001\", # single-line-implicit-string-concatenation\n153: ]\n154: \n155: [tool.ruff.lint.per-file-ignores]\n156: \"tests/*\" = [\n157:     \"ANN\",     # flake8-annotations\n158:     \"ARG\",     # flake8-unused-arguments\n159:     \"D\",       # pydocstyle\n160:     \"FBT\",     # flake8-boolean-trap\n161:     \"PLR0913\", # too-many-arguments\n162:     \"PT007\",   # pytest-parametrize-values-wrong-type  # TODO\n163:     \"PT009\",   # pytest-unittest-assertion  # TODO\n164:     \"PT011\",   # pytest-raises-too-broad  # TODO\n165:     \"S101\",    # assert\n166:     \"S108\",    # hardcoded-temp-file\n167:     \"SLF001\",  # private-member-access\n168:     \"TRY002\",  # raise-vanilla-class\n169: ]\n170: \n171: [tool.ruff.lint.pydocstyle]\n172: convention = \"google\"\n173: \n174: \n175: [tool.rumdl.global]\n176: flavor = \"mkdocs\"\n177: disable = [\n178:     \"MD013\",  # Line length too strict for docs with long URLs\n179:     \"MD014\",  # Dollar signs before commands without output is common in docs\n180:     \"MD036\",  # Bold text used legitimately as labels within list items\n181:     \"MD051\",  # False positives on cross-page fragment links\n182: ]\n183: \n184: \n185: [tool.setuptools.package-data]\n186: \"*\" = [\"*.conf\"]\n187: \"mopidy.http.data\" = [\"*\"]\n188: \n189: \n190: [tool.setuptools_scm]\n191: \n192: \n193: [tool.tox]\n194: env_list = [\n195:     \"3.13\",\n196:     \"3.14\",\n197:     \"pyright\",\n198:     \"rumdl\",\n199:     \"ruff-check\",\n200:     \"ruff-format\",\n201:     \"ty\",\n202:     \"docs\",\n203: ]\n204: \n205: [tool.tox.env_run_base]\n206: package = \"wheel\"\n207: wheel_build_env = \".pkg\"\n208: dependency_groups = [\"tests\"]\n209: commands = [\n210:     [\n211:         \"pytest\",\n212:         \"--cov\",\n213:         \"--basetemp={envtmpdir}\",\n214:         { replace = \"posargs\", extend = true },\n215:     ],\n216: ]\n217: \n218: [tool.tox.env.pyright]\n219: dependency_groups = [\"typing\"]\n220: commands = [[\"pyright\", \"{posargs:src}\"]]\n221: \n222: [tool.tox.env.rumdl]\n223: skip_install = true\n224: dependency_groups = [\"rumdl\"]\n225: commands = [[\"rumdl\", \"check\", \"docs/\"]]\n226: \n227: [tool.tox.env.ruff-check]\n228: skip_install = true\n229: dependency_groups = [\"ruff\"]\n230: commands = [[\"ruff\", \"check\", \"{posargs:.}\"]]\n231: \n232: [tool.tox.env.ruff-format]\n233: skip_install = true\n234: dependency_groups = [\"ruff\"]\n235: commands = [[\"ruff\", \"format\", \"--check\", \"--diff\", \"{posargs:.}\"]]\n236: \n237: [tool.tox.env.ty]\n238: dependency_groups = [\"typing\"]\n239: commands = [[\"ty\", \"check\", \"{posargs:src}\"]]\n240: \n241: [tool.tox.env.docs]\n242: dependency_groups = [\"docs\"]\n243: commands = [[\"zensical\", \"build\", \"--clean\"]]\n\n(End of file - total 243 lines)\n</content>","metadata":{"preview":"[project]\nname = \"mopidy\"\ndescription = \"Mopidy is an extensible music server written in Python\"\nreadme = \"README.rst\"\nrequires-python = \">= 3.13\"\nlicense = { text = \"Apache-2.0\" }\nauthors = [{ name = \"Stein Magnus Jodal\", email = \"stein.magnus@jodal.no\" }]\nclassifiers = [\n    \"Development Status :: 5 - Production/Stable\",\n    \"Environment :: No Input/Output (Daemon)\",\n    \"Intended Audience :: End Users/Desktop\",\n    \"License :: OSI Approved :: Apache Software License\",\n    \"Operating System :: OS Independent\",\n    \"Topic :: Multimedia :: Sound/Audio :: Players\",\n]\ndynamic = [\"version\"]\ndependencies = [\n    \"cyclopts >= 3.12\",\n    \"httpx >= 0.28.1\",\n    \"platformdirs >= 4.3\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1776094035283,"end":1776094035289}}}]}
