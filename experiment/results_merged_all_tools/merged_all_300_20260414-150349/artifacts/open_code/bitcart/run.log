{"type":"session_message","session_id":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","role":"assistant","message_id":"msg_d88b295ca001wKjuLvL6wpTQQG","parts":[{"id":"prt_d88b2a186001U0VVEgjNjMZ24T","messageID":"msg_d88b295ca001wKjuLvL6wpTQQG","sessionID":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","type":"tool","tool":"read","callID":"call_c8c7bb3272aa4016990ffa87","state":{"status":"completed","input":{"filePath":"/workspace/justfile"},"output":"<path>/workspace/justfile</path>\n<type>file</type>\n<content>1: set no-exit-message := true\n2: \n3: test-args := env(\"TEST_ARGS\", \"\")\n4: \n5: [private]\n6: default:\n7:     @just --list --unsorted --justfile {{ justfile() }}\n8: \n9: # python-level tasks\n10: \n11: # run api service\n12: [group(\"Services\")]\n13: dev-api:\n14:     uvicorn main:app --ws websockets-sansio --timeout-graceful-shutdown 1 --reload\n15: \n16: # run worker service\n17: [group(\"Services\")]\n18: worker:\n19:     python3 worker.py\n20: \n21: # run api service in production\n22: [group(\"Services\")]\n23: prod-api:\n24:     gunicorn -c gunicorn.conf.py main:app\n25: \n26: # run migrations and start api service in production\n27: [group(\"Services\")]\n28: prod-api-up: db-migrate prod-api\n29: \n30: # run coin daemons\n31: [group(\"Services\")]\n32: daemon coin:\n33:     python3 daemons/{{ coin }}.py\n34: \n35: # run linters with autofix\n36: [group(\"Linting\")]\n37: lint:\n38:     ruff format . && ruff check --fix .\n39: \n40: # run linters (check only)\n41: [group(\"Linting\")]\n42: lint-check:\n43:     ruff format --check . && ruff check .\n44: \n45: # run type checking\n46: [group(\"Linting\")]\n47: lint-types:\n48:     mypy api tests main.py worker.py\n49: \n50: # run tests\n51: [group(\"Testing\")]\n52: test *args:\n53:     pytest {{ trim(test-args + \" \" + args) }}\n54: \n55: # run functional tests\n56: [group(\"Testing\")]\n57: functional *args:\n58:     BTC_LIGHTNING=true pytest tests/functional/ --cov-append -n 0 {{ trim(test-args + \" \" + args) }}\n59: \n60: # create new migration\n61: [group(\"Database\")]\n62: db-migration MESSAGE:\n63:     alembic revision --autogenerate -m \"{{ MESSAGE }}\"\n64: \n65: # run alembic upgrade\n66: [group(\"Database\")]\n67: db-migrate:\n68:     alembic upgrade head\n69: \n70: # run alembic downgrade\n71: [group(\"Database\")]\n72: db-rollback:\n73:     alembic downgrade -1\n74: \n75: # run ci checks (without tests)\n76: [group(\"CI\")]\n77: ci-lint: lint-check lint-types\n78: \n79: # run ci checks\n80: [group(\"CI\")]\n81: ci *args: ci-lint (test args)\n82: \n83: # btc-setup tasks\n84: \n85: # start electrum regtest daemon\n86: [group(\"BTC setup\")]\n87: regtest:\n88:     rm -rf ~/.electrum/regtest\n89:     BTC_DEBUG=true BTC_NETWORK=regtest BTC_SERVER=127.0.0.1:51002:s BTC_LIGHTNING=true BTC_LIGHTNING_GOSSIP=true just daemon btc\n90: \n91: # start electrum regtest daemon (lightning node)\n92: [group(\"BTC setup\")]\n93: regtestln:\n94:     rm -rf /tmp/bitcartln\n95:     BTC_DEBUG=true BTC_DATA_PATH=/tmp/bitcartln BTC_NETWORK=regtest BTC_SERVER=127.0.0.1:51002:s BTC_LIGHTNING=true BTC_LIGHTNING_GOSSIP=true BTC_LIGHTNING_LISTEN=0.0.0.0:9735 BTC_PORT=5110 just daemon btc\n96: \n97: # start electrum testnet daemon\n98: [group(\"BTC setup\")]\n99: testnet:\n100:     BTC_DEBUG=true BTC_NETWORK=testnet BTC_LIGHTNING=true just daemon btc\n101: \n102: # start electrum mainnet daemon\n103: [group(\"BTC setup\")]\n104: mainnet:\n105:     BTC_DEBUG=true BTC_LIGHTNING=true BTC_NETWORK=mainnet just daemon btc\n106: \n107: # start bitcoind\n108: [group(\"BTC setup\")]\n109: bitcoind:\n110:     tests/functional/bootstrap/start_bitcoind.sh\n111: \n112: # start fulcrum\n113: [group(\"BTC setup\")]\n114: fulcrum:\n115:     tests/functional/bootstrap/start_fulcrum.sh\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"set no-exit-message := true\n\ntest-args := env(\"TEST_ARGS\", \"\")\n\n[private]\ndefault:\n    @just --list --unsorted --justfile {{ justfile() }}\n\n# python-level tasks\n\n# run api service\n[group(\"Services\")]\ndev-api:\n    uvicorn main:app --ws websockets-sansio --timeout-graceful-shutdown 1 --reload\n\n# run worker service\n[group(\"Services\")]\nworker:\n    python3 worker.py\n","truncated":false,"loaded":[]},"title":"justfile","time":{"start":1776114901672,"end":1776114901677}}}]}
