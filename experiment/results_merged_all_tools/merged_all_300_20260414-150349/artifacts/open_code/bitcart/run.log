{"type":"session_message","session_id":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","role":"assistant","message_id":"msg_d88b2b91900151jkDh31bm9MXA","parts":[{"id":"prt_d88b2cc500010tZKsTUvmJpMXe","messageID":"msg_d88b2b91900151jkDh31bm9MXA","sessionID":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","type":"tool","tool":"read","callID":"call_e9cd66080ce8477bac802145","state":{"status":"completed","input":{"filePath":"/workspace/tests/conftest.py"},"output":"<path>/workspace/tests/conftest.py</path>\n<type>file</type>\n<content>1: import functools\n2: import os\n3: import tempfile\n4: from collections.abc import AsyncGenerator, AsyncIterator, Generator, Iterator\n5: from decimal import Decimal\n6: from typing import Any, NewType, cast\n7: from unittest.mock import AsyncMock\n8: \n9: import pytest\n10: import pytest_mock\n11: from bitcart import BTC  # type: ignore[attr-defined]\n12: from dishka import Provider, Scope, decorate, from_context, provide\n13: from fastapi import FastAPI\n14: from filelock import FileLock\n15: from httpx import AsyncClient\n16: from httpx_ws.transport import ASGIWebSocketTransport\n17: from pwdlib import PasswordHash\n18: from pwdlib.hashers.bcrypt import BcryptHasher\n19: from sqlalchemy import text\n20: \n21: from api.bootstrap import get_app\n22: from api.db import AsyncEngine, create_async_engine\n23: from api.ioc import build_container, setup_dishka\n24: from api.logging import configure as configure_logging\n25: from api.models import Model\n26: from api.plugins import PluginObjects\n27: from api.services.coins import CoinService\n28: from api.services.exchange_rate import ExchangeRateService\n29: from api.settings import Settings\n30: \n31: pytest_plugins = [\"tests.fixtures.pytest.data\"]\n32: \n33: ANYIO_BACKEND_OPTIONS = {\"use_uvloop\": True}\n34: \n35: \n36: @pytest.fixture(scope=\"session\")\n37: def anyio_backend() -> tuple[str, dict[str, Any]]:\n38:     return (\"asyncio\", ANYIO_BACKEND_OPTIONS)\n39: \n40: \n41: def get_db_url(settings: Settings, worker_id: str) -> str:\n42:     if worker_id != \"master\":\n43:         return f\"{settings.DB_DATABASE}_{worker_id}\"\n44:     return settings.DB_DATABASE\n45: \n46: \n47: async def initialize_test_database(settings: Settings, worker_id: str) -> None:\n48:     template_db_name = f\"{settings.DB_DATABASE}_template\"\n49:     database_url = settings.build_postgres_dsn(db_name=template_db_name)\n50:     engine = create_async_engine(settings, \"test\", dsn=settings.build_postgres_dsn(db_name=\"postgres\"))\n51:     async with engine.connect() as conn:\n52:         await conn.execution_options(isolation_level=\"AUTOCOMMIT\")\n53:         await conn.execute(text(f\"DROP DATABASE IF EXISTS {template_db_name}\"))\n54:         await conn.execute(text(f\"CREATE DATABASE {template_db_name}\"))\n55:     await engine.dispose()\n56:     engine = create_async_engine(settings, \"test\", dsn=database_url)\n57:     async with engine.begin() as conn:\n58:         await conn.run_sync(Model.metadata.create_all)\n59:     await engine.dispose()\n60: \n61: \n62: @pytest.fixture(scope=\"session\", autouse=True)\n63: async def initialize_test_database_fixture(\n64:     settings: Settings,\n65:     worker_id: str,\n66:     tmp_path_factory: pytest.TempPathFactory,\n67: ) -> None:\n68:     if worker_id == \"master\":\n69:         await initialize_test_database(settings, worker_id)\n70:         return\n71:     root_tmp_dir = tmp_path_factory.getbasetemp().parent\n72: \n73:     fn = root_tmp_dir / \"data.json\"\n74:     with FileLock(str(fn) + \".lock\"):\n75:         if fn.is_file():\n76:             pass\n77:         else:\n78:             await initialize_test_database(settings, worker_id)\n79:             fn.write_text(\"DONE\")\n80: \n81: \n82: WorkerId = NewType(\"WorkerId\", str)\n83: \n84: \n85: class TestingProvider(Provider):\n86:     worker_id = from_context(provides=WorkerId, scope=Scope.APP)\n87: \n88:     @provide(scope=Scope.RUNTIME)\n89:     def get_plugin_clases(self) -> PluginObjects:\n90:         return cast(PluginObjects, {})\n91: \n92:     @provide(scope=Scope.RUNTIME)\n93:     def get_password_context(self) -> PasswordHash:\n94:         return PasswordHash((BcryptHasher(rounds=4),))\n95: \n96:     @provide(scope=Scope.APP)\n97:     async def get_async_engine(self, settings: Settings, worker_id: WorkerId) -> AsyncIterator[AsyncEngine]:\n98:         engine = create_async_engine(\n99:             settings, \"test\", dsn=settings.build_postgres_dsn(db_name=get_db_url(settings, worker_id))\n100:         )\n101:         yield engine\n102:         await engine.dispose()\n103: \n104:     # TODO: if we make fake redis work with functional tests of websockets, we can no longer require redis for tests\n105:     # @provide(scope=Scope.RUNTIME)\n106:     # async def get_redis(self) -> AsyncIterator[Redis]:\n107:     #     async with FakeAsyncRedis(decode_responses=True) as redis:\n108:     #         yield redis\n109: \n110:     @decorate\n111:     async def get_exchange_rate_service(\n112:         self,\n113:         service: ExchangeRateService,\n114:     ) -> AsyncIterator[ExchangeRateService]:\n115:         await service.init()\n116:         yield service\n117: \n118: \n119: @pytest.fixture(autouse=True)\n120: async def configure_dishka_test_session(app: FastAPI, worker_id: str, settings: Settings) -> AsyncIterator[None]:\n121:     db_name = get_db_url(settings, worker_id)\n122:     template_db = f\"{settings.DB_DATABASE}_template\"\n123:     engine = create_async_engine(settings, \"test\", dsn=settings.build_postgres_dsn(db_name=\"postgres\"))\n124:     async with engine.connect() as conn:\n125:         await conn.execution_options(isolation_level=\"AUTOCOMMIT\")\n126:         await conn.execute(text(f\"DROP DATABASE IF EXISTS {db_name}\"))\n127:         await conn.execute(text(f\"CREATE DATABASE {db_name} TEMPLATE {template_db}\"))\n128:     await engine.dispose()\n129:     async with app.state.dishka_container(scope=Scope.APP, context={WorkerId: worker_id}) as container:\n130:         original_container = app.state.dishka_container\n131:         app.state.dishka_container = container\n132:         yield\n133:     app.state.dishka_container = original_container\n134: \n135: \n136: @pytest.fixture(scope=\"session\")\n137: def settings(tmp_path_factory: pytest.TempPathFactory) -> Settings:\n138:     os.environ[\"BITCART_ENV\"] = \"testing\"\n139:     os.environ[\"BITCART_CRYPTOS\"] = \"btc\"\n140:     os.environ[\"BTC_NETWORK\"] = \"testnet\"\n141:     os.environ[\"BITCART_DATADIR\"] = str(tmp_path_factory.mktemp(\"data\"))\n142:     return Settings()\n143: \n144: \n145: @pytest.fixture(scope=\"session\")\n146: def app(settings: Settings) -> Generator[FastAPI]:\n147:     container = build_container(\n148:         settings, extra_providers=(TestingProvider(),), include_plugins=False, start_scope=Scope.RUNTIME\n149:     )\n150:     app = get_app(settings)\n151:     setup_dishka(container=container, app=app)\n152:     configure_logging(settings=settings)\n153:     yield app\n154: \n155: \n156: @pytest.fixture\n157: async def client(app: FastAPI, anyio_backend: tuple[str, dict[str, Any]]) -> AsyncGenerator[AsyncClient]:\n158:     async with AsyncClient(transport=ASGIWebSocketTransport(app=app), base_url=\"http://testserver\") as client:\n159:         yield client\n160: \n161: \n162: @pytest.fixture\n163: def service_dir() -> Iterator[str]:\n164:     with tempfile.TemporaryDirectory() as directory:\n165:         with open(f\"{directory}/hostname\", \"w\") as f:\n166:             f.write(\"test.onion\\n\\n\\n\")\n167:         yield directory\n168: \n169: \n170: @pytest.fixture\n171: def torrc(service_dir: str) -> str:\n172:     filename = f\"{service_dir}/torrc\"\n173:     with open(filename, \"w\") as f:\n174:         f.write(\n175:             f\"\"\"\n176: HiddenServiceDir {service_dir}\n177: HiddenServicePort 80 127.0.0.1:80\"\"\"\n178:         )\n179:     return filename\n180: \n181: \n182: def deleting_file_base(filename: str) -> Generator[str, None, None]:\n183:     assert os.path.exists(filename)\n184:     with open(filename) as f:\n185:         contents = f.read().strip()\n186:     yield filename\n187:     if not os.path.exists(filename):\n188:         with open(filename, \"w\") as f:\n189:             f.write(f\"{contents}\\n\")\n190: \n191: \n192: @pytest.fixture\n193: def log_file() -> Generator[str, None, None]:\n194:     yield from deleting_file_base(\"tests/fixtures/logs/bitcart20210821.log\")\n195: \n196: \n197: def pytest_configure(config: pytest.Config) -> None:\n198:     \"\"\"Register custom markers\"\"\"\n199:     config.addinivalue_line(\n200:         \"markers\",\n201:         (\n202:             \"exchange_rates: mark test as requiring exchange rates mocking. For now in all tests it is mocked, you can use\"\n203:             \" cryptos param to specify which cryptos to enable\"\n204:         ),\n205:     )\n206: \n207: \n208: async def mock_fetch_delayed(*args: Any, all_cryptos: dict[str, BTC], **kwargs: Any) -> Any:\n209:     req_url = args[1]\n210:     if \"simple/supported_vs_currencies\" in req_url:\n211:         return [\"btc\", \"usd\", \"eur\"]\n212:     if \"coins/list\" in req_url:\n213:         coins = []\n214:         for crypto in all_cryptos:\n215:             coins.append({\"id\": crypto, \"symbol\": crypto, \"name\": crypto.upper()})\n216:         return coins\n217:     if \"simple/price\" in req_url:\n218:         return {crypto: {\"usd\": 50000, \"eur\": 45000} for crypto in all_cryptos}\n219:     return {}\n220: \n221: \n222: @pytest.fixture\n223: async def coin_service(app: FastAPI) -> CoinService:\n224:     return await app.state.dishka_container.get(CoinService)\n225: \n226: \n227: @pytest.fixture\n228: def mock_btc_balance(mocker: pytest_mock.MockerFixture) -> AsyncMock:\n229:     return mocker.patch(\n230:         \"bitcart.BTC.balance\",\n231:         new=AsyncMock(\n232:             return_value={\n233:                 \"confirmed\": Decimal(\"1.5\"),\n234:                 \"unconfirmed\": Decimal(\"0\"),\n235:                 \"unmatured\": Decimal(\"0\"),\n236:                 \"lightning\": Decimal(\"0\"),\n237:             }\n238:         ),\n239:     )\n240: \n241: \n242: @pytest.fixture(autouse=True)\n243: def mock_coingecko_api(\n244:     request: pytest.FixtureRequest,\n245:     mocker: pytest_mock.MockerFixture,\n246:     coin_service: CoinService,\n247:     anyio_backend: tuple[str, dict[str, Any]],\n248: ) -> None:\n249:     all_cryptos = coin_service.cryptos\n250:     marker = request.node.get_closest_marker(\"exchange_rates\")\n251:     cryptos = marker.kwargs.get(\"cryptos\") if marker else None\n252:     if cryptos is not None:\n253:         all_cryptos = cryptos\n254:         mocker.patch.object(coin_service, \"_cryptos\", cryptos)\n255:     mocker.patch(\n256:         \"api.ext.exchanges.coingecko.fetch_delayed\", side_effect=functools.partial(mock_fetch_delayed, all_cryptos=all_cryptos)\n257:     )\n\n(End of file - total 257 lines)\n</content>","metadata":{"preview":"import functools\nimport os\nimport tempfile\nfrom collections.abc import AsyncGenerator, AsyncIterator, Generator, Iterator\nfrom decimal import Decimal\nfrom typing import Any, NewType, cast\nfrom unittest.mock import AsyncMock\n\nimport pytest\nimport pytest_mock\nfrom bitcart import BTC  # type: ignore[attr-defined]\nfrom dishka import Provider, Scope, decorate, from_context, provide\nfrom fastapi import FastAPI\nfrom filelock import FileLock\nfrom httpx import AsyncClient\nfrom httpx_ws.transport import ASGIWebSocketTransport\nfrom pwdlib import PasswordHash\nfrom pwdlib.hashers.bcrypt import BcryptHasher\nfrom sqlalchemy import text\n","truncated":false,"loaded":[]},"title":"tests/conftest.py","time":{"start":1776114912627,"end":1776114912632}}}]}
