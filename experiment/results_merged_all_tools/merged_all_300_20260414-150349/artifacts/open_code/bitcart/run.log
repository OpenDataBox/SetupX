{"type":"session_message","session_id":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","role":"assistant","message_id":"msg_d88b2a34b001VHmgCSQ26FV4if","parts":[{"id":"prt_d88b2b056001dJYvDcLmGheGHW","messageID":"msg_d88b2a34b001VHmgCSQ26FV4if","sessionID":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","type":"tool","tool":"read","callID":"call_9d830f61bb4942658fa7b92d","state":{"status":"completed","input":{"filePath":"/workspace/.github/workflows/ci.yml"},"output":"<path>/workspace/.github/workflows/ci.yml</path>\n<type>file</type>\n<content>1: name: CI\n2: \n3: on:\n4:   push:\n5:     branches:\n6:       - master\n7:   pull_request:\n8: \n9: concurrency:\n10:   group: ${{ github.workflow_ref }}-${{ github.event.pull_request.number || github.run_id }}\n11:   cancel-in-progress: true\n12: \n13: permissions:\n14:   contents: read\n15: \n16: jobs:\n17:   lint:\n18:     name: lint\n19:     uses: bitcart/bitcart-actions/.github/workflows/lint.yml@master\n20:     with:\n21:       install-dependencies: |\n22:         uv sync --frozen --compile-bytecode --no-dev --group web --group types --group lint --group test\n23:       extra-checks: just ci-lint\n24: \n25:   zizmor:\n26:     name: zizmor\n27:     uses: bitcart/bitcart-actions/.github/workflows/zizmor-audit.yml@master\n28:     permissions:\n29:       contents: read\n30:       security-events: write\n31: \n32:   test:\n33:     name: test-${{ matrix.python-version }}\n34:     needs: [lint, zizmor]\n35:     runs-on: ubuntu-latest\n36: \n37:     strategy:\n38:       matrix:\n39:         python-version: [\"3.12\", \"3.13\", \"3.14\"]\n40: \n41:     services:\n42:       redis:\n43:         image: redis:alpine\n44:         ports:\n45:           - 6379:6379\n46: \n47:       postgres:\n48:         image: postgres:18-alpine\n49:         env:\n50:           POSTGRES_DB: bitcart_test\n51:           POSTGRES_HOST_AUTH_METHOD: trust\n52:         ports:\n53:           - 5432:5432\n54: \n55:     env:\n56:       TEST_ARGS: \"-o junit_family=legacy --junitxml test-results/junit.xml --cov-report html:coverage\"\n57: \n58:     steps:\n59:       - uses: actions/checkout@v6\n60:         with:\n61:           persist-credentials: false\n62: \n63:       - name: Set up Python ${{ matrix.python-version }}\n64:         uses: bitcart/bitcart-actions/actions/setup-python@master\n65:         with:\n66:           python-version: ${{ matrix.python-version }}\n67: \n68:       - name: Install Python dependencies\n69:         uses: bitcart/bitcart-actions/actions/install-daemon@master\n70:         with:\n71:           install-dependencies: |\n72:             uv sync --frozen --compile-bytecode --no-dev --group web --group otel --group test --group btc\n73: \n74:       - name: Prepare daemon\n75:         uses: bitcart/bitcart-actions/actions/run-in-background@master\n76:         with:\n77:           run: BTC_EXPERIMENTAL_NOSYNC=true just testnet\n78:           key: testnet\n79: \n80:       - name: Run tests\n81:         run: |\n82:           just test -n 4 --pytest-durations=-1\n83: \n84:       - name: Upload coverage to Codecov\n85:         uses: bitcart/bitcart-actions/actions/codecov@master\n86:         if: ${{ !cancelled() }}\n87:         with:\n88:           token: ${{ secrets.CODECOV_TOKEN }} # zizmor: ignore[secrets-outside-env] # safe for codecov\n89:           name: Tests - Python ${{ env.PYTHON }}\n90:           flags: tests\n91:           env_vars: PYTHON\n92:           upload_coverage: ${{ job.status == 'success' }}\n93: \n94:       - name: Upload test results\n95:         uses: bitcart/bitcart-actions/actions/upload-test-results@master\n96:         if: ${{ !cancelled() }}\n97:         with:\n98:           suffix: py${{ env.PYTHON }}\n99: \n100:   functional-tests:\n101:     name: functional-tests\n102:     uses: bitcart/bitcart-actions/.github/workflows/functional-tests.yml@master\n103:     needs: test\n104:     with:\n105:       install-dependencies: |\n106:         uv sync --frozen --compile-bytecode --no-dev --group web --group otel --group test --group btc\n107:       enable-redis: true\n108:       enable-postgres: true\n109:     secrets:\n110:       CODECOV_TOKEN: ${{ secrets.CODECOV_TOKEN }}\n111: \n112:   combine-coverage:\n113:     name: combine-coverage\n114:     uses: bitcart/bitcart-actions/.github/workflows/combine-coverage.yml@master\n115:     needs: [test, functional-tests]\n116:     if: ${{ !cancelled() }}\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"name: CI\n\non:\n  push:\n    branches:\n      - master\n  pull_request:\n\nconcurrency:\n  group: ${{ github.workflow_ref }}-${{ github.event.pull_request.number || github.run_id }}\n  cancel-in-progress: true\n\npermissions:\n  contents: read\n\njobs:\n  lint:\n    name: lint\n    uses: bitcart/bitcart-actions/.github/workflows/lint.yml@master\n    with:","truncated":false,"loaded":[]},"title":".github/workflows/ci.yml","time":{"start":1776114905607,"end":1776114905613}}}]}
