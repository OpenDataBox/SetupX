{"type":"session_message","session_id":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","role":"assistant","message_id":"msg_d88b295ca001wKjuLvL6wpTQQG","parts":[{"id":"prt_d88b29f52001QKsIDGp5rp42ib","messageID":"msg_d88b295ca001wKjuLvL6wpTQQG","sessionID":"ses_2774d7dd0ffeOnrt7jO6r8uvEJ","type":"tool","tool":"read","callID":"call_47da0ccf04d44c3faab818de","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [project]\n2: name = \"bitcart-api\"\n3: version = \"1.0.0\"\n4: description = \"Bitcart Merchants API\"\n5: requires-python = \">=3.12\"\n6: dependencies = [\"python-decouple\", \"rust-just>=1.46.0\"]\n7: \n8: [dependency-groups]\n9: lint = [\"mypy>=1.13.0\", \"prek>=0.3.1\", \"ruff>=0.9.5\"]\n10: test = [\n11:     \"fakeredis>=2.31.1\",\n12:     \"filelock>=3.19.1\",\n13:     \"httpx>=0.28.1\",\n14:     \"httpx-ws>=0.7.2\",\n15:     \"pytest>=8.3.5\",\n16:     \"pytest-cov>=6.2.1\",\n17:     \"pytest-durations>=1.6.1\",\n18:     \"pytest-mock>=3.15.0\",\n19:     \"pytest-xdist>=3.8.0\",\n20: ]\n21: types = [\"types-aiofiles>=24.1.0.20250822\", \"types-paramiko>=4.0.0.20250822\"]\n22: web = [\n23:     \"advanced-alchemy>=0.26.2\",\n24:     \"aiofiles>=24.1.0\",\n25:     \"alembic>=1.16.1\",\n26:     \"apprise>=1.9.4\",\n27:     \"asyncpg>=0.30.0\",\n28:     \"bitcart>=1.18.0.0\",\n29:     \"dishka>=1.4.2\",\n30:     \"fastapi>=0.115.6\",\n31:     \"fido2>=2.0.0\",\n32:     \"jinja2>=3.1.6\",\n33:     \"jsonschema>=4.25.1\",\n34:     \"msgpack>=1.1.1\",\n35:     \"paramiko>=4.0.0\",\n36:     \"prometheus-fastapi-instrumentator>=7.1.0\",\n37:     \"pwdlib[bcrypt]>=0.2.1\",\n38:     \"py-machineid>=0.8.0\",\n39:     \"pydantic-settings>=2.7.0\",\n40:     \"pydantic[email]>=2.10.3\",\n41:     \"pyotp>=2.9.0\",\n42:     \"python-multipart>=0.0.20\",\n43:     \"python-ulid[pydantic]>=3.0.0\",\n44:     \"redis[hiredis]>=5.2.1\",\n45:     \"scalar-fastapi>=1.4.0\",\n46:     \"sentry-sdk[fastapi,sqlalchemy]\",\n47:     \"sqlalchemy[asyncio]>=2.0.36\",\n48:     \"structlog>=24.4.0\",\n49:     \"taskiq>=0.11.18\",\n50:     \"taskiq-redis>=1.1.0\",\n51:     \"uvicorn[standard]>=0.34.0\",\n52: ]\n53: otel = [\n54:     \"opentelemetry-distro[otlp]>=0.61b0,<0.62\",\n55:     \"opentelemetry-instrumentation>=0.61b0,<0.62\",\n56:     # required for LoggingHandler in daemon\n57:     \"opentelemetry-instrumentation-logging>=0.61b0,<0.62\",\n58:     \"opentelemetry-sdk>=1.40.0,<1.41.0\",\n59: ]\n60: production = [\"gunicorn>=23.0.0\"]\n61: \n62: # daemons\n63: daemon-base = [\"aiohttp<4.0\"]\n64: btc-based = [{ include-group = \"daemon-base\" }]\n65: btc-derived = [\n66:     { include-group = \"btc-based\" },\n67:     \"electrum-ecc @ git+https://github.com/bitcart/electrum-ecc@d90e8c79fb7d83fdea9ad0de94dce07f836f69bb\",\n68: ]\n69: eth-based = [{ include-group = \"daemon-base\" }, \"aiolimiter\", \"mnemonic\", \"web3>=7,<8\"]\n70: \n71: # sort alphabetically\n72: bch = [\n73:     { include-group = \"btc-based\" },\n74:     \"electron-cash @ https://github.com/Electron-Cash/Electron-Cash/archive/492f050ebe87d58faf57bee131912b6c0d049820.zip\",\n75: ]\n76: bnb = [{ include-group = \"eth-based\" }]\n77: btc = [\n78:     { include-group = \"btc-derived\" },\n79:     \"electrum[crypto] @ git+https://github.com/spesmilo/electrum@0f4d8d6d57bbff3428950cf531bc98eae473beec\",\n80: ]\n81: eth = [{ include-group = \"eth-based\" }]\n82: grs = [\n83:     { include-group = \"btc-derived\" },\n84:     \"electrum-grs[crypto] @ git+https://github.com/Groestlcoin/electrum-grs@a10de858525b7045b835a840200cf9fcff3bfe9e\",\n85: ]\n86: ltc = [\n87:     { include-group = \"btc-derived\" },\n88:     \"electrum-ltc[crypto] @ git+https://github.com/bitcart/electrum-ltc@5fd99314de302d9ed3c90537643f2e0ba82c1f02\",\n89:     \"scrypt>=0.6.0\",\n90: ]\n91: matic = [{ include-group = \"eth-based\" }]\n92: trx = [{ include-group = \"eth-based\" }, \"async-lru\", \"tronpy\", \"trontxsize\"]\n93: xmr = [{ include-group = \"daemon-base\" }, \"monero\", \"universalasync\"]\n94: xrg = [\n95:     { include-group = \"btc-based\" },\n96:     \"oregano @ https://github.com/Ergon-moe/Oregano/archive/6bf78d3be864c053c95ee332c6ab366e5695d8a4.zip\",\n97: ]\n98: \n99: daemons = [\n100:     { include-group = \"bch\" },\n101:     { include-group = \"bnb\" },\n102:     { include-group = \"btc\" },\n103:     { include-group = \"eth\" },\n104:     { include-group = \"grs\" },\n105:     { include-group = \"ltc\" },\n106:     { include-group = \"matic\" },\n107:     { include-group = \"trx\" },\n108:     { include-group = \"xmr\" },\n109:     { include-group = \"xrg\" },\n110: ]\n111: \n112: # all groups\n113: dev = [\n114:     { include-group = \"lint\" },\n115:     { include-group = \"test\" },\n116:     { include-group = \"web\" },\n117:     { include-group = \"types\" },\n118:     { include-group = \"daemons\" },\n119:     { include-group = \"otel\" },\n120:     { include-group = \"production\" },\n121: ]\n122: \n123: [tool.uv]\n124: # python-dateutil override for electron-cash (transitive dependency) requiring an older version for no reason\n125: override-dependencies = [\"python-dateutil>=2.9.0\"]\n126: config-settings-package = { \"electrum-ecc\" = { \"electrum_ecc.dont_compile\" = \"1\" } }\n127: # dependency cooldowns for security\n128: exclude-newer = \"1 week\"\n129: \n130: # except for our packages\n131: [tool.uv.exclude-newer-package]\n132: bitcart = \"0 days\"\n133: trontxsize = \"0 days\"\n134: universalasync = \"0 days\"\n135: tronpy = \"0 days\"\n136: uvicorn = \"0 days\" # remove when 7 days passed since 0.44.0\n137: \n138: [tool.ruff]\n139: target-version = \"py312\"\n140: line-length = 127\n141: \n142: [tool.ruff.lint]\n143: select = [\n144:     \"F\",\n145:     \"E\",\n146:     \"I\",\n147:     \"UP\",\n148:     \"YTT\",\n149:     \"B\",\n150:     \"T10\",\n151:     \"C\",\n152:     \"SIM\",\n153:     \"RUF100\",\n154:     \"RET\",\n155:     \"A\",\n156:     \"S\",\n157:     \"ASYNC\",\n158:     \"TID\",\n159:     \"PLC0415\",\n160:     \"T201\",\n161: ]\n162: preview = true\n163: unfixable = [\"F401\"]\n164: ignore = [\n165:     \"RET502\",\n166:     \"RET503\",\n167:     \"S104\",\n168:     \"S507\",\n169:     \"ASYNC110\",\n170:     \"ASYNC240\", # TODO: potentially enable this\n171:     \"A005\",\n172:     \"PLC0415\",\n173: ] # Enable PLC0415 when ready\n174: mccabe = { max-complexity = 12 }\n175: \n176: [tool.ruff.lint.per-file-ignores]\n177: \"tests/*\" = [\"S\"]\n178: \"scripts/*\" = [\"S\", \"T201\"]\n179: \"backups/*\" = [\"T201\"]\n180: \n181: [tool.ruff.lint.isort]\n182: known-third-party = [\"bitcart\"]\n183: \n184: [tool.ruff.lint.flake8-bugbear]\n185: extend-immutable-calls = [\n186:     \"fastapi.Depends\",\n187:     \"fastapi.params.Depends\",\n188:     \"fastapi.Query\",\n189:     \"fastapi.params.Query\",\n190:     \"fastapi.Path\",\n191:     \"fastapi.params.Path\",\n192:     \"fastapi.Body\",\n193:     \"fastapi.params.Body\",\n194:     \"fastapi.Form\",\n195:     \"fastapi.params.Form\",\n196:     \"fastapi.Header\",\n197:     \"fastapi.params.Header\",\n198:     \"fastapi.File\",\n199:     \"fastapi.params.File\",\n200:     \"fastapi.Cookie\",\n201:     \"fastapi.params.Cookie\",\n202:     \"fastapi.Security\",\n203:     \"fastapi.params.Security\",\n204: ]\n205: \n206: [tool.mypy]\n207: ignore_missing_imports = true\n208: plugins = [\"pydantic.mypy\"]\n209: warn_redundant_casts = true\n210: warn_unused_ignores = true\n211: disallow_any_generics = true\n212: check_untyped_defs = true\n213: no_implicit_reexport = true\n214: strict_equality = true\n215: disallow_untyped_defs = true\n216: skip_cache_mtime_checks = true\n217: exclude = [\"daemons\", \"backups\"]\n218: \n219: [tool.pydantic-mypy]\n220: init_forbid_extra = true\n221: init_typed = true\n222: warn_required_dynamic_aliases = true\n223: warn_untyped_fields = true\n224: \n225: [tool.pytest.ini_options]\n226: junit_duration_report = \"call\"\n227: junit_suite_name = \"bitcart_test_suite\"\n228: addopts = [\"-n\", \"auto\", \"--cov=api\", \"--cov-report\", \"term-missing\"]\n229: filterwarnings = [\n230:     \"error::DeprecationWarning\",\n231:     \"error::PendingDeprecationWarning\",\n232:     # https://github.com/MagicStack/uvloop/issues/703\n233:     \"ignore:.*asyncio.iscoroutinefunction.*:DeprecationWarning\",\n234:     # dishka added the warning, but didn't fix it's own invocations\n235:     \"ignore:`dishka.integrations.starlette` will be removed:DeprecationWarning:dishka.*\",\n236: ]\n237: norecursedirs = [\"tests/functional\"]\n\n(End of file - total 237 lines)\n</content>","metadata":{"preview":"[project]\nname = \"bitcart-api\"\nversion = \"1.0.0\"\ndescription = \"Bitcart Merchants API\"\nrequires-python = \">=3.12\"\ndependencies = [\"python-decouple\", \"rust-just>=1.46.0\"]\n\n[dependency-groups]\nlint = [\"mypy>=1.13.0\", \"prek>=0.3.1\", \"ruff>=0.9.5\"]\ntest = [\n    \"fakeredis>=2.31.1\",\n    \"filelock>=3.19.1\",\n    \"httpx>=0.28.1\",\n    \"httpx-ws>=0.7.2\",\n    \"pytest>=8.3.5\",\n    \"pytest-cov>=6.2.1\",\n    \"pytest-durations>=1.6.1\",\n    \"pytest-mock>=3.15.0\",\n    \"pytest-xdist>=3.8.0\",\n]","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1776114901100,"end":1776114901107}}}]}
