if [ \"$(git branch --show-current)\" != \"main\" ]; then\n43:         echo \"Error: not on main branch\" >&2\n44:         exit 1\n45:     fi\n46:     if [ -n \"$(git status --porcelain)\" ]; then\n47:         echo \"Error: working tree is not clean\" >&2\n48:         exit 1\n49:     fi\n50:     if [ ! -f \"CHANGELOG/{{VERSION}}.md\" ]; then\n51:         echo \"Error: CHANGELOG/{{VERSION}}.md not found\" >&2\n52:         exit 1\n53:     fi\n54:     echo \"Tagging v{{VERSION}}\"\n55:     git tag -a v{{VERSION}} -m \"Release {{VERSION}}\"\n56:     git push origin main\n57:     git push origin v{{VERSION}}\n58: \n59: # Run all tests with coverage\n60: coverage:\n61:     uv run --python=3.13 --isolated --group test -- \\\n62:         pytest --cov-report=html --cov-report=xml --cov-branch --cov-fail-under=100\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"# List all the justfile recipes\nlist:\n    just -l\n\n# Generate Sphinx HTML documentation, including API docs\ndocs:\n    uv run --python=3.13 --isolated --group docs -- sphinx-build docs docs/_build\n    open docs/_build/index.html\n\n# Host the docs locally and rebuild on changes\nservedocs:\n    uv run --python=3.13 --isolated --group docs -- \\\n        sphinx-autobuild -Wa docs/ docs/_build/html --open-browser --port 9812 \\\n            --watch cookiecutter\n\n# lint with ruff\nlint:\n    uv run --python=3.13 --isolated --group lint -- ruff check . --fix\n\n# lint check with ruff","truncated":false,"loaded":[]},"title":"justfile","time":{"start":1775753169150,"end":1775753169157}}}]}
