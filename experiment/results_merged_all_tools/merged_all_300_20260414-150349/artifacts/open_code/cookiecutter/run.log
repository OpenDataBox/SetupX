     \"Jinja2>=2.7,<4.0.0\",\n39:     \"click>=7.0,<9.0.0\",\n40:     \"pyyaml>=5.3.1\",\n41:     \"python-slugify>=4.0.0\",\n42:     \"requests>=2.23.0\",\n43:     \"arrow\",\n44:     \"rich\",\n45: ]\n46: requires-python = \">=3.10\"\n47: \n48: [project.urls]\n49: Homepage = \"https://github.com/cookiecutter/cookiecutter\"\n50: Documentation = \"https://cookiecutter.readthedocs.io\"\n51: Issues = \"https://github.com/cookiecutter/cookiecutter/issues\"\n52: Discord = \"https://discord.gg/9BrxzPKuEW\"\n53: \n54: [project.scripts]\n55: cookiecutter = \"cookiecutter.__main__:main\"\n56: \n57: [dependency-groups]\n58: dev = [\n59:     \"uv\",                       # Is needed by justfile tasks\n60:     \"rust-just>=1.42.3\",        # Justfile tasks\n61:     { include-group = \"test\" }, # test runner and helpers\n62: ]\n63: \n64: docs = [\n65:     \"sphinx\",\n66:     \"sphinx_click\",\n67:     \"myst_parser\",\n68:     \"sphinx_autodoc_typehints\",\n69:     \"sphinxcontrib.apidoc\",\n70:     \"sphinx_rtd_theme\",\n71:     \"sphinx-autobuild\",\n72: ]\n73: \n74: test = [\n75:     \"pytest\",\n76:     \"pytest-cov\",\n77:     \"pytest-mock\",\n78:     \"freezegun\",\n79: ]\n80: \n81: lint = [\n82:     \"ruff\",\n83:     \"safety\",\n84: ]\n85: \n86: [tool.pytest.ini_options]\n87: testpaths = \"tests\"\n88: addopts = \"-vvv --cov-report term-missing --cov=cookiecutter\"\n89: \n90: [tool.doc8]\n91: # TODO: Remove current max-line-length ignore in follow-up and adopt black limit.\n92: # max-line-length = 88\n93: ignore = [\"D001\"]\n94: \n95: [tool.ruff]\n96: \n97: target-version = \"py310\"\n98: \n99: [tool.ruff.lint]\n100: \n101: select = [\n102:     \"A\", # flake8-builtins\n103:     #    \"ANN\", # flake8-annotations\n104:     \"ARG\",   # flake8-unused-arguments\n105:     \"ASYNC\", # flake8-async\n106:     \"B\",     # flake8-bugbear\n107:     #    \"BLE\",    # flake8-blind-except\n108:     \"C4\", # flake8-comprehensions\n109:     #    \"C90\",    # cognitive complexity\n110:     #    \"COM\",    # flake8-commas\n111:     #    \"D\", # pydocstyle\n112:     \"DTZ\", # flake8-datetimez\n113:     \"E\",   # pycodestyle errors\n114:     \"EM\",  # flake8-errmsg\n115:     #    \"ERA\",    # flake8-eradicate\n116:     \"EXE\", # flake8-executable\n117:     \"F\",   # pyflakes\n118:     \"FA\",  # flake8-future-annotations\n119:     #    \"FBT\",    # boolean trap\n120:     \"FLY\",  # flynt\n121:     \"FURB\", # refurb\n122:     #    \"G\",      # flake8-logging-format\n123:     \"I\",    # isort\n124:     \"ICN\",  # flake8-import-conventions\n125:     \"INT\",  # flake8-gettext\n126:     \"ISC\",  # implicit-str-concat\n127:     \"LOG\",  # flake8-logging\n128:     \"N\",    # pep8-naming\n129:     \"PERF\", # perflint\n130:     \"PGH\",  # pygrep-hooks\n131:     \"PIE\",  # flake8-pie\n132:     #    \"PL\",     # pylint\n133:     #    \"PT\",     # flake8-pytest-style\n134:     #    \"PTH\",    # flake8-use-pathlib\n135:     #    \"PYI\",    # flake8-pyi\n136:     #    \"Q\",      # flake8-quotes\n137:     \"RET\",  # flake8-return\n138:     \"RSE\",  # flake8-raise\n139:     \"RUF\",  # Ruff-specific lints\n140:     \"S\",    # flake8-bandit\n141:     \"SIM\",  # flake8-simplify\n142:     \"SLF\",  # flake8-self\n143:     \"SLOT\", # flake8-slots\n144:     #    \"T20\",    # flake8-print\n145:     \"TCH\", # flake8-type-checking\n146:     \"TID\", # ban relative imports\n147:     \"TRY\", # tryceratops\n148:     \"UP\",  # pyupgrade\n149:     \"W\",   # pycodestyle warnings\n150:     \"YTT\", # flake8-2020\n151: ]\n152: \n153: # pydocstyle.convention = \"google\"\n154: \n155: ignore = [\n156:     \"B028\",   # No explicit `stacklevel` keyword argument found\n157:     \"COM812\", # ignore when using ruff-format\n158:     \"G004\",   # Logging statement uses f-string\n159:     \"ISC001\", # ignore when using ruff-format\n160:     \"N818\",   # Exception name should be named with an Error suffix\n161:     \"RUF012\", # Mutable class attributes should be annotated with `typing.ClassVar`\n162:     \"S404\",   # `subprocess` module is possibly insecure\n163:     \"TC003\",  # Ignore request to put Iterable into TYPE CHECKING block\n164: ]\n165: \n166: exclude = [\"tests/**/hooks/*\"]\n167: \n168: [tool.ruff.lint.per-file-ignores]\n169: \"tests/*\" = [\n170:     \"D104\", # Missing docstring in public package\n171:     \"D200\", # One-line docstring should fit on one line with quotes\n172:     \"S101\", # use of assert\n173:     \"S603\", # `subprocess` call: check for execution of untrusted input\"\n174:     \"S106\", # Possible hardcoded password assigned to argument: \"password\"\n175:     \"S108\", # Probable insecure usage of temporary file or directory: \"/tmp\"\n176: ]\n177: \"cookiecutter/*\" = [\n178:     \"S603\", # `subprocess` call: check for execution of untrusted input\"\n179: ]\n180: \"docs/conf.py\" = [\"A001\", \"D100\"]\n181: \n182: [tool.ruff.format]\n183: \n184: quote-style = \"preserve\"\n185: exclude = [\"tests/hooks-abort-render/hooks/*\"]\n186: \n187: \n188: [tool.mypy]\n189: strict = true\n190: show_error_codes = true\n191: files = [\"cookiecutter\", \"tests\"]\n192: exclude = \"(?x)(/hooks/ | tests/test-output-folder/)\"\n193: no_implicit_reexport = true\n194: \n195: \n196: [[tool.mypy.overrides]]\n197: module = [\n198:     \"cookiecutter.prompt\",\n199: ]\n200: ignore_errors = true\n201: \n202: [[tool.mypy.overrides]]\n203: module = [\n204:     \"tests.*\",\n205: ]\n206: disable_error_code = [\"no-untyped-def\"]\n207: \n208: [tool.coverage.report]\n209: exclude_also = [\"if TYPE_CHECKING:\"]\n210: \n211: [tool.coverage.run]\n212: omit = [\n213:     \"cookiecutter/__main__.py\",\n214: ]\n215: \n216: [tool.uv]\n217: # Treat this repo as an installable *package*, not just a “virtual” project.\n218: # Result: `uv sync` / `uv run` will install *this library itself* into the venv in\n219: # editable (meaning: linked to your working tree) mode, not only its dependencies.\n220: # This enables entry points (meaning: auto-created CLI scripts), plugin discovery,\n221: # and proper distribution metadata (meaning: standard package info used by tools).\n222: package = true\n223: \n224: [tool.setuptools]\n225: packages = [\"cookiecutter\"]\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"[project]\nname = \"cookiecutter\"\nversion = \"2.7.1\"\ndescription = \"A command-line utility that creates projects from project templates, e.g. creating a Python package project from a Python package project template.\"\nreadme = \"README.md\"\nauthors = [{ name = \"Audrey M. Roy Greenfeld\", email = \"audrey@feldroy.com\" }]\nclassifiers = [\n    \"Development Status :: 5 - Production/Stable\",\n    \"Environment :: Console\",\n    \"Intended Audience :: Developers\",\n    \"Natural Language :: English\",\n    \"Programming Language :: Python :: 3 :: Only\",\n    \"Programming Language :: Python :: 3\",\n    \"Programming Language :: Python :: 3.10\",\n    \"Programming Language :: Python :: 3.11\",\n    \"Programming Language :: Python :: 3.12\",\n    \"Programming Language :: Python :: 3.13\",\n    \"Programming Language :: Python :: 3.14\",\n    \"Programming Language :: Python :: Implementation :: CPython\",\n    \"Programming Language :: Python :: Implementation :: PyPy\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775753164335,"end":1775753164343}}}]}
