{"type":"session_message","session_id":"ses_28a1d194dffeV6NdtTaUN1GyyK","role":"assistant","message_id":"msg_d75e30db5001ixpvZPPP6BiovS","parts":[{"id":"prt_d75e31a26001pqtPh3w2X161j0","messageID":"msg_d75e30db5001ixpvZPPP6BiovS","sessionID":"ses_28a1d194dffeV6NdtTaUN1GyyK","type":"tool","tool":"read","callID":"call_cbe9944b015c4d9887177cd0","state":{"status":"completed","input":{"filePath":"/workspace/libs/langgraph/Makefile"},"output":"<path>/workspace/libs/langgraph/Makefile</path>\n<type>file</type>\n<content>1: .PHONY: all format lint type test test_watch integration_tests spell_check spell_fix benchmark profile start-dev-server integration_tests\n2: \n3: # Default target executed when no arguments are given to make.\n4: all: help\n5: \n6: ######################\n7: # TESTING AND COVERAGE\n8: ######################\n9: \n10: # Benchmarks\n11: \n12: OUTPUT ?= out/benchmark.json\n13: \n14: install:  ## Install dependencies\n15: \tuv sync --frozen --all-extras --all-packages --group dev\n16: \n17: benchmark:\n18: \tmkdir -p out\n19: \trm -f $(OUTPUT)\n20: \tuv run python -m bench -o $(OUTPUT) --rigorous\n21: \n22: benchmark-fast:\n23: \tmkdir -p out\n24: \trm -f $(OUTPUT)\n25: \tuv run python -m bench -o $(OUTPUT) --fast\n26: \n27: GRAPH ?= bench/fanout_to_subgraph.py\n28: \n29: profile:\n30: \tmkdir -p out\n31: \tsudo uv run py-spy record -g -o out/profile.svg -- python $(GRAPH)\n32: \n33: # Run unit tests and generate a coverage report.\n34: coverage:\n35: \tuv run pytest --cov \\\n36: \t\t--cov-config=.coveragerc \\\n37: \t\t--cov-report xml \\\n38: \t\t--cov-report term-missing:skip-covered\n39: \n40: start-services:\n41: \tdocker compose -f tests/compose-postgres.yml -f tests/compose-redis.yml up -V --force-recreate --wait --remove-orphans\n42: \n43: stop-services:\n44: \tdocker compose -f tests/compose-postgres.yml -f tests/compose-redis.yml down -v\n45: \n46: start-dev-server:\n47: \tLOG_LEVEL=warning uv run langgraph dev --config tests/example_app/langgraph.json --no-browser & echo \"$$!\" > .devserver.pid\n48: \t@echo \"Dev server started.\"\n49: \n50: stop-dev-server:\n51: \t@if [ -f .devserver.pid ]; then \\\n52: \t\tkill `cat .devserver.pid` && rm .devserver.pid; \\\n53: \t\t echo \"Dev server stopped.\"; \\\n54: \telse \\\n55: \t\techo \"No dev server PID file found.\"; \\\n56: \tfi\n57: \n58: TEST ?= .\n59: NO_DOCKER ?= $(sh command -v docker >/dev/null 2>&1 && echo \"false\" || echo \"true\")\n60: \n61: test:\n62: \tif [ \"$(NO_DOCKER)\" = \"false\" ]; then \\\n63: \t\tmake start-services &&\\\n64: \t\tmake start-dev-server &&\\\n65: \t\tuv run pytest $(TEST); \\\n66: \t\tEXIT_CODE=$$?; \\\n67: \t\tmake stop-services; \\\n68: \t\tmake stop-dev-server; \\\n69: \t\texit $$EXIT_CODE; \\\n70: \telse \\\n71: \t\tNO_DOCKER=true uv run pytest $(TEST) ; \\\n72: \t\tEXIT_CODE=$$?; \\\n73: \t\texit $$EXIT_CODE; \\\n74: \tfi\n75: \n76: test_parallel:\n77: \tmake start-services &&\\\n78: \tmake start-dev-server &&\\\n79: \tuv run pytest -n auto --dist worksteal $(TEST) -vv --lf; \\\n80: \tEXIT_CODE=$$?; \\\n81: \tmake stop-services; \\\n82: \tmake stop-dev-server; \\\n83: \texit $$EXIT_CODE\n84: \n85: integration_tests:\n86: \tuv run pytest integration_tests\n87: \n88: WORKERS ?= auto\n89: XDIST_ARGS := $(if $(WORKERS),-n $(WORKERS) --dist worksteal,)\n90: MAXFAIL ?= 1\n91: MAXFAIL_ARGS = $(if $(MAXFAIL),--maxfail $(MAXFAIL),)\n92: # Add an '-x' if xdist is enabled\n93: XDIST_ARGS := $(if $(WORKERS),-x $(XDIST_ARGS),)\n94: \n95: test_watch:\n96: \tmake start-services &&\\\n97: \tmake start-dev-server &&\\\n98: \tuv run ptw -- --ff -vv $(XDIST_ARGS) $(MAXFAIL_ARGS) $(TEST); \\\n99: \tEXIT_CODE=$$?; \\\n100: \tmake stop-services; \\\n101: \tmake stop-dev-server; \\\n102: \texit $$EXIT_CODE\n103: \n104: test_watch_all:\n105: \tnpx concurrently -n langgraph,checkpoint,checkpoint-sqlite,postgres \"make test_watch\" \"make -C ../checkpoint test_watch\" \"make -C ../checkpoint-sqlite test_watch\" \"make -C ../checkpoint-postgres test_watch\"\n106: \n107: \n108: ######################\n109: # LINTING AND FORMATTING\n110: ######################\n111: \n112: # Define a variable for Python and notebook files.\n113: PYTHON_FILES=.\n114: MYPY_CACHE=.mypy_cache\n115: lint format: PYTHON_FILES=.\n116: lint_diff format_diff: PYTHON_FILES=$(shell git diff --name-only --relative --diff-filter=d main . | grep -E r'\\.py$$|\\.ipynb$$')\n117: lint_package: PYTHON_FILES=langgraph\n118: lint_tests: PYTHON_FILES=tests\n119: lint_tests: MYPY_CACHE=.mypy_cache_test\n120: \n121: lint lint_diff lint_package lint_tests:\n122: \tuv run ruff check .\n123: \t[ \"$(PYTHON_FILES)\" = \"\" ] || uv run ruff format $(PYTHON_FILES) --diff\n124: \t[ \"$(PYTHON_FILES)\" = \"\" ] || uv run ruff check --select I $(PYTHON_FILES)\n125: \t[ \"$(PYTHON_FILES)\" = \"\" ] || mkdir -p $(MYPY_CACHE)\n126: \t[ \"$(PYTHON_FILES)\" = \"\" ] || uv run mypy langgraph --cache-dir $(MYPY_CACHE)\n127: \n128: type:\n129: \tmkdir -p $(MYPY_CACHE) && uv run mypy langgraph --cache-dir $(MYPY_CACHE)\n130: \n131: format format_diff:\n132: \tuv run ruff format $(PYTHON_FILES)\n133: \tuv run ruff check --fix $(PYTHON_FILES)\n134: \n135: spell_check:\n136: \tuv run codespell --toml pyproject.toml\n137: \n138: spell_fix:\n139: \tuv run codespell --toml pyproject.toml -w\n140: \n141: \n142: ######################\n143: # HELP\n144: ######################\n145: \n146: help:\n147: \t@echo '===================='\n148: \t@echo '-- DOCUMENTATION --'\n149: \t\n150: \t@echo '-- LINTING --'\n151: \t@echo 'format                       - run code formatters'\n152: \t@echo 'lint                         - run linters'\n153: \t@echo 'type                         - run type checking'\n154: \t@echo 'spell_check               \t- run codespell on the project'\n155: \t@echo 'spell_fix               \t\t- run codespell on the project and fix the errors'\n156: \t@echo '-- TESTS --'\n157: \t@echo 'coverage                     - run unit tests and generate coverage report'\n158: \t@echo 'test                         - run unit tests'\n159: \t@echo 'test TEST_FILE=<test_file>   - run all tests in file'\n160: \t@echo 'test_watch                   - run unit tests in watch mode'\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":".PHONY: all format lint type test test_watch integration_tests spell_check spell_fix benchmark profile start-dev-server integration_tests\n\n# Default target executed when no arguments are given to make.\nall: help\n\n######################\n# TESTING AND COVERAGE\n######################\n\n# Benchmarks\n\nOUTPUT ?= out/benchmark.json\n\ninstall:  ## Install dependencies\n\tuv sync --frozen --all-extras --all-packages --group dev\n\nbenchmark:\n\tmkdir -p out\n\trm -f $(OUTPUT)\n\tuv run python -m bench -o $(OUTPUT) --rigorous","truncated":false,"loaded":[]},"title":"libs/langgraph/Makefile","time":{"start":1775799311409,"end":1775799311413}}}]}
