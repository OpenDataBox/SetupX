h.object(sys, \"argv\", testargs):\n574:         args = cli.parse_args(testargs)\n575: \n576:     f = io.StringIO()\n577:     with redirect_stdout(f):\n578:         cli.process_args(args)\n579:     if LANGID_FLAG:\n580:         assert f.getvalue().strip() == \"\"\n581:         args.target_language = \"en\"\n582:         f2 = io.StringIO()\n583:         with redirect_stdout(f2):\n584:             cli.process_args(args)\n585:         assert f2.getvalue().strip() == url\n586:     else:\n587:         assert f.getvalue().strip() == url\n588: \n589: \n590: if __name__ == \"__main__\":\n591:     test_parser()\n592:     test_climain()\n593:     test_input_type()\n594:     test_input_filtering()\n595:     test_sysoutput()\n596:     test_cli_pipeline()\n597:     test_file_processing()\n598:     test_cli_config_file()\n599:     test_crawling()\n600:     test_download()\n601:     test_probing()\n\n(End of file - total 601 lines)\n</content>","metadata":{"preview":"\"\"\"\nUnit tests for the command-line interface.\n\"\"\"\n\nimport io\nimport logging\nimport os\nimport re\nimport subprocess\nimport sys\n\nfrom contextlib import redirect_stdout\nfrom datetime import datetime\nfrom os import path\nfrom tempfile import gettempdir\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom courlan import UrlStore","truncated":false,"loaded":[]},"title":"tests/cli_tests.py","time":{"start":1775778166034,"end":1775778166043}}}]}
