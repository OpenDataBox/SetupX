{"type":"session_message","session_id":"ses_28b5fbb4bffe94OzzmB6XrWMxR","role":"assistant","message_id":"msg_d74a066d00012dMUrjRYuBK4hP","parts":[{"id":"prt_d74a07424001bi19IiL5Fb114i","messageID":"msg_d74a066d00012dMUrjRYuBK4hP","sessionID":"ses_28b5fbb4bffe94OzzmB6XrWMxR","type":"tool","tool":"read","callID":"call_9f32a2dd5a5e407086c81638","state":{"status":"completed","input":{"filePath":"/workspace/tests/cli_tests.py"},"output":"<path>/workspace/tests/cli_tests.py</path>\n<type>file</type>\n<content>1: \"\"\"\n2: Unit tests for the command-line interface.\n3: \"\"\"\n4: \n5: import io\n6: import logging\n7: import os\n8: import re\n9: import subprocess\n10: import sys\n11: \n12: from contextlib import redirect_stdout\n13: from datetime import datetime\n14: from os import path\n15: from tempfile import gettempdir\n16: from unittest.mock import patch\n17: \n18: import pytest\n19: \n20: from courlan import UrlStore\n21: \n22: from trafilatura import cli, cli_utils, spider, settings\n23: from trafilatura.downloads import add_to_compressed_dict, fetch_url\n24: from trafilatura.utils import LANGID_FLAG\n25: \n26: logging.basicConfig(stream=sys.stdout, level=logging.DEBUG)\n27: RESOURCES_DIR = path.join(path.abspath(path.dirname(__file__)), \"resources\")\n28: \n29: settings.MAX_FILES_PER_DIRECTORY = 1\n30: \n31: \n32: def test_parser():\n33:     \"\"\"test argument parsing for the command-line interface\"\"\"\n34:     testargs = [\"\", \"-fvv\", \"--xmltei\", \"--no-tables\", \"-u\", \"https://www.example.org\"]\n35:     with patch.object(sys, \"argv\", testargs):\n36:         args = cli.parse_args(testargs)\n37:     assert args.fast is True\n38:     assert args.verbose == 2\n39:     assert args.no_tables is False\n40:     assert args.xmltei is True\n41:     assert args.URL == \"https://www.example.org\"\n42:     args = cli.map_args(args)\n43:     assert args.output_format == \"xmltei\"\n44:     testargs = [\"\", \"--output-format\", \"csv\", \"--no-tables\", \"-u\", \"https://www.example.org\"]\n45:     with patch.object(sys, \"argv\", testargs):\n46:         args = cli.parse_args(testargs)\n47:     assert args.fast is False\n48:     assert args.verbose == 0\n49:     assert args.output_format == \"csv\"\n50:     assert args.no_tables is False\n51:     # test args mapping\n52:     testargs = [\"\", \"--markdown\"]\n53:     with patch.object(sys, \"argv\", testargs):\n54:         args = cli.parse_args(testargs)\n55:     args = cli.map_args(args)\n56:     assert args.output_format == \"markdown\"\n57:     testargs = [\"\", \"--xml\", \"--no-comments\", \"--precision\", \"--recall\"]\n58:     with patch.object(sys, \"argv\", testargs):\n59:         args = cli.parse_args(testargs)\n60:     args = cli.map_args(args)\n61:     assert args.output_format == \"xml\" and args.no_comments is False\n62:     # combination possible (?)\n63:     assert args.precision is True and args.recall is True\n64:     args.xml, args.csv = False, True\n65:     args = cli.map_args(args)\n66:     assert args.output_format == \"csv\"\n67:     args.csv, args.json = False, True\n68:     args = cli.map_args(args)\n69:     assert args.output_format == \"json\"\n70:     testargs = [\"\", \"--only-with-metadata\"]\n71:     with patch.object(sys, \"argv\", testargs):\n72:         args = cli.parse_args(testargs)\n73:     args = cli.map_args(args)\n74:     assert args.only_with_metadata is True\n75:     # process_args\n76:     args.input_dir = \"/dev/null\"\n77:     args.verbose = 1\n78:     args.blacklist = path.join(RESOURCES_DIR, \"list-discard.txt\")\n79:     cli.process_args(args)\n80:     assert len(args.blacklist) == 3\n81:     # filter\n82:     testargs = [\n83:         \"\",\n84:         \"-i\",\n85:         \"resources/list-discard.txt\",\n86:         \"--url-filter\",\n87:         \"test1\",\n88:         \"test2\",\n89:         \"-vvv\",\n90:     ]\n91:     with patch.object(sys, \"argv\", testargs):\n92:         args = cli.parse_args(testargs)\n93:     assert args.input_file == \"resources/list-discard.txt\"\n94:     assert args.url_filter == [\"test1\", \"test2\"]\n95:     args.input_file = path.join(RESOURCES_DIR, \"list-discard.txt\")\n96:     args.blacklist = path.join(RESOURCES_DIR, \"list-discard.txt\")\n97:     f = io.StringIO()\n98:     with redirect_stdout(f):\n99:         cli.process_args(args)\n100:     assert len(f.getvalue()) == 0\n101:     # input directory\n102:     testargs = [\"\", \"--input-dir\", \"resources/test/\"]\n103:     with patch.object(sys, \"argv\", testargs):\n104:         args = cli.parse_args(testargs)\n105:     f = io.StringIO()\n106:     with redirect_stdout(f):\n107:         cli.process_args(args)\n108:     assert len(f.getvalue()) == 0\n109:     # version\n110:     testargs = [\"\", \"--version\"]\n111:     with pytest.raises(SystemExit) as e, redirect_stdout(f):\n112:         with patch.object(sys, \"argv\", testargs):\n113:             args = cli.parse_args(testargs)\n114:     assert e.type == SystemExit\n115:     assert e.value.code == 0\n116:     assert re.match(\n117:         r\"Trafilatura [0-9]\\.[0-9]+\\.[0-9] - Python [0-9]\\.[0-9]+\\.[0-9]\", f.getvalue()\n118:     )\n119: \n120: \n121: def test_climain(capfd):\n122:     \"\"\"test arguments and main CLI entrypoint\"\"\"\n123:     # exit status required: 0\n124:     # Windows platforms\n125:     if os.name == \"nt\":\n126:         trafilatura_bin = path.join(sys.prefix, \"Scripts\", \"trafilatura\")\n127:     # other platforms\n128:     else:\n129:         trafilatura_bin = \"trafilatura\"\n130:     # help display\n131:     assert subprocess.run([trafilatura_bin, \"--help\"], check=True).returncode == 0\n132:     # piped input\n133:     empty_input = b\"<html><body><article>\" + b\"<p>ABC</p>\"*100 + b\"</article></body></html>\"\n134:     result = subprocess.run([trafilatura_bin], input=empty_input, check=True)\n135:     assert result.returncode == 0\n136:     captured = capfd.readouterr()\n137:     assert captured.out.strip().endswith(\"ABC\")\n138:     # input directory walking and processing\n139:     env = os.environ.copy()\n140:     if os.name == \"nt\":\n141:         # Force encoding to utf-8 for Windows (seem to be a problem only in GitHub Actions)\n142:         env[\"PYTHONIOENCODING\"] = \"utf-8\"\n143:     assert (\n144:         subprocess.run(\n145:             [trafilatura_bin, \"--input-dir\", RESOURCES_DIR], env=env, check=True\n146:         ).returncode\n147:         == 0\n148:     )\n149:     # compressed file\n150:     with open(path.join(RESOURCES_DIR, \"webpage.html.gz\"), \"rb\") as inputf:\n151:         compressed_input = inputf.read()\n152:     assert subprocess.run([trafilatura_bin], input=compressed_input, check=True).returncode == 0\n153:     captured = capfd.readouterr()\n154:     assert captured.out.strip().endswith(\"in deep-red West Virginia.\")\n155: \n156: \n157: def test_input_type():\n158:     \"\"\"test input type errors\"\"\"\n159:     testfile = \"docs/trafilatura-demo.gif\"\n160:     testargs = [\"\", \"-u\", \"http\"]\n161:     with patch.object(sys, \"argv\", testargs):\n162:         assert cli.main() is None\n163:     testargs = [\"\", \"-v\"]\n164:     with patch.object(sys, \"argv\", testargs):\n165:         args = cli.parse_args(testargs)\n166:     with open(testfile, \"rb\") as f:\n167:         teststring = f.read(1024)\n168:     assert cli.examine(teststring, args) is None\n169:     assert cli.examine([1, 2, 3], args) is None\n170:     testfile = \"docs/usage.rst\"\n171:     with open(testfile, \"r\", encoding=\"utf-8\") as f:\n172:         teststring = f.read()\n173:     assert cli.examine(teststring, args) is None\n174:     # test file list\n175:     assert 10 <= len(list(cli_utils.generate_filelist(RESOURCES_DIR))) <= 21\n176: \n177: \n178: def test_sysoutput():\n179:     \"\"\"test command-line output with respect to CLI arguments\"\"\"\n180:     testargs = [\"\", \"--csv\", \"-o\", \"/root/forbidden/\"]\n181:     with patch.object(sys, \"argv\", testargs):\n182:         args = cli.parse_args(testargs)\n183:     filepath, destdir = cli_utils.determine_output_path(args, args.output_dir, \"\")\n184:     assert len(filepath) >= 10 and filepath.endswith(\".csv\")\n185:     assert destdir == \"/root/forbidden/\"\n186:     # doesn't work the same on Windows\n187:     if os.name != \"nt\":\n188:         assert cli_utils.check_outputdir_status(args.output_dir) is False\n189:     else:\n190:         assert cli_utils.check_outputdir_status(args.output_dir) is True\n191:     testargs = [\"\", \"--xml\", \"-o\", \"/tmp/you-touch-my-tralala\"]\n192:     with patch.object(sys, \"argv\", testargs):\n193:         args = cli.parse_args(testargs)\n194:     assert cli_utils.check_outputdir_status(args.output_dir) is True\n195:     # test fileslug for name\n196:     filepath, destdir = cli_utils.determine_output_path(\n197:         args, args.output_dir, \"\", new_filename=\"AAZZ\"\n198:     )\n199:     assert filepath.endswith(\"AAZZ.xml\")\n200:     # test json output\n201:     args2 = args\n202:     args2.xml, args2.json = False, True\n203:     args2 = cli.map_args(args2)\n204:     filepath2, destdir2 = cli_utils.determine_output_path(\n205:         args, args.output_dir, \"\", new_filename=\"AAZZ\"\n206:     )\n207:     assert filepath2.endswith(\"AAZZ.json\")\n208:     assert \"you-touch-my-tralala\" in destdir2\n209:     # test directory counter\n210:     # doesn't work the same on Windows\n211:     if os.name != \"nt\":\n212:         assert cli_utils.determine_counter_dir(\"testdir\", 0) == \"testdir/1\"\n213:     else:\n214:         assert cli_utils.determine_counter_dir(\"testdir\", 0) == \"testdir\\\\1\"\n215:     # test file writing\n216:     testargs = [\"\", \"--markdown\", \"-o\", \"/dev/null/\", \"-b\", \"/dev/null/\"]\n217:     with patch.object(sys, \"argv\", testargs):\n218:         args = cli.parse_args(testargs)\n219:     result = \"DADIDA\"\n220:     cli_utils.write_result(result, args)\n221:     args.output_dir = gettempdir()\n222:     args.backup_dir = None\n223:     cli_utils.write_result(result, args)\n224:     # process with backup directory and no counter\n225:     options = settings.args_to_extractor(args)\n226:     assert options.format == \"markdown\" and options.formatting is True\n227:     assert cli_utils.process_result(\"DADIDA\", args, -1, options) == -1\n228: \n229:     # with counter\n230:     with open(\n231:         path.join(RESOURCES_DIR, \"httpbin_sample.html\"), \"r\", encoding=\"utf-8\"\n232:     ) as f:\n233:         teststring = f.read()\n234:     assert cli_utils.process_result(teststring, args, 1, options) == 2\n235: \n236:     # test keeping dir structure\n237:     testargs = [\"\", \"-i\", \"myinputdir/\", \"-o\", \"test/\", \"--keep-dirs\"]\n238:     with patch.object(sys, \"argv\", testargs):\n239:         args = cli.parse_args(testargs)\n240:     filepath, destdir = cli_utils.determine_output_path(args, \"testfile.txt\", \"\")\n241:     assert filepath == \"test/testfile.txt\"\n242:     # test hash as output file name\n243:     assert args.keep_dirs is True\n244:     args.keep_dirs = False\n245:     filepath, destdir = cli_utils.determine_output_path(args, \"testfile.txt\", \"\")\n246:     assert filepath == \"test/uOHdo6wKo4IK0pkL.txt\"\n247: \n248: \n249: def test_download():\n250:     \"\"\"test page download and command-line interface\"\"\"\n251:     assert cli_utils._define_exit_code([], 0) == 0\n252:     assert cli_utils._define_exit_code([\"a\"], 1) == 126\n253:     assert cli_utils._define_exit_code([\"a\"], 2) == 1\n254: \n255:     testargs = [\"\", \"-v\"]\n256:     with patch.object(sys, \"argv\", testargs):\n257:         args = cli.parse_args(testargs)\n258:     assert cli.examine(None, args) is None\n259:     assert cli.examine(\" \", args) is None\n260:     assert cli.examine(\"0\" * int(10e7), args) is None\n261:     # url = 'https://httpbun.org/status/200'\n262:     # teststring = fetch_url(url)\n263:     # assert teststring is None  # too small\n264:     # assert cli.examine(teststring, args, url) is None\n265:     # url = 'https://httpbun.org/links/2/2'\n266:     # teststring = fetch_url(url)\n267:     # assert teststring is not None\n268:     # assert cli.examine(teststring, args, url) is None\n269:     url = \"https://httpbun.com/html\"\n270:     teststring = fetch_url(url)\n271:     assert teststring is not None\n272:     assert cli.examine(teststring, args, url) is not None\n273:     # test exit code for faulty URLs\n274:     testargs = [\"\", \"-u\", \"https://1234.yz/\"]\n275:     with patch.object(sys, \"argv\", testargs):\n276:         args = cli.parse_args(testargs)\n277:     with pytest.raises(SystemExit) as e:\n278:         cli.process_args(args)\n279:     assert e.type == SystemExit and e.value.code == 126\n280: \n281: \n282: # @patch('trafilatura.settings.MAX_FILES_PER_DIRECTORY', 1)\n283: def test_cli_pipeline():\n284:     \"\"\"test command-line processing pipeline\"\"\"\n285:     # Force encoding to utf-8 for Windows in future processes spawned by multiprocessing.Pool\n286:     os.environ[\"PYTHONIOENCODING\"] = \"utf-8\"\n287: \n288:     # test URL listing\n289:     testargs = [\"\", \"--list\"]\n290:     with patch.object(sys, \"argv\", testargs):\n291:         args = cli.parse_args(testargs)\n292:     assert cli_utils.url_processing_pipeline(args, UrlStore()) is False\n293: \n294:     # test inputlist + blacklist\n295:     testargs = [\"\", \"-i\", path.join(RESOURCES_DIR, \"list-process.txt\")]\n296:     with patch.object(sys, \"argv\", testargs):\n297:         args = cli.parse_args(testargs)\n298:     my_urls = cli_utils.load_input_urls(args)\n299:     assert my_urls is not None and len(my_urls) == 3\n300:     testargs = [\n301:         \"\",\n302:         \"-i\",\n303:         path.join(RESOURCES_DIR, \"list-process.txt\"),\n304:         \"--blacklist\",\n305:         path.join(RESOURCES_DIR, \"list-discard.txt\"),\n306:         \"--archived\",\n307:     ]\n308:     with patch.object(sys, \"argv\", testargs):\n309:         args = cli.parse_args(testargs)\n310:     assert args.blacklist is not None\n311:     # test backoff between domain requests\n312:     url_store = add_to_compressed_dict(my_urls, args.blacklist, None, None)\n313:     reftime = datetime.now()\n314:     cli_utils.url_processing_pipeline(args, url_store)\n315:     delta = (datetime.now() - reftime).total_seconds()\n316:     assert delta > 2\n317:     # test blacklist and empty dict\n318:     args.blacklist = cli_utils.load_blacklist(args.blacklist)\n319:     assert len(args.blacklist) == 3\n320:     url_store = add_to_compressed_dict(my_urls, args.blacklist, None, None)\n321:     cli_utils.url_processing_pipeline(args, url_store)\n322:     # test backup\n323:     testargs = [\"\", \"--backup-dir\", \"/tmp/\"]\n324:     with patch.object(sys, \"argv\", testargs):\n325:         args = cli.parse_args(testargs)\n326:     cli_utils.archive_html(\"00Test\", args)\n327:     # test date-based exclusion\n328:     testargs = [\"\", \"--output-format\", \"xml\", \"--only-with-metadata\"]\n329:     with patch.object(sys, \"argv\", testargs):\n330:         args = cli.parse_args(testargs)\n331:     with open(\n332:         path.join(RESOURCES_DIR, \"httpbin_sample.html\"), \"r\", encoding=\"utf-8\"\n333:     ) as f:\n334:         teststring = f.read()\n335:     assert cli.examine(teststring, args) is None\n336:     testargs = [\"\", \"--output-format\", \"xml\", \"--only-with-metadata\", \"--precision\"]\n337:     with patch.object(sys, \"argv\", testargs):\n338:         args = cli.parse_args(testargs)\n339:     with open(\n340:         path.join(RESOURCES_DIR, \"httpbin_sample.html\"), \"r\", encoding=\"utf-8\"\n341:     ) as f:\n342:         teststring = f.read()\n343:     assert cli.examine(teststring, args) is None\n344:     # test JSON output\n345:     testargs = [\"\", \"--output-format\", \"json\", \"--recall\"]\n346:     with patch.object(sys, \"argv\", testargs):\n347:         args = cli.parse_args(testargs)\n348:     with open(\n349:         path.join(RESOURCES_DIR, \"httpbin_sample.html\"), \"r\", encoding=\"utf-8\"\n350:     ) as f:\n351:         teststring = f.read()\n352:     assert cli.examine(teststring, args) is not None\n353:     # sitemaps: tested in --explore\n354:     testargs = [\n355:         \"\",\n356:         \"--sitemap\",\n357:         \"https://sitemaps.org/sitemap.xml\",\n358:         \"--list\",\n359:         \"--parallel\",\n360:         \"1\",\n361:     ]\n362:     with patch.object(sys, \"argv\", testargs):\n363:         args = cli.parse_args(testargs)\n364:     f = io.StringIO()\n365:     with redirect_stdout(f):\n366:         cli.process_args(args)\n367:     assert f.getvalue().strip().endswith(\"https://www.sitemaps.org/zh_TW/terms.html\")\n368:     # CLI options\n369:     testargs = [\"\", \"--links\", \"--images\"]\n370:     with patch.object(sys, \"argv\", testargs):\n371:         args = cli.parse_args(testargs)\n372:     with open(\n373:         path.join(RESOURCES_DIR, \"http_sample.html\"), \"r\", encoding=\"utf-8\"\n374:     ) as f:\n375:         teststring = f.read()\n376:     result = cli.examine(teststring, args)\n377:     assert \"[link](testlink.html)\" in result and \"test.jpg\" in result\n378:     # HTML format as option\n379:     testargs = [\"\", \"--html\"]\n380:     with patch.object(sys, \"argv\", testargs):\n381:         args = cli.parse_args(testargs)\n382:     result = cli.examine(teststring, args)\n383:     assert result.startswith(\"<html\") and result.endswith(\"</html>\")\n384: \n385: \n386: def test_file_processing():\n387:     \"Test file processing pipeline on actual directories.\"\n388:     backup = settings.MAX_FILES_PER_DIRECTORY\n389:     settings.MAX_FILES_PER_DIRECTORY = 0\n390: \n391:     # dry-run file processing pipeline\n392:     testargs = [\"\", \"--parallel\", \"1\", \"--input-dir\", \"/dev/null\"]\n393:     with patch.object(sys, \"argv\", testargs):\n394:         args = cli.parse_args(testargs)\n395:     cli_utils.file_processing_pipeline(args)\n396:     # file processing pipeline on resources/\n397:     args.input_dir = RESOURCES_DIR\n398:     cli_utils.file_processing_pipeline(args)\n399:     # test manually\n400:     for f in cli_utils.generate_filelist(args.input_dir):\n401:         cli_utils.file_processing(f, args)\n402:     options = settings.args_to_extractor(args)\n403:     args.output_dir = \"/dev/null\"\n404:     for f in cli_utils.generate_filelist(args.input_dir):\n405:         cli_utils.file_processing(f, args, options=options)\n406: \n407:     settings.MAX_FILES_PER_DIRECTORY = backup\n408: \n409: \n410: def test_cli_config_file():\n411:     \"Test if the configuration file is loaded correctly from the CLI.\"\n412:     testargs = [\"\", \"--input-dir\", \"/dev/null\", \"--config-file\", \"newsettings.cfg\"]\n413:     with patch.object(sys, \"argv\", testargs):\n414:         args = cli.parse_args(testargs)\n415:     with open(\n416:         path.join(RESOURCES_DIR, \"httpbin_sample.html\"), \"r\", encoding=\"utf-8\"\n417:     ) as f:\n418:         teststring = f.read()\n419:     args.config_file = path.join(RESOURCES_DIR, args.config_file)\n420:     options = settings.args_to_extractor(args)\n421:     assert cli.examine(teststring, args, options=options) is None\n422: \n423: \n424: def test_input_filtering():\n425:     \"\"\"test internal functions to filter urls\"\"\"\n426:     testargs = [\"\"]\n427:     with patch.object(sys, \"argv\", testargs):\n428:         args = cli.parse_args(testargs)\n429: \n430:     # load dictionary\n431:     args.input_file = path.join(RESOURCES_DIR, \"list-process.txt\")\n432:     url_store = cli.load_input_dict(args)\n433:     assert len(url_store.find_known_urls(\"https://httpbin.org\")) == 3\n434:     args.input_file = path.join(RESOURCES_DIR, \"list-process.txt\")\n435:     args.blacklist = {\"httpbin.org/status/404\"}\n436:     url_store = cli.load_input_dict(args)\n437:     assert len(url_store.find_known_urls(\"https://httpbin.org\")) == 2\n438: \n439:     # deduplication and filtering\n440:     inputlist = [\n441:         \"https://example.org/1\",\n442:         \"https://example.org/2\",\n443:         \"https://example.org/2\",\n444:         \"https://example.org/3\",\n445:         \"https://example.org/4\",\n446:         \"https://example.org/5\",\n447:         \"https://example.org/6\",\n448:     ]\n449:     args.blacklist = {\"example.org/1\", \"example.org/3\", \"example.org/5\"}\n450:     url_store = add_to_compressed_dict(inputlist, blacklist=args.blacklist)\n451:     assert url_store.find_known_urls(\"https://example.org\") == [\n452:         \"https://example.org/2\",\n453:         \"https://example.org/4\",\n454:         \"https://example.org/6\",\n455:     ]\n456: \n457:     # URL in blacklist\n458:     args.input_file = path.join(RESOURCES_DIR, \"list-process.txt\")\n459:     my_urls = cli_utils.load_input_urls(args)\n460:     my_blacklist = cli_utils.load_blacklist(\n461:         path.join(RESOURCES_DIR, \"list-discard.txt\")\n462:     )\n463:     url_store = add_to_compressed_dict(my_urls, blacklist=my_blacklist)\n464:     assert len(url_store.dump_urls()) == 0\n465:     # other method\n466:     args.input_file = path.join(RESOURCES_DIR, \"list-process.txt\")\n467:     args.blacklist = path.join(RESOURCES_DIR, \"list-discard.txt\")\n468:     args.blacklist = cli_utils.load_blacklist(args.blacklist)\n469:     url_store = cli_utils.load_input_dict(args)\n470:     assert len(url_store.dump_urls()) == 0\n471: \n472:     # URL filter\n473:     args.input_file = path.join(RESOURCES_DIR, \"list-process.txt\")\n474:     my_urls = cli_utils.load_input_urls(args)\n475:     url_store = add_to_compressed_dict(\n476:         my_urls, blacklist=None, url_filter=[\"status\"], url_store=None\n477:     )\n478:     assert len(url_store.urldict) == 1\n479:     url_store = add_to_compressed_dict(\n480:         my_urls, blacklist=None, url_filter=[\"teststring\"], url_store=None\n481:     )\n482:     assert len(url_store.urldict) == 0\n483:     url_store = add_to_compressed_dict(\n484:         my_urls, blacklist=None, url_filter=[\"status\", \"teststring\"], url_store=None\n485:     )\n486:     assert len(url_store.urldict) == 1\n487: \n488:     # malformed URLs\n489:     url_store = add_to_compressed_dict([\"123345\", \"https://www.example.org/1\"])\n490:     assert len(url_store.urldict) == 1\n491: \n492:     # double URLs\n493:     args.input_file = path.join(RESOURCES_DIR, \"redundant-urls.txt\")\n494:     my_urls = cli_utils.load_input_urls(args)\n495:     url_store = add_to_compressed_dict(my_urls)\n496:     assert len(url_store.find_known_urls(\"https://example.org\")) == 1\n497: \n498:     # filter before exploration\n499:     input_store = add_to_compressed_dict(\n500:         [\"https://example.org/1\", \"https://sitemaps.org/test\"]\n501:     )\n502:     input_urls = [\"https://example.org\", \"http://sitemaps.org/\", \"https://test.info/\"]\n503:     url_store = cli_utils.build_exploration_dict(input_store, input_urls, args)\n504:     assert url_store.get_known_domains() == [\"https://test.info\"]\n505: \n506: \n507: def test_crawling():\n508:     \"Test crawling and exploration functions.\"\n509: \n510:     testargs = [\"\", \"--crawl\", \"\"]\n511:     with patch.object(sys, \"argv\", testargs):\n512:         args = cli.parse_args(testargs)\n513:     cli_utils.cli_crawler(args)\n514: \n515:     testargs = [\"\", \"--crawl\", \" \"]\n516:     with patch.object(sys, \"argv\", testargs):\n517:         args = cli.parse_args(testargs)\n518:     cli_utils.cli_crawler(args)\n519: \n520:     testargs = [\"\", \"--crawl\", \"https://httpbun.com/html\"]\n521:     with patch.object(sys, \"argv\", testargs):\n522:         args = cli.parse_args(testargs)\n523:     f = io.StringIO()\n524:     with redirect_stdout(f):\n525:         cli.process_args(args)\n526:     assert 