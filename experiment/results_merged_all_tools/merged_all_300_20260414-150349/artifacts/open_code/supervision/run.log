{"type":"session_message","session_id":"ses_28c5e8909fferNzL6qoAwJamOF","role":"assistant","message_id":"msg_d73a18d94001lNISzvy7wotvML","parts":[{"id":"prt_d73a19b40001ZiH9r1nmXsZS9c","messageID":"msg_d73a18d94001lNISzvy7wotvML","sessionID":"ses_28c5e8909fferNzL6qoAwJamOF","type":"tool","tool":"read","callID":"call_48fc6bab8bf84d36b50f3fa8","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: build-backend = \"setuptools.build_meta\"\n3: requires = [ \"setuptools>=61\" ]\n4: \n5: [project]\n6: name = \"supervision\"\n7: version = \"0.28.0rc0\"\n8: description = \"A set of easy-to-use utils that will come in handy in any Computer Vision project\"\n9: readme = \"README.md\"\n10: keywords = [\n11:   \"AI\",\n12:   \"deep-learning\",\n13:   \"DL\",\n14:   \"machine-learning\",\n15:   \"ML\",\n16:   \"Roboflow\",\n17:   \"vision\",\n18: ]\n19: license = \"MIT\"\n20: maintainers = [\n21:   { name = \"Piotr Skalski\", email = \"piotr@roboflow.com\" },\n22: ]\n23: authors = [\n24:   { name = \"Roboflow et al.\", email = \"develop@roboflow.com\" },\n25: ]\n26: requires-python = \">=3.9\"\n27: classifiers = [\n28:   \"Development Status :: 5 - Production/Stable\",\n29:   \"Intended Audience :: Developers\",\n30:   \"Intended Audience :: Education\",\n31:   \"Intended Audience :: Science/Research\",\n32:   \"Operating System :: MacOS\",\n33:   \"Operating System :: Microsoft :: Windows\",\n34:   \"Operating System :: POSIX :: Linux\",\n35:   \"Programming Language :: Python :: 3 :: Only\",\n36:   \"Programming Language :: Python :: 3.9\",\n37:   \"Programming Language :: Python :: 3.10\",\n38:   \"Programming Language :: Python :: 3.11\",\n39:   \"Programming Language :: Python :: 3.12\",\n40:   \"Programming Language :: Python :: 3.13\",\n41:   \"Programming Language :: Python :: 3.14\",\n42:   \"Topic :: Multimedia :: Graphics\",\n43:   \"Topic :: Multimedia :: Video\",\n44:   \"Topic :: Scientific/Engineering\",\n45:   \"Topic :: Scientific/Engineering :: Artificial Intelligence\",\n46:   \"Topic :: Scientific/Engineering :: Image Recognition\",\n47:   \"Topic :: Software Development\",\n48:   \"Typing :: Typed\",\n49: ]\n50: dependencies = [\n51:   \"defusedxml>=0.7.1\",\n52:   \"matplotlib>=3.6\",\n53:   \"numpy>=1.21.2\",\n54:   \"opencv-python>=4.5.5.64\",\n55:   \"pillow>=9.4\",\n56:   \"pyyaml>=5.3\",\n57:   \"requests>=2.26\",\n58:   \"scipy>=1.10\",\n59:   \"tqdm>=4.62.3\",\n60: ]\n61: optional-dependencies.metrics = [\n62:   \"pandas>=2\",\n63: ]\n64: urls.Documentation = \"https://supervision.roboflow.com/latest/\"\n65: urls.Homepage = \"https://github.com/roboflow/supervision\"\n66: urls.Repository = \"https://github.com/roboflow/supervision\"\n67: \n68: [dependency-groups]\n69: dev = [\n70:   \"docutils!=0.21\",\n71:   \"ipywidgets>=8.1.1\",\n72:   \"jupytext>=1.16.1\",\n73:   \"nbconvert>=7.14.2\",\n74:   \"notebook>=6.5.3,<8\",\n75:   \"pre-commit>=3.8\",\n76:   \"pytest>=7.2.2,<9\",\n77:   \"pytest-cov>=4,<8\",\n78:   \"tox>=4.11.4\",\n79: ]\n80: docs = [\n81:   \"mike>=2\",\n82:   \"mkdocs-git-committers-plugin-2>=2.4.1; python_version>='3.9' and python_version<'4'\",\n83:   \"mkdocs-git-revision-date-localized-plugin>=1.2.4\",\n84:   \"mkdocs-jupyter>=0.24.3\",\n85:   \"mkdocs-material[imaging]>=9.7\",\n86:   \"mkdocstrings>=0.25.2,<0.31\",\n87:   \"mkdocstrings-python>=1.10.9,<2\",                                                      # todo: breaking changes in 2.x\n88: ]\n89: build = [\n90:   \"build>=0.10,<1.5\",\n91:   \"twine>=5.1.1,<7\",\n92:   \"wheel>=0.40,<0.47\",\n93: ]\n94: \n95: [tool.setuptools]\n96: include-package-data = false\n97: package-data.supervision = [ \"py.typed\" ]\n98: packages.find.where = [ \"src\" ]\n99: packages.find.include = [ \"supervision*\" ]\n100: \n101: # exclude = [ \"docs*\", \"tests*\", \"examples*\" ]\n102: [tool.ruff]\n103: target-version = \"py39\"\n104: line-length = 88\n105: indent-width = 4\n106: # Exclude a variety of commonly ignored directories.\n107: exclude = [\n108:   \".bzr\",\n109:   \".direnv\",\n110:   \".eggs\",\n111:   \".git\",\n112:   \".git-rewrite\",\n113:   \".hg\",\n114:   \".mypy_cache\",\n115:   \".nox\",\n116:   \".pants.d\",\n117:   \".pytype\",\n118:   \".ruff_cache\",\n119:   \".svn\",\n120:   \".tox\",\n121:   \".venv\",\n122:   \"__pypackages__\",\n123:   \"_build\",\n124:   \"buck-out\",\n125:   \"build\",\n126:   \"dist\",\n127:   \"docs\",\n128:   \"node_modules\",\n129:   \"venv\",\n130:   \"yarn-error.log\",\n131:   \"yarn.lock\",\n132: ]\n133: # Like Black, indent with spaces, rather than tabs.\n134: format.indent-style = \"space\"\n135: # Like Black, use double quotes for strings.\n136: format.quote-style = \"double\"\n137: # Like Black, automatically detect the appropriate line ending.\n138: format.line-ending = \"auto\"\n139: # Like Black, respect magic trailing commas.\n140: format.skip-magic-trailing-comma = false\n141: # Enable linting rules for code style, imports, and best practices.\n142: lint.select = [\n143:   \"A\",   # flake8-builtins - https://docs.astral.sh/ruff/rules/#flake8-builtins-a\n144:   \"E\",   # pycodestyle errors - https://docs.astral.sh/ruff/rules/#error-e\n145:   \"F\",   # Pyflakes - https://docs.astral.sh/ruff/rules/#pyflakes-f\n146:   \"I\",   # isort - https://docs.astral.sh/ruff/rules/#isort-i\n147:   \"PT\",  # pytest - https://docs.astral.sh/ruff/rules/#flake8-pytest-style-pt\n148:   \"Q\",   # flake8-quotes - https://docs.astral.sh/ruff/rules/#flake8-quotes-q\n149:   \"RUF\", # Ruff-specific rules - https://docs.astral.sh/ruff/rules/#ruff-specific-rules-ruf\n150:   \"S\",   # bandit - https://docs.astral.sh/ruff/rules/#flake8-bandit-s\n151:   \"UP\",  # pyupgrade - https://docs.astral.sh/ruff/rules/#pyupgrade-up\n152:   \"W\",   # pycodestyle warnings - https://docs.astral.sh/ruff/rules/#pycodestyle-w\n153: ]\n154: lint.ignore = []\n155: lint.per-file-ignores.\"__init__.py\" = [ \"E402\", \"F401\" ]\n156: lint.per-file-ignores.\"src/**\" = [\n157:   \"S101\", # TODO: Replace asserts with proper error handling\n158: ]\n159: lint.per-file-ignores.\"tests/**\" = [\n160:   \"S101\", # Use of `assert` detected\n161: ]\n162: lint.unfixable = []\n163: # Allow unused variables when underscore-prefixed.\n164: lint.dummy-variable-rgx = \"^(_+|(_+[a-zA-Z0-9_]*[a-zA-Z0-9]+?))$\"\n165: lint.flake8-quotes.docstring-quotes = \"double\"\n166: lint.flake8-quotes.inline-quotes = \"double\"\n167: lint.flake8-quotes.multiline-quotes = \"double\"\n168: lint.isort.no-sections = false\n169: lint.isort.order-by-type = true\n170: # Flag errors (`C901`) whenever the complexity level exceeds 5.\n171: lint.mccabe.max-complexity = 20\n172: lint.pydocstyle.convention = \"google\"\n173: lint.pylint.max-args = 20\n174: \n175: [tool.codespell]\n176: skip = \"*.ipynb\"\n177: count = true\n178: quiet-level = 3\n179: ignore-words-list = \"STrack,sTrack,strack\"\n180: \n181: [tool.mypy]\n182: python_version = \"3.9\"\n183: ignore_missing_imports = false\n184: explicit_package_bases = true\n185: strict = true\n186: mypy_path = \"src\"\n187: overrides = [\n188:   # exclude = [\n189:   #  \"docs\",\n190:   #  \"test\",\n191:   #  \"examples\",\n192:   #  \"setup.py\",\n193:   # ]\n194:   { module = [\n195:     \"tests.*\",\n196:     \"examples.*\",\n197:   ], ignore_errors = true },\n198: ]\n199: \n200: [tool.pytest]\n201: ini_options.addopts = [\n202:   \"--doctest-modules\",\n203:   \"--color=yes\",\n204: ]\n205: ini_options.doctest_optionflags = \"ELLIPSIS NORMALIZE_WHITESPACE\"\n206: \n207: [tool.autoflake]\n208: check = true\n209: imports = [ \"cv2\", \"supervision\" ]\n\n(End of file - total 209 lines)\n</content>","metadata":{"preview":"[build-system]\nbuild-backend = \"setuptools.build_meta\"\nrequires = [ \"setuptools>=61\" ]\n\n[project]\nname = \"supervision\"\nversion = \"0.28.0rc0\"\ndescription = \"A set of easy-to-use utils that will come in handy in any Computer Vision project\"\nreadme = \"README.md\"\nkeywords = [\n  \"AI\",\n  \"deep-learning\",\n  \"DL\",\n  \"machine-learning\",\n  \"ML\",\n  \"Roboflow\",\n  \"vision\",\n]\nlicense = \"MIT\"\nmaintainers = [","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775761464420,"end":1775761464427}}}]}
