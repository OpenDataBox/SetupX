{"type":"session_message","session_id":"ses_28919c1ddffePC2i5DMhxqi0Ur","role":"assistant","message_id":"msg_d76e65702001oiZzOuXMXvKIYW","parts":[{"id":"prt_d76e6642c001KbKlfXN2nsHJJG","messageID":"msg_d76e65702001oiZzOuXMXvKIYW","sessionID":"ses_28919c1ddffePC2i5DMhxqi0Ur","type":"tool","tool":"read","callID":"call_0c377b26b5e9460d9f196e65","state":{"status":"completed","input":{"filePath":"/workspace/justfile"},"output":"<path>/workspace/justfile</path>\n<type>file</type>\n<content>1: # SPDX-FileCopyrightText: 2025-present Tobias Kunze\n2: # SPDX-License-Identifier: Apache-2.0\n3: \n4: set shell := [\"bash\", \"-euo\", \"pipefail\", \"-c\"]\n5: set quiet\n6: \n7: _ := require(\"uv\")\n8: python := \"uv run python\"\n9: uv_dev := \"uv run --extra=dev\"\n10: uv_devdocs := \"uv run --extra=devdocs\"\n11: src_dir := \"src\"\n12: \n13: [private]\n14: default:\n15:     just --list\n16: \n17: # Install dependencies (use --extras to include e.g. dev, devdocs, postgres, redis)\n18: [group('development')]\n19: install *args:\n20:     uv lock --upgrade\n21:     uv sync {{ args }}\n22: \n23: # Install all dependencies (dev, devdocs, postgres, redis)\n24: [group('development')]\n25: install-all:\n26:     uv lock --upgrade\n27:     uv sync --all-extras\n28: \n29: # Set up development environment (install deps, database, test event, start server)\n30: [group('development')]\n31: dev-setup: install-all\n32:     just run collectstatic --noinput\n33:     just run compilemessages\n34:     just run migrate\n35:     just run createsuperuser\n36:     uv pip install faker\n37:     just run create_test_event\n38:     just run\n39: \n40: # Install npm dependencies for the schedule editor frontend\n41: [group('development')]\n42: [working-directory(\"src/pretalx/frontend/schedule-editor/\")]\n43: install-npm:\n44:     npm ci\n45: \n46: # Install a plugin\n47: [group('development')]\n48: install-plugin path=\"\":\n49:     uv pip install -e {{ path }}\n50: \n51: # Check for outdated dependencies\n52: [group('development')]\n53: [script('python3')]\n54: deps-outdated:\n55:     import json, subprocess, tomllib\n56:     from packaging.requirements import Requirement\n57: \n58:     result = subprocess.run(['uv', 'pip', 'list', '--outdated', '--format=json'], capture_output=True, text=True)\n59:     outdated = {p['name'].lower(): p for p in json.loads(result.stdout)}\n60:     deps = tomllib.load(open('pyproject.toml', 'rb')).get('project', {}).get('dependencies', [])\n61:     direct = {Requirement(d).name.lower() for d in deps}\n62: \n63:     for name in sorted(outdated.keys() & direct):\n64:         p = outdated[name]\n65:         print(f\"{p['name']}: {p['version']} → {p['latest_version']}\")\n66: \n67: # Bump a dependency version\n68: [group('development')]\n69: [script('python3')]\n70: deps-bump package version:\n71:     import subprocess, tomllib\n72:     from pathlib import Path\n73:     from packaging.requirements import Requirement\n74: \n75:     p = Path('pyproject.toml')\n76:     deps = tomllib.load(open('pyproject.toml', 'rb')).get('project', {}).get('dependencies', [])\n77:     old = next((d for d in deps if Requirement(d).name.lower() == '{{ package }}'.lower()), None)\n78:     if old:\n79:         p.write_text(p.read_text().replace(old, f'{Requirement(old).name}~={{ version }}'))\n80:     subprocess.run(['uv', 'lock', '--upgrade-package', '{{ package }}'])\n81: \n82: \n83: # Run the development server or other commands, e.g. `just run makemigrations`\n84: [group('development')]\n85: [working-directory(\"src\")]\n86: run *args=\"runserver --skip-checks\":\n87:     {{ python }} manage.py {{ args }}\n88: \n89: # Update translation files\n90: [group('development')]\n91: [working-directory(\"src\")]\n92: makemessages:\n93:     just run rebuild --npm-install\n94:     just run makemessages --keep-pot --all\n95: \n96: # Run the background task worker\n97: [group('development')]\n98: [working-directory(\"src\")]\n99: worker:\n100:     uv run celery -A pretalx.celery_app worker -l info\n101: \n102: # Clean documentation build artifacts\n103: [group('documentation')]\n104: [working-directory(\"doc\")]\n105: @docs-clean:\n106:     rm -rf _build/*\n107: \n108: # Build documentation (use `just docs-build dirhtml` for production)\n109: [group('documentation')]\n110: [working-directory(\"doc\")]\n111: docs-build format=\"html\" *args:\n112:     just clean\n113:     {{ uv_devdocs }} python -m sphinx -b {{ format }} -d _build/doctrees . _build/{{ format }} -j auto -a -q {{ args }}\n114: \n115: # Build and deploy documentation to a target directory\n116: [group('documentation')]\n117: docs-deploy target:\n118:     just docs-build dirhtml\n119:     rsync -avu --delete doc/_build/dirhtml/ {{ target }}\n120: \n121: # Check documentation for broken links\n122: [group('documentation')]\n123: [working-directory(\"doc\")]\n124: docs-linkcheck:\n125:     {{ uv_devdocs }} python -m sphinx -b linkcheck -d _build/doctrees . _build/linkcheck\n126: \n127: # Serve the documentation from a live server\n128: [group('documentation')]\n129: [working-directory(\"doc\")]\n130: docs-serve *args=\"--port 8001\":\n131:     rm -rf _build/html\n132:     {{ uv_devdocs }} sphinx-autobuild . _build/html -q {{ args }}\n133: \n134: # Update the API documentation\n135: [group('documentation')]\n136: api-docs:\n137:     just run spectacular --color --file ../doc/api/schema.yml\n138: \n139: # Check codebase for licensing compliance\n140: [group('linting')]\n141: reuse:\n142:     uvx reuse lint\n143: \n144: # Check Django templates with djhtml (check only)\n145: [group('linting')]\n146: djhtml-check:\n147:     just djhtml --check\n148: \n149: # Format Django templates with djhtml\n150: [group('linting')]\n151: djhtml *args=\"\":\n152:     find src -name \"*.html\" -not -path '*/vendored/*' -not -path '*/node_modules/*' -not -path '*/htmlcov/*' -not -path '*/local/*' -not -path '*dist/*' -not -path \"*.min.html\" -not -path '*/pretalx-schedule' -print | xargs {{ uv_dev }} djhtml {{ args }}\n153: \n154: # Run ruff format\n155: [group('linting')]\n156: format *args=\"\":\n157:     {{ uv_dev }} ruff format {{ args }}\n158: \n159: # Run ruff check\n160: [group('linting')]\n161: check *args=\"\":\n162:     {{ uv_dev }} ruff check {{ args }}\n163: \n164: # Run all formatters and linters\n165: [group('linting')]\n166: [parallel]\n167: fmt: format (check \"--fix\") djhtml\n168: \n169: # Run all code quality checks\n170: [group('linting')]\n171: fmt-check: (format \"--check\") check\n172: \n173: # Check for untrimmed blocktranslate tags\n174: [group('linting')]\n175: blocktranslate-check:\n176:     ! git grep ' blocktranslate ' -- '*.html' | grep -v trimmed\n177: \n178: # Check documentation for spelling errors\n179: [group('documentation')]\n180: [working-directory(\"doc\")]\n181: docs-spelling:\n182:     {{ uv_devdocs }} python -m sphinx -b spelling -d _build/doctrees . _build/spelling\n183:     ! find _build -type f -name '*.spelling' | grep -q .\n184: \n185: # Run most CI checks\n186: [group('tests')]\n187: ci: fmt reuse blocktranslate-check docs-spelling (run \"compilemessages\") install-npm release-checks test-parallel && _ci-done\n188: \n189: [private]\n190: _ci-done:\n191:     echo '{{ GREEN }}All CI checks passed{{ NORMAL }}'\n192: \n193: # Open Django shell scoped to a specific event if given\n194: [group('development')]\n195: [no-exit-message]\n196: shell event=\"\" *args:\n197:     just run shell {{ if event == \"\" { \"--unsafe-disable-scopes\" } else { \"--event \" + event } }} {{ args }}\n198: \n199: # Open Django shell with all scopes disabled (unsafe, full database access)\n200: [group('development')]\n201: [no-exit-message]\n202: [positional-arguments]\n203: [working-directory(\"src\")]\n204: python *args:\n205:     {{ python }} manage.py shell --no-pretalx-information --unsafe-disable-scopes \"$@\"\n206: \n207: # Remove Python caches, build artifacts, and coverage reports\n208: [group('development')]\n209: clean:\n210:     -find . -type d -name __pycache__ -exec rm -rf {} +\n211:     -find . -type f -name \"*.pyc\" -delete\n212:     -find . -type d -name \"*.egg-info\" -exec rm -rf {} +\n213:     -rm -rf .pytest_cache .coverage htmlcov dist build\n214:     -just docs-clean\n215: \n216: # Run the test suite\n217: [group('tests')]\n218: [positional-arguments]\n219: test *args:\n220:     {{ uv_dev }} --extra=devdocs pytest \"$@\"; status=$?; git checkout -- src/pretalx/locale; exit $status\n221: \n222: # Run tests in parallel (requires pytest-xdist)\n223: [group('tests')]\n224: [positional-arguments]\n225: test-parallel n=\"auto\" *args:\n226:     shift; just test -n {{ n }} \"$@\"\n227: \n228: # Run tests with coverage report\n229: [group('tests')]\n230: [positional-arguments]\n231: test-coverage *args:\n232:     just test --cov=src --cov-report=term-missing:skip-covered --cov-config=pyproject.toml \"$@\"\n233: \n234: # Run tests for a given app and filter the coverage report\n235: [group('tests')]\n236: [positional-arguments]\n237: test-app-coverage app=\"\" *args:\n238:     shift; {{ uv_dev }} pytest --cov=src --cov-report=term-missing:skip-covered --cov-config=pyproject.toml src/tests/{{ app }} \"$@\" | ag \"/{{ app }}/\"\n239: \n240: # Show test coverage report in browser\n241: [group('tests')]\n242: test-coverage-report: test-coverage\n243:     #!/usr/bin/env sh\n244:     if [ -f \"src/htmlcov/index.html\" ]; then\n245:         open src/htmlcov/index.html 2>/dev/null || \\\n246:         xdg-open src/htmlcov/index.html 2>/dev/null || \\\n247:         echo \"Coverage report: src/htmlcov/index.html\"\n248:     else\n249:         echo \"No coverage report found. Run just test-coverage first.\"\n250:     fi\n251: \n252: # Run release checks\n253: [group('release')]\n254: release-checks:\n255:     uv run check-manifest\n256:     rm -rf dist\n257:     {{ python }} -m build\n258:     uv run twine check dist/*\n259:     unzip -l dist/pretalx*whl | grep frontend || exit 1\n260:     unzip -l dist/pretalx*whl | grep node_modules && exit 1 || exit 0\n261:     echo \"{{ GREEN }}All release checks successful{{ NORMAL }}\"\n262: \n263: # Release a new pretalx version\n264: [group('release')]\n265: [confirm(\"This will publish to PyPI and push tags. Continue?\")]\n266: [arg('version', pattern='\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?')]\n267: release version:\n268:     uv pip install build\n269:     git commit -am \"Release {{ version }}\"\n270:     git tag -m \"Release {{ version }}\" {{ version }}\n271:     rm -rf dist/ build/ pretalx.egg-info\n272:     {{ python }} -m build -n\n273:     uvx twine upload dist/pretalx-*\n274:     git push\n275:     git push --tags\n\n(End of file - total 275 lines)\n</content>","metadata":{"preview":"# SPDX-FileCopyrightText: 2025-present Tobias Kunze\n# SPDX-License-Identifier: Apache-2.0\n\nset shell := [\"bash\", \"-euo\", \"pipefail\", \"-c\"]\nset quiet\n\n_ := require(\"uv\")\npython := \"uv run python\"\nuv_dev := \"uv run --extra=dev\"\nuv_devdocs := \"uv run --extra=devdocs\"\nsrc_dir := \"src\"\n\n[private]\ndefault:\n    just --list\n\n# Install dependencies (use --extras to include e.g. dev, devdocs, postgres, redis)\n[group('development')]\ninstall *args:\n    uv lock --upgrade","truncated":false,"loaded":[]},"title":"justfile","time":{"start":1775816303952,"end":1775816303957}}}]}
