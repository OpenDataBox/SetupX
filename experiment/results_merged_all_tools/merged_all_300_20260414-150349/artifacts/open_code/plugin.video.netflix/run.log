{"type":"session_message","session_id":"ses_28b0a4ba4ffe21O4BCcP31nHt7","role":"assistant","message_id":"msg_d74f5cd1f001wZVP3dc6nPWbC9","parts":[{"id":"prt_d74f5d842001ojvHEY05iWfAH9","messageID":"msg_d74f5cd1f001wZVP3dc6nPWbC9","sessionID":"ses_28b0a4ba4ffe21O4BCcP31nHt7","type":"tool","tool":"read","callID":"call_5904ddf9bc0943e28bc18edb","state":{"status":"completed","input":{"filePath":"/workspace/Makefile"},"output":"<path>/workspace/Makefile</path>\n<type>file</type>\n<content>1: export PYTHONPATH := .:$(CURDIR)/test\n2: PYTHON := python\n3: KODI_PYTHON_ABIS := 3.0.0 2.26.0\n4: \n5: name = $(shell xmllint --xpath 'string(/addon/@id)' addon.xml)\n6: version = $(shell xmllint --xpath 'string(/addon/@version)' addon.xml)\n7: git_branch = $(shell git rev-parse --abbrev-ref HEAD)\n8: git_hash = $(shell git rev-parse --short HEAD)\n9: matrix = $(findstring $(shell xmllint --xpath 'string(/addon/requires/import[@addon=\"xbmc.python\"]/@version)' addon.xml), $(word 1,$(KODI_PYTHON_ABIS)))\n10: \n11: ifdef release\n12: \tzip_name = $(name)-$(version).zip\n13: else\n14: \tzip_name = $(name)-$(version)-$(git_branch)-$(git_hash).zip\n15: endif\n16: \n17: include_files = addon.py addon.xml LICENSE.txt README.md resources/ service.py\n18: include_paths = $(patsubst %,$(name)/%,$(include_files))\n19: exclude_files = \\*.new \\*.orig \\*.pyc \\*.pyo\n20: zip_dir = $(name)/\n21: \n22: languages = $(filter-out en_gb, $(patsubst resources/language/resource.language.%, %, $(wildcard resources/language/*)))\n23: \n24: blue = \\e[1;34m\n25: white = \\e[1;37m\n26: reset = \\e[0m\n27: \n28: all: check test build\n29: zip: build\n30: test: check test-unit test-service test-run\n31: \n32: check: check-tox check-pylint check-translations\n33: \n34: check-tox:\n35: \t@echo -e \"$(white)=$(blue) Starting sanity tox test$(reset)\"\n36: \t$(PYTHON) -m tox -q -e\n37: \n38: check-pylint:\n39: \t@echo -e \"$(white)=$(blue) Starting sanity pylint test$(reset)\"\n40: \t$(PYTHON) -m pylint resources/lib/ tests/\n41: \n42: check-translations:\n43: \t@echo -e \"$(white)=$(blue) Starting language test$(reset)\"\n44: \t@-$(foreach lang,$(languages), \\\n45: \t\tmsgcmp resources/language/resource.language.$(lang)/strings.po resources/language/resource.language.en_gb/strings.po; \\\n46: \t)\n47: \n48: update-translations:\n49: \t@echo -e \"$(white)=$(blue) Updating languages$(reset)\"\n50: \t@-$(foreach lang,$(languages), \\\n51: \t\ttests/update_translations.py resources/language/resource.language.$(lang)/strings.po resources/language/resource.language.en_gb/strings.po; \\\n52: \t)\n53: \n54: check-addon: clean\n55: \t@echo -e \"$(white)=$(blue) Starting sanity addon tests$(reset)\"\n56: \tkodi-addon-checker --branch=leia\n57: \n58: unit: test-unit\n59: run: test-run\n60: \n61: test-unit: clean\n62: \t@echo -e \"$(white)=$(blue) Starting unit tests$(reset)\"\n63: \t$(PYTHON) -m unittest discover\n64: \n65: test-run:\n66: \t@echo -e \"$(white)=$(blue) Run CLI$(reset)\"\n67: \tcoverage run -a tests/run.py /action/purge_cache/\n68: \tcoverage run -a tests/run.py /action/purge_cache/?on_disk=True\n69: \tcoverage run -a service.py &\n70: \tsleep 10\n71: \tcoverage run -a tests/run.py /directory/root\n72: \tcoverage run -a tests/run.py /directory/profiles\n73: \tcoverage run -a tests/run.py /directory/home\n74: \tcoverage run -a tests/run.py /directory/video_list_sorted/myList/queue\n75: \tcoverage run -a tests/run.py /directory/video_list_sorted/newRelease/newRelease\n76: \tcoverage run -a tests/run.py /directory/video_list/continueWatching/continueWatching\n77: \tcoverage run -a tests/run.py /directory/video_list/chosenForYou/topTen\n78: \tcoverage run -a tests/run.py /directory/video_list/recentlyAdded/1592210\n79: \tcoverage run -a tests/run.py /directory/show/80057281/\n80: \tcoverage run -a tests/run.py /directory/show/80057281/season/80186799/\n81: \tcoverage run -a tests/run.py /directory/genres/tvshows/83/\n82: \tcoverage run -a tests/run.py /directory/genres/movies/34399/\n83: \tcoverage run -a tests/run.py /directory/search/search/cool\n84: \tcoverage run -a tests/run.py /directory/exported/exported\n85: \tpkill -ef service.py\n86: \n87: build: clean\n88: \t@echo -e \"$(white)=$(blue) Building new package$(reset)\"\n89: \t@rm -f ../$(zip_name)\n90: \tcd ..; zip -r $(zip_name) $(include_paths) -x $(exclude_files)\n91: \t@echo -e \"$(white)=$(blue) Successfully wrote package as: $(white)../$(zip_name)$(reset)\"\n92: \n93: multizip: clean\n94: \t@-$(foreach abi,$(KODI_PYTHON_ABIS), \\\n95: \t\techo \"cd /addon/requires/import[@addon='xbmc.python']/@version\\nset $(abi)\\nsave\\nbye\" | xmllint --shell addon.xml; \\\n96: \t\tmatrix=$(findstring $(abi), $(word 1,$(KODI_PYTHON_ABIS))); \\\n97: \t\tif [ $$matrix ]; then version=$(version)+matrix.1; else version=$(version); fi; \\\n98: \t\techo \"cd /addon/@version\\nset $$version\\nsave\\nbye\" | xmllint --shell addon.xml; \\\n99: \t\tmake build; \\\n100: \t)\n101: \n102: clean:\n103: \t@echo -e \"$(white)=$(blue) Cleaning up$(reset)\"\n104: \tfind . -name '*.py[cod]' -type f -delete\n105: \tfind . -name __pycache__ -type d -delete\n106: \trm -rf .pytest_cache/ .tox/\n107: \trm -f *.log\n\n(End of file - total 107 lines)\n</content>","metadata":{"preview":"export PYTHONPATH := .:$(CURDIR)/test\nPYTHON := python\nKODI_PYTHON_ABIS := 3.0.0 2.26.0\n\nname = $(shell xmllint --xpath 'string(/addon/@id)' addon.xml)\nversion = $(shell xmllint --xpath 'string(/addon/@version)' addon.xml)\ngit_branch = $(shell git rev-parse --abbrev-ref HEAD)\ngit_hash = $(shell git rev-parse --short HEAD)\nmatrix = $(findstring $(shell xmllint --xpath 'string(/addon/requires/import[@addon=\"xbmc.python\"]/@version)' addon.xml), $(word 1,$(KODI_PYTHON_ABIS)))\n\nifdef release\n\tzip_name = $(name)-$(version).zip\nelse\n\tzip_name = $(name)-$(version)-$(git_branch)-$(git_hash).zip\nendif\n\ninclude_files = addon.py addon.xml LICENSE.txt README.md resources/ service.py\ninclude_paths = $(patsubst %,$(name)/%,$(include_files))\nexclude_files = \\*.new \\*.orig \\*.pyc \\*.pyo\nzip_dir = $(name)/","truncated":false,"loaded":[]},"title":"Makefile","time":{"start":1775783762276,"end":1775783762280}}}]}
