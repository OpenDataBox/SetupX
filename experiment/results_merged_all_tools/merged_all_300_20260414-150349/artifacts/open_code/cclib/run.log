pts.ccget:ccget\"\n42: ccwrite = \"cclib.scripts.ccwrite:main\"\n43: cda = \"cclib.scripts.cda:main\"\n44: \n45: [project.optional-dependencies]\n46: bridges = [\n47:     \"ase>=3.21\",\n48:     \"biopython\",\n49:     \"chemfiles\",\n50:     \"pandas\",\n51:     \"pyscf\",\n52:     \"pyberny\",\n53:     \"geometric\",\n54:     \"qc-iodata>=1.0.0a2\",\n55: ]\n56: docs = [\n57:     \"sphinx\",\n58:     \"sphinx_rtd_theme\",\n59: ]\n60: test-infrastructure = [\n61:     \"pytest\",\n62:     \"coverage\",\n63:     \"pytest-cov\",\n64:     \"pyyaml\",\n65: ]\n66: test = [\"cclib[bridges,docs,test-infrastructure]\"]\n67: dev = [\"cclib[bridges,docs,test-infrastructure]\"]\n68: all = [\"cclib[bridges]\"]\n69: \n70: [build-system]\n71: requires = [\n72:     \"setuptools>=61.0\",\n73:     \"versioningit>=2.0\",\n74: ]\n75: build-backend = \"setuptools.build_meta\"\n76: \n77: [tool.setuptools]\n78: zip-safe = false\n79: \n80: [tool.setuptools.package-dir]\n81: cclib = \"cclib\"\n82: \n83: [tool.coverage.run]\n84: branch = true\n85: \n86: [tool.isort]\n87: profile = \"black\"\n88: line_length = 100\n89: # default is FUTURE,STDLIB,THIRDPARTY,FIRSTPARTY,LOCALFOLDER\n90: # Placing third-party imports at the end makes their inclusion more obvious\n91: sections = [\"FUTURE\", \"STDLIB\", \"FIRSTPARTY\", \"THIRDPARTY\", \"LOCALFOLDER\"]\n92: \n93: [tool.ruff]\n94: line-length = 100\n95: src = [\"cclib\"]\n96: target-version = \"py37\"\n97: \n98: [tool.ruff.format]\n99: skip-magic-trailing-comma = true\n100: \n101: [tool.ruff.lint]\n102: \n103: \n104: [tool.ruff.lint.isort]\n105: lines-after-imports = 2\n106: section-order = [\"future\", \"standard-library\", \"first-party\", \"third-party\", \"local-folder\"]\n107: \n108: [tool.ruff.lint.per-file-ignores]\n109: \"test/test*.py\" = [\n110:     \"PLR2004\", # magic value comparison\n111:     \"S101\",    # use of assert detected\n112:     \"TCH002\",  # third party import (for pytest)\n113: ]\n114: \n115: [tool.mypy]\n116: disable_error_code = [\n117:     \"attr-defined\",\n118: ]\n119: disallow_incomplete_defs = true\n120: disallow_untyped_defs = true\n121: enable_error_code = [\n122:     \"ignore-without-code\",\n123: ]\n124: strict = true\n125: \n126: [[tool.mypy.overrides]]\n127: module = [\n128:     \"Bio.PDB.Atom\",\n129:     \"Bio.PDB.Superimposer\",\n130:     \"PyQuante.CGBF\",\n131:     \"PyQuante.Molecule\",\n132:     \"PyQuante.hartree_fock\",\n133:     \"ase\",\n134:     \"ase.calculators.calculator\",\n135:     \"ase.calculators.emt\",\n136:     \"ase.io.trajectory\",\n137:     \"h5py\",\n138:     \"horton\",\n139:     \"horton.io.iodata\",\n140:     \"iodata\",\n141:     \"iodata.api\",\n142:     \"iodata.orbitals\",\n143:     \"openbabel\",\n144:     \"openbabel.pybel\",\n145:     \"periodictable\",\n146:     \"psi4\",\n147:     \"psi4.core\",\n148:     \"pybel\",\n149:     \"pyquante2\",\n150:     \"pyscf\",\n151:     \"pyscf.geomopt.berny_solver\",\n152:     \"pyscf.geomopt.geometric_solver\",\n153:     \"pyscf.prop\",\n154:     \"pyvtk\",\n155:     \"pyvtk.DataSetAttr\",\n156:     \"scipy\",\n157:     \"scipy.constants\",\n158:     \"scipy.spatial\",\n159:     \"scipy.spatial.transform\",\n160:     \"skip\",\n161:     \"test_data\",\n162:     \"common\",\n163: ]\n164: ignore_missing_imports = true\n165: \n166: [tool.versioningit.format]\n167: method = {module = \"versioningit_override\", value = \"cclib_format\", module-dir = \"tools\"}\n168: \n169: [tool.versioningit.template-fields.version-tuple]\n170: pep440 = true\n171: \n172: [tool.versioningit.vcs]\n173: method = \"git\"\n174: match = [\"v*\"]\n175: \n176: [tool.versioningit.write]\n177: file = \"cclib/_version.py\"\n\n(End of file - total 177 lines)\n</content>","metadata":{"preview":"[project]\nname = \"cclib\"\ndynamic = [\"version\"]\ndescription = \"parsers and algorithms for computational chemistry\"\nreadme = \"README.md\"\nauthors = [\n    {name = \"cclib development team\", email = \"cclib@googlegroups.com\"}\n]\