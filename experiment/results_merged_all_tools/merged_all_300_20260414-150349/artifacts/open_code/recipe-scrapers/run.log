rect scraper to use*\n58:     testhtml : pathlib.Path\n59:         Path to testhtml file that the scraper will parse..\n60:     testjson : pathlib.Path\n61:         Path to testjson file that contains the expected output from the scraper\n62:         for the testhtml file.\n63: \n64: \n65:     * We can't use the canonical url from the expected output to determine the scraper\n66:     that should be used because some website that aggregate recipes from others site will\n67:     set the canonical url to the site the recipe came from. tastykitchen.com is an example\n68:     of this.\n69: \n70: \n71:     Returns\n72:     -------\n73:     Callable\n74:         Function that asserts the expected output from the scraper matches the\n75:         actual output.\n76:     \"\"\"\n77: \n78:     def test_func(self):\n79:         with open(testjson, encoding=\"utf-8\") as f:\n80:             expect = json.load(f)\n81:             expect[\"ingredient_groups\"] = (\n82:                 [\n83:                     IngredientGroup(**group)\n84:                     for group in expect.get(\"ingredient_groups\", [])\n85:                 ]\n86:                 if \"ingredient_groups\" in expect\n87:                 else [IngredientGroup(expect[\"ingredients\"], purpose=None)]\n88:             )\n89:         supported_only = host in SCRAPERS\n90:         actual = scrape_html(\n91:             html=testhtml.read_text(encoding=\"utf-8\"),\n92:             org_url=host,\n93:             online=False,\n94:             supported_only=supported_only,\n95:         )\n96:         if not supported_only:\n97:             self.assertFalse(self.been_wild, \"Only one wild mode test should occur.\")\n98:             type(self).been_wild = True\n99: \n100:         # Mandatory tests\n\n(Showing lines 1-100 of 233. Use offset=101 to continue.)\n</content>","metadata":{"preview":"import json\nimport pathlib\nimport unittest\nfrom typing import Callable\n\nfrom recipe_scrapers import SCRAPERS, scrape_html\n