= 3.10\"\n35: dependencies = [\n36:     \"beautifulsoup4 >= 4.12.3\",\n37:     \"extruct >= 0.17.0\",\n38:     \"isodate >= 0.6.1\",\n39: ]\n40: \n41: [project.optional-dependencies]\n42: online = [\n43:     \"requests>=2.31.0\",\n44: ]\n45: # Documentation dependencies\n46: # Install these to build and serve the documentation:\n47: #   pip install -e \".[docs]\"\n48: #\n49: # Common commands:\n50: #   mkdocs serve  # Start local docs server at http://127.0.0.1:8000\n51: #                 # The server auto-reloads when you change files in docs/\n52: docs = [\n53:     \"mkdocs >= 1.6.1\",               # Core documentation generator\n54:     \"mkdocs-material >= 9.5.48\",     # Material theme for MkDocs\n55:     \"mkdocstrings >= 0.27.0\",        # API documentation from docstrings\n56:     \"mkdocstrings-python >= 1.12.2\", # Python handler for mkdocstrings\n57:     \"markdown-exec >= 1.10.0\",       # Execute code blocks in markdown\n58: ]\n59: # Testing dependencies\n60: # Install these to run tests and check coverage:\n61: #   pip install -e \".[test]\"\n62: # Common commands:\n63: #   python -m unittest                        # Run tests sequentially\n64: #   python -m unittest_parallel --level test  # Run tests in parallel (speeed)\n65: #   coverage run -m unittest                  # Run tests with coverage\n66: #   coverage report                           # View coverage report in terminal\n67: #   coverage html                             # Generate HTML coverage report\n68: tests = [\n69:     \"coverage >= 7.6.9\",           # Code coverage measurement tool\n70:     \"unittest-parallel >= 1.7.0\",  # Run unittest tests in parallel\n71: ]\n72: linters = [\n73:     \"pre-commit == 4.0.1\",    # latest from PyPI\n74:     \"black == 24.10.0\",       # match what's in .pre-commit-config.yaml\n75:     \"flake8 == 7.1.1\",        # match what's in .pre-commit-config.yaml\n76:     \"pep8-naming == 0.14.1\",  # match what's in .pre-commit-config.yaml\n77:     \"mypy == 1.14.0\",         # match what's in .pre-commit-config.yaml\n78:     \"types-beautifulsoup4\",   # needed for mypy\n79:     \"types-requests\",         # needed for mypy\n80: ]\n81: dev = [\n82:     \"recipe-scrapers[docs,tests,linters]\",\n83: ]\n84: all = [\n85:     \"recipe_scrapers[online,docs,tests,linters,dev]\"\n86: ]\n87: \n88: \n89: [tool.setuptools.packages.find]\n90: include = [\"recipe_scrapers\", \"recipe_scrapers.*\"]\n91: exclude = [\"tests\", \"tests.*\"]\n92: \n93: [tool.setuptools.dynamic]\n94: readme = {file = \"README.rst\"}\n95: version = {attr = \"recipe_scrapers.__version__.__version__\"}\n96: \n97: [tool.setuptools.package-data]\n98: recipe_scrapers = [\"py.typed\"]\n99: \n100: [tool.coverage.run]\n101: branch = true\n102: source = [\"recipe_scrapers\"]\n103: relative_files = true\n104: \n105: [tool.coverage.report]\n106: omit = [\n107:     \"recipe_scrapers/__version__.py\",\n108:     \"recipe_scrapers/plugins/template.py\",\n109:     \"recipe_scrapers/settings/template.py\"\n110: ]\n111: exclude_lines = [\n112:     \"raise NotImplementedError\"\n113: ]\n114: \n115: [tool.mypy]\n116: [[tool.mypy.overrides]]\n117: module = \"recipe_scrapers.*\"\n118: disable_error_code = \"union-attr\"\n119: [[tool.mypy.overrides]]\n120: module = \"._abstract\"\n121: ignore_missing_imports = true\n122: [[tool.mypy.overrides]]\n123: module = \"isodate\"\n124: ignore_missing_imports = true\n125: [[tool.mypy.overrides]]\n126: module = \"extruct\"\n127: ignore_missing_imports = true\n\n(End of file - total 127 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"recipe_scrapers\"\ndescription = \"Python package, scraping recipes from all over the internet\"\nauthors = [\n    {name = \"Hristo Harsev\", email = \"r+pypi@hharsev.com\"},\n    {name = \"James Addison\", email = \"james@reciperadar.com\"},\n]\nmaintainers = [\n    {name = \"Hristo Harsev\", email = \