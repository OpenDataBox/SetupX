53:         sync-args: [null]\n54:         pytest-args: [null]\n55:         label: [null]\n56: \n57:         # Test all on ubuntu, test ends on macos and windows\n58:         include:\n59:           - os: macos-latest\n60:             python-version: '3.10'\n61:             sync-args: null\n62:             pytest-args: null\n63:             label: null\n64:           - os: windows-latest\n65:             python-version: '3.10'\n66:             sync-args: null\n67:             pytest-args: null\n68:             label: null\n69:           - os: macos-latest\n70:             python-version: '3.14'\n71:             sync-args: null\n72:             pytest-args: null\n73:           - os: windows-latest\n74:             python-version: '3.14'\n75:             sync-args: null\n76:             pytest-args: null\n77:             label: null\n78: \n79:           # with integration deps\n80:           - os: ubuntu-latest\n81:             python-version: '3.14'\n82:             sync-args: --group integration\n83:             pytest-args: null\n84:             label: integration\n85: \n86:           # with lowest dependencies\n87:           - os: ubuntu-22.04\n88:             python-version: '3.10.0'\n89:             sync-args: --resolution=lowest --group integration\n90:             pytest-args: null\n91:             label: oldestdeps\n92: \n93:           # with doctests\n94:           - os: ubuntu-latest\n95:             python-version: '3.10'\n96:             sync-args: --group doc\n97:             pytest-args: --doctest-modules --doctest-plus\n98:             label: doctests\n99: \n100:     steps:\n101:       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n102:         with:\n103:           fetch-depth: 0\n104:           persist-credentials: false\n105:       - name: Setup Python\n106:         uses: astral-sh/setup-uv@cec208311dfd045dd5311c1add060b2062131d57 # v8.0.0\n107:         with:\n108:           python-version: ${{ matrix.python-version }}\n109:           enable-cache: false\n110:       - name: Install test env\n111:         run: uv sync --group covcheck ${{ matrix.sync-args }}\n112:       - name: Run tests\n113:         shell: bash # for windows compat\n114:         run: |\n115:           uv run --no-sync coverage run --parallel-mode -m \\\n116:             pytest --color=yes ${{ matrix.pytest-args }}\n117: \n118:       - name: Upload coverage data\n119:         # only using reports from ubuntu because\n120:         # combining reports from multiple platforms is tricky\n121:         if: startsWith( matrix.os , 'ubuntu' )\n122:         uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n123:         with:\n124:           name: unyt_coverage_data-${{matrix.os}}-${{matrix.python-version}}-${{matrix.label}}\n125:           path: .coverage.*\n126:           if-no-files-found: ignore\n127:           include-hidden-files: true\n128: \n129:   coverage:\n130:     name: Combine & check coverage.\n131:     runs-on: ubuntu-latest\n132:     needs: [test]\n133: \n134:     steps:\n135:     - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n136:       with:\n137:         fetch-depth: 0\n138:         persist-credentials: false\n139:     - uses: astral-sh/setup-uv@cec208311dfd045dd5311c1add060b2062131d57 # v8.0.0\n140:       with:\n141:         python-version: '3.14'\n142:         enable-cache: false\n143: \n144:     - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n145:       with:\n146:         pattern: unyt_coverage_data-*\n147:         merge-multiple: true\n148: \n149:     - name: Check coverage\n150:       run: |\n151:         uv tool install coverage\n152:         coverage combine\n153:         coverage html --skip-covered --skip-empty\n154:         coverage report --skip-covered --format=markdown >> \"$GITHUB_STEP_SUMMARY\"\n155:         coverage report --fail-under=99\n156: \n157:     - name: Upload HTML report\n158:       uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n159:       with:\n160:         name: unyt_coverage_report\n161:         path: htmlcov\n162: \n163:   docs:\n164:     runs-on: ubuntu-latest\n165:     needs: [build]\n166:     steps:\n167:       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n168:         with:\n169:           fetch-depth: 0\n170:           persist-credentials: false\n171:       - name: Setup Python\n172:         uses: astral-sh/setup-uv@cec208311dfd045dd5311c1add060b2062131d57 # v8.0.0\n173:         with:\n174:           python-version: '3.10'\n175:           enable-cache: false\n176:       - run: uv sync --group doc --group test\n177:       - name: Build docs\n178:         run: |\n179:           uv run --no-sync --directory=docs \\\n180:             python -m sphinx -M html \".\" \"_build\" -W\n181:       - name: Upload build\n182:         uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n183:         with:\n184:           name: unyt_docs\n185:           path: docs/_build/html\n186:           if-no-files-found: error\n\n(End of file - total 186 lines)\n</content>","metadata":{"preview":"name: CI\n\non:\n  push:\n    branches:\n    - master\n  pull_request:\n  schedule:\n    - cron:  '1 0 * * *'\n  workflow_dispatch:\n\n\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n        with:\n          fetch-depth: 0\n          persist-credentials: false","truncated":false,"loaded":[]},"title":".github/workflows/ci.yml","time":{"start":1775824708838,"end":1775824708844}}}]}
