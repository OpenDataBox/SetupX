     \"coverage>=7.10.0\",\n50: ]\n51: doc = [\n52:     {include-group = \"integration\"},\n53:     \"docutils>=0.21.2\",\n54:     \"sphinx>=7.4.7\",\n55: ]\n56: integration = [\n57:     \"astropy>=4.0.4\",\n58:     \"dask[array,diagnostics]>=2021.4.1\",\n59:     \"h5py>=3.0.0\",\n60:     \"matplotlib>=3.3.3,!=3.5.0\",\n61:     \"pint>=0.9\",\n62: ]\n63: \n64: [tool.uv]\n65: # never build the following packages from source. Prefer more recent versions\n66: # with binary distributions even with --resolution=lowest[-direct]\n67: no-build-package = [\n68:     \"astropy\",\n69:     \"bokeh\",\n70:     \"coverage\",\n71:     \"h5py\",\n72:     \"numpy\",\n73:     \"matplotlib\",\n74:     \"pandas\",\n75:     \"toolz\",\n76:     \"pyyaml\",\n77:     \"kiwisolver\",\n78:     \"pillow\",\n79:     \"pyerfa\",\n80: ]\n81: constraint-dependencies = [\n82:     \"mpmath>=1.2.1\",\n83: ]\n84: \n85: # ensure that uv resolves envs that are compatible with macOS arm64,\n86: # even in drastic conditions like --resolution=lowest[-direct],\n87: # taking into account tool.uv.no-build-package\n88: required-environments = [\n89:     \"sys_platform == 'darwin' and platform_machine == 'arm64'\",\n90: ]\n91: \n92: \n93: [tool.flit.sdist]\n94: include = [\n95:     \"unyt\",\n96:     \"unyt.tests\",\n97:     \"unyt.tests.data\",\n98:     \"unyt._mpl_array_converter\",\n99: ]\n100: \n101: [tool.black]\n102: exclude = '''\n103: (\n104:   /(\n105:       \\.eggs\n106:     | \\.git\n107:     | \\.hg\n108:     | \\.mypy_cache\n109:     | \\.tox\n110:     | \\.venv\n111:     | _build\n112:     | buck-out\n113:     | build\n114:     | dist\n115:     | _version.py\n116:   )\n117: )\n118: '''\n119: \n120: [tool.ruff]\n121: exclude = [\n122:     \".*/\",\n123:     \"benchmarks/*.py\",\n124:     \"paper/*.py\",\n125:     \"*/_version.py\",\n126:     \"*/__init__.py\",\n127: ]\n128: [tool.ruff.lint]\n129: ignore = [\n130:     \"E501\",\n131:     \"B904\",\n132:     \"B905\", # zip-without-explicit-strict\n133: ]\n134: select = [\n135:     \"E\",\n136:     \"F\",\n137:     \"W\",\n138:     \"C4\",  # flake8-comprehensions\n139:     \"B\",   # flake8-bugbear\n140:     \"YTT\", # flake8-2020\n141:     \"I\",   # isort\n142:     \"UP\",  # pyupgrade\n143:     \"NPY\", # numpy specific rules\n144: ]\n145: \n146: [tool.ruff.lint.isort]\n147: combine-as-imports = true\n148: \n149: [tool.pytest.ini_options]\n150: addopts = \"-ra --ignore=benchmarks --ignore=paper --ignore=unyt/_mpl_array_converter --color=yes\"\n151: filterwarnings = [\n152:     \"error\",\n153:     \"ignore:Matplotlib is currently using agg, which is a non-GUI backend, so cannot show the figure.:UserWarning\",\n154:     \"ignore:FigureCanvasAgg is non-interactive, and thus cannot be shown:UserWarning\",\n155:     \"ignore:distutils Version classes are deprecated. Use packaging.version instead.:DeprecationWarning\",\n156:     'ignore:datetime\\.datetime\\.utcfromtimestamp\\(\\) is deprecated:DeprecationWarning', # https://github.com/dateutil/dateutil/pull/1285\n157:     'ignore:mpnumeric is deprecated:DeprecationWarning', # sympy 1.12 VS mpmath 1.4, solution: https://github.com/sympy/sympy/pull/25290\n158:     'ignore:`np.compat`, which was used during the Python 2 to 3 transition, is deprecated since 1.26.0, and will be removed:DeprecationWarning' # from dask 2021.x\n159: ]\n160: \n161: [tool.coverage.run]\n162: source = [\n163:     \"unyt\",\n164: ]\n165: omit = [\n166:     \"docs/*\",\n167:     \"unyt/_version.py\",\n168:     \"unyt/_on_demand_imports.py\",\n169:     \"unyt/tests/test_linters.py\",\n170: ]\n171: \n172: [tool.coverage.report]\n173: show_missing = true\n174: skip_covered = false\n\n(End of file - total 174 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"flit_core >=3.11,<4\"]\nbuild-backend = \"flit_core.buildapi\"\n\n[project]\nname = \"unyt\"\nversion = \"3.1.0.dev0\"\ndescription = \"A package for handling numpy arrays with units\"\nauthors = [\n    { name = \"Th