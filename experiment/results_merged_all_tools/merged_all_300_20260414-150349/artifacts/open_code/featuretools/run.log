{"type":"session_message","session_id":"ses_2786aed32ffe2LKopNEVo1fXh6","role":"assistant","message_id":"msg_d87986ef3001FO9z2aHbzM1hbm","parts":[{"id":"prt_d87987e8b001TGmoXuKEP0qZOp","messageID":"msg_d87986ef3001FO9z2aHbzM1hbm","sessionID":"ses_2786aed32ffe2LKopNEVo1fXh6","type":"tool","tool":"read","callID":"call_d95dbc782cbb483da5af27e2","state":{"status":"completed","input":{"filePath":"/workspace/featuretools/demo/retail.py","limit":100},"output":"<path>/workspace/featuretools/demo/retail.py</path>\n<type>file</type>\n<content>1: import pandas as pd\n2: from woodwork.logical_types import NaturalLanguage\n3: \n4: import featuretools as ft\n5: \n6: \n7: def load_retail(id=\"demo_retail_data\", nrows=None, return_single_table=False):\n8:     \"\"\"Returns the retail entityset example.\n9:     The original dataset can be found `here <https://archive.ics.uci.edu/ml/datasets/online+retail>`_.\n10: \n11:     We have also made some modifications to the data. We\n12:     changed the column names, converted the ``customer_id``\n13:     to a unique fake ``customer_name``, dropped duplicates,\n14:     added columns for ``total`` and ``cancelled`` and\n15:     converted amounts from GBP to USD. You can download the modified CSV in gz `compressed (7 MB)\n16:     <https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv.gz>`_\n17:     or `uncompressed (43 MB)\n18:     <https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv>`_ formats.\n19: \n20:     Args:\n21:         id (str):  Id to assign to EntitySet.\n22:         nrows (int):  Number of rows to load of the underlying CSV.\n23:             If None, load all.\n24:         return_single_table (bool): If True, return a CSV rather than an EntitySet. Default is False.\n25: \n26:     Examples:\n27: \n28:         .. ipython::\n29:             :verbatim:\n30: \n31:             In [1]: import featuretools as ft\n32: \n33:             In [2]: es = ft.demo.load_retail()\n34: \n35:             In [3]: es\n36:             Out[3]:\n37:             Entityset: demo_retail_data\n38:               DataFrames:\n39:                 orders (shape = [22190, 3])\n40:                 products (shape = [3684, 3])\n41:                 customers (shape = [4372, 2])\n42:                 order_products (shape = [401704, 7])\n43: \n44:         Load in subset of data\n45: \n46:         .. ipython::\n47:             :verbatim:\n48: \n49:             In [4]: es = ft.demo.load_retail(nrows=1000)\n50: \n51:             In [5]: es\n52:             Out[5]:\n53:             Entityset: demo_retail_data\n54:               DataFrames:\n55:                 orders (shape = [67, 5])\n56:                 products (shape = [606, 3])\n57:                 customers (shape = [50, 2])\n58:                 order_products (shape = [1000, 7])\n59:     \"\"\"\n60:     es = ft.EntitySet(id)\n61:     csv_s3_gz = (\n62:         \"https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv.gz?library=featuretools&version=\"\n63:         + ft.__version__\n64:     )\n65:     csv_s3 = (\n66:         \"https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv?library=featuretools&version=\"\n67:         + ft.__version__\n68:     )\n69:     # Try to read in gz compressed file\n70:     try:\n71:         df = pd.read_csv(csv_s3_gz, nrows=nrows, parse_dates=[\"order_date\"])\n72:     # Fall back to uncompressed\n73:     except Exception:\n74:         df = pd.read_csv(csv_s3, nrows=nrows, parse_dates=[\"order_date\"])\n75:     if return_single_table:\n76:         return df\n77: \n78:     es.add_dataframe(\n79:         dataframe_name=\"order_products\",\n80:         dataframe=df,\n81:         index=\"order_product_id\",\n82:         make_index=True,\n83:         time_index=\"order_date\",\n84:         logical_types={\"description\": NaturalLanguage},\n85:     )\n86: \n87:     es.normalize_dataframe(\n88:         new_dataframe_name=\"products\",\n89:         base_dataframe_name=\"order_products\",\n90:         index=\"product_id\",\n91:         additional_columns=[\"description\"],\n92:     )\n93: \n94:     es.normalize_dataframe(\n95:         new_dataframe_name=\"orders\",\n96:         base_dataframe_name=\"order_products\",\n97:         index=\"order_id\",\n98:         additional_columns=[\"customer_name\", \"country\", \"cancelled\"],\n99:     )\n100: \n\n(Showing lines 1-100 of 108. Use offset=101 to continue.)\n</content>","metadata":{"preview":"import pandas as pd\nfrom woodwork.logical_types import NaturalLanguage\n\nimport featuretools as ft\n\n\ndef load_retail(id=\"demo_retail_data\", nrows=None, return_single_table=False):\n    \"\"\"Returns the retail entityset example.\n    The original dataset can be found `here <https://archive.ics.uci.edu/ml/datasets/online+retail>`_.\n\n    We have also made some modifications to the data. We\n    changed the column names, converted the ``customer_id``\n    to a unique fake ``customer_name``, dropped duplicates,\n    added columns for ``total`` and ``cancelled`` and\n    converted amounts from GBP to USD. You can download the modified CSV in gz `compressed (7 MB)\n    <https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv.gz>`_\n    or `uncompressed (43 MB)\n    <https://oss.alteryx.com/datasets/online-retail-logs-2018-08-28.csv>`_ formats.\n\n    Args:","truncated":true,"loaded":[]},"title":"featuretools/demo/retail.py","time":{"start":1776096411995,"end":1776096411999}}}]}
