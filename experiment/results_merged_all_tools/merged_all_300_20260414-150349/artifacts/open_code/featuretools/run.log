{"type":"session_message","session_id":"ses_2786aed32ffe2LKopNEVo1fXh6","role":"assistant","message_id":"msg_d879749690014x41hAra3KNtHF","parts":[{"id":"prt_d8797508b001VhVdIk91qeBQYt","messageID":"msg_d879749690014x41hAra3KNtHF","sessionID":"ses_2786aed32ffe2LKopNEVo1fXh6","type":"tool","tool":"read","callID":"call_fb292668966d4f58b32f10ed","state":{"status":"completed","input":{"filePath":"/workspace/featuretools/demo/mock_customer.py"},"output":"<path>/workspace/featuretools/demo/mock_customer.py</path>\n<type>file</type>\n<content>1: import pandas as pd\n2: from numpy import random\n3: from numpy.random import choice\n4: from woodwork.logical_types import Categorical, PostalCode\n5: \n6: import featuretools as ft\n7: \n8: \n9: def load_mock_customer(\n10:     n_customers=5,\n11:     n_products=5,\n12:     n_sessions=35,\n13:     n_transactions=500,\n14:     random_seed=0,\n15:     return_single_table=False,\n16:     return_entityset=False,\n17: ):\n18:     \"\"\"Return dataframes of mock customer data\"\"\"\n19: \n20:     random.seed(random_seed)\n21:     last_date = pd.to_datetime(\"12/31/2013\")\n22:     first_date = pd.to_datetime(\"1/1/2008\")\n23:     first_bday = pd.to_datetime(\"1/1/1970\")\n24: \n25:     join_dates = [\n26:         random.uniform(0, 1) * (last_date - first_date) + first_date\n27:         for _ in range(n_customers)\n28:     ]\n29:     birth_dates = [\n30:         random.uniform(0, 1) * (first_date - first_bday) + first_bday\n31:         for _ in range(n_customers)\n32:     ]\n33: \n34:     customers_df = pd.DataFrame({\"customer_id\": range(1, n_customers + 1)})\n35:     customers_df[\"zip_code\"] = choice(\n36:         [\"60091\", \"13244\"],\n37:         n_customers,\n38:     )\n39:     customers_df[\"join_date\"] = pd.Series(join_dates).dt.round(\"1s\")\n40:     customers_df[\"birthday\"] = pd.Series(birth_dates).dt.round(\"1d\")\n41: \n42:     products_df = pd.DataFrame({\"product_id\": pd.Categorical(range(1, n_products + 1))})\n43:     products_df[\"brand\"] = choice([\"A\", \"B\", \"C\"], n_products)\n44: \n45:     sessions_df = pd.DataFrame({\"session_id\": range(1, n_sessions + 1)})\n46:     sessions_df[\"customer_id\"] = choice(customers_df[\"customer_id\"], n_sessions)\n47:     sessions_df[\"device\"] = choice([\"desktop\", \"mobile\", \"tablet\"], n_sessions)\n48: \n49:     transactions_df = pd.DataFrame({\"transaction_id\": range(1, n_transactions + 1)})\n50:     transactions_df[\"session_id\"] = choice(sessions_df[\"session_id\"], n_transactions)\n51:     transactions_df = transactions_df.sort_values(\"session_id\").reset_index(drop=True)\n52:     transactions_df[\"transaction_time\"] = pd.date_range(\n53:         \"1/1/2014\",\n54:         periods=n_transactions,\n55:         freq=\"65s\",\n56:     )  # todo make these less regular\n57:     transactions_df[\"product_id\"] = pd.Categorical(\n58:         choice(products_df[\"product_id\"], n_transactions),\n59:     )\n60:     transactions_df[\"amount\"] = random.randint(500, 15000, n_transactions) / 100\n61: \n62:     # calculate and merge in session start\n63:     # based on the times we came up with for transactions\n64:     session_starts = transactions_df.drop_duplicates(\"session_id\")[\n65:         [\"session_id\", \"transaction_time\"]\n66:     ].rename(columns={\"transaction_time\": \"session_start\"})\n67:     sessions_df = sessions_df.merge(session_starts)\n68: \n69:     if return_single_table:\n70:         return (\n71:             transactions_df.merge(sessions_df)\n72:             .merge(customers_df)\n73:             .merge(products_df)\n74:             .reset_index(drop=True)\n75:         )\n76:     elif return_entityset:\n77:         es = ft.EntitySet(id=\"transactions\")\n78:         es = es.add_dataframe(\n79:             dataframe_name=\"transactions\",\n80:             dataframe=transactions_df,\n81:             index=\"transaction_id\",\n82:             time_index=\"transaction_time\",\n83:             logical_types={\"product_id\": Categorical},\n84:         )\n85: \n86:         es = es.add_dataframe(\n87:             dataframe_name=\"products\",\n88:             dataframe=products_df,\n89:             index=\"product_id\",\n90:         )\n91: \n92:         es = es.add_dataframe(\n93:             dataframe_name=\"sessions\",\n94:             dataframe=sessions_df,\n95:             index=\"session_id\",\n96:             time_index=\"session_start\",\n97:         )\n98: \n99:         es = es.add_dataframe(\n100:             dataframe_name=\"customers\",\n101:             dataframe=customers_df,\n102:             index=\"customer_id\",\n103:             time_index=\"join_date\",\n104:             logical_types={\"zip_code\": PostalCode},\n105:         )\n106: \n107:         rels = [\n108:             (\"products\", \"product_id\", \"transactions\", \"product_id\"),\n109:             (\"sessions\", \"session_id\", \"transactions\", \"session_id\"),\n110:             (\"customers\", \"customer_id\", \"sessions\", \"customer_id\"),\n111:         ]\n112:         es = es.add_relationships(rels)\n113:         es.add_last_time_indexes()\n114:         return es\n115: \n116:     return {\n117:         \"customers\": customers_df,\n118:         \"sessions\": sessions_df,\n119:         \"transactions\": transactions_df,\n120:         \"products\": products_df,\n121:     }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"import pandas as pd\nfrom numpy import random\nfrom numpy.random import choice\nfrom woodwork.logical_types import Categorical, PostalCode\n\nimport featuretools as ft\n\n\ndef load_mock_customer(\n    n_customers=5,\n    n_products=5,\n    n_sessions=35,\n    n_transactions=500,\n    random_seed=0,\n    return_single_table=False,\n    return_entityset=False,\n):\n    \"\"\"Return dataframes of mock customer data\"\"\"\n\n    random.seed(random_seed)","truncated":false,"loaded":[]},"title":"featuretools/demo/mock_customer.py","time":{"start":1776096334252,"end":1776096334262}}}]}
