trongly recommended\n29: # to use two separate database IDs.\n30: REDIS = {\n31:     'tasks': {\n32:         'HOST': 'localhost',\n33:         'PORT': 6379,\n34:         # Comment out `HOST` and `PORT` lines and uncomment the following if using Redis Sentinel\n35:         # 'SENTINELS': [('mysentinel.redis.example.com', 6379)],\n36:         # 'SENTINEL_SERVICE': 'netbox',\n37:         'USERNAME': '',\n38:         'PASSWORD': '',\n39:         'DATABASE': 0,\n40:         'SSL': False,\n41:         # Set this to True to skip TLS certificate verification\n42:         # This can expose the connection to attacks, be careful\n43:         # 'INSECURE_SKIP_TLS_VERIFY': False,\n44:         # Set a path to a certificate authority, typically used with a self signed certificate.\n45:         # 'CA_CERT_PATH': '/etc/ssl/certs/ca.crt',\n46:     },\n47:     'caching': {\n48:         'HOST': 'localhost',\n49:         'PORT': 6379,\n50:         # Comment out `HOST` and `PORT` lines and uncomment the following if using Redis Sentinel\n51:         # 'SENTINELS': [('mysentinel.redis.example.com', 6379)],\n52:         # 'SENTINEL_SERVICE': 'netbox',\n53:         'USERNAME': '',\n54:         'PASSWORD': '',\n55:         'DATABASE': 1,\n56:         'SSL': False,\n57:         # Set this to True to skip TLS certificate verification\n58:         # This can expose the connection to attacks, be careful\n59:         # 'INSECURE_SKIP_TLS_VERIFY': False,\n60:         # Set a path to a certificate authority, typically used with a self signed certificate.\n61:         # 'CA_CERT_PATH': '/etc/ssl/certs/ca.crt',\n62:     }\n63: }\n64: \n65: # This key is used for secure generation of random numbers and strings. It must never be exposed outside of this file.\n66: # For optimal security, SECRET_KEY should be at least 50 characters in length and contain a mix of letters, numbers, and\n67: # symbols. NetBox will not run without this defined. For more information, see\n68: # https://docs.djangoproject.com/en/stable/ref/settings/#std:setting-SECRET_KEY\n69: SECRET_KEY = ''\n70: \n71: # Define a mapping of cryptographic peppers to use when hashing API tokens. A minimum of one pepper is required to\n72: # enable v2 API tokens (NetBox v4.5+). Define peppers as a mapping of numeric ID to pepper value, as shown below. Each\n73: # pepper must be at least 50 characters in length.\n74: #\n75: #     API_TOKEN_PEPPERS = {\n76: #         1: \"<random string>\",\n77: #         2: \"<random string>\",\n78: #     }\n79: API_TOKEN_PEPPERS = {}\n80: \n81: \n82: #########################\n83: #                       #\n84: #   Optional settings   #\n85: #                       #\n86: #########################\n87: \n88: # Specify one or more name and email address tuples representing NetBox administrators. These people will be notified of\n89: # application errors (assuming correct email settings are provided).\n90: ADMINS = [\n91:     # ('John Doe', 'jdoe@example.com'),\n92: ]\n93: \n94: # Enable any desired validators for local account passwords below. For a list of included validators, please see the\n95: # Django documentation at https://docs.djangoproject.com/en/stable/topics/auth/passwords/#password-validation.\n96: AUTH_PASSWORD_VALIDATORS = [\n97:     # {\n98:     #     'NAME': 'django.contrib.auth.password_validation.MinimumLengthValidator',\n99:     #     'OPTIONS': {\n100:     #         'min_length': 10,\n101:     #     }\n102:     # },\n103: ]\n104: \n105: # Base URL path if accessing NetBox within a directory. For example, if installed at https://example.com/netbox/, set:\n106: # BASE_PATH = 'netbox/'\n107: BASE_PATH = ''\n108: \n109: # API Cross-Origin Resource Sharing (CORS) settings. If CORS_ORIGIN_ALLOW_ALL is set to True, all origins will be\n110: # allowed. Otherwise, define a list of allowed origins using either CORS_ORIGIN_WHITELIST or\n111: # CORS_ORIGIN_REGEX_WHITELIST. For more information, see https://github.com/ottoyiu/django-cors-headers\n112: CORS_ORIGIN_ALLOW_ALL = False\n113: CORS_ORIGIN_WHITELIST = [\n114:     # 'https://hostname.example.com',\n115: ]\n116: CORS_ORIGIN_REGEX_WHITELIST = [\n117:     # r'^(https?://)?(\\w+\\.)?example\\.com$',\n118: ]\n119: \n120: # The name to use for the CSRF token cookie.\n121: CSRF_COOKIE_NAME = 'csrftoken'\n122: \n123: # Set to True to enable server debugging. WARNING: Debugging introduces a substantial performance penalty and may reveal\n124: # sensitive information about your installation. Only enable debugging while performing testing. Never enable debugging\n125: # on a production system.\n126: DEBUG = False\n127: \n128: # Set the default preferred language/locale\n129: DEFAULT_LANGUAGE = 'en-us'\n130: \n131: # Email settings\n132: EMAIL = {\n133:     'SERVER': 'localhost',\n134:     'PORT': 25,\n135:     'USERNAME': '',\n136:     'PASSWORD': '',\n137:     'USE_SSL': False,\n138:     'USE_TLS': False,\n139:     'TIMEOUT': 10,  # seconds\n140:     'FROM_EMAIL': '',\n141: }\n142: \n143: # Exempt certain models from the enforcement of view permissions. Models listed here will be viewable by all users and\n144: # by anonymous users. List models in the form `<app>.<model>`. Add '*' to this list to exempt all models.\n145: EXEMPT_VIEW_PERMISSIONS = [\n146:     # 'dcim.site',\n147:     # 'dcim.region',\n148:     # 'ipam.prefix',\n149: ]\n150: \n151: # HTTP proxies NetBox should use when sending outbound HTTP requests (e.g. for webhooks).\n152: # HTTP_PROXIES = {\n153: #     'http': 'http://10.10.1.10:3128',\n154: #     'https': 'http://10.10.1.10:1080',\n155: # }\n156: \n157: # IP addresses recognized as internal to the system. The debugging toolbar will be available only to clients accessing\n158: # NetBox from an internal IP.\n159: INTERNAL_IPS = ('127.0.0.1', '::1')\n160: \n161: # Enable custom logging. Please see the Django documentation for detailed guidance on configuring custom logs:\n162: #   https://docs.djangoproject.com/en/stable/topics/logging/\n163: LOGGING = {}\n164: \n165: # Automatically reset the lifetime of a valid session upon each authenticated request. Enables users to remain\n166: # authenticated to NetBox indefinitely.\n167: LOGIN_PERSISTENCE = False\n168: \n169: # Setting this to False will permit unauthenticated users to access most areas of NetBox (but not make any changes).\n170: LOGIN_REQUIRED = True\n171: \n172: # The length of time (in seconds) for which a user will remain logged into the web UI before being prompted to\n173: # re-authenticate. (Default: 1209600 [14 days])\n174: LOGIN_TIMEOUT = None\n175: \n176: # Hide the login form. Useful when only allowing SSO authentication.\n177: LOGIN_FORM_HIDDEN = False\n178: \n179: # The view name or URL to which users are redirected after logging out.\n180: LOGOUT_REDIRECT_URL = 'home'\n181: \n182: # The file path where uploaded media such as image attachments are stored. A trailing slash is not needed. Note that\n183: # the default value of this setting is derived from the installed location.\n184: # MEDIA_ROOT = '/opt/netbox/netbox/media'\n185: \n186: # Expose Prometheus monitoring metrics at the HTTP endpoint '/metrics'\n187: METRICS_ENABLED = False\n188: \n189: # Enable installed plugins. Add the name of each plugin to the list.\n190: PLUGINS = []\n191: \n192: # Plugins configuration settings. These settings are used by various plugins that the user may have installed.\n193: # Each key in the dictionary is the name of an installed plugin and its value is a dictionary of settings.\n194: # PLUGINS_CONFIG = {\n195: #     'my_plugin': {\n196: #         'foo': 'bar',\n197: #         'buzz': 'bazz'\n198: #     }\n199: # }\n200: \n201: # Remote authentication support\n202: REMOTE_AUTH_ENABLED = False\n203: REMOTE_AUTH_BACKEND = 'netbox.authentication.RemoteUserBackend'\n204: REMOTE_AUTH_HEADER = 'HTTP_REMOTE_USER'\n205: REMOTE_AUTH_USER_FIRST_NAME = 'HTTP_REMOTE_USER_FIRST_NAME'\n206: REMOTE_AUTH_USER_LAST_NAME = 'HTTP_REMOTE_USER_LAST_NAME'\n207: REMOTE_AUTH_USER_EMAIL = 'HTTP_REMOTE_USER_EMAIL'\n208: REMOTE_AUTH_AUTO_CREATE_USER = True\n209: REMOTE_AUTH_DEFAULT_GROUPS = []\n210: REMOTE_AUTH_DEFAULT_PERMISSIONS = {}\n211: \n212: # This repository is used to check whether there is a new release of NetBox available. Set to None to disable the\n213: # version check or use the URL below to check for release in the official NetBox repository.\n214: RELEASE_CHECK_URL = None\n215: # RELEASE_CHECK_URL = 'https://api.github.com/repos/netbox-community/netbox/releases'\n216: \n217: # The file path where custom reports will be stored. A trailing slash is not needed. Note that the default value of\n218: # this setting is derived from the installed location.\n219: # REPORTS_ROOT = '/opt/netbox/netbox/reports'\n220: \n221: # Maximum execution time for background tasks, in seconds.\n222: RQ_DEFAULT_TIMEOUT = 300\n223: \n224: # The file path where custom scripts will be stored. A trailing slash is not needed. Note that the default value of\n225: # this setting is derived from the installed location.\n226: # SCRIPTS_ROOT = '/opt/netbox/netbox/scripts'\n227: \n228: # The name to use for the session cookie.\n229: SESSION_COOKIE_NAME = 'sessionid'\n230: \n231: # By default, NetBox will store session data in the database. Alternatively, a file path can be specified here to use\n232: # local file storage instead. (This can be useful for enabling authentication on a standby instance with read-only\n233: # database access.) Note that the user as which NetBox runs must have read and write permissions to this path.\n234: SESSION_FILE_PATH = None\n235: \n236: # By default the memory and disk sizes are displayed using base 10 (e.g. 1000 MB = 1 GB).\n237: # If you would like to use base 2 (e.g. 1024 MB = 1 GB) set this to 1024.\n238: # DISK_BASE_UNIT = 1024\n239: # RAM_BASE_UNIT = 1024\n240: \n241: # Within the STORAGES dictionary, \"default\" is used for image uploads, \"staticfiles\" is for static files and \"scripts\"\n242: # is used for custom scripts. See django-storages and django-storage-swift libraries for more details. By default the\n243: # following configuration is used:\n244: # STORAGES = {\n245: #     \"default\": {\n246: #         \"BACKEND\": \"django.core.files.storage.FileSystemStorage\",\n247: #     },\n248: #     \"staticfiles\": {\n249: #         \"BACKEND\": \"django.contrib.staticfiles.storage.StaticFilesStorage\",\n250: #     },\n251: #     \"scripts\": {\n252: #         \"BACKEND\": \"extras.storage.ScriptFileSystemStorage\",\n253: #         \"OPTIONS\": {\n254: #             \"allow_overwrite\": True,\n255: #         },\n256: #     },\n257: # }\n258: \n259: # Time zone (default: UTC)\n260: TIME_ZONE = 'UTC'\n\n(End of file - total 260 lines)\n</content>","metadata":{"preview":"#########################\n#                       #\n#   Required settings   #\n#                       #\n#########################\n\n# This is a list of valid fully-qualified domain names (FQDNs) for the NetBox server. NetBox will not permit write\n# access to the server via any other hostnames. The first FQDN in the list will be treated as the preferred name.\n#\n# Example: ALLOWED_HOSTS = ['netbox.example.com', 'netbox.internal.local']\nALLOWED_HOSTS = []\n\n# PostgreSQL database configuration. See the Django documentation for a complete list of available parameters:\n#   https://docs.djangoproject.com/en/stable/ref/settings/#databases\nDATABASES = {\n    'default': {\n        'ENGINE': 'django.db.backends.postgresql',  # Database engine\n        'NAME': 'netbox',         # Database name\n        'USER': '',               # PostgreSQL username\n        'PASSWORD': '',           # PostgreSQL password","truncated":false,"loaded":[]},"title":"netbox/netbox/configuration_example.py","time":{"start":1776109103255,"end":1776109103268}}}]}
