ig.yaml\n-rw-r--r--  1 root root  574 Apr  9 22:59 .readthedocs.yaml\n-rw-r--r--  1 root root  220 Apr  9 22:59 CITATION.bib\n-rw-r--r--  1 root root 1082 Apr  9 22:59 LICENSE\n-rw-r--r--  1 root root 2798 Apr  9 22:59 Makefile\n-rw-r--r--  1 root root 5365 Apr  9 22:59 README.md\n-rw-r--r--  1 root root 5243 Apr  9 22:59 code-of-conduct.md\n-rw-r--r--  1 root root  238 Apr  9 22:59 codecov.yml\ndrwxr-xr-x  3 root root 4096 Apr  9 22:59 doc\ndrwxr-xr-x  2 root root 4096 Apr  9 22:59 licences\ndrwxr-xr-x 15 root root 4096 Apr  9 22:59 plotnine\n-rw-r--r--  1 root root 6332 Apr  9 22:59 pyproject.toml\ndrwxr-xr-x  2 root root 4096 Apr  9 22:59 requirements\ndrwxr-xr-x  4 root root 4096 Apr  9 22:59 tests\ndrwxr-xr-x  2 root root 4096 Apr  9 22:59 tools\n","exit":0,"description":"List workspace directory contents","truncated":false},"title":"List workspace directory contents","time":{"start":1775775553080,"end":1775775553129}}}]}
