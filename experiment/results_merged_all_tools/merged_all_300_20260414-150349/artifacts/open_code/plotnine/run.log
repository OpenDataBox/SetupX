{"type":"session_message","session_id":"ses_28b877bdbffeT3wTjyt3WtTnYt","role":"assistant","message_id":"msg_d74789ba3001dG62xDOuYDhrln","parts":[{"id":"prt_d7478a5ed001G5G3P9nlFbBF0B","messageID":"msg_d74789ba3001dG62xDOuYDhrln","sessionID":"ses_28b877bdbffeT3wTjyt3WtTnYt","type":"tool","tool":"read","callID":"call_f59f69257b8a447daa14e99a","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: ########## Project ##########\n2: [project]\n3: name = \"plotnine\"\n4: description = \"A Grammar of Graphics for Python\"\n5: license = {file = \"LICENSE\"}\n6: authors = [\n7:   {name = \"Hassan Kibirige\", email = \"has2k1@gmail.com\"},\n8: ]\n9: dynamic = [\"version\"]\n10: readme = \"README.md\"\n11: classifiers = [\n12:     \"Intended Audience :: Science/Research\",\n13:     \"License :: OSI Approved :: MIT License\",\n14:     \"Operating System :: Microsoft :: Windows\",\n15:     \"Operating System :: Unix\",\n16:     \"Operating System :: MacOS\",\n17:     \"Programming Language :: Python :: 3 :: Only\",\n18:     \"Programming Language :: Python :: 3.10\",\n19:     \"Programming Language :: Python :: 3.11\",\n20:     \"Programming Language :: Python :: 3.12\",\n21:     \"Programming Language :: Python :: 3.13\",\n22:     \"Framework :: Matplotlib\",\n23:     \"Topic :: Scientific/Engineering :: Visualization\"\n24: ]\n25: dependencies = [\n26:     \"matplotlib>=3.8.0\",\n27:     \"pandas>=2.2.0\",\n28:     \"mizani~=0.14.0\",\n29:     \"numpy>=1.23.5\",\n30:     \"scipy>=1.8.0\",\n31:     \"statsmodels>=0.14.6\",\n32: ]\n33: requires-python = \">=3.10\"\n34: \n35: [project.optional-dependencies]\n36: all = [\n37:     \"plotnine[extra]\",\n38:     \"plotnine[doc]\",\n39:     \"plotnine[lint]\",\n40:     \"plotnine[test]\",\n41:     \"plotnine[build]\",\n42:     \"plotnine[dev]\",\n43: ]\n44: \n45: # These should include all packages that we use in the tests and in the\n46: # examples\n47: extra = [\n48:     \"adjustText>=1.2.0\",\n49:     \"geopandas>=1.0.0\",\n50:     \"geodatasets>=2024.8.0\",\n51:     \"scikit-learn>=1.3.0\",\n52:     \"scikit-misc>=0.5.1\",\n53:     \"polars>=1.24.0\",\n54:     \"pyarrow>=19.0.1\",\n55: ]\n56: \n57: doc = [\n58:     \"jupyter\",\n59:     \"click\",\n60:     \"griffe==1.15.0\",\n61:     \"numpydoc>=0.9.1\",\n62:     \"quartodoc>=0.11.1\",\n63: ]\n64: \n65: lint = [\n66:     \"ruff\",\n67: ]\n68: \n69: test = [\n70:     \"pytest-cov>=4.0.0\"\n71: ]\n72: \n73: build = [\n74:     \"build\",\n75:     \"wheel\",\n76: ]\n77: \n78: dev = [\n79:     \"twine\",\n80:     \"plotnine[typing]\",\n81:     \"pre-commit\",\n82: ]\n83: \n84: typing = [\n85:     \"pyright==1.1.408\",\n86:     \"ipython\",\n87:     \"pandas-stubs\",\n88: ]\n89: \n90: [project.urls]\n91: homepage = \"https://plotnine.readthedocs.io/en/stable\"\n92: repository = \"https://github.com/has2k1/plotnine\"\n93: changelog = \"https://plotnine.readthedocs.io/en/stable/changelog.html\"\n94: ci = \"https://github.com/has2k1/plotnine/actions\"\n95: \n96: ########## Build System ##########\n97: # Reference https://github.com/pydata/xarray/blob/main/pyproject.toml\n98: [build-system]\n99: requires = [\n100:     \"setuptools>=59\",\n101:     \"setuptools_scm[toml]>=6.4\",\n102:     \"wheel\",\n103: ]\n104: build-backend = \"setuptools.build_meta\"\n105: \n106: ########## Tool - Setuptools ##########\n107: # If you only specify the top-level package (=plotnine) setuptools complains\n108: # about not listing the sub-packages. Since we want every sub-package in the\n109: # plotnine package, it is easier to use find directive.\n110: [tool.setuptools.packages.find]\n111: include = [\"plotnine*\"]\n112: \n113: [tool.setuptools_scm]\n114: fallback_version = \"999\"\n115: version_scheme = 'post-release'\n116: \n117: ########## Tool - Pytest ##########\n118: [tool.pytest.ini_options]\n119: testpaths = [\n120:     \"tests\"\n121: ]\n122: doctest_optionflags = \"ALLOW_BYTES NORMALIZE_WHITESPACE\"\n123: addopts = \"--pyargs --cov=plotnine --cov-report=xml --import-mode=importlib\"\n124: \n125: ########## Tool - Coverage ##########\n126: # Coverage.py\n127: [tool.coverage.run]\n128: branch = true\n129: source = [\"plotnine\"]\n130: include = [\n131:     \"plotnine/*\"\n132: ]\n133: omit = [\n134:     \"tests/*\",\n135:     \"plotnine/typing.py\",\n136:     \"plotnine/_utils/dev.py\",\n137: ]\n138: \n139: disable_warnings = [\"include-ignored\"]\n140: \n141: [tool.coverage.report]\n142: exclude_lines = [\n143:     \"pragma: no cover\",\n144:     \"^def test_\",\n145:     \"if __name__ == .__main__.:\",\n146:     \"raise NotImplementedError('Not Implemented')\",\n147:     \"if typing.TYPE_CHECKING:\",\n148:     \"if TYPE_CHECKING:\",\n149:     \"except ImportError:\",\n150:     \"except PackageNotFoundError:\",\n151: ]\n152: precision = 1\n153: \n154: \n155: ########## Tool - Pyright ##########\n156: [tool.pyright]\n157: # Paths of directories or files that should be included. If no paths\n158: # are specified, pyright defaults to the directory that contains the\n159: # config file. Paths may contain wildcard characters ** (a directory or\n160: # multiple levels of directories), * (a sequence of zero or more\n161: # characters), or ? (a single character). If no include paths are\n162: # specified, the root path for the workspace is assumed.\n163: include = [\n164:     \"plotnine/\"\n165: ]\n166: \n167: # Paths of directories or files whose diagnostic output (errors and\n168: # warnings) should be suppressed even if they are an included file or\n169: # within the transitive closure of an included file. Paths may contain\n170: # wildcard characters ** (a directory or multiple levels of\n171: # directories), * (a sequence of zero or more characters), or ? (a\n172: # single character).\n173: ignore = []\n174: \n175: # Set of identifiers that should be assumed to contain a constant\n176: # value wherever used within this program. For example, { \"DEBUG\": true\n177: # } indicates that pyright should assume that the identifier DEBUG will\n178: # always be equal to True. If this identifier is used within a\n179: # conditional expression (such as if not DEBUG:) pyright will use the\n180: # indicated value to determine whether the guarded block is reachable\n181: # or not. Member expressions that reference one of these constants\n182: # (e.g. my_module.DEBUG) are also supported.\n183: defineConstant = { DEBUG = true }\n184: \n185: # typeCheckingMode = \"strict\"\n186: useLibraryCodeForTypes = true\n187: reportUnnecessaryTypeIgnoreComment = true\n188: \n189: \n190: # Specifies a list of execution environments (see below). Execution\n191: # environments are searched from start to finish by comparing the path\n192: # of a source file with the root path specified in the execution\n193: # environment.\n194: executionEnvironments = []\n195: \n196: stubPath = \"\"\n197: \n198: ########## Tool - Ruff ##########\n199: [tool.ruff]\n200: line-length = 79\n201: \n202: [tool.ruff.lint]\n203: select = [\n204:    \"E\",\n205:    \"F\",\n206:    \"I\",\n207:    \"TCH\",\n208:    \"Q\",\n209:    \"PIE\",\n210:    \"PTH\",\n211:    \"PD\",\n212:    \"PYI\",\n213:    \"RSE\",\n214:    \"SIM\",\n215:    \"B904\",\n216:    \"FLY\",\n217:    \"NPY\",\n218:    \"PERF102\"\n219: ]\n220: ignore = [\n221:     \"E741\",  # Ambiguous l\n222:     \"E743\",  # Ambiguous I\n223:     # .reset_index, .rename, .replace\n224:     # This will remain the correct choice until we enable copy-on-write\n225:     \"PD002\",\n226:     # Use specific rule codes when ignoring type issues and\n227:     # not # type: ignore\n228:     \"PGH003\"\n229: ]\n230: \n231: # Allow autofix for all enabled rules (when `--fix`) is provided.\n232: fixable = [\"ALL\"]\n233: unfixable = []\n234: \n235: # Exclude a variety of commonly ignored directories.\n236: exclude = [\n237:     \"plotnine/themes/seaborn_rcmod.py\",\n238:     \"**/__pycache__\",\n239:     \"node_modules\"\n240: ]\n241: \n242: \n243: # Allow unused variables when underscore-prefixed.\n244: dummy-variable-rgx = \"^(_+|(_+[a-zA-Z0-9_]*[a-zA-Z0-9]+?))$\"\n245: \n246: [tool.ruff.lint.per-file-ignores]\n247: \"plotnine/__init__.py\" = [\"F403\", \"F405\"]\n248: \"plotnine/typing.py\" = [\"F401\", \"TCH001\"]\n249: \"doc/_renderers/numpydoc.py\" = [\"F811\"]\n250: \"doc/_renderers/format.py\" = [\"F811\"]\n251: \"doc/_renderer.py\" = [\"F811\"]\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"########## Project ##########\n[project]\nname = \"plotnine\"\ndescription = \"A Grammar of Graphics for Python\"\nlicense = {file = \"LICENSE\"}\nauthors = [\n  {name = \"Hassan Kibirige\", email = \"has2k1@gmail.com\"},\n]\ndynamic = [\"version\"]\nreadme = \"README.md\"\nclassifiers = [\n    \"Intended Audience :: Science/Research\",\n    \"License :: OSI Approved :: MIT License\",\n    \"Operating System :: Microsoft :: Windows\",\n    \"Operating System :: Unix\",\n    \"Operating System :: MacOS\",\n    \"Programming Language :: Python :: 3 :: Only\",\n    \"Programming Language :: Python :: 3.10\",\n    \"Programming Language :: Python :: 3.11\",\n    \"Programming Language :: Python :: 3.12\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775775557536,"end":1775775557542}}}]}
