{"type":"session_message","session_id":"ses_28c14dec6ffei2yhPyO5TGMEeN","role":"assistant","message_id":"msg_d73eb35ba001srdS0JRZ3R4OfW","parts":[{"id":"prt_d73eb464f001A32iFTiVLXkfRW","messageID":"msg_d73eb35ba001srdS0JRZ3R4OfW","sessionID":"ses_28c14dec6ffei2yhPyO5TGMEeN","type":"tool","tool":"read","callID":"call_cf8c34e2eb144be6aad95b85","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [project]\n2: name = \"tortoise-orm\"\n3: description = \"Easy async ORM for python, built with relations in mind\"\n4: authors = [{ name = \"Andrey Bondar\", email = \"andrey@bondar.ru\" }, { name = \"Nickolas Grigoriadis\", email = \"nagrigoriadis@gmail.com\" }, { name = \"long2ice\", email = \"long2ice@gmail.com\" }]\n5: license = { text = \"Apache-2.0\" }\n6: readme = \"README.rst\"\n7: keywords = [\"sql\", \"mysql\", \"postgres\", \"psql\", \"sqlite\", \"aiosqlite\", \"asyncpg\", \"relational\", \"database\", \"rdbms\", \"orm\", \"object mapper\", \"async\", \"asyncio\", \"aio\", \"psycopg\"]\n8: dynamic = [\"version\"]\n9: requires-python = \">=3.10\"\n10: dependencies = [\n11:     \"pypika-tortoise (>=0.6.5,<1.0.0)\",\n12:     \"iso8601 (>=2.1.0,<3.0.0); python_version < '4.0'\",\n13:     \"aiosqlite (>=0.16.0,<1.0.0)\",\n14:     \"anyio\",\n15:     \"tomlkit (>=0.11.4,<1.0.0); python_version < '3.11'\",\n16:     \"typing-extensions (>= 4.1.0); python_version < '3.11'\",\n17: ]\n18: classifiers = [\n19:     \"License :: OSI Approved :: Apache Software License\",\n20:     \"Development Status :: 3 - Alpha\",\n21:     \"Intended Audience :: Developers\",\n22:     \"Programming Language :: Python :: 3\",\n23:     \"Programming Language :: Python :: 3.10\",\n24:     \"Programming Language :: Python :: 3.11\",\n25:     \"Programming Language :: Python :: 3.12\",\n26:     \"Programming Language :: Python :: 3.13\",\n27:     \"Programming Language :: Python :: 3.14\",\n28:     \"Programming Language :: Python :: Implementation :: CPython\",\n29:     \"Programming Language :: Python :: Implementation :: PyPy\",\n30:     \"Programming Language :: PL/SQL\",\n31:     \"Framework :: AsyncIO\",\n32:     \"Topic :: Software Development :: Libraries :: Python Modules\",\n33:     \"Topic :: Database\",\n34:     \"Typing :: Typed\",\n35:     \"Operating System :: POSIX\",\n36:     \"Operating System :: MacOS :: MacOS X\",\n37:     \"Operating System :: Microsoft :: Windows\",\n38: ]\n39: \n40: [project.optional-dependencies]\n41: ipython = [\n42:     \"ipython\",\n43:     \"nest-asyncio>=1.6.0\",\n44: ]\n45: ptpython = [\n46:     \"ptpython>=3.0.0\",\n47: ]\n48: accel = [\n49:     \"ciso8601; sys_platform != 'win32' and implementation_name == 'cpython'\",\n50:     \"uvloop; sys_platform != 'win32' and implementation_name == 'cpython'\",\n51:     \"orjson\",\n52: ]\n53: asyncpg = [\"asyncpg\"]\n54: aiomysql = [\"aiomysql\"]\n55: asyncmy = [\"asyncmy (>=0.2.11,<1.0.0)\"]\n56: psycopg = [\"psycopg[pool,binary] (>=3.0.12,<4.0.0)\"]\n57: asyncodbc = [\"asyncodbc (>=0.1.1,<1.0.0); python_version < '4.0'\"]\n58: \n59: [project.urls]\n60: documentation = \"https://tortoise.github.io\"\n61: homepage = \"https://github.com/tortoise/tortoise-orm\"\n62: repository = \"https://github.com/tortoise/tortoise-orm.git\"\n63: \n64: [project.scripts]\n65: tortoise = \"tortoise.cli:main\"\n66: \n67: [dependency-groups]\n68: dev = [\n69:     # Linter tools\n70:     \"mypy\",\n71:     \"ruff\",\n72:     \"pylint\",\n73:     \"bandit\",\n74:     \"codespell\",\n75:     # Pypi\n76:     \"twine\",\n77:     # mypy\n78:     \"types-PyYAML\",\n79:     \"types-pytz\",\n80:     \"types-PyMySQL\",\n81: ]\n82: contrib = [\n83:     # Sample integration - Quart\n84:     \"quart\",\n85:     # Sample integration - Sanic\n86:     \"sanic\",\n87:     \"sanic-testing\",\n88:     # Sample integration - Starlette\n89:     \"starlette\",\n90:     # Pydantic support\n91:     \"pydantic >=2.0,!=2.7.0\",\n92:     # FastAPI support\n93:     \"fastapi >=0.115.0\",\n94:     \"asgi_lifespan\",\n95:     \"httpx\",\n96:     # Aiohttp support\n97:     \"aiohttp\",\n98:     # BlackSheep support\n99:     \"blacksheep>=2.0.8\",\n100:     \"pytest-asyncio>=0.24.0\",\n101: ]\n102: test = [\n103:     # Test tools\n104:     \"pytest\",\n105:     \"pytest-xdist\",\n106:     \"pytest-cov\",\n107:     \"pytest-codspeed\",\n108:     \"pytest-asyncio\",\n109:     \"cryptography>=46.0.3\",\n110:     \"aiomysql>=0.3.2\",\n111:     \"pytz>=2025.2\",\n112: ]\n113: docs = [\n114:     # Documentation tools\n115:     \"sphinx-immaterial\",\n116:     \"sphinx-copybutton\",\n117:     \"Pygments\",\n118:     \"docutils\",\n119: ]\n120: \n121: [build-system]\n122: requires = [\"pdm-backend\"]\n123: build-backend = \"pdm.backend\"\n124: \n125: [tool.pdm]\n126: version = { source = \"file\", path = \"tortoise/__init__.py\" }\n127: \n128: [tool.pdm.build]\n129: excludes = [\"./**/.git\", \"./**/.*_cache\", \"examples\"]\n130: include = [\"CHANGELOG.rst\", \"LICENSE\", \"README.rst\"]\n131: \n132: [tool.mypy]\n133: pretty = true\n134: exclude = [\"docs\"]\n135: ignore_missing_imports = true\n136: check_untyped_defs = true\n137: disallow_subclassing_any = true\n138: disallow_untyped_calls = true\n139: disallow_untyped_defs = false\n140: disallow_incomplete_defs = false\n141: disallow_untyped_decorators = true\n142: no_implicit_optional = true\n143: warn_redundant_casts = true\n144: warn_unused_ignores = true\n145: warn_no_return = true\n146: warn_return_any = false\n147: warn_unused_configs = true\n148: warn_unreachable = true\n149: allow_redefinition = true\n150: strict_equality = true\n151: show_error_context = true\n152: \n153: [[tool.mypy.overrides]]\n154: module = \"tests.*\"\n155: check_untyped_defs = false\n156: disallow_untyped_defs = false\n157: disallow_incomplete_defs = false\n158: warn_unreachable = false\n159: \n160: [[tool.mypy.overrides]]\n161: module = \"examples.*\"\n162: check_untyped_defs = false\n163: disallow_untyped_calls = false\n164: disallow_untyped_defs = false\n165: disallow_incomplete_defs = false\n166: \n167: [[tool.mypy.overrides]]\n168: module = \"examples.fastapi.*\"\n169: check_untyped_defs = true\n170: disallow_untyped_calls = true\n171: disallow_untyped_defs = false\n172: disallow_incomplete_defs = false\n173: \n174: [[tool.mypy.overrides]]\n175: module = \"tortoise.contrib.test.*\"\n176: disallow_untyped_defs = false\n177: disallow_incomplete_defs = false\n178: \n179: [[tool.mypy.overrides]]\n180: module = \"tortoise.contrib.sanic.*\"\n181: disallow_untyped_defs = false\n182: \n183: [[tool.mypy.overrides]]\n184: module = [\"conftest\", \"tortoise.backends.base.client\"]\n185: disallow_untyped_defs = false\n186: \n187: [tool.flake8]\n188: ignore = \"E203,E501,W503,DAR101,DAR201,DAR402\"\n189: max-line-length = 100\n190: per-file-ignores = [\n191:     \"tortoise/__init__.py:F401\",\n192:     \"tortoise/fields/__init__.py:F401\",\n193:     \"tortoise/backends/base/client.py:DAR401,DAR202\",\n194:     \"tortoise/contrib/test/__init__.py:DAR401\",\n195: ]\n196: docstring_style = \"sphinx\"\n197: \n198: [tool.pytest.ini_options]\n199: asyncio_mode = \"strict\"\n200: asyncio_default_fixture_loop_scope = \"session\"\n201: asyncio_default_test_loop_scope = \"session\"\n202: markers = [\n203:     \"benchmark: Performance regression tests (excluded from coverage runs)\",\n204: ]\n205: filterwarnings = [\n206:     'ignore:`pk` is deprecated:DeprecationWarning',\n207:     'ignore:`index` is deprecated:DeprecationWarning',\n208:     'ignore:Do not add pk field to `update_fields`!:RuntimeWarning',\n209: ]\n210: \n211: [tool.coverage.report]\n212: show_missing = true\n213: \n214: [tool.ruff]\n215: line-length = 100\n216: exclude = [\"docs/type_globals.py\"]\n217: [tool.ruff.lint]\n218: ignore = [\"E501\"]\n219: extend-select = [\n220:     \"I\", # https://docs.astral.sh/ruff/rules/#isort-i\n221:     \"FA\", # https://docs.astral.sh/ruff/rules/#flake8-future-annotations-fa\n222:     \"UP\", # https://docs.astral.sh/ruff/rules/#pyupgrade-up\n223:     \"RUF100\", # https://docs.astral.sh/ruff/rules/#ruff-specific-rules-ruf\n224: ]\n225: \n226: [tool.ruff.lint.isort]\n227: extra-standard-library = [\"tomllib\"]\n228: \n229: [tool.bandit]\n230: exclude_dirs = [\n231:     \"tests\",\n232:     \"examples/*/_tests.py\",\n233:     \"examples/pytest\",\n234:     \"conftest.py\",\n235:     \"tortoise/migrations/schema_editor/mssql.py\",\n236:     \"examples/postgres_full_text_search.py\",\n237:     \"examples/postgres.py\",\n238: ]\n239: \n240: [tool.codespell]\n241: ignore-words-list = \"notin,NotIn,brin,BRIN,astroid\"\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"[project]\nname = \"tortoise-orm\"\ndescription = \"Easy async ORM for python, built with relations in mind\"\nauthors = [{ name = \"Andrey Bondar\", email = \"andrey@bondar.ru\" }, { name = \"Nickolas Grigoriadis\", email = \"nagrigoriadis@gmail.com\" }, { name = \"long2ice\", email = \"long2ice@gmail.com\" }]\nlicense = { text = \"Apache-2.0\" }\nreadme = \"README.rst\"\nkeywords = [\"sql\", \"mysql\", \"postgres\", \"psql\", \"sqlite\", \"aiosqlite\", \"asyncpg\", \"relational\", \"database\", \"rdbms\", \"orm\", \"object mapper\", \"async\", \"asyncio\", \"aio\", \"psycopg\"]\ndynamic = [\"version\"]\nrequires-python = \">=3.10\"\ndependencies = [\n    \"pypika-tortoise (>=0.6.5,<1.0.0)\",\n    \"iso8601 (>=2.1.0,<3.0.0); python_version < '4.0'\",\n    \"aiosqlite (>=0.16.0,<1.0.0)\",\n    \"anyio\",\n    \"tomlkit (>=0.11.4,<1.0.0); python_version < '3.11'\",\n    \"typing-extensions (>= 4.1.0); python_version < '3.11'\",\n]\nclassifiers = [\n    \"License :: OSI Approved :: Apache Software License\",\n    \"Development Status :: 3 - Alpha\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775766292322,"end":1775766292333}}}]}
