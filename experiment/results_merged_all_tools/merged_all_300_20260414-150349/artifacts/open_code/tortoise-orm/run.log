$(checkfiles)\n36: \t#pylint -d C,W,R $(checkfiles)\n37: \t$(MAKE) _codeqc\n38: \n39: style: deps _style\n40: _style:\n41: \tuv run --frozen ruff format $(checkfiles)\n42: \tuv run --frozen ruff check --fix $(checkfiles)\n43: \n44: lint: build _lint\n45: _lint:\n46: \t$(MAKE) _style\n47: \t$(MAKE) _codeqc\n48: \n49: codeqc: build _codeqc\n50: _codeqc:\n51: \tuv run --frozen mypy $(checkfiles)\n52: \tuv run --frozen bandit -c pyproject.toml -r $(checkfiles)\n53: \tuv run --frozen twine check dist/*\n54: \n55: test: deps\n56: \t$(py_warn) TORTOISE_TEST_DB=sqlite://:memory: uv run --frozen pytest $(pytest_opts)\n57: \n58: test_fast: deps\n59: \t$(py_warn) TORTOISE_TEST_DB=sqlite://:memory: uv run --frozen pytest -n auto --tb=native -q\n60: \n61: test_sqlite:\n62: \t$(py_warn) TORTOISE_TEST_DB=sqlite://:memory: uv run --frozen pytest --cov-report= $(pytest_opts)\n63: \n64: test_sqlite_regexp:\n65: \t$(py_warn) TORTOISE_TEST_DB=sqlite://:memory:?install_regexp_functions=True uv run --frozen pytest --cov-report= $(pytest_opts)\n66: \n67: test_postgres_asyncpg:\n68: \tuv run --frozen python -V | grep PyPy || $(py_warn) TORTOISE_TEST_DB=\"asyncpg://postgres:$(TORTOISE_POSTGRES_PASS)@127.0.0.1:5432/test_\\{\\}\" uv run --frozen pytest $(pytest_opts) --cov-report=\n69: \n70: test_postgres_psycopg:\n71: \tuv run --frozen python -V | grep PyPy || $(py_warn) TORTOISE_TEST_DB=\"psycopg://postgres:$(TORTOISE_POSTGRES_PASS)@127.0.0.1:5432/test_\\{\\}\" uv run --frozen pytest $(pytest_opts) --cov-report=\n72: \n73: test_mysql_myisam:\n74: \t$(py_warn) TORTOISE_TEST_DB=\"mysql://root:$(TORTOISE_MYSQL_PASS)@127.0.0.1:3306/test_\\{\\}?storage_engine=MYISAM\" uv run --frozen pytest $(pytest_opts) --cov-report=\n75: \n76: test_mysql:\n77: \t$(py_warn) TORTOISE_TEST_DB=\"mysql://root:$(TORTOISE_MYSQL_PASS)@127.0.0.1:3306/test_\\{\\}\" uv run --frozen pytest $(pytest_opts) --cov-report=\n78: \n79: test_mysql_asyncmy:\n80: \t$(MAKE) deps_with_asyncmy\n81: \t$(MAKE) test_mysql\n82: \t# Resto