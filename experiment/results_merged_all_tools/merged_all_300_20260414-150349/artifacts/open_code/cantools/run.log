\"https://github.com/cantools/cantools\"\n57: \n58: [tool.setuptools.packages.find]\n59: where = [\"src\"]\n60: \n61: [tool.setuptools.package-data]\n62: cantools = [\"py.typed\"]\n63: \n64: [tool.mypy]\n65: show_error_codes = true\n66: warn_return_any = true\n67: warn_unused_configs = true\n68: no_implicit_optional = true\n69: disallow_incomplete_defs = true\n70: warn_redundant_casts = true\n71: warn_unused_ignores = true\n72: exclude = \"^(?!src).*$\"\n73: \n74: [tool.ruff]\n75: line-length = 80\n76: lint.extend-select = [\n77:     \"A\",    # flake8-builtins\n78:     \"B\",    # pyflakes-bugbear\n79:     \"C4\",   # flake8-comprehensions\n80:     \"E\",    # pycodestyle Error\n81:     \"F\",    # pyflakes\n82:     \"FURB\", # refurb\n83:     \"I\",    # isort\n84:     \"PIE\",  # flake8-pie\n85:     \"PL\",   # pylint\n86:     \"RUF\",  # Ruff-specific rules\n87:     \"TCH\",  # flake8-type-checking\n88:     \"UP\",   # pyupgrade\n89:     \"W\",    # pycodestyle Warning\n90: ]\n91: lint.ignore = [\n92:     \"E501\",    # line too long\n93:     \"F541\",    # f-string-missing-placeholders\n94:     \"PLR09\",   # too-many-this, too-many-that\n95:     \"PLR2004\", # magic-value-comparison\n96:     \"PLW1641\", # eq-without-hash\n97:     \"PLW2901\", # redefined-loop-name\n98:     \"RUF012\",  # mutable-class-default\n99: ]\n100: lint.isort.known-first-party = [\"cantools\"]\n101: lint.per-file-ignores.\"signal.py\" = [\"A005\"]\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=68\", \"setuptools_scm>=8\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"cantools\"\nauthors = [\n    {name = \"Erik Moqvist\", email = \"erik.moqvist@gmail.com\"},\n]\ndescription = \"CAN BUS tools.\"\nreadme = \"README.rst\"\nrequires-python = \">=3.10\"\nkeywords = [\n    \"can\",\n    \"can bus\",\n    \"arxml\",\n    \"dbc\",\n    \"kcd\",\n    \"automotive\",\n]","truncated":false,"loaded":[]},"title":"p