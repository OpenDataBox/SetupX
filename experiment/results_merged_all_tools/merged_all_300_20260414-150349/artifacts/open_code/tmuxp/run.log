   { path = \"examples\", format = \"sdist\" },\n38:   { path = \"docs\", format = \"sdist\" },\n39:   { path = \"conftest.py\", format = \"sdist\" },\n40: ]\n41: dependencies = [\n42:   \"libtmux~=0.55.0\",\n43:   \"PyYAML>=6.0\"\n44: ]\n45: \n46: [project.urls]\n47: \"Bug Tracker\" = \"https://github.com/tmux-python/tmuxp/issues\"\n48: Documentation = \"https://tmuxp.git-pull.com\"\n49: Repository = \"https://github.com/tmux-python/tmuxp\"\n50: Changes = \"https://github.com/tmux-python/tmuxp/blob/master/CHANGES\"\n51: \n52: [project.scripts]\n53: tmuxp = 'tmuxp:cli.cli'\n54: \n55: [dependency-groups]\n56: dev = [\n57:   # Docs\n58:   \"aafigure\",  # https://launchpad.net/aafigure\n59:   \"pillow\",  # https://pillow.readthedocs.io/\n60:   \"gp-sphinx==0.0.1a0\",  # https://gp-sphinx.git-pull.com/\n61:   \"sphinx-argparse-neo==0.0.1a0\",  # https://gp-sphinx.git-pull.com/\n62:   \"gp-libs\",  # https://gp-libs.git-pull.com/\n63:   \"sphinx-autobuild\",  # https://sphinx-extensions.readthedocs.io/en/latest/sphinx-autobuild.html\n64:   # Testing\n65:   \"gp-libs\",\n66:   \"pytest\",\n67:   \"pytest-rerunfailures\",\n68:   \"pytest-mock\",\n69:   \"pytest-watcher\",\n70:   # Coverage\n71:   \"codecov\",\n72:   \"coverage\",\n73:   \"pytest-cov\",\n74:   # Lint\n75:   \"ruff\",\n76:   \"mypy\",\n77:   \"types-docutils\",\n78:   \"types-Pygments\",\n79:   \"types-PyYAML\",\n80: ]\n81: \n82: docs = [\n83:   \"aafigure\",  # https://launchpad.net/aafigure\n84:   \"pillow\",  # https://pillow.readthedocs.io/\n85:   \"gp-sphinx==0.0.1a0\",  # https://gp-sphinx.git-pull.com/\n86:   \"sphinx-argparse-neo==0.0.1a0\",  # https://gp-sphinx.git-pull.com/\n87:   \"gp-libs\",  # https://gp-libs.git-pull.com/\n88:   \"sphinx-autobuild\",  # https://sphinx-extensions.readthedocs.io/en/latest/sphinx-autobuild.html\n89: ]\n90: testing = [\n91:   \"gp-libs\",\n92:   \"pytest\",\n93:   \"pytest-rerunfailures\",\n94:   \"pytest-mock\",\n95:   \"pytest-watcher\",\n96: ]\n97: coverage =[\n98:   \"codecov\",\n99:   \"coverage\",\n100:   \"pytest-cov\",\n101: ]\n102: lint = [\n103:   \"ruff\",\n104:   \"mypy\",\n105:   \"types-docutils\",\n106:   \"types-Pygments\",\n107:   \"types-PyYAML\",\n108: ]\n109: \n110: [build-system]\n111: requires = [\"hatchling\"]\n112: build-backend = \"hatchling.build\"\n113: \n114: [tool.coverage.run]\n115: branch = true\n116: source = [\n117:   \"tmuxp\",\n118: ]\n119: omit = [\n120:   \"tests/*\",\n121:   \"*/_vendor/*\",\n122:   \"*/_*\",\n123:   \"pkg/*\",\n124:   \"*/log.py\",\n125:   \"docs/_ext/*\",\n126: ]\n127: \n128: [tool.coverage.report]\n129: exclude_lines = [\n130:   \"pragma: no cover\",\n131:   \"def __repr__\",\n132:   \"raise NotImplementedError\",\n133:   \"if __name__ == .__main__.:\",\n134:   \"def parse_args\",\n135:   \"from __future__ import annotations\",\n136:   \"if TYPE_CHECKING:\",\n137:   \"if t.TYPE_CHECKING:\",\n138: ]\n139: \n140: [tool.mypy]\n141: strict = true\n142: python_version = \"3.10\"\n143: files = [\n144:   \"src/\",\n145:   \"tests/\",\n146: ]\n147: enable_incomplete_feature = []\n148: \n149: [[tool.mypy.overrides]]\n150: module = [\n151:   \"shtab\",\n152:   \"IPython.*\",\n153:   \"ptpython.*\",\n154:   \"prompt_toolkit.*\",\n155:   \"bpython\",\n156:   \"aafigure\",\n157: ]\n158: ignore_missing_imports = true\n159: \n160: [tool.ruff]\n161: target-version = \"py310\"\n162: \n163: [tool.ruff.lint]\n164: select = [\n165:   \"E\", # pycodestyle\n166:   \"F\", # pyflakes\n167:   \"I\", # isort\n168:   \"UP\", # pyupgrade\n169:   \"A\", # flake8-builtins\n170:   \"B\", # flake8-bugbear\n171:   \"C4\", # flake8-comprehensions\n172:   \"COM\", # flake8-commas\n173:   \"EM\", # flake8-errmsg\n174:   \"Q\", # flake8-quotes\n175:   \"PTH\", # flake8-use-pathlib\n176:   \"SIM\", # flake8-simplify\n177:   \"TRY\", # Trycertatops\n178:   \"PERF\", # Perflint\n179:   \"RUF\", # Ruff-specific rules\n180:   \"D\", # pydocstyle\n181:   \"FA100\",  # future annotations\n182: ]\n183: ignore = [\n184:   \"COM812\", # missing trailing comma, ruff format conflict\n185: ]\n186: extend-safe-fixes = [\n187:   \"UP006\",\n188:   \"UP007\",\n189: ]\n190: pyupgrade.keep-runtime-typing = false\n191: \n192: [tool.ruff.lint.isort]\n193: known-first-party = [\n194:   \"tmuxp\",\n195: ]\n196: combine-as-imports = true\n197: required-imports = [\n198:   \"from __future__ import annotations\",\n199: ]\n200: \n201: [tool.ruff.lint.flake8-builtins]\n202: builtins-allowed-modules = [\n203:   \"types\",\n204: ]\n205: \n206: [tool.ruff.lint.pydocstyle]\n207: convention = \"numpy\"\n208: \n209: [tool.ruff.lint.per-file-ignores]\n210: \"*/__init__.py\" = [\"F401\"]\n211: \"src/tmuxp/workspace/finders.py\" = [\"PTH\"]\n212: \"src/tmuxp/cli/*.py\" = [\"PTH\"]\n213: \"docs/_ext/aafig.py\" = [\"PTH\"]\n214: \n215: [tool.pytest.ini_options]\n216: addopts = \"--reruns=0 --tb=short --no-header --showlocals --doctest-modules\"\n217: doctest_optionflags = \"ELLIPSIS NORMALIZE_WHITESPACE\"\n218: testpaths = [\n219:   \"src/tmuxp\",\n220:   \"tests\",\n221:   \"docs\",\n222: ]\n223: filterwarnings = [\n224:   \"ignore:The frontend.Option(Parser)? class.*:DeprecationWarning::\",\n225:   \"ignore:.*invalid escape sequence.*:SyntaxWarning:.*aafigure.*:\",\n226: ]\n\n(End of file - total 226 lines)\n</content>","metadata":{"preview":"[project]\nname = \"tmuxp\"\nversion = \"1.67.0\"\ndescription = \"Session manager for tmux, which allows users to save and load tmux sessions through simple configuration files.\"\nrequires-python = \">=3.10,<4.0\"\nauthors = [\n  {name = \"Tony Narlock\", email = \"tony@git-pull.com\"}\n]\nlicense = { text = \"MIT\" }\nclassifiers = [\n  \"Development Status :: 5 - Production/Stable\",\n  \"License :: OSI Approved :: MIT License\",\n  \"Operating System :: POSIX\",\n  \"Operating System :: MacOS :: MacOS X\",\n  \"Environment :: Web Environment\",\n  \"Intended Audience :: Developers\",\n  \"Programming Language :: Python\",\n  \"Programming Language :: Python :: 3.10\",\n  \"Programming Language :: Python :: 3.11\",\n  \"Programming Language :: Python :: 3.12\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775777673468,"end":1775777673473}}}]}
