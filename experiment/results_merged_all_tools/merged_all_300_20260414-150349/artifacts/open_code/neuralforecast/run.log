t)\n40:     assert (y_hat == y_hat2).all()\n41: \n42: \n43: #test no leakage with test_size\n44: def test_nbeats_model_no_leakage(setup_data):\n45:     dataset, *_ = setup_data\n46:     model = NBEATS(input_size=24, h=12,\n47:                    windows_batch_size=None, max_steps=1)\n48:     model.fit(dataset=dataset, test_size=12)\n49:     y_hat_test = model.predict(dataset=dataset, step_size=1)\n50: \n51:     #test we recover the same forecast\n52:     y_hat_test2 = model.predict(dataset=dataset, step_size=1)\n53:     assert (y_hat_test == y_hat_test2).all()\n54: \n55: # test validation step\n56: def test_nbeats_model_with_validation(setup_data):\n57:     dataset, Y_train_df, Y_test_df = setup_data\n58:     model = NBEATS(input_size=24, h=12, windows_batch_size=None, max_steps=1)\n59:     model.fit(dataset=dataset, val_size=12)\n60:     y_hat_w_val = model.predict(dataset=dataset)\n61:     Y_test_df['N-BEATS'] = y_hat_w_val\n62: \n63:     # pd.concat([Y_train_df, Y_test_df]).drop('unique_id', axis=1).set_index('ds').plot()\n64: \n65:     # test no leakage with test_size and val_size\n66:     dataset, *_ = TimeSeriesDataset.from_df(Y_train_df)\n67:     model = NBEATS(input_size=24, h=12, windows_batch_size=None, max_steps=1)\n68:     model.fit(dataset=dataset, val_size=12)\n69:     y_hat_w_val = model.predict(dataset=dataset)\n70: \n71:     dataset, *_ = TimeSeriesDataset.from_df(Y_df)\n72:     model = NBEATS(input_size=24, h=12, windows_batch_size=None, max_steps=1)\n73:     model.fit(dataset=dataset, val_size=12, test_size=12)\n74: \n75:     y_hat_test_w_val = model.predict(dataset=dataset, step_size=1)\n76: \n77:     np.testing.assert_almost_equal(y_hat_test_w_val, y_hat_w_val, decimal=4)\n78: \n79: def test_autonbeats(setup_dataset):\n80:     dataset = setup_dataset\n81: \n82:     # Unit test to test that Auto* model contains all required arguments from BaseAuto\n83:     check_args(AutoNBEATS, exclude_args=['cls_model'])\n84: \n85:     # Unit test for situation