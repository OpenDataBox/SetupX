1:         err_code = os.system(f\"git checkout -b {self.version_branch}\")\n312:         if err_code != 0:\n313:             raise RuntimeError(\"Failed to create branch.\")\n314: \n315:         # Change the version in meerkat/version.py\n316:         self.status(f\"Updating version {VERSION} -> {self.version}\")\n317:         update_version(self.version)\n318:         # TODO: Add a check to make sure the version actually updated.\n319:         # if VERSION != self.version:\n320:         #     self._undo()\n321:         #     raise RuntimeError(\"Failed to update version.\")\n322: \n323:         self.status(f\"npm install to bump package-lock.json\")\n324:         err_code = os.system(\"mk install\")\n325:         if err_code != 0:\n326:             self._undo()\n327:             raise RuntimeError(\"Failed to update package-lock.json.\")\n328: \n329:         self.status(f\"Adding {', '.join(self.updated_files)} to git\")\n330:         err_code = os.system(f\"git add {' '.join(self.updated_files)}\")\n331:         if err_code != 0:\n332:             self._undo()\n333:             raise RuntimeError(\"Failed to add file to git.\")\n334: \n335:         self.status(f\"Commit with message '[bumpversion] v{self.version}'\")\n336:         err_code = os.system(\"git commit -m '[bumpversion] v{}'\".format(self.version))\n337:         if err_code != 0:\n338:             self._undo()\n339:             raise RuntimeError(\"Failed to commit file to git.\")\n340: \n341:         # Push the commit to origin.\n342:         self.status(f\"Pushing commit to origin/{self.version_branch}\")\n343:         err_code = os.system(\n344:             f\"git push --force --set-upstream origin {self.version_branch}\"\n345:         )\n346:         if err_code != 0:\n347:             # TODO: undo the commit automatically.\n348:             self._undo()\n349:             raise RuntimeError(\"Failed to push commit to origin.\")\n350: \n351:         os.system(f\"git checkout {self.base_branch}\")\n352:         os.system(f\"git branch -D {self.version_branch}\")\n353:         sys.exit()\n354: \n355: \n356: def update_version(version):\n357:     import json\n358: \n359:     # Update python.\n360:     ver_path = convert_path(\"meerkat/version.py\")\n361:     init_py = [\n362:         line if not line.startswith(\"__version__\") else f'__version__ = \"{version}\"\\n'\n363:         for line in open(ver_path, \"r\").readlines()\n364:     ]\n365:     with open(ver_path, \"w\") as f:\n366:         f.writelines(init_py)\n367: \n368:     # Update npm.\n369:     ver_path = convert_path(\"meerkat/interactive/app/package.json\")\n370:     with open(ver_path, \"r\") as f:\n371:         package_json = json.load(f)\n372:     package_json[\"version\"] = version\n373:     with open(ver_path, \"w\") as f:\n374:         json.dump(package_json, f, indent=4)\n375:         f.write(\"\\n\")\n376: \n377: \n378: def get_git_branch():\n379:     \"\"\"Return the name of the current branch.\"\"\"\n380:     proc = subprocess.Popen([\"git branch\"], stdout=subprocess.PIPE, shell=True)\n381:     (out, err) = proc.communicate()\n382:     if err is not None:\n383:         raise RuntimeError(f\"Error finding git branch: {err}\")\n384:     out = out.decode(\"utf-8\").split(\"\\n\")\n385:     current_branch = [line for line in out if line.startswith(\"*\")][0]\n386:     current_branch = current_branch.replace(\"*\", \"\").strip()\n387:     return current_branch\n388: \n389: \n390: # Where the magic happens:\n391: setup(\n392:     name=NAME,\n393:     version=about[\"__version__\"],\n394:     description=DESCRIPTION,\n395:     long_description=long_description,\n396:     long_description_content_type=\"text/markdown\",\n397:     author=AUTHOR,\n398:     author_email=EMAIL,\n399:     python_requires=REQUIRES_PYTHON,\n400:     url=URL,\n401:     packages=find_packages(exclude=[\"tests\", \"*.tests\", \"*.tests.*\", \"tests.*\", \"demo\"])\n402:     + [\"meerkat-demo\"],\n403:     package_dir={\"mee