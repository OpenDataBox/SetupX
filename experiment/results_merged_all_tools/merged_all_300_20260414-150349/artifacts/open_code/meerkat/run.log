{"type":"session_message","session_id":"ses_28973c886ffeuilhHEURLxpCND","role":"assistant","message_id":"msg_d768c4bd3001CHPQHSzbWdW4nr","parts":[{"id":"prt_d768c5932001gsU9o5Ubmst1If","messageID":"msg_d768c4bd3001CHPQHSzbWdW4nr","sessionID":"ses_28973c886ffeuilhHEURLxpCND","type":"tool","tool":"read","callID":"call_6353960b33394f8883a83be7","state":{"status":"completed","input":{"filePath":"/workspace/setup.py"},"output":"<path>/workspace/setup.py</path>\n<type>file</type>\n<content>1: #!/usr/bin/env python\n2: # -*- coding: utf-8 -*-\n3: \n4: import io\n5: import os\n6: \n7: # Note: To use the 'upload' functionality of this file, you must:\n8: #   $ pipenv install twine --dev\n9: import shutil\n10: import subprocess\n11: import sys\n12: from distutils.util import convert_path\n13: from shutil import rmtree\n14: \n15: from setuptools import Command, find_packages, setup\n16: \n17: main_ns = {}\n18: ver_path = convert_path(\"meerkat/version.py\")\n19: with open(ver_path) as ver_file:\n20:     exec(ver_file.read(), main_ns)\n21: \n22: # Restrict ipython version based on the python version.\n23: # https://github.com/ipython/ipython/issues/14053\n24: # TODO: Remove this once the wheel is pushed up.\n25: if sys.version_info[0] == 3 and sys.version_info[1] <= 8:\n26:     ipython_requirement = \"IPython<8.13.0\"\n27: else:\n28:     # python >= 3.9\n29:     ipython_requirement = \"IPython\"\n30: \n31: \n32: # Package meta-data.\n33: NAME = \"meerkat-ml\"\n34: DESCRIPTION = (\n35:     \"Meerkat is building new data abstractions to make \" \"machine learning easier.\"\n36: )\n37: URL = \"https://github.com/robustness-gym/meerkat\"\n38: EMAIL = \"eyuboglu@stanford.edu\"\n39: AUTHOR = \"The Meerkat Team\"\n40: REQUIRES_PYTHON = \">=3.7.0\"\n41: VERSION = main_ns[\"__version__\"]\n42: \n43: # What packages are required for this module to be executed?\n44: REQUIRED = [\n45:     \"dataclasses>=0.6\",\n46:     \"pandas\",\n47:     \"dill>=0.3.3\",\n48:     \"numpy>=1.18.0\",\n49:     \"cytoolz\",\n50:     \"ujson\",\n51:     \"torch>=1.7.0\",\n52:     \"scikit-learn\",\n53:     \"tqdm>=4.49.0\",\n54:     \"datasets>=1.4.1\",\n55:     \"pyarrow>=11.0.0\",\n56:     \"pydantic<2.0\",\n57:     \"PyYAML>=5.4.1\",\n58:     \"omegaconf>=2.0.5\",\n59:     \"semver>=2.13.0\",\n60:     \"multiprocess>=0.70.11\",\n61:     \"Cython>=0.29.21\",\n62:     \"progressbar>=2.5\",\n63:     \"fvcore\",\n64:     \"ipywidgets>=7.0.0\",\n65:     ipython_requirement,\n66:     \"fastapi\",\n67:     \"uvicorn\",\n68:     \"rich\",\n69:     \"cryptography\",\n70:     \"fastapi\",\n71:     \"wrapt\",\n72:     \"typer\",\n73:     \"jinja2\",\n74:     \"nbformat\",\n75:     \"sse-starlette\",\n76:     \"tabulate\",\n77:     \"pyparsing\",\n78: ]\n79: \n80: # Read in docs/requirements.txt\n81: with open(\"docs/requirements.txt\") as f:\n82:     DOCS_REQUIREMENTS = f.read().splitlines()\n83: \n84: # What packages are optional?\n85: EXTRAS = {\n86:     \"dev\": [\n87:         \"black==22.12.0\",\n88:         \"isort>=5.12.0\",\n89:         \"flake8>=3.8.4\",\n90:         \"docformatter>=1.4\",\n91:         \"pytest-cov>=2.10.1\",\n92:         \"recommonmark>=0.7.1\",\n93:         \"parameterized\",\n94:         \"pre-commit>=2.9.3\",\n95:         \"twine\",\n96:         \"httpx\",\n97:         \"ray\",\n98:     ]\n99:     + DOCS_REQUIREMENTS,\n100:     \"embeddings-mac\": [\n101:         \"faiss-cpu\",\n102:         \"umap-learn[plot]\",\n103:     ],\n104:     \"embeddings-linux\": [\n105:         \"faiss-gpu\",\n106:         \"umap-learn[plot]\",\n107:     ],\n108:     \"text\": [\n109:         \"transformers\",\n110:         \"spacy>=3.0.0\",\n111:     ],\n112:     \"vision\": [\"torchvision>=0.9.0\", \"opencv-python\", \"Pillow\"],\n113:     \"audio\": [\"torchaudio\"],\n114:     \"medimg\": [\n115:         \"pyvoxel\",\n116:         \"kaggle\",\n117:         \"google-cloud-storage\",\n118:         \"google-cloud-bigquery[bqstorage,pandas]\",\n119:     ],\n120: }\n121: EXTRAS[\"all\"] = list(set(sum(EXTRAS.values(), [])))\n122: \n123: # The rest you shouldn't have to touch too much :)\n124: # ------------------------------------------------\n125: # Except, perhaps the License and Trove Classifiers!\n126: # If you do change the License, remember to change the Trove Classifier for that!\n127: \n128: here = os.path.abspath(os.path.dirname(__file__))\n129: \n130: # Import the README and use it as the long-description.\n131: # Note: this will only work if 'README.md' is present in your MANIFEST.in file!\n132: try:\n133:     with io.open(os.path.join(here, \"README.md\"), encoding=\"utf-8\") as f:\n134:         long_description = \"\\n\" + f.read()\n135: except FileNotFoundError:\n136:     long_description = DESCRIPTION\n137: \n138: # Load the package's __version__.py module as a dictionary.\n139: about = {}\n140: if not VERSION:\n141:     project_slug = NAME.lower().replace(\"-\", \"_\").replace(\" \", \"_\")\n142:     with open(os.path.join(here, project_slug, \"__version__.py\")) as f:\n143:         exec(f.read(), about)\n144: else:\n145:     about[\"__version__\"] = VERSION\n146: \n147: \n148: class UploadCommand(Command):\n149:     \"\"\"Support setup.py upload.\"\"\"\n150: \n151:     description = \"Build and publish the package.\"\n152:     user_options = [(\"skip-upload\", \"u\", \"skip git tagging and pypi upload\")]\n153:     boolean_options = [\"skip-upload\"]\n154: \n155:     @staticmethod\n156:     def status(s):\n157:         \"\"\"Prints things in bold.\"\"\"\n158:         print(\"\\033[1m{0}\\033[0m\".format(s))\n159: \n160:     def initialize_options(self):\n161:         self.skip_upload = False\n162: \n163:     def finalize_options(self):\n164:         self.skip_upload = bool(self.skip_upload)\n165: \n166:     def run(self):\n167:         from huggingface_hub.repository import Repository\n168: \n169:         try:\n170:             self.status(\"Removing previous builds…\")\n171:             rmtree(os.path.join(here, \"dist\"))\n172:             rmtree(os.path.join(here, \"build\"))\n173:         except OSError:\n174:             pass\n175: \n176:         # Build static components\n177:         self.status(\"Building static components…\")\n178:         env = os.environ.copy()\n179:         env.update({\"VITE_API_URL_PLACEHOLDER\": \"http://meerkat.dummy\"})\n180:         if os.path.exists(\"./meerkat/interactive/app/build\"):\n181:             shutil.rmtree(\"./meerkat/interactive/app/build\")\n182:         build_process = subprocess.run(\n183:             \"npm run build\",\n184:             env=env,\n185:             stdout=subprocess.PIPE,\n186:             stderr=subprocess.STDOUT,\n187:             shell=True,\n188:             cwd=\"./meerkat/interactive/app\",\n189:         )\n190:         if build_process.returncode != 0:\n191:             print(build_process.stdout.decode(\"utf-8\"))\n192:             sys.exit(1)\n193: \n194:         # Package static components to a tar file and push to huggingface.\n195:         # This requires having write access to meerkat-ml.\n196:         # TODO: Consider making this a github action.\n197:         self.status(\"Packaging static component build...\")\n198:         components_build_targz = shutil.make_archive(\n199:             base_name=f\"static-build-{VERSION}\",\n200:             format=\"gztar\",\n201:             root_dir=\"./meerkat/interactive/app/build\",\n202:         )\n203: \n204:         self.status(\"Uploading static build to huggingface...\")\n205:         local_repo_dir = os.path.abspath(\n206:             os.path.expanduser(\"~/.meerkat/hf/component-static-builds\")\n207:         )\n208:         repo = Repository(\n209:             local_dir=local_repo_dir,\n210:             clone_from=\"meerkat-ml/component-static-builds\",\n211:             repo_type=\"dataset\",\n212:             token=os.environ.get(\"HF_TOKEN\", True),\n213:         )\n214:         shutil.move(\n215:             components_build_targz,\n216:             os.path.join(local_repo_dir, os.path.basename(components_build_targz)),\n217:         )\n218:         repo.git_pull()\n219:         repo.push_to_hub(commit_message=f\"{VERSION}: new component builds\")\n220: \n221:         # Build the source and wheel.\n222:         self.status(\"Building Source and Wheel (universal) distribution…\")\n223:         os.system(\"{0} setup.py sdist bdist_wheel --universal\".format(sys.executable))\n224: \n225:         if self.skip_upload:\n226:             self.status(\"Skipping git tagging and pypi upload\")\n227:             sys.exit()\n228: \n229:         self.status(\"Uploading the package to PyPI via Twine…\")\n230:         os.system(\"twine upload dist/*\")\n231: \n232:         self.status(\"Pushing git tags…\")\n233:         os.system(\"git tag v{0}\".format(about[\"__version__\"]))\n234:         os.system(\"git push --tags\")\n235: \n236:         sys.exit()\n237: \n238: \n239: class BumpVersionCommand(Command):\n240:     \"\"\"\n241:     To use: python setup.py bumpversion -v <version>\n242: \n243:     This command will push the new version directly and tag it.\n244:     \"\"\"\n245: \n246:     description = \"Installs the foo.\"\n247:     user_options = [\n248:         (\"version=\", \"v\", \"the new version number\"),\n249:     ]\n250: \n251:     @staticmethod\n252:     def status(s):\n253:         \"\"\"Prints things in bold.\"\"\"\n254:         print(\"\\033[1m{0}\\033[0m\".format(s))\n255: \n256:     def initialize_options(self):\n257:         self.version = None\n258:         self.base_branch = None\n259:         self.version_branch = None\n260:         self.updated_files = [\n261:             \"meerkat/version.py\",\n262:             \"meerkat/interactive/app/package.json\",\n263:             \"meerkat/interactive/app/package-lock.json\",\n264:         ]\n265: \n266:     def finalize_options(self):\n267:         # This package cannot be imported at top level because it\n268:         # is not recognized by Github Act