= \"luigi.tools.deps:main\"\n44: luigi-deps-tree = \"luigi.tools.deps_tree:main\"\n45: \n46: [project.optional-dependencies]\n47: jsonschema = [\"jsonschema\"]\n48: prometheus = [\"prometheus-client>=0.5,<0.25\"]\n49: toml = [\"toml<2.0.0\"]\n50: \n51: [dependency-groups]\n52: # groups and dependencies should be sort in lexicographical order\n53: cdh = [\n54:   \"hdfs>=2.0.4,<3.0.0\",\n55: ]\n56: \n57: common = [\n58:   \"avro-python3\",\n59:   \"azure-storage-blob<=12.20.0\",\n60:   \"boto>=2.42,<3.0\",\n61:   \"boto3>=1.11.0\",\n62:   \"codecov>=1.4.0\",\n63:   \"coverage>=5.0,<6\",\n64:   \"datadog==0.22.0\",\n65:   \"docker>=2.1.0\",\n66:   \"elasticsearch>=1.0.0,<2.0.0\",\n67:   \"google-compute-engine\",\n68:   \"HTTPretty==0.8.10\",\n69:   \"hypothesis>=6.7.0,<7.0.0\",\n70:   \"jsonschema\",\n71:   \"mock<2.0\",\n72:   \"moto>=1.3.10,<5.0\",\n73:   \"mypy\",\n74:   \"mysql-connector-python\",\n75:   \"prometheus-client>=0.5.0,<0.25\",\n76:   \"psutil<4.0\",\n77:   \"pygments\",\n78:   \"pyhive[presto]==0.6.1\",\n79:   \"pymongo==3.4.0\",\n80:   \"pytest\",\n81:   \"pytest-cov\",\n82:   \"pytest-xdist\",\n83:   \"requests>=2.20.0,<=2.31.0\",\n84:   \"responses<1.0.0\",\n85:   \"s3transfer>=0.3,<4.0\",\n86:   \"selenium==3.0.2\",\n87:   \"sqlalchemy<1.4\",\n88:   \"toml<2.0.0\",\n89:   \"types-python-dateutil\",\n90:   \"types-requests\",\n91:   \"types-toml\",\n92: ]\n93: \n94: docs = [\n95:   \"azure-storage-blob<=12.28.0\",\n96:   \"jinja2>=3.1,<4\",\n97:   \"mypy\",\n98:   \"prometheus-client>=0.5.0,<0.25\",\n99:   \"Sphinx>=9.0,<10; python_version >= '3.12'\",\n100:   \"sphinx-rtd-theme>=2.0; python_version >= '3.12'\",\n101:   \"sqlalchemy\",\n102: ]\n103: \n104: dropbox = [\n105:   \"dropbox>=11.0.0\",\n106: ]\n107: \n108: gcloud = [\n109:   \"google-api-python-client>=1.6.6,<2.0\",\n110:   \"google-auth==1.4.1\",\n111:   \"google-auth-httplib2==0.0.3\",\n112: ]\n113: \n114: hdp = [\n115:   \"hdfs>=2.0.4,<3.0.0\",\n116: ]\n117: \n118: lint = [\n119:   \"