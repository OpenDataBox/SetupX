{"type":"session_message","session_id":"ses_289464e49ffe0PfCgeymUZjBBs","role":"assistant","message_id":"msg_d76ba160b001gYxLRjXS2pVODP","parts":[{"id":"prt_d76ba218e001l4ehaQ0iCXY7KH","messageID":"msg_d76ba160b001gYxLRjXS2pVODP","sessionID":"ses_289464e49ffe0PfCgeymUZjBBs","type":"tool","tool":"read","callID":"call_f94570789aec485f8c18cdd2","state":{"status":"completed","input":{"filePath":"/workspace/tests-pytest/tests/test_base.py"},"output":"<path>/workspace/tests-pytest/tests/test_base.py</path>\n<type>file</type>\n<content>1: # pylint: skip-file\n2: import atexit\n3: import logging\n4: import json\n5: import os\n6: import requests\n7: import time\n8: import subprocess\n9: import sys\n10: import shutil\n11: import pytest\n12: \n13: url = 'http://localhost:8000'\n14: \n15: @pytest.fixture(scope=\"session\")\n16: def handle_ajenti_process():\n17:     print(\"\\n--> Starting Ajenti\")\n18:     cmd = \"source /opt/ajenti/bin/activate; python3 ./ajenti-test-instance.py\"\n19:     process = subprocess.Popen(cmd, shell=True, executable='/bin/bash')\n20:     while True:\n21:         try:\n22:             requests.get(url)\n23:             break\n24:         except:\n25:             print('Ajenti is not ready yet, still waiting...')\n26:             time.sleep(1)\n27:     print(\"\\n--> Ajenti started\")\n28:     yield\n29:     os.system(f'kill {process.pid}')\n30:     print(\"\\n--> Ajenti stopped\")\n31: \n32: class TestBasicHttp:\n33:     def test_identity(self, handle_ajenti_process):\n34:         rq = requests.get(url)\n35:         assert rq.status_code == 200\n36:         assert 'x-auth-identity' in rq.headers\n37: \n38:     def test_not_found(self):\n39:         rq = requests.get(url + '/asdasdasd')\n40:         assert rq.status_code == 404\n41: \n42: \n43: class TestFilesystem:\n44:     dir = '/tmp/ajenti-filesystem-test'\n45: \n46:     def path(self, p):\n47:         return os.path.join(self.dir, p)\n48: \n49:     @pytest.fixture(scope=\"session\")\n50:     def tmp_dir(self):\n51:         print(\"\\n-->  Creating tmp dir\")\n52:         if os.path.exists(self.dir):\n53:             shutil.rmtree(self.dir)\n54:         os.makedirs(self.dir)\n55:         yield\n56:         print(\"\\n-->  Removing tmp dir\")\n57:         shutil.rmtree(self.dir)\n58: \n59:     def test_read(self, tmp_dir):\n60:         with open(self.path('1'), 'w') as f:\n61:             f.write('file 1')\n62: \n63:         rq = requests.get(f'{url}/api/filesystem/read/{self.path(\"1\")}?encoding=utf-8')\n64:         assert rq.text == '\"file 1\"'\n65:         rq = requests.get(f'{url}/api/filesystem/read/{self.path(\"3\")}')\n66:         assert rq.status_code == 404\n67: \n68:     def test_write(self):\n69:         content = 'file 2'\n70:         rq = requests.post(\n71:             f'{url}/api/filesystem/write/{self.path(\"2\")}?encoding=utf-8',\n72:             data=content\n73:         )\n74:         assert rq.status_code == 200\n75:         with open(self.path('2')) as tmp2:\n76:             assert tmp2.read() == content\n77: \n78:     # def upload_test(self):\n79:     #     content = 'uploaded stuff'\n80:     #     with open(self.path('4'), 'w') as f:\n81:     #         f.write(content)\n82:     #     rq = self.session.post(\n83:     #         f'{url}/api/filesystem/upload/{self.path(\"2\")}',\n84:     #         files={'upload': open(self.path('4'))}\n85:     #     )\n86:     #     assert rq.status_code, 200)\n87:     #     assert open(self.path('2')).read(), content)\n88: \n89:     def test_list(self):\n90:         os.makedirs(self.path('list'))\n91:         path = self.path('list/file')\n92:         open(path, 'w').close()\n93:         os.chmod(path, 0o765)\n94:         rq = requests.get(f'{url}/api/filesystem/list/{self.path(\"list\")}')\n95:         assert rq.status_code == 200\n96: \n97:         data = rq.json()['items']\n98:         assert rq.json()['parent'] == self.dir\n99: \n100:         assert len(data) == 1\n101:         assert data[0]['name'] == 'file'\n102:         assert data[0]['path'] == path\n103:         assert data[0]['isDir'] == False\n104:         assert data[0]['isFile'] == True\n105:         assert data[0]['isLink'] == False\n106:         assert data[0]['mode'] == 0o100765\n107:         assert data[0]['uid'] == os.stat(path).st_uid\n108:         assert data[0]['gid'] == os.stat(path).st_gid\n109:         assert data[0]['size'] == 0\n110: \n111:         shutil.rmtree(self.path('list'))\n112: \n113:     def test_stat(self):\n114:         path = self.path('file')\n115:         open(path, 'w').close()\n116:         os.chmod(path, 0o765)\n117:         rq = requests.get(f'{url}/api/filesystem/stat/{path}')\n118:         assert rq.status_code == 200\n119: \n120:         data = rq.json()\n121:         assert data['name'] == 'file'\n122:         assert data['path'] == path\n123:         assert data['isDir'] == False\n124:         assert data['isFile'] == True\n125:         assert data['isLink'] == False\n126:         assert data['mode'] == 0o100765\n127:         assert data['uid'] == os.stat(path).st_uid\n128:         assert data['gid'] == os.stat(path).st_gid\n129:         assert data['size'] == 0\n130: \n131:     def test_chmod(self):\n132:         path = self.path('file')\n133:         open(path, 'w').close()\n134:         os.chmod(path, 0o765)\n135:         rq = requests.post(\n136:             f'{url}/api/filesystem/chmod/{path}',\n137:             data=json.dumps({'mode': 0o767})\n138:         )\n139:         assert rq.status_code == 200\n140:         assert os.stat(path).st_mode, 0o100767\n141: \n142:     def test_create_file(self):\n143:         path = self.path('create_file_test')\n144:         assert not os.path.exists(path)\n145:         rq = requests.post(f'{url}/api/filesystem/create-file/{path}')\n146:         assert rq.status_code == 200\n147:         assert os.path.isfile(path)\n148: \n149:     def test_create_dir(self):\n150:         path = self.path('create_dir_test')\n151:         assert not os.path.exists(path)\n152:         rq = requests.post(f'{url}/api/filesystem/create-directory/{path}')\n153:         assert rq.status_code == 200\n154:         assert os.path.isdir(path)\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"# pylint: skip-file\nimport atexit\nimport logging\nimport json\nimport os\nimport requests\nimport time\nimport subprocess\nimport sys\nimport shutil\nimport pytest\n\nurl = 'http://localhost:8000'\n\n@pytest.fixture(scope=\"session\")\ndef handle_ajenti_process():\n    print(\"\\n--> Starting Ajenti\")\n    cmd = \"source /opt/ajenti/bin/activate; python3 ./ajenti-test-instance.py\"\n    process = subprocess.Popen(cmd, shell=True, executable='/bin/bash')\n    while True:","truncated":false,"loaded":[]},"title":"tests-pytest/tests/test_base.py","time":{"start":1775813403402,"end":1775813403406}}}]}
