one):\n45:         \"\"\"\n46:         Generator for all packages.\n47: \n48:         :param query: Search string\n49:         :type query: string\n50:         :return: Package object\n51:         :rtype:Package object\n52:         \"\"\"\n53: \n54:         cache = apt.Cache()\n55:         for _id in cache.keys():\n56:             yield self.__make_package(cache[_id])\n57: \n58:     def get_package(self, _id):\n59:         \"\"\"\n60:         Get package informations.\n61: \n62:         :param _id: Package name\n63:         :type _id: string\n64:         :return: Package object\n65:         :rtype: Package object\n66:         \"\"\"\n67: \n68:         cache = apt.Cache()\n69:         return self.__make_package(cache[_id])\n70: \n71:     def update_lists(self, progress_callback):\n72:         \"\"\"\n73:         Refresh list of packages.\n74: \n75:         :param progress_callback: Callback function to follow progress\n76:         :type progress_callback: function\n77:         \"\"\"\n78: \n79:         class Progress(AcquireProgress):\n80:             def fetch(self, item):\n81:                 progress = int(100 * self.current_items / self.total_items)\n82:                 message = f'{progress}%% {item.shortdesc}'\n83:                 progress_callback(message=message, done=self.current_items, total=self.total_items)\n84: \n85:             def stop(self):\n86:                 self.done = True\n87: \n88:         cache = apt.Cache()\n89:         ack = Progress()\n90:         try:\n91:             cache.update(fetch_progress=ack)\n92:         except apt.cache.FetchFailedException:\n93:             pass\n94: \n95:         while not hasattr(ack, 'done'):\n96:             gevent.sleep(1)\n97: \n98:     def get_apply_cmd(self, selection):\n99:         \"\"\"\n100:         Prepare command to apply.\n101: \n102:         :param selection: Dict of packages an actions\n103:         :type selection: dict\n104:         :return: Command for terminal use\n105:         :rtype: string\n106:         \"\"\"\n107: \n108:         cmd = 'apt-get install '\n109:         for sel in selection:\n110:             cmd += sel['package']['id'] + {\n111:                 'remove': '-',\n112:                 'install': '+',\n113:                 'upgrade': '+'\n114:             }[sel['operation']] + ' '\n115:         return cmd\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"import gevent\nimport apt\nimport apt.cache\nfrom apt.progress.base import AcquireProgress\n\nfrom jadi import component\nfrom aj.plugins.packages.api import PackageManager, Package\n\n\n@component(PackageManager)\nclass APTPackageManager(PackageManager):\n    \"\"\"\n    Manager to handle apt packages.\n    \"\"\"\n\n    id = 'apt'\n    name = 'APT'\n\n    def __init__(self, context):\n        PackageManager.__init__(self, context)","truncated":false,"loaded":[]},"title":"plugins/packages/managers/apt_manager.py","time":{"start":1775813736942,"end":1775813736943}}}]}
