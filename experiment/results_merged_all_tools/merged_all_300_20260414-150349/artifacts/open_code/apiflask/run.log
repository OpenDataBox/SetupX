t.urls]\n38: Documentation = \"https://apiflask.com/docs\"\n39: Changes = \"https://apiflask.com/changelog\"\n40: \"Source Code\" = \"https://github.com/apiflask/apiflask\"\n41: \"Issue Tracker\" = \"https://github.com/apiflask/apiflask/issues\"\n42: Donate = \"https://opencollective.com/apiflask\"\n43: \n44: [project.optional-dependencies]\n45: dotenv = [\"python-dotenv\"]\n46: async = [\"asgiref>=3.2\"]\n47: yaml = [\"pyyaml\"]\n48: \n49: [project.entry-points.\"console_scripts\"]\n50: apiflask = \"flask.cli:main\"\n51: [project.entry-points.\"flask.commands\"]\n52: spec = \"apiflask.commands:spec_command\"\n53: \n54: [build-system]\n55: requires = [\"setuptools\"]\n56: build-backend = \"setuptools.build_meta\"\n57: \n58: [tool.mypy]\n59: files = [\"src/apiflask\"]\n60: allow_redefinition = true\n61: warn_redundant_casts = true\n62: warn_unused_configs = true\n63: no_implicit_optional = true\n64: local_partial_types = true\n65: strict_equality = true\n66: warn_return_any = true\n67: warn_unreachable = true\n68: disallow_untyped_calls = true\n69: \n70: [[tool.mypy.overrides]]\n71: module = [\"flask_marshmallow.*\", \"apispec.*\", \"flask_httpauth.*\"]\n72: ignore_missing_imports = true\n73: \n74: [tool.pytest.ini_options]\n75: testpaths = [\"tests\", \"examples\"]\n76: filterwarnings = [\"ignore::UserWarning\"]\n77: addopts = [\"--cov=apiflask\", \"--cov-branch\", \"--cov-report=term-missing\", \"--cov-report=xml\"]\n78: \n79: [tool.coverage.run]\n80: omit = [\"src/apiflask/_decorators.py\", \"src/apiflask/views.py\"]\n81: \n82: [tool.coverage.paths]\n83: source = [\"src\"]\n84: \n85: [tool.ruff]\n86: indent-width = 4\n87: line-length = 100\n88: exclude = [\n89:     \".*\",\n90:     \"*.txt\",\n91:     \"*.md\",\n92:     \"__pycache__\",\n93: ]\n94: \n95: [tool.ruff.format]\n96: quote-style = \"single\"\n97: indent-style = \"space\"\n98: \n99: [tool.ruff.lint]\n100: # B = bugbear\n101: # E = pycodestyle errors\n102: # F = flake8 pyflakes\n103: # W = pycodestyle war