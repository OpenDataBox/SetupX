int_path, \"compile_vmap.md\"), \"w\") as ff:\n44:                 state = torch.func.stack_module_state([workflow] * 3)\n45:                 state = state[0] | state[1]\n46:                 ff.write(\n47:                     torch._dynamo.explain(vmap_state_step)(state).__str__()\n48:                 )\n49:     # profile\n50:     print(\"Initial best fitness:\", workflow.monitor.topk_fitness)\n51:     compile_step()\n52:     if profiling:\n53:         with profile(\n54:             activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n55:         ) as prof:\n56:             for _ in range(1000):\n57:                 compile_step()\n58:         print(prof.key_averages().table(), flush=True)\n59:     else:\n60:         for _ in range(1000):\n61:             compile_step()\n62:     print(\"Final best fitness:\", workflow.monitor.topk_fitness)\n63:     torch.cuda.synchronize()\n64:     if test_compile:\n65:         state = torch.func.stack_module_state([workflow] * 3)\n66:         state = state[0] | state[1]\n67:         vmap_state_step(state)\n68:         print(\"Initial best fitness:\", state[\"monitor.topk_fitness\"])\n69:         if profiling:\n70:             with profile(\n71:                 activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA], record_shapes=True, profile_memory=True\n72:             ) as prof:\n73:                 for _ in range(1000):\n74:                     state = vmap_state_step(state)\n75:             print(prof.key_averages().table(), flush=True)\n76:         else:\n77:             for _ in range(1000):\n78:                 state = vmap_state_step(state)\n79:         print(\"Final best fitness:\", state[\"monitor.topk_fitness\"])\n80:         torch.cuda.synchronize()\n81: \n82: \n83: if __name__ == \"__main__\":\n84:     torch.set_default_device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n85: \n86:     from evox.algorithms import PSO\n87: \n88:     test(PSO(pop_size=1000, lb=-10 *