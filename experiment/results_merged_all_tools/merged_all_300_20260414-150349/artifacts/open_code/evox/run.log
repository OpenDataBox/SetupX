{"type":"session_message","session_id":"ses_277ed28e1ffeq6ogfgqGZBiS62","role":"assistant","message_id":"msg_d8817e84d001a9A0pg9QLHfhkz","parts":[{"id":"prt_d8817fbe7001W1bPwy7a9zbPt6","messageID":"msg_d8817e84d001a9A0pg9QLHfhkz","sessionID":"ses_277ed28e1ffeq6ogfgqGZBiS62","type":"tool","tool":"read","callID":"call_94455c5e0d514da9b0d87247","state":{"status":"completed","input":{"filePath":"/workspace/unit_test/algorithms/test_base.py"},"output":"<path>/workspace/unit_test/algorithms/test_base.py</path>\n<type>file</type>\n<content>1: from unittest import TestCase\n2: \n3: import torch\n4: \n5: from evox.core import Algorithm, Problem, use_state, vmap\n6: from evox.workflows import EvalMonitor, StdWorkflow\n7: \n8: \n9: def transform_getitem_args(x: torch.Tensor, index_args):\n10:     print(x, index_args)\n11:     if isinstance(index_args, tuple):\n12:         return (x, list(index_args))\n13:     elif not isinstance(index_args, (list, tuple)):\n14:         return (x, [index_args])\n15:     return (x, index_args)\n16: \n17: \n18: class Sphere(Problem):\n19:     def __init__(self):\n20:         super().__init__()\n21: \n22:     def evaluate(self, pop: torch.Tensor):\n23:         return (pop**2).sum(-1)\n24: \n25: \n26: class TestBase(TestCase):\n27:     def run_algorithm(self, algo: Algorithm):\n28:         state_dict = algo.state_dict()\n29:         monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n30:         prob = Sphere()\n31:         workflow = StdWorkflow(algo, prob, monitor)\n32:         workflow.init_step()\n33:         self.assertIsNotNone(workflow.get_submodule(\"monitor\").topk_fitness)\n34:         for _ in range(3):\n35:             workflow.step()\n36:         # reset state\n37:         algo.load_state_dict(state_dict)\n38: \n39:     def run_compiled_algorithm(self, algo: Algorithm):\n40:         state_dict = algo.state_dict()\n41:         monitor = EvalMonitor(full_fit_history=False, full_sol_history=False)\n42:         prob = Sphere()\n43:         workflow = StdWorkflow(algo, prob, monitor)\n44:         workflow.init_step()\n45:         jit_state_step = torch.compile(workflow.step)\n46:         for _ in range(3):\n47:             jit_state_step()\n48:         # reset state\n49:         algo.load_state_dict(state_dict)\n50: \n51:     def run_vmap_algorithm(self, algo: Algorithm):\n52:         prob = Sphere()\n53:         workflow = StdWorkflow(algo, prob)\n54:         params, buffers = torch.func.stack_module_state([workflow] * 3)\n55:         state = params | buffers\n56: \n57:         vmap_state_init_step = vmap(use_state(workflow.init_step), randomness=\"different\")\n58:         vmap_state_init_step = torch.compile(vmap_state_init_step)\n59:         vmap_state_step = vmap(use_state(workflow.step), randomness=\"different\")\n60:         vmap_state_step = torch.compile(vmap_state_step)\n61:         state = vmap_state_init_step(state)\n62:         for _ in range(3):\n63:             state = vmap_state_step(state)\n64: \n65:     def run_all(self, algo: Algorithm):\n66:         self.run_algorithm(algo)\n67:         self.run_compiled_algorithm(algo)\n68:         self.run_vmap_algorithm(algo)\n\n(End of file - total 68 lines)\n</content>","metadata":{"preview":"from unittest import TestCase\n\nimport torch\n\nfrom evox.core import Algorithm, Problem, use_state, vmap\nfrom evox.workflows import EvalMonitor, StdWorkflow\n\n\ndef transform_getitem_args(x: torch.Tensor, index_args):\n    print(x, index_args)\n    if isinstance(index_args, tuple):\n        return (x, list(index_args))\n    elif not isinstance(index_args, (list, tuple)):\n        return (x, [index_args])\n    return (x, index_args)\n\n\nclass Sphere(Problem):\n    def __init__(self):\n        super().__init__()","truncated":false,"loaded":[]},"title":"unit_test/algorithms/test_base.py","time":{"start":1776104766836,"end":1776104766840}}}]}
