{"type":"session_message","session_id":"ses_2778a24f3ffey0nn0R2oBBORZV","role":"assistant","message_id":"msg_d8875db8c001UtOLtN1yhRsskK","parts":[{"id":"prt_d8875ee83001s4UyE9JVfeFeSa","messageID":"msg_d8875db8c001UtOLtN1yhRsskK","sessionID":"ses_2778a24f3ffey0nn0R2oBBORZV","type":"tool","tool":"read","callID":"call_2d22686bf9e8450f9fe65e51","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [build-system]\n2: requires = [\n3:     # setuptools 77.0.1+ required for PEP 639 support\n4:     \"setuptools>=77.0.1\",\n5: ]\n6: build-backend = \"setuptools.build_meta\"\n7: \n8: # https://packaging.python.org/en/latest/specifications/declaring-project-metadata/\n9: [project]\n10: name = \"torchgeo\"\n11: description = \"TorchGeo: datasets, samplers, transforms, and pre-trained models for geospatial data\"\n12: readme = \"README.md\"\n13: requires-python = \">=3.12\"\n14: license = \"MIT\"\n15: license-files = [\"LICENSE\"]\n16: authors = [\n17:     {name = \"Adam J. Stewart\", email = \"ajstewart426@gmail.com\"},\n18: ]\n19: maintainers = [\n20:     {name = \"Adam J. Stewart\", email = \"ajstewart426@gmail.com\"},\n21:     {name = \"Caleb Robinson\", email = \"Caleb.Robinson@microsoft.com\"},\n22:     {name = \"Isaac Corley\", email = \"isaac.corley@proton.me\"},\n23:     {name = \"Nils Lehmann\", email = \"n.lehmann@tum.de\"},\n24:     {name = \"Ashwin Nair\", email = \"ashnair0007@gmail.com\"},\n25: ]\n26: keywords = [\"pytorch\", \"deep learning\", \"machine learning\", \"remote sensing\", \"satellite imagery\", \"earth observation\", \"geospatial\"]\n27: classifiers = [\n28:     \"Development Status :: 4 - Beta\",\n29:     \"Intended Audience :: Science/Research\",\n30:     \"Operating System :: OS Independent\",\n31:     \"Programming Language :: Python :: 3\",\n32:     \"Programming Language :: Python :: 3.12\",\n33:     \"Programming Language :: Python :: 3.13\",\n34:     \"Programming Language :: Python :: 3.14\",\n35:     \"Topic :: Scientific/Engineering :: Artificial Intelligence\",\n36:     \"Topic :: Scientific/Engineering :: GIS\",\n37: ]\n38: dependencies = [\n39:     # einops 0.3+ required for einops.repeat\n40:     \"einops>=0.3\",\n41:     # geopandas 1.0+ required to use pyogrio backend instead of Fiona (unmaintained)\n42:     \"geopandas>=1.0\",\n43:     # jsonargparse 4.35+ required for Python 3.12.8+ support\n44:     \"jsonargparse[signatures]>=4.35\",\n45:     # kornia 0.8.2+ required for fix to VideoSequential\n46:     # https://github.com/kornia/kornia/pull/3330\n47:     \"kornia>=0.8.2\",\n48:     # lightly 1.4.5+ required for LARS optimizer\n49:     # lightly 1.4.26 is incompatible with the version of timm required by smp\n50:     # https://github.com/torchgeo/torchgeo/issues/1824\n51:     \"lightly>=1.4.5,!=1.4.26\",\n52:     # lightning 2.4+ required for fastapi and pydantic v2 support in lightning\n53:     # lightning 2.5.0 contains backwards-incompatible import changes\n54:     # https://github.com/Lightning-AI/pytorch-lightning/issues/20511\n55:     # lightning 2.5.5-2.5.6 contain known bugs related to checkpoint loading\n56:     # https://github.com/torchgeo/torchgeo/issues/2995\n57:     \"lightning>=2.4,!=2.5.0,!=2.5.5,!=2.5.6\",\n58:     # matplotlib 3.7.3+ required for Python 3.12 wheels\n59:     \"matplotlib>=3.7.3\",\n60:     # numpy 1.26+ required for Python 3.12 wheels\n61:     \"numpy>=1.26\",\n62:     # pandas 2.1.1+ required for Python 3.12 wheels\n63:     \"pandas>=2.1.1\",\n64:     # pillow 10+ required for Python 3.12 wheels\n65:     \"pillow>=10\",\n66:     # pyproj 3.6.1+ required for Python 3.12 wheels\n67:     \"pyproj>=3.6.1\",\n68:     # rasterio 1.4+ required for rasterio.merge.merge support for positive y-resolution\n69:     # https://github.com/rasterio/rasterio/issues/3094\n70:     # rasterio 1.4.0-1.4.2 lack support for merging WarpedVRT objects\n71:     # https://github.com/rasterio/rasterio/issues/3196\n72:     \"rasterio>=1.4.3\",\n73:     # requests 2.25+ required for urllib3 with Python 3.12 support\n74:     \"requests>=2.25\",\n75:     # segmentation-models-pytorch 0.5+ required for new UnetDecoder API\n76:     \"segmentation-models-pytorch>=0.5\",\n77:     # shapely 2.0.2+ required for Python 3.12 wheels\n78:     \"shapely>=2.0.2\",\n79:     # timm 1.0.3+ required for forward_intermediates support for ViT\n80:     \"timm>=1.0.3\",\n81:     # torch 2.2+ required for Python 3.12 wheels\n82:     \"torch>=2.2\",\n83:     # torchmetrics 1.2+ required for average argument in mAP metric\n84:     \"torchmetrics[detection]>=1.2\",\n85:     # torchvision 0.17+ required for Python 3.12 wheels\n86:     \"torchvision>=0.17\",\n87:     # typing-extensions 4.8+ required by torch 2.2\n88:     # can be removed once Python 3.13 is minimum supported version\n89:     \"typing-extensions>=4.8\",\n90: ]\n91: dynamic = [\"version\"]\n92: \n93: [project.optional-dependencies]\n94: datasets = [\n95:     # h5py 3.10+ required for Python 3.12 wheels\n96:     # h5py 3.15+ is incompatible with netcdf4 wheels; no h5py on Python 3.14+\n97:     \"h5py>=3.10,<3.15; python_version<'3.14'\",\n98:     # laspy 2.5.3+ required for wheels\n99:     \"laspy>=2.5.3\",\n100:     # netcdf4 1.6.5+ required for Python 3.12 wheels\n101:     \"netcdf4>=1.6.5\",\n102:     # pandas 2.1.1+ required for Python 3.12 wheels\n103:     \"pandas[parquet]>=2.1.1\",\n104:     # rioxarray 0.14.1+ required for rasterio 1.4+ compatibility\n105:     \"rioxarray>=0.14.1\",\n106:     # scipy 1.11.2+ required for Python 3.12 wheels\n107:     \"scipy>=1.11.2\",\n108:     # webdataset 0.2.4+ required for PyTorch tuple seed support\n109:     \"webdataset>=0.2.4\",\n110:     # xarray 0.17+ required by rioxarray\n111:     \"xarray>=0.17\",\n112: ]\n113: docs = [\n114:     # ipywidgets 7+ required by nbsphinx\n115:     \"ipywidgets>=7\",\n116:     # myst-parser 0.18.0+ required for sphinx 5.0+ compatibility\n117:     \"myst-parser>=0.18.0\",\n118:     # nbsphinx 0.8.5 fixes bug with nbformat attributes\n119:     \"nbsphinx>=0.8.5\",\n120:     # pydata-sphinx-theme 0.14.0+ required for sphinx 5.0+ compatibility\n121:     \"pydata-sphinx-theme>=0.14.0\",\n122:     # sphinx 5.3+ required to allow section titles inside autodoc class docstrings\n123:     # https://github.com/sphinx-doc/sphinx/pull/10887\n124:     \"sphinx>=5.3\",\n125:     # sphinx-github-changelog 1.7.2+ required for image URL fix\n126:     \"sphinx-github-changelog>=1.7.2\",\n127: ]\n128: models = [\n129:     # microsoft-aurora 1.6+ required for timm 1.0+ support\n130:     \"microsoft-aurora>=1.6\",\n131:     # olmoearth-pretrain-minimal 0.0.2+ required for normalization support\n132:     \"olmoearth-pretrain-minimal>=0.0.2\",\n133: ]\n134: style = [\n135:     # pandas 2.1.1+ required for Python 3.12 wheels\n136:     \"pandas-stubs>=2.1.1\",\n137:     # ruff 0.9+ required for 2025 style guide\n138:     \"ruff>=0.9\",\n139:     # ty 0.0.25+ required for the following bug fix: https://github.com/astral-sh/ty/issues/2985\n140:     \"ty>=0.0.25\",\n141:     # geopandas 1.0+ required to use pyogrio backend instead of Fiona (unmaintained)\n142:     \"types-geopandas>=1.0\",\n143:     # requests 2.25+ required for urllib3 with Python 3.12 support\n144:     \"types-requests>=2.25\",\n145:     # shapely 2.0.2+ required for Python 3.12 wheels\n146:     \"types-shapely>=2.0.2\",\n147: ]\n148: tests = [\n149:     # nbmake 1.4.5+ removes pkg_resources dependency\n150:     \"nbmake>=1.4.5\",\n151:     # packaging 21+ required by sphinx\n152:     \"packaging>=21\",\n153:     # pytest 7.3.2+ required for Python 3.12 support\n154:     \"pytest>=7.3.2\",\n155:     # pytest-cov 4+ required for pytest 7.2+ compatibility\n156:     \"pytest-cov>=4\",\n157:     # pytest-socket 0.3.4+ required for wheels\n158:     \"pytest-socket>=0.3.4\",\n159: ]\n160: all = [\n161:     \"torchgeo[datasets,docs,models,style,tests]\",\n162: ]\n163: \n164: [project.scripts]\n165: torchgeo = \"torchgeo.main:main\"\n166: \n167: [project.urls]\n168: Codecov = \"https://app.codecov.io/gh/torchgeo/torchgeo\"\n169: Documentation = \"https://torchgeo.readthedocs.io\"\n170: Homepage = \"https://github.com/torchgeo/torchgeo\"\n171: Slack = \"https://torchgeo.slack.com\"\n172: \n173: # https://coverage.readthedocs.io/en/latest/config.html\n174: [tool.coverage.report]\n175: # Ignore warnings for overloads\n176: # https://github.com/nedbat/coveragepy/issues/970#issuecomment-612602180\n177: exclude_also = [\n178:     \"@overload\",\n179: ]\n180: show_missing = true\n181: \n182: [tool.pytest.ini_options]\n183: # Skip slow tests by default\n184: addopts = \"-m 'not slow' --disable-socket\"\n185: # https://docs.pytest.org/en/latest/how-to/capture-warnings.html\n186: filterwarnings = [\n187:     # Warnings raised by dependencies of dependencies, out of our control\n188:     # https://github.com/pytorch/pytorch/issues/153607\n189:     'ignore:The global interpreter lock \\(GIL\\) has been enabled to load module:RuntimeWarning',\n190:     # https://github.com/Lightning-AI/pytorch-lightning/issues/21326\n191:     'ignore:`isinstance\\(treespec, LeafSpec\\)` is deprecated, use `isinstance\\(treespec, TreeSpec\\) and treespec.is_leaf\\(\\)` instead.:FutureWarning',\n192:     # https://github.com/pytorch/pytorch/pull/24929\n193:     \"ignore:Default grid_sample and affine_grid behavior has changed to align_corners=False since 1.3.0:UserWarning\",\n194:     # https://github.com/pytorch/pytorch/issues/136264\n195:     \"ignore:__array__ implementation doesn't accept a copy keyword:DeprecationWarning\",\n196:     \"ignore:__array_wrap__ must accept context and return_scalar arguments:DeprecationWarning\",\n197:     # https://github.com/lightly-ai/lightly/issues/1791\n198:     # https://github.com/pydantic/pydantic/issues/12618\n199:     \"ignore:Core Pydantic V1 functionality isn't compatible with Python 3.14 or greater.