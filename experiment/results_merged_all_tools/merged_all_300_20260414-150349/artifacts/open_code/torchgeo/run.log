4096 Apr 13 20:08 .git\n-rw-r--r--  1 root root    260 Apr 13 20:08 .git-blame-ignore-revs\n-rw-r--r--  1 root root    162 Apr 13 20:08 .gitattributes\ndrwxr-xr-x  4 root root   4096 Apr 13 20:08 .github\n-rw-r--r--  1 root root   1988 Apr 13 20:08 .gitignore\n-rw-r--r--  1 root root   1090 Apr 13 20:08 .pre-commit-config.yaml\n-rw-r--r--  1 root root    125 Apr 13 20:08 .prettierignore\n-rw-r--r--  1 root root    630 Apr 13 20:08 .readthedocs.yaml\n-rw-r--r--  1 root root   5903 Apr 13 20:08 AGENTS.md\n-rw-r--r--  1 root root   1242 Apr 13 20:08 CITATION.cff\n-rw-r--r--  1 root root   1073 Apr 13 20:08 LICENSE\n-rw-r--r--  1 root root  15549 Apr 13 20:08 README.md\ndrwxr-xr-x  6 root root   4096 Apr 13 20:08 docs\n-rw-r--r--  1 root root   1616 Apr 13 20:08 hubconf.py\n-rw-r--r--  1 root root    653 Apr 13 20:08 package-lock.json\n-rw-r--r--  1 root root    138 Apr 13 20:08 package.json\n-rw-r--r--  1 root root  10443 Apr 13 20:08 pyproject.toml\ndrwxr-xr-x 11 root root   4096 Apr 13 20:08 tests\ndrwxr-xr-x  9 root root   4096 Apr 13 20:08 torchgeo\n-rw-r--r--  1 root root 701207 Apr 13 20:08 uv.lock\n","exit":0,"description":"List workspace directory contents","truncated":false},"title":"List workspace directory contents","time":{"start":1776110923389,"end":1776110923391}}}]}
