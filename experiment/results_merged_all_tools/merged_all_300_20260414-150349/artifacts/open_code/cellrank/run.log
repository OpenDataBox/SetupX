: ]\n45: dynamic = [ \"version\" ]\n46: dependencies = [\n47:   \"anndata>=0.11\",\n48:   \"docrep>=0.3\",\n49:   \"joblib>=1.4\",\n50:   \"matplotlib>=3.9\",\n51:   \"networkx>=3.4\",\n52:   \"numba>=0.60\",\n53:   \"numpy>=2\",\n54:   \"pandas>=2.2\",\n55:   \"pygam>=0.10\",\n56:   \"pygpcca>=1.0.4\",\n57:   \"rich>=13\",\n58:   \"scanpy>=1.11\",\n59:   \"scikit-learn>=1.6\",\n60:   \"scipy>=1.14\",\n61:   \"seaborn>=0.13\",\n62:   \"session-info2>=0.2\",\n63:   \"wrapt>=1.16\",\n64: ]\n65: \n66: optional-dependencies.jax = [ \"jax\", \"jaxlib\" ]\n67: optional-dependencies.moscot = [ \"moscot\" ]\n68: optional-dependencies.petsc = [ \"mpi4py\", \"petsc4py\", \"slepc4py\" ]\n69: optional-dependencies.plot = [ \"adjusttext\" ]\n70: optional-dependencies.r = [ \"rpy2>=3.3\" ]\n71: optional-dependencies.scvelo = [ \"scvelo>=0.3\" ]\n72: urls.\"Bug Tracker\" = \"https://github.com/theislab/cellrank/issues\"\n73: urls.Documentation = \"https://cellrank.readthedocs.io\"\n74: urls.Download = \"https://cellrank.readthedocs.io/en/latest/installation.html\"\n75: urls.Homepage = \"https://github.com/theislab/cellrank\"\n76: urls.\"Source Code\" = \"https://github.com/theislab/cellrank\"\n77: \n78: [dependency-groups]\n79: dev = [\n80:   \"pre-commit>=3\",\n81: ]\n82: test = [\n83:   \"adjusttext\",\n84:   \"coverage[toml]>=7\",\n85:   \"igraph>=1\",\n86:   \"jax\",\n87:   \"pillow>=10\",\n88:   \"pytest>=8\",\n89:   \"pytest-cov>=6\",\n90:   \"pytest-mock>=3.14\",\n91:   \"pytest-xdist\",\n92:   \"scvelo>=0.3\",\n93: ]\n94: docs = [\n95:   \"furo>=2024.8.6\",\n96:   \"myst-nb>=1.2\",\n97:   \"sphinx>=7.4\",\n98:   \"sphinx-autobuild\",\n99:   \"sphinx-autodoc-typehints>=2.5\",\n100:   \"sphinx-copybutton>=0.5\",\n101:   \"sphinx-design>=0.6\",\n102:   \"sphinx-tippy>=0.4.3\",\n103:   \"sphinxcontrib-bibtex>=2.6\",\n104:   \"sphinxcontrib-spelling>=8\",\n105: ]\n106: \n107: [tool.hatch.build.targets.wheel]\n108: packages = [ \"src/cellrank\" ]\n109: \n110: [tool.hatch.version]\n111: source = \"vcs\"\n112: \n113: [tool.hatch.envs.default]\n114: installer = \"uv\"\n115: dependency-groups = [ \"dev\" ]\n116: \n117: [tool.hatch.envs.hatch-test]\n118: dependency-groups = [ \"test\" ]\n119: \n120: [[tool.hatch.envs.hatch-test.matrix]]\n121: deps = [ \"stable\" ]\n122: python = [ \"3.12\", \"3.14\" ]\n123: \n124: [[tool.hatch.envs.hatch-test.matrix]]\n125: deps = [ \"pre\" ]\n126: python = [ \"3.14\" ]\n127: \n128: [[tool.hatch.envs.hatch-test.overrides.matrix.deps.env-vars]]\n129: key = \"UV_PRERELEASE\"\n130: value = \"allow\"\n131: if = [ \"pre\" ]\n132: \n133: [tool.hatch.envs.docs]\n134: dependency-groups = [ \"docs\" ]\n135: scripts.build = \"sphinx-build -M html docs docs/_build {args}\"\n136: scripts.open = \"python -m webbrowser -t docs/_build/html/index.html\"\n137: scripts.clean = \"git clean -fdX -- {args:docs}\"\n138: scripts.auto = \"sphinx-autobuild docs docs/_build/html --open-browser --watch README.md {args}\"\n139: \n140: [tool.ruff]\n141: line-length = 120\n142: src = [ \"src\" ]\n143: \n144: format.docstring-code-format = true\n145: lint.select = [\n146:   \"B\",   # flake8-bugbear\n147:   \"BLE\", # flake8-blind-except\n148:   \"C4\",  # flake8-comprehensions\n149:   \"D\",   # flake8-docstrings\n150:   \"E\",   # pycodestyle\n151:   \"F\",   # pyflakes\n152:   \"I\",   # isort\n153:   \"NPY\", # NumPy-specific rules\n154:   \"PT\",  # flake8-pytest-style\n155:   \"Q\",   # flake8-quotes\n156:   \"RET\", # flake8-raise\n157:   \"SIM\", # flake8-simplify\n158:   \"T20\", # flake8-print\n159:   \"TID\", # flake8-tidy-imports\n160:   \"UP\",  # pyupgrade\n161:   \"W\",   # pycodestyle\n162: ]\n163: lint.ignore = [\n164:   # `zip()` without an explicit `strict=` parameter (67 pre-existing, fix separately)\n165:   \"B905\",\n166:   # Missing docstring in public module\n167:   \"D100\",\n168:   # Missing docstring in public package\n169:   \"D104\",\n170:   # Missing docstring in magic method\n171:   \"D105\",\n172:   # Missing docstring in __init__\n173:   \"D107\",\n174:   # Do not assign a lambda expression, use a def -> lambda expression assignments are convenient\n175:   \"E731\",\n176:   # allow I, O, l as variable names -> I is the identity matrix, i, j, k, l is reasonable indexing notation\n177:   \"E741\",\n178:   \"PT011\", # TODO/\n179:   # Do not implicitly `return None` in function able to return non-`None` value\n180:   \"RET502\",\n181:   # Missing explicit `return` at the end of function able to return non-`None` value\n182:   \"RET503\",\n183: ]\n184: lint.exclude = [\n185:   \".eggs\",\n186:   \".git\",\n187:   \".ruff_cache\",\n188:   \".tox\",\n189:   \"__pypackages__\",\n190:   \"_build\",\n191:   \"build\",\n192:   \"dist\",\n193: ]\n194: lint.per-file-ignores.\"*/__init__.py\" = [ \"F401\" ]\n195: lint.per-file-ignores.\"docs/*\" = [ \"D\" ]\n196: lint.per-file-ignores.\"tests/*\" = [ \"D\" ]\n197: lint.unfixable = [ \"B\", \"BLE\", \"C4\", \"RET\", \"T20\" ]\n198: lint.flake8-quotes.inline-quotes = \"double\"\n199: lint.flake8-tidy-imports.ban-relative-imports = \"all\"\n200: lint.pydocstyle.convention = \"numpy\"\n201: \n202: [tool.pytest.ini_options]\n203: testpaths = \"tests\"\n204: xfail_strict = true\n205: addopts = [ \"--import-mode=importlib\" ]\n206: \n207: [tool.coverage.run]\n208: branch = true\n209: parallel = true\n210: source = [ \"src/\" ]\n211: omit = [\n212:   \"*/__init__.py\",\n213: ]\n214: \n215: [tool.coverage.report]\n216: exclude_lines = [\n217:   '\\#.*pragma:\\s*no.?cover',\n218:   \"^if __name__ == .__main__.:$\",\n219:   '^\\s*raise AssertionError\\b',\n220:   '^\\s*raise NotImplementedError\\b',\n221:   '^\\s*return NotImplemented\\b',\n222: ]\n223: precision = 2\n224: show_missing = true\n225: skip_empty = true\n226: sort = \"Miss\"\n227: \n228: [tool.rstcheck]\n229: ignore_directives = [\n230:   \"toctree\",\n231:   \"currentmodule\",\n232:   \"autosummary\",\n233:   \"module\",\n234:   \"automodule\",\n235:   \"autoclass\",\n236:   \"bi