{"type":"session_message","session_id":"ses_28c6e0507ffeaXxTAMFtC4gCYu","role":"assistant","message_id":"msg_d739214bd001TsAAWaaPqnQ3j7","parts":[{"id":"prt_d73922006001lGT8Dm7yCF4moE","messageID":"msg_d739214bd001TsAAWaaPqnQ3j7","sessionID":"ses_28c6e0507ffeaXxTAMFtC4gCYu","type":"tool","tool":"read","callID":"call_9cb9fce59965472da3674289","state":{"status":"completed","input":{"filePath":"/workspace/pyproject.toml"},"output":"<path>/workspace/pyproject.toml</path>\n<type>file</type>\n<content>1: [project]\n2: name = \"poetry\"\n3: version = \"2.4.0.dev0\"\n4: description = \"Python dependency management and packaging made easy.\"\n5: requires-python = \">=3.10,<4.0\"\n6: dependencies = [\n7:     \"poetry-core (==2.3.2)\",\n8:     \"build (>=1.2.1,<2.0.0)\",\n9:     \"cachecontrol[filecache] (>=0.14.0,<0.15.0)\",\n10:     \"cleo (>=2.1.0,<3.0.0)\",\n11:     \"dulwich (>=0.25.0,<2)\",\n12:     \"fastjsonschema (>=2.18.0,<3.0.0)\",\n13:     \"installer (>=0.7.0,<0.8.0)\",\n14:     \"keyring (>=25.1.0,<26.0.0)\",\n15:     # packaging uses calver, so version is unclamped\n16:     \"packaging (>=24.2)\",  # PEP 639 support was added in 24.2\n17:     \"pkginfo (>=1.12,<2.0)\",\n18:     \"platformdirs (>=3.0.0,<5)\",\n19:     \"pyproject-hooks (>=1.0.0,<2.0.0)\",\n20:     \"requests (>=2.26,<3.0)\",\n21:     \"requests-toolbelt (>=1.0.0,<2.0.0)\",\n22:     \"shellingham (>=1.5,<2.0)\",\n23:     \"tomli (>=2.0.1,<3.0.0) ; python_version < '3.11'\",\n24:     \"tomlkit (>=0.11.4,<1.0.0)\",\n25:     # trove-classifiers uses calver, so version is unclamped\n26:     \"trove-classifiers (>=2022.5.19)\",\n27:     \"virtualenv (>=20.26.6)\",\n28:     \"xattr (>=1.0.0,<2.0.0) ; sys_platform == 'darwin'\",\n29:     \"findpython (>=0.6.2,<0.8.0)\",\n30:     # pbs-installer uses calver, so version is unclamped\n31:     \"pbs-installer[download,install] (>=2025.6.10)\",\n32: ]\n33: authors = [\n34:     { name = \"Sébastien Eustace\", email = \"sebastien@eustace.io\" }\n35: ]\n36: maintainers = [\n37:     { name = \"Arun Babu Neelicattu\", email = \"arun.neelicattu@gmail.com\" },\n38:     { name = \"Bjorn Neergaard\", email = \"bjorn@neersighted.com\" },\n39:     { name = \"Branch Vincent\", email = \"branchevincent@gmail.com\" },\n40:     { name = \"Randy Döring\", email = \"radoering.poetry@gmail.com\" },\n41:     { name = \"Steph Samson\", email = \"hello@stephsamson.com\" },\n42:     { name = \"finswimmer\", email = \"finswimmer77@gmail.com\" },\n43:     { name = \"Bartosz Sokorski\", email = \"b.sokorski@gmail.com\" },\n44: ]\n45: license = \"MIT\"\n46: readme = \"README.md\"\n47: keywords = [\"packaging\", \"dependency\", \"poetry\"]\n48: # classifiers are dynamic because we want to create Python classifiers automatically\n49: dynamic = [ \"classifiers\" ]\n50: \n51: [project.urls]\n52: Homepage = \"https://python-poetry.org/\"\n53: Changelog = \"https://python-poetry.org/history/\"\n54: Repository = \"https://github.com/python-poetry/poetry\"\n55: Documentation = \"https://python-poetry.org/docs\"\n56: \n57: [project.scripts]\n58: poetry = \"poetry.console.application:main\"\n59: \n60: \n61: [tool.poetry]\n62: requires-poetry = \">=2.0\"\n63: classifiers = [\n64:     \"Topic :: Software Development :: Build Tools\",\n65:     \"Topic :: Software Development :: Libraries :: Python Modules\",\n66: ]\n67: include = [{ path = \"tests\", format = \"sdist\" }]\n68: \n69: [tool.poetry.group.dev.dependencies]\n70: pre-commit = \">=2.10\"\n71: \n72: [tool.poetry.group.test.dependencies]\n73: coverage = \">=7.2.0\"\n74: deepdiff = \">=6.3\"\n75: responses = \">=0.25.8\"\n76: jaraco-classes = \">=3.3.1\"\n77: pytest = \">=8.0\"\n78: pytest-cov = \">=4.0\"\n79: pytest-mock = \">=3.9\"\n80: pytest-randomly = \">=3.12\"\n81: pytest-xdist = { version = \">=3.1\", extras = [\"psutil\"] }\n82: \n83: [tool.poetry.group.typing.dependencies]\n84: mypy = \">=1.8.0\"\n85: types-requests = \">=2.28.8\"\n86: \n87: # only used in github actions\n88: [tool.poetry.group.github-actions]\n89: optional = true\n90: [tool.poetry.group.github-actions.dependencies]\n91: pytest-github-actions-annotate-failures = \"^0.1.7\"\n92: \n93: \n94: [build-system]\n95: requires = [\"poetry-core>=2.0\"]\n96: build-backend = \"poetry.core.masonry.api\"\n97: \n98: \n99: [tool.ruff]\n100: extend-exclude = [\n101:     \"docs/*\",\n102:     # External to the project's coding standards\n103:     \"tests/fixtures/git/*\",\n104:     \"tests/fixtures/project_with_setup*/*\",\n105: ]\n106: fix = true\n107: line-length = 88\n108: \n109: [tool.ruff.lint]\n110: extend-select = [\n111:     \"B\",   # flake8-bugbear\n112:     \"C4\",  # flake8-comprehensions\n113:     \"ERA\", # flake8-eradicate/eradicate\n114:     \"I\",   # isort\n115:     \"N\",   # pep8-naming\n116:     \"PIE\", # flake8-pie\n117:     \"PGH\", # pygrep\n118:     \"RUF\", # ruff checks\n119:     \"SIM\", # flake8-simplify\n120:     \"T20\", # flake8-print\n121:     \"TC\",  # flake8-type-checking\n122:     \"TID\", # flake8-tidy-imports\n123:     \"UP\",  # pyupgrade\n124: ]\n125: ignore = [\n126:     \"B904\", # use 'raise ... from err'\n127:     \"B905\", # use explicit 'strict=' parameter with 'zip()'\n128: ]\n129: extend-safe-fixes = [\n130:     \"TC\",  # move import from and to TYPE_CHECKING blocks\n131: ]\n132: unfixable = [\n133:     \"ERA\", # do not autoremove commented out code\n134: ]\n135: \n136: [tool.ruff.lint.flake8-tidy-imports]\n137: ban-relative-imports = \"all\"\n138: \n139: [tool.ruff.lint.isort]\n140: force-single-line = true\n141: lines-between-types = 1\n142: lines-after-imports = 2\n143: known-first-party = [\"poetry\"]\n144: known-third-party = [\"poetry.core\"]\n145: required-imports = [\"from __future__ import annotations\"]\n146: \n147: \n148: [tool.mypy]\n149: files = \"src, tests\"\n150: mypy_path = \"src\"\n151: namespace_packages = true\n152: explicit_package_bases = true\n153: strict = true\n154: enable_error_code = [\n155:     \"ignore-without-code\",\n156:     \"redundant-expr\",\n157:     \"truthy-bool\",\n158: ]\n159: exclude = [\n160:     \"tests/fixtures\",\n161:     \"tests/masonry/builders/fixtures\",\n162:     \"tests/utils/fixtures\",\n163: ]\n164: \n165: # use of importlib-metadata backport makes it impossible to satisfy mypy\n166: # without some ignores: but we get different sets of ignores at different\n167: # python versions.\n168: [[tool.mypy.overrides]]\n169: module = [\n170:     'poetry.repositories.installed_repository',\n171:     'tests.console.commands.self.test_show_plugins',\n172:     'tests.repositories.test_installed_repository',\n173:     'tests.helpers',\n174: ]\n175: warn_unused_ignores = false\n176: \n177: [[tool.mypy.overrides]]\n178: module = [\n179:     'deepdiff.*',\n180:     'fastjsonschema.*',\n181:     'findpython.*',\n182:     'requests_toolbelt.*',\n183:     'shellingham.*',\n184:     'virtualenv.*',\n185:     'xattr.*',\n186: ]\n187: ignore_missing_imports = true\n188: \n189: \n190: [tool.pytest.ini_options]\n191: addopts = [ \"-n\", \"logical\", \"-ra\", \"--strict-config\", \"--strict-markers\" ]\n192: testpaths = [\"tests\"]\n193: markers = [\n194:     \"network: mark tests that require internet access\",\n195:     \"skip_git_mock: mark tests that should not auto-apply git_mock\"\n196: ]\n197: log_cli_level = \"INFO\"\n198: xfail_strict = true\n199: \n200: \n201: [tool.coverage.report]\n202: exclude_also = [\n203:     \"if TYPE_CHECKING:\"\n204: ]\n205: \n206: \n207: [tool.repo-review]\n208: ignore = [\n209:     \"PY007\",\n210:     \"PP302\",\n211:     \"PP309\",\n212:     \"GH101\",\n213:     \"GH212\",\n214:     \"PC111\",\n215:     \"PC140\",\n216:     \"PC160\",\n217:     \"PC170\",\n218:     \"PC180\",\n219:     \"PC180\",\n220:     \"PC901\",\n221:     \"MY103\",\n222:     \"RTD100\",\n223: ]\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"[project]\nname = \"poetry\"\nversion = \"2.4.0.dev0\"\ndescription = \"Python dependency management and packaging made easy.\"\nrequires-python = \">=3.10,<4.0\"\ndependencies = [\n    \"poetry-core (==2.3.2)\",\n    \"build (>=1.2.1,<2.0.0)\",\n    \"cachecontrol[filecache] (>=0.14.0,<0.15.0)\",\n    \"cleo (>=2.1.0,<3.0.0)\",\n    \"dulwich (>=0.25.0,<2)\",\n    \"fastjsonschema (>=2.18.0,<3.0.0)\",\n    \"installer (>=0.7.0,<0.8.0)\",\n    \"keyring (>=25.1.0,<26.0.0)\",\n    # packaging uses calver, so version is unclamped\n    \"packaging (>=24.2)\",  # PEP 639 support was added in 24.2\n    \"pkginfo (>=1.12,<2.0)\",\n    \"platformdirs (>=3.0.0,<5)\",\n    \"pyproject-hooks (>=1.0.0,<2.0.0)\",\n    \"requests (>=2.26,<3.0)\",","truncated":false,"loaded":[]},"title":"pyproject.toml","time":{"start":1775760449835,"end":1775760449838}}}]}
