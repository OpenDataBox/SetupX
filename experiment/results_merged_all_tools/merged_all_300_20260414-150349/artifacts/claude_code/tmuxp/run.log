{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0f1821f769b64fa9a376d58a","type":"tool_result","content":"1\t\"\"\"Conftest.py (root-level).\n2\t\n3\tWe keep this in root pytest fixtures in pytest's doctest plugin to be available, as well\n4\tas avoiding conftest.py from being included in the wheel, in addition to pytest_plugin\n5\tfor pytester only being available via the root directory.\n6\t\n7\tSee \"pytest_plugins in non-top-level conftest files\" in\n8\thttps://docs.pytest.org/en/stable/deprecations.html\n9\t\"\"\"\n10\t\n11\tfrom __future__ import annotations\n12\t\n13\timport logging\n14\timport os\n15\timport pathlib\n16\timport shutil\n17\timport typing as t\n18\t\n19\timport pytest\n20\tfrom _pytest.doctest import DoctestItem\n21\tfrom libtmux.test.random import namer\n22\t\n23\tfrom tests.fixtures import utils as test_utils\n24\tfrom tmuxp.workspace.finders import get_workspace_dir\n25\t\n26\tif t.TYPE_CHECKING:\n27\t    from libtmux.session import Session\n28\t\n29\tlogger = logging.getLogger(__name__)\n30\tUSING_ZSH = \"zsh\" in os.getenv(\"SHELL\", \"\")\n31\t\n32\t\n33\t@pytest.fixture(autouse=USING_ZSH, scope=\"session\")\n34\tdef zshrc(user_path: pathlib.Path) -> pathlib.Path | None:\n35\t    \"\"\"Quiets ZSH default message.\n36\t\n37\t    Needs a startup file .zshenv, .zprofile, .zshrc, .zlogin.\n38\t    \"\"\"\n39\t    if not USING_ZSH:\n40\t        return None\n41\t    p = user_path / \".zshrc\"\n42\t    p.touch()\n43\t    return p\n44\t\n45\t\n46\t@pytest.fixture(autouse=True)\n47\tdef home_path_default(monkeypatch: pytest.MonkeyPatch, user_path: pathlib.Path) -> None:\n48\t    \"\"\"Set HOME to user_path (random, temporary directory).\"\"\"\n49\t    monkeypatch.setenv(\"HOME\", str(user_path))\n50\t\n51\t\n52\t@pytest.fixture\n53\tdef tmuxp_configdir(user_path: pathlib.Path) -> pathlib.Path:\n54\t    \"\"\"Ensure and return tmuxp config directory.\"\"\"\n55\t    xdg_config_dir = user_path / \".config\"\n56\t    xdg_con