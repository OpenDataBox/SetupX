{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_f5b7796f5b6641419f21ccff","type":"tool_result","content":"1\tname: CI\n2\t\n3\ton:\n4\t    push:\n5\t        branches: [main]\n6\t    pull_request:\n7\t        branches: [main]\n8\t\n9\tjobs:\n10\t    # Skip CI if commit message contains `[ci skip]` in the subject\n11\t    init:\n12\t        runs-on: ubuntu-latest\n13\t        outputs:\n14\t            skip: ${{ steps.ci-skip-step.outputs.ci-skip }}\n15\t        steps:\n16\t            - uses: actions/checkout@v2\n17\t              with:\n18\t                  fetch-depth: 0\n19\t            - id: ci-skip-step\n20\t              uses: mstachniuk/ci-skip@master\n21\t\n22\t    # Check if pre-commit hooks pass and if README.rst can be converted to HTML\n23\t    linting:\n24\t        needs: init\n25\t        if: ${{ needs.init.outputs.skip == 'false' }}\n26\t        runs-on: ubuntu-latest\n27\t        steps:\n28\t            - uses: actions/checkout@v2\n29\t            - name: Setup Python 3.10\n30\t              uses: actions/setup-python@v2\n31\t              with:\n32\t                  python-version: \"3.10\"\n33\t            - name: Install dependencies\n34\t              run: |\n35\t                  python -m pip install --upgrade pip\n36\t                  pip install pre-commit\n37\t            - name: Check pre-commit compatibility\n38\t              run: pre-commit run --all-files --show-diff-on-failure\n39\t\n40\t    # Run unit tests\n41\t    test:\n42\t        needs: linting\n43\t        runs-on: ${{ matrix.os }}\n44\t        strategy:\n45\t            fail-fast: false\n46\t            matrix:\n47\t                os: [ubuntu-latest]\n48\t                python-version: [\"3.9\", \"3.10\"]\n49\t        steps:\n50\t            - uses: actions/checkout@v2\n51\t            - name: Set up Python ${{ matrix.python-version }}\n52\t              uses: actions/setup-python@v2\n53\t              with:\n54\t                  python-version: ${{ matrix.python-version }}\n55\t            - name: Install dependencies\n56\t              run: pip install -e '.[dev]'\n57\t            - name: Unit tests\n58\t              timeout-minutes: 60\n59\t              run: python -m pytest --durations=25 --ignore=tests/datasets/test_datasets.py --hypothesis-profile=ci --cov=scvelo -vv\n60\t\n61\t    test-dataset-downloads:\n62\t        needs: test\n63\t        runs-on: ubuntu-latest\n64\t        steps:\n65\t            - uses: actions/checkout@v2\n66\t            - name: Setup Python 3.10\n67\t              uses: actions/setup-python@v2\n68\t              with:\n69\t                  python-version: \"3.10\"\n70\t            - name: Install dependencies\n71\t              run: |\n72\t                  pip install -e .\n73\t                  pip install hypothesis pytest pytest-cov\n74\t            - name: Test dataset downloads\n75\t              timeout-minutes: 60\n76\t              run: python -m pytest tests/datasets/test_datasets.py -vv\n77\t"}]},"parent_tool_use_id":null,"session_id":"c1f0803e-6e60-4d44-a56a-c5f6ff56949c","uuid":"48e9a5f7-d36a-4d9d-b7ff-4d179337360a","timestamp":"2026-04-07T03:55:51.011Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.github/workflows/ci.yml","content":"name: CI\n\non:\n    push:\n        branches: [main]\n    pull_request:\n        branches: [main]\n\njobs:\n    # Skip CI if commit message contains `[ci skip]` in the subject\n    init:\n        runs-on: ubuntu-latest\n        outputs:\n            skip: ${{ steps.ci-skip-step.outputs.ci-skip }}\n        steps:\n            - uses: actions/checkout@v2\n              with:\n                  fetch-depth: 0\n            - id: ci-skip-step\n              uses: mstachniuk/ci-skip@master\n\n    # Check if pre-commit hooks pass and if README.rst can be converted to HTML\n    linting:\n        needs: init\n        if: ${{ needs.init.outputs.skip == 'false' }}\n        runs-on: ubuntu-latest\n        steps:\n            - uses: actions/checkout@v2\n            - name: Setup Python 3.10\n              uses: actions/setup-python@v2\n              with:\n                  python-version: \"3.10\"\n            - name: Install dependencies\n              run: |\n                  python -m pip install --upgrade pip\n                  pip install pre-commit\n            - name: Check pre-commit compatibility\n              run: pre-commit run --all-files --show-diff-on-failure\n\n    # Run unit tests\n    test:\n        needs: linting\n        runs-on: ${{ matrix.os }}\n        strategy:\n            fail-fast: false\n            matrix:\n                os: [ubuntu-latest]\n                python-version: [\"3.9\", \"3.10\"]\n        steps:\n            - uses: actions/checkout@v2\n            - name: Set up Python ${{ matrix.python-version }}\n              uses: actions/setup-python@v2\n              with:\n                  python-version: ${{ matrix.python-version }}\n            - name: Install dependencies\n              run: pip install -e '.[dev]'\n            - name: Unit tests\n              timeout-minutes: 60\n              run: python -m pytest --durations=25 --ignore=tests/datasets/test_datasets.py --hypothesis-profile=ci --cov=scvelo -vv\n\n    test-dataset-downloads:\n        needs: test\n        runs-on: ubuntu-latest\n        steps:\n            - uses: actions/checkout@v2\n            - name: Setup Python 3.10\n              uses: actions/setup-python@v2\n              with:\n                  python-version: \"3.10\"\n            - name: Install dependencies\n              run: |\n                  pip install -e .\n                  pip install hypothesis pytest pytest-cov\n            - name: Test dataset downloads\n              timeout-minutes: 60\n              run: python -m pytest tests/datasets/test_datasets.py -vv\n","numLines":77,"startLine":1,"totalLines":77}}}
