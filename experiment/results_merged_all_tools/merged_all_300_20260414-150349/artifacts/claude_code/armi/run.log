{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_08127b9157f74d7ab96bb864","type":"tool_result","content":"1\t# Copyright 2023 TerraPower, LLC\n2\t#\n3\t# Licensed under the Apache License, Version 2.0 (the \"License\");\n4\t# you may not use this file except in compliance with the License.\n5\t# You may obtain a copy of the License at\n6\t#\n7\t#     http://www.apache.org/licenses/LICENSE-2.0\n8\t#\n9\t# Unless required by applicable law or agreed to in writing, software\n10\t# distributed under the License is distributed on an \"AS IS\" BASIS,\n11\t# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n12\t# See the License for the specific language governing permissions and\n13\t# limitations under the License.\n14\t\n15\t#######################################################################\n16\t#                        GENERAL PYTHON CONFIG                        #\n17\t#######################################################################\n18\t[build-system]\n19\trequires = [\"setuptools>=61.2\"]\n20\tbuild-backend = \"setuptools.build_meta\"\n21\t\n22\t[project]\n23\tname = \"armi\"\n24\tversion = \"0.7.0\"\n25\tdescription = \"An open-source nuclear reactor analysis automation framework that helps design teams increase efficiency and quality.\"\n26\tlicense = {file = \"LICENSE.md\"}\n27\trequires-python = \">3.8\"\n28\treadme = \"README.rst\"\n29\tauthors = [\n30\t    { name=\"TerraPower, LLC\", email=\"armi-devs@terrapower.com\" },\n31\t]\n32\tdependencies = [\n33\t    \"coverage>=7.2.0\", # Code coverage tool. Sadly baked into every Case.\n34\t    \"h5py>=3.0,<=3.9 ; python_version < '3.11.0'\",\n35\t    \"h5py>=3.9 ; python_version >= '3.11.0'\", # Needed because our database files are H5 format\n36\t    \"matplotlib>=3.5.3,<3.8.0 ; python_version < '3.11.0'\",\n37\t    \"matplotlib>=3.5.3 ; python_version >= '3.11.0'\", # Important plotting library\n38\t    \"numpy>=1.21\", # Important math library\n39\t    \"ordered-set>=3.1.1\", # A useful data structure\n40\t    \"pluggy>=1.2.0\", # Central tool behind the ARMI Plugin system\n41\t    \"pyevtk>=1.2.0\", # Handles binary VTK visualization files\n42\t    \"ruamel.yaml>=0.19.1 ; python_version >= '3.11.0'\", # Our foundational YAML library\n43\t    \"ruamel.yaml<=0.17.21 ; python_version < '3.11.0'\", # Our foundational YAML library\n44\t    \"scipy>=1.7.0\", # Used for curve-fitting and matrix math\n45\t    \"sympy>=1.14\", # Used to represent mathematical curves for material properties\n46\t    \"toml>0.9.5\", # Needed to parse the pyproject.toml file\n47\t    \"voluptuous>=0.12.1\", # Used to validate YAML data files\n48\t    \"yamlize==0.7.1\", # Custom YAML-to-object library\n49\t]\n50\tclassifiers = [\n51\t    \"Development Status :: 4 - Beta\",\n52\t    \"Intended Audience :: Science/Research\",\n53\t    \"License :: OSI Approved :: Apache Software License\",\n54\t    \"Operating System :: OS Independent\",\n55\t    \"Programming Language :: Python\",\n56\t    \"Programming Language :: Python :: 3\",\n57\t    \"Programming Language :: Python :: 3 :: Only\",\n58\t    \"Programming Language :: Python :: 3.9\",\n59\t    \"Programming Language :: Python :: 3.10\",\n60\t    \"Programming Language :: Python :: 3.11\",\n61\t    \"Programming Language :: Python :: 3.12\",\n62\t    \"Programming Language :: Python :: 3.13\",\n63\t    \"Programming Language :: Python :: 3.14\",\n64\t    \"Topic :: Scientific/Engineering :: Information Analysis\",\n65\t]\n66\t\n67\t[project.urls]\n68\tHomepage = \"https://terrapower.github.io/armi/\"\n69\tDocumentation = \"https://terrapower.github.io/armi\"\n70\tChangelog = \"https://github.com/terrapower/armi/releases\"\n71\tRepository = \"https://github.com/terrapower/armi\"\n72\t\"Bug Tracker\" = \"https://github.com/terrapower/armi/issues\"\n73\t\n74\t[project.optional-dependencies]\n75\tgrids = [\"wxpython==4.2.1\"]\n76\tmemprof = [\"psutil\"]\n77\tmpi = [\"mpi4py\"]\n78\ttest = [\n79\t    \"ipykernel>=6.0.0\", # IPython Kernel (We run test notebooks from the doc tutorials.)\n80\t    \"jupyter_client>=7.0.0\", # Reference implementation of the Jupyter protocol\n81\t    \"nbconvert>=7.0.0\", # Converting Jupyter Notebooks to other formats\n82\t    \"nbformat>=5.5.0\", # Jupyter Notebook reader\n83\t    \"pytest-cov>=4.0.0\", # coverage plugin\n84\t    \"pytest-xdist>=3.0.0\", # To spread our tests over multiple CPUs\n85\t    \"pytest>=7.0.0\", # Our primary test tooling\n86\t    \"ruff==0.9.7\", # Linting and code formatting (version-pinned)\n87\t]\n88\tdocs = [\n89\t######################################################################################\n90\t# These are most specified that usual, because Sphinx docs seem to be quite fragile. #\n91\t#                                                                                    #\n92\t# Officially, we build our docs with Python 3.13.                                    #\n93\t######################################################################################\n94\t    \"docutils==0.21.2\", # Needed by sphinx-rtd-them\n95\t    \"ipykernel>=6.0.0\", # iPython kernel to run Jupyter notebooks\n96\t    \"Jinja2==3.1.5\", # Used in numpydoc and nbconvert\n97\t    \"nbsphinx-link==1.3.1\", # Adds Jupyter NBs to Sphinx source root\n98\t    \"nbsphinx==0.9.6\", # Parses Jupyter notebooks\n99\t    \"pandoc\", # Must be in the path (to convert file formats)\n100\t    \"pylint\", # Generates UML diagrams\n101\t    \"pypdf==5.3.1\", # Generating a single PDF file for the Sphinx documentation\n102\t    \"setuptools\",  # needed for conf.py tooling\n103\t    \"sphinx-data-viewer==0.1.5\",\n104\t    \"sphinx-gallery==0.13.0\", # Builds an HTML version of a Python script and puts it into a gallery\n105\t    \"sphinx-needs==4.2.0\", # Requirements traceability matrices for QA\n106\t    \"sphinx-rtd-theme==3.0.2\", # Read-The-Docs theme for Sphinx\n107\t    \"sphinx-test-reports==1.1.0\", # sphinx-needs test reports in the STR\n108\t    \"Sphinx==7.4.7\", # central library used to build our docs\n109\t    \"sphinxcontrib-apidoc==0.5.0\", # More easily document our API\n110\t    \"sphinxcontrib-applehelp==2.0.0\",\n111\t    \"sphinxcontrib-devhelp==2.0.0\",\n112\t    \"sphinxcontrib-htmlhelp==2.1.0\",\n113\t    \"sphinxcontrib-jquery==4.1\", # Handle missing jquery errors\n114\t    \"sphinxcontrib-jsmath==1.0.1\",\n115\t    \"sphinxcontrib-plantuml==0.30\", # UML support in sphinx-needs\n116\t    \"sphinxcontrib-qthelp==2.0.0\",\n117\t    \"sphinxcontrib-serializinghtml==2.0.0\",\n118\t    \"sphinxext-opengraph==0.9.1\", # Generates OpenGraph metadata to make cards for social media\n119\t    \"unittest-xml-reporting==3.2.0\", # Allows us to generate junit XML test reports\n120\t]\n121\t\n122\t[project.scripts]\n123\tarmi = \"armi.__main__:main\"\n124\t\n125\t[tool.setuptools.packages]\n126\tfind = {}\n127\t\n128\t\n129\t#######################################################################\n130\t#                             RUFF CONFIG                             #\n131\t#######################################################################\n132\t[tool.ruff]\n133\t# This is the exact version of Ruff we use.\n134\trequired-version = \"0.9.7\"\n135\t\n136\t# Assume Python 3.13\n137\ttarget-version = \"py313\"\n138\t\n139\t# Setting line-length to 120\n140\tline-length = 120\n141\t\n142\t# Exclude a variety of commonly ignored directories.\n143\texclude = [\n144\t    \".bzr\",\n145\t    \".direnv\",\n146\t    \".eggs\",\n147\t    \".git\",\n148\t    \".git-rewrite\",\n149\t    \".hg\",\n150\t    \".mypy_cache\",\n151\t    \".nox\",\n152\t    \".pants.d\",\n153\t    \".pytype\",\n154\t    \".ruff_cache\",\n155\t    \".svn\",\n156\t    \".tox\",\n157\t    \".venv\",\n158\t    \"__pycache__\",\n159\t    \"__pypackages__\",\n160\t    \"_build\",\n161\t    \"buck-out\",\n162\t    \"build\",\n163\t    \"dist\",\n164\t    \"doc/tutorials/armi-example-app\",\n165\t    \"node_modules\",\n166\t    \"venv\",\n167\t]\n168\t\n169\t[tool.ruff.lint]\n170\t# Enable pycodestyle (E) and Pyflakes (F) codes by default.\n171\t# D - NumPy docstring rules\n172\t# I - Sorting imports\n173\t# N801 - Class name should use CapWords convention\n174\t# SIM - code simplification rules\n175\t# TID - tidy imports\n176\tselect = [\"D\", \"E\", \"F\", \"I\", \"N801\", \"SIM\", \"TID\"]\n177\t\n178\t# Ruff rules we ignore (for now) because they are not 100% automatable\n179\t#\n180\t# D100 - Missing docstring in public module\n181\t# D101 - Missing docstring in public class\n182\t# D102 - Missing docstring in public method\n183\t# D103 - Missing docstring in public function\n184\t# D106 - Missing docstring in public nested class\n185\t# D401 - First line of docstring should be in imperative mood\n186\t# D404 - First word of the docstring should not be \"This\"\n187\t# SIM102 - Use a single if statement instead of nested if statements\n188\t# SIM105 - Use contextlib.suppress({exception}) instead of try-except-pass\n189\t# SIM108 - Use ternary operator {contents} instead of if-else-block\n190\t# SIM114 - Combine if branches using logical or operator\n191\t# SIM115 - Use context handler for opening files\n192\t# SIM117 - Use a single with statement with multiple contexts instead of nested with statements\n193\t\n194\t# Ruff rules we ignore because we don't want them\n195\t#\n196\t# D105 - we don't need to document well-known magic methods\n197\t# D205 - 1 blank line required between summary line and description\n198\t# E731 - we can use lambdas however we want\n199\t# RUF100 - no unused noqa statements (not consistent enough yet)\n200\t# SIM118 - this does not work where we overload the .keys() method\n201\t#\n202\tignore = [\"D100\", \"D101\", \"D102\", \"D103\", \"D105\", \"D106\", \"D205\", \"D401\", \"D404\", \"E731\", \"RUF100\", \"SIM102\", \"SIM105\", \"SIM108\", \"SIM114\", \"SIM115\", \"SIM117\", \"SIM118\"]\n203\t\n204\t[tool.ruff.lint.per-file-ignores]\n205\t# D1XX - enforces writing docstrings\n206\t# E741 - ambiguous variable name\n207\t# N - We have our own naming conventions for unit tests.\n208\t# SLF001 - private member access\n209\t\"*/tests/*\" = [\"D1\", \"E741\", \"N\", \"SLF001\"]\n210\t\"doc/gallery-src/*\" = [\"D400\"]\n211\t\n212\t[tool.ruff.lint.flake8-tidy-imports]\n213\tban-relative-imports = \"all\"\n214\t\n215\t[tool.ruff.lint.pydocstyle]\n216\tconvention = \"numpy\"\n217\t\n218\t[tool.ruff.format]\n219\tdocstring-code-format = true\n220\tdocstring-code-line-length = 120\n221\t\n222\t\n223\t#######################################################################\n224\t#                            PYTEST CONFIG                            #\n225\t#######################################################################\n226\t[tool.pytest.ini_options]\n227\tpython_files = \"test_*.py\"\n228\tpython_functions = \"nothing matches this pattern\"\n229\taddopts = \"--durations=30 --tb=native\"\n230\tfilterwarnings = [\n231\t    \"ignore: the matrix subclass is not the recommended way:PendingDeprecationWarning\",\n232\t]\n233\t\n234\t[tool.coverage.run]\n235\texclude_also = [\n236\t    \"armi/cli/gridGui.py\",\n237\t    \"armi/utils/gridEditor.py\",\n238\t    \"armi/utils/tests/test_gridGui.py\",\n239\t    \"venv/\",\n240\t    ]\n241\tsource = [\"armi\"]\n242\tparallel = true\n243\t# Change default .coverage file to something that doesn't have a dot because some Windows services can't handle dots.\n244\tdata_file = \"coverage_results.cov\"\n245\t\n246\t[tool.coverage.report]\n247\t# Regexes for lines to exclude from consideration\n248\tomit = [\n249\t    \"*/tests/*\",\n250\t    \"armi/cli/gridGui.py\",\n251\t    \"armi/utils/gridEditor.py\",\n252\t    ]\n253\t\n254\texclude_also = [\n255\t    # Don't complain about missing debug-only code:\n256\t    \"def __repr__\",\n257\t    \"if self\\\\.debug\",\n258\t\n259\t    # Don't complain if non-runnable code isn't run:\n260\t    \"if __name__ == .__main__.:\",\n261\t\n262\t    # Don't complain about missing type checking-only code:\n263\t    \"if TYPE_CHECKING\",\n264\t\n265\t    # Don't complain if tests don't hit defensive assertion code:\n266\t    \"except ImportError\",\n267\t    \"pass\",\n268\t    \"raise AssertionError\",\n269\t    \"raise KeyboardInterrupt\",\n270\t    \"raise NotImplementedError\",\n271\t    ]\n272\t\n273\tignore_errors = true\n274\t\n275\t\n276\t#######################################################################\n277\t#              DATA FILES TO BE INCLUDED WITH THE PROJECT             #\n278\t#######################################################################\n279\t[tool.setuptools.package-data]\n280\tarmi = [\n281\t    \"bookkeeping/tests/armiRunSmallest-A0000-aHist-ref.txt\",\n282\t    \"matProps/dataSchema/dataSchema.json\",\n283\t    \"matProps/dataSchema/tests/inputs/*.yaml\",\n284\t    \"matProps/tests/invalidTestFiles/*\",\n285\t    \"matProps/tests/testDir1/*\",\n286\t    \"matProps/tests/testDir2/*\",\n287\t    \"matProps/tests/testDir3/*\",\n288\t    \"matProps/tests/testDir4/*\",\n289\t    \"matProps/tests/testMaterialsData/*\",\n290\t    \"nuclearDataIO/cccc/tests/fixtures/labels.ascii\",\n291\t    \"nuclearDataIO/cccc/tests/fixtures/labels.binary\",\n292\t    \"nuclearDataIO/cccc/tests/fixtures/mc2v3.dlayxs\",\n293\t    \"nuclearDataIO/cccc/tests/fixtures/simple_cartesian.pwdint\",\n294\t    \"nuclearDataIO/cccc/tests/fixtures/simple_cartesian.rtflux\",\n295\t    \"nuclearDataIO/cccc/tests/fixtures/simple_cartesian.rzflux\",\n296\t    \"nuclearDataIO/cccc/tests/fixtures/simple_hexz.dif3d\",\n297\t    \"nuclearDataIO/cccc/tests/fixtures/simple_hexz.geodst\",\n298\t    \"nuclearDataIO/cccc/tests/fixtures/simple_hexz.nhflux\",\n299\t    \"nuclearDataIO/tests/fixtures/AA.gamiso\",\n300\t    \"nuclearDataIO/tests/fixtures/AA.pmatrx\",\n301\t    \"nuclearDataIO/tests/fixtures/AB.gamiso\",\n302\t    \"nuclearDataIO/tests/fixtures/AB.pmatrx\",\n303\t    \"nuclearDataIO/tests/fixtures/com