{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_8f1cb0bd96274dd690418005","type":"tool_result","content":"1\timport functools\n2\timport os\n3\timport tempfile\n4\tfrom collections.abc import AsyncGenerator, AsyncIterator, Generator, Iterator\n5\tfrom decimal import Decimal\n6\tfrom typing import Any, NewType, cast\n7\tfrom unittest.mock import AsyncMock\n8\t\n9\timport pytest\n10\timport pytest_mock\n11\tfrom bitcart import BTC  # type: ignore[attr-defined]\n12\tfrom dishka import Provider, Scope, decorate, from_context, provide\n13\tfrom fastapi import FastAPI\n14\tfrom filelock import FileLock\n15\tfrom httpx import AsyncClient\n16\tfrom httpx_ws.transport import ASGIWebSocketTransport\n17\tfrom pwdlib import PasswordHash\n18\tfrom pwdlib.hashers.bcrypt import BcryptHasher\n19\tfrom sqlalchemy import text\n20\t\n21\tfrom api.bootstrap import get_app\n22\tfrom api.db import AsyncEngine, create_async_engine\n23\tfrom api.ioc import build_container, setup_dishka\n24\tfrom api.logging import configure as configure_logging\n25\tfrom api.models import Model\n26\tfrom api.plugins import PluginObjects\n27\tfrom api.services.coins import CoinService\n28\tfrom api.services.exchange_rate import ExchangeRateService\n29\tfrom api.settings import Settings\n30\t\n31\tpytest_plugins = [\"tests.fixtures.pytest.data\"]\n32\t\n33\tANYIO_BACKEND_OPTIONS = {\"use_uvloop\": True}\n34\t\n35\t\n36\t@pytest.fixture(scope=\"session\")\n37\tdef anyio_backend() -> tuple[str, dict[str, Any]]:\n38\t    return (\"asyncio\", ANYIO_BACKEND_OPTIONS)\n39\t\n40\t\n41\tdef get_db_url(settings: Settings, worker_id: str) -> str:\n42\t    if worker_id != \"master\":\n43\t        return f\"{settings.DB_DATABASE}_{worker_id}\"\n44\t    return settings.DB_DATABASE\n45\t\n46\t\n47\tasync def initialize_test_database(settings: Settings, worker_id: str) -> None:\n48\t    template_db_name = f\"{settings.DB_DATABASE}_template\"\n49\t    database_url = settings.build_postgres_dsn(db_name=template_db_name)\n50\t    engine = create_async_engine(settings, \"test\", dsn=settings.build_postgres_dsn(db_name=\"postgres\"))\n51\t    async with engine.connect() as conn:\n52\t        await conn.execution_options(isolation_level=\"AUTOCOMMIT\")\n53\t        await conn.execute(text(f\"DROP DATABASE IF EXISTS {template_db_name}\"))\n54\t        await conn.execute(text(f\"CREATE DATABASE {template_db_name}\"))\n55\t    await engine.dispose()\n56\t    engine = create_async_engine(settings, \"test\", dsn=database_url)\n57\t    async with engine.begin() as conn:\n58\t        await conn.run_sync(Model.metadata.create_all)\n59\t    await engine.dispose()\n60\t\n61\t\n62\t@pytest.fixture(scope=\"session\", autouse=True)\n63\tasync def initialize_test_database_fixture(\n64\t    settings: Settings,\n65\t    worker_id: str,\n66\t    tmp_path_factory: pytest.TempPathFactory,\n67\t) -> None:\n68\t    if worker_id == \"master\":\n69\t        await initialize_test_database(settings, worker_id)\n70\t        return\n71\t    root_tmp_dir = tmp_path_factory.getbasetemp().parent\n72\t\n73\t    fn = root_tmp_dir / \"data.json\"\n74\t    with FileLock(str(fn) + \".lock\"):\n75\t        if fn.is_file():\n76\t            pass\n77\t        else:\n78\t            await initialize_test_database(settings, worker_id)\n79\t            fn.write_text(\"DONE\")\n80\t\n81\t\n82\tWorkerId = NewType(\"WorkerId\", str)\n83\t\n84\t\n85\tclass TestingProvider(Provider):\n86\t    worker_id = from_context(provides=WorkerId, scope=Scope.APP)\n87\t\n88\t    @provide(scope=Scope.RUNTIME)\n89\t    def get_plugin_clases(self) -> PluginObjects:\n90\t        return cast(PluginObjects, {})\n91\t\n92\t    @provide(scope=Scope.RUNTIME)\n93\t    def get_password_context(self) -> PasswordHash:\n94\t        return PasswordHash((BcryptHasher(rounds=4),))\n95\t\n96\t    @provide(scope=Scope.APP)\n97\t    async def get_async_engine(self, settings: Settings, worker_id: WorkerId) -> AsyncIterator[AsyncEngine]:\n98\t 