{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_3b6ea75f213e471f827b3aab","type":"tool_result","content":"1\t---\n2\trepos:\n3\t  - repo: https://github.com/codespell-project/codespell\n4\t    rev: v2.4.2\n5\t    hooks:\n6\t      - id: codespell\n7\t        additional_dependencies:\n8\t          - tomli\n9\t        exclude_types: [csv, json]\n10\t  - repo: https://github.com/charliermarsh/ruff-pre-commit\n11\t    rev: 'v0.15.6'\n12\t    hooks:\n13\t      - id: ruff\n14\t        # in CI it is directly run by tox to allow dependency upgrade checks\n15\t        stages: [pre-commit]\n16\t        args: [ --fix, --exit-non-zero-on-fix ]\n17\t      - id: ruff-format\n18\t        files: ^((xknx|test|examples|docs)/.+)?[^/]+\\.py$\n19\t        # in CI it is directly run by tox to allow dependency upgrade checks\n20\t        stages: [pre-commit]\n21\t  - repo: https://github.com/pre-commit/pre-commit-hooks\n22\t    rev: v6.0.0\n23\t    hooks:\n24\t      - id: check-executables-have-shebangs\n25\t        stages: [manual]\n26\t      - id: check-json\n27\t      - id: no-commit-to-branch\n28\t        args:\n29\t          - --branch=main\n30\t      - id: trailing-whitespace\n31\t  - repo: https://github.com/cdce8p/python-typing-update\n32\t    rev: v0.8.1\n33\t    hooks:\n34\t      # Run `pre-commit run --hook-stage manual python-typing-update --all-files` manually\n35\t      # from time to time to update python typing syntax.\n36\t      # Will require manual work, before submitting changes!\n37\t      - id: python-typing-update\n38\t        stages: [manual]\n39\t        args:\n40\t          - --py310-plus\n41\t          - --force\n42\t          - --keep-updates\n43\t        files: ^(xknx)/.+\\.py$\n44\t  - repo: local\n45\t    hooks:\n46\t      # Run mypy through our wrapper script in order to get the possible\n47\t      # pyenv and/or virtualenv activated; it may not have been e.g. if\n48\t      # committing from a GUI tool that was not launched from an activated\n49\t      # shell.\n50\t      - id: mypy\n51\t        name: mypy\n52\t        entry: script/run-in-env.sh mypy\n53\t        language: script\n54\t        types: [python]\n55\t        require_serial: true\n56\t        files: ^xknx/.+\\.py$\n57\t\n58\t  - repo: local\n59\t    hooks:\n60\t    - id: pylint-xknx\n61\t      name: pylint-xknx\n62\t      entry: pylint xknx examples\n63\t      language: python\n64\t      types: [python]\n65\t      pass_filenames: true\n66\t      require_serial: true\n67\t      files: ^(xknx/|examples/)\n68\t\n69\t    - id: pylint-test\n70\t      name: pylint-test\n71\t      entry: pylint --disable=protected-access,abstract-class-instantiated\n72\t      language: python\n73\t      types: [python]\n74\t      pass_filenames: true\n75\t      require_serial: true\n76\t      files: ^test/\n77\t\n78\t"}]},"parent_tool_use_id":null,"session_id":"37c1a712-60bd-4f75-ab17-9d44a1017a49","uuid":"8fbb43a9-49af-4760-bc12-2aee9a35065b","timestamp":"2026-04-09T03:57:30.178Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.pre-commit-config.yaml","content":"---\nrepos:\n  - repo: https://github.com/codespell-project/codespell\n    rev: v2.4.2\n    hooks:\n      - id: codespell\n        additional_dependencies:\n          - tomli\n        exclude_types: [csv, json]\n  - repo: https://github.com/charliermarsh/ruff-pre-commit\n    rev: 'v0.15.6'\n    hooks:\n      - id: ruff\n        # in CI it is directly run by tox to allow dependency upgrade checks\n        stages: [pre-commit]\n        args: [ --fix, --exit-non-zero-on-fix ]\n      - id: ruff-format\n        files: ^((xknx|test|examples|docs)/.+)?[^/]+\\.py$\n        # in CI it is directly run by tox to allow dependency upgrade checks\n        stages: [pre-commit]\n  - repo: https://github.com/pre-commit/pre-commit-hooks\n    rev: v6.0.0\n    hooks:\n      - id: check-executables-have-shebangs\n        stages: [manual]\n      - id: check-json\n      - id: no-commit-to-branch\n        args:\n          - --branch=main\n      - id: trailing-whitespace\n  - repo: https://github.com/cdce8p/python-typing-update\n    rev: v0.8.1\n    hooks:\n      # Run `pre-commit run --hook-stage manual python-typing-update --all-files` manually\n      # from time to time to update python typing syntax.\n      # Will require manual work, before submitting changes!\n      - id: python-typing-update\n        stages: [manual]\n        args:\n          - --py310-plus\n          - --force\n          - --keep-updates\n        files: ^(xknx)/.+\\.py$\n  - repo: local\n    hooks:\n      # Run mypy through our wrapper script in order to get the possible\n      # pyenv and/or virtualenv activated; it may not have been e.g. if\n      # committing from a GUI tool that was not launched from an activated\n      # shell.\n      - id: mypy\n        name: mypy\n        entry: script/run-in-env.sh mypy\n        language: script\n        types: [python]\n        require_serial: true\n        files: ^xknx/.+\\.py$\n\n  - repo: local\n    hooks:\n    - id: pylint-xknx\n      name: pylint-xknx\n      entry: pylint xknx examples\n      language: python\n      types: [python]\n      pass_filenames: true\n      require_serial: true\n      files: ^(xknx/|examples/)\n\n    - id: pylint-test\n      name: pylint-test\n      entry: pylint --disable=protected-access,abstract-class-instantiated\n      language: python\n      types: [python]\n      pass_filenames: true\n      require_serial: true\n      files: ^test/\n\n","numLines":78,"startLine":1,"totalLines":78}}}
