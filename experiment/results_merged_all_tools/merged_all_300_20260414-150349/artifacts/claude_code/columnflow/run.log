e__\"],\n57\t    url=pkg[\"__contact__\"],\n58\t    keywords=keywords,\n59\t    classifiers=classifiers,\n60\t    long_description=long_description,\n61\t    long_description_content_type=\"text/markdown\",\n62\t    install_requires=install_requires,\n63\t    python_requires=\">=3.7, <=3.11\",\n64\t    zip_safe=False,\n65\t    packages=find_packages(exclude=[\"tests\"]),\n66\t)\n67\t"}]},"parent_tool_use_id":null,"session_id":"5c9e6616-16e8-4e21-b85a-de06f17f1fa1","uuid":"cb95f207-3b91-4c5a-af29-107c21ea035a","timestamp":"2026-04-09T02:59:47.424Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/setup.py","content":"# coding: utf-8\n\n\nimport os\nfrom setuptools import setup, find_packages\n\n\nthis_dir = os.path.dirname(os.path.abspath(__file__))\n\n\nkeywords = [\n    \"physics\", \"analysis\", \"experiment\", \"columnar\", \"vectorized\",\n    \"law\", \"order\", \"luigi\", \"workflow\", \"automation\", \"lhc\", \"cern\",\n]\n\n\nclassifiers = [\n    \"Programming Language :: Python\",\n    \"Programming Language :: Python :: 3\",\n    \"Programming Language :: Python :: 3.7\",\n    \"Programming Language :: Python :: 3.8\",\n    \"Programming Language :: Python :: 3.9\",\n    \"Programming Language :: Python :: 3.10\",\n    \"Programming Language :: Python :: 3.11\",\n    \"Development Status :: 4 - Beta\",\n    \"Operating System :: OS Independent\",\n    \"License :: OSI Approved :: BSD License\",\n    \"Intended Audience :: Developers\",\n    \"Intended Audience :: Science/Research\",\n    \"Intended Audience :: Information Technology\",\n]\n\n\n# read the readme file\nwith open(os.path.join(this_dir, \"README.md\"), \"r\") as f:\n    long_description = f.read()\n\n\n# load installation requirements\nwith open(os.path.join(this_dir, \"sandboxes\", \"cf.txt\"), \"r\") as f:\n    install_requires = [line.strip() for line in f.readlines() if line.strip()]\n\n\n# load package infos\npkg = {}\nwith open(os.path.join(this_dir, \"columnflow\", \"__version__.py\"), \"r\") as f:\n    exec(f.read(), pkg)\n\n\nsetup(\n    name=\"columnflow\",\n    version=pkg[\"__version__\"],\n    author=pkg[\"__author__\"],\n    author_email=pkg[\"__email__\"],\n    description=pkg[\"__doc__\"].strip().split(\"\\n\")[0].strip(),\n    license=pkg[\"__license__\"],\n    url=pkg[\"__contact__\"],\n    keywords=keywords,\n    classifiers=classifiers,\n    long_description=long_description,\n    long_description_content_type=\"text/markdown\",\n    install_requires=install_requires,\n    python_requires=\">=3.7, <=3.11\",\n    zip_safe=False,\n    packages=find_packages(exclude=[\"tests\"]),\n)\n","numLines":67,"startLine":1,"totalLines":67}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_9e5754581a2748bfa71e10bd","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t\n3\tsetup_columnflow() {\n4\t    # Runs the entire project setup, leading to a collection of environment variables starting with\n5\t    # \"CF_\", the installation of the software stack via virtual environments, and optionally an\n6\t    # interactive setup where the user can configure certain variables.\n7\t    #\n8\t    # Arguments:\n9\t    #   1. The name of the setup. \"default\" (which is itself the default when no name is set)\n10\t    #      triggers a setup with good defaults, avoiding all queries to the user and the writing of\n11\t    #      a custom setup file. See \"interactive_setup()\" for more info.\n12\t    #\n13\t    # Boolean flags are considered true-ish if they are \"1\", \"yes\" or \"true\" (case-insensitive).\n14\t    #\n15\t    # Optionally preconfigured environment variables:\n16\t    #   CF_REINSTALL_SOFTWARE\n17\t    #       When true-ish, any existing software stack is removed and freshly installed.\n18\t    #   CF_REINSTALL_HOOKS\n19\t    #       When true-ish, existing git hooks are removed and linked again.\n20\t    #   CF_REMOTE_ENV\n21\t    #       When true-ish, applies configurations for remote job. Remote jobs will set this value if needed\n22\t    #       and there is no need to set this by hand.\n23\t    #   CF_LCG_SETUP\n24\t    #       The location of a custom LCG software setup file.\n25\t    #   X509_USER_PROXY\n26\t    #       A custom globus user proxy location.\n27\t    #   LANGUAGE, LANG, LC_ALL\n28\t    #       Custom language flags.\n29\t    #\n30\t    # Variables defined by the setup and potentially required throughout columnflow:\n31\t    #   CF_SETUP_NAME\n32\t    #       The name of the setup. See above.\n33\t    #   CF_BASE\n34\t    #       The absolute columnflow base directory. Used to infer file locations relative to it.\n35\t    #   CF_DATA\n36\t    #       The main data directory where outputs and software can be stored in. Internally, this\n37\t    #       serves as a default for e.g. $CF_SOFTWARE_BASE, $CF_CMSSW_BASE, $CF_JOB_BASE and\n38\t    #       $CF_VENV_BASE which can, however, potentially point to a different directory. Queried\n39\t    #       during the interactive setup.\n40\t    #   CF_SOFTWARE_BASE\n41\t    #       The directory where general software is installed. Might point to $CF_DATA/software.\n42\t    #       Queried during the interactive setup.\n43\t    #   CF_REPO_BASE\n44\t    #       The base path of the main repository invoking tasks or scripts. Used by columnflow tasks\n45\t    #       to identify the repository that is bundled into remote jobs. Set to $CF_BASE when not\n46\t    #       defined already.\n47\t    #   CF_REPO_BASE_ALIAS\n48\t    #       Name of an environment variable whose value is identical to that of CF_REPO_BASE and\n49\t    #      that is usually used by an upstream analysis. For instance, if the analysis base is\n50\t    #      stored in \"$MY_ANALYSIS_BASE\", CF_REPO_BASE_ALIAS should be \"MY_ANALYSIS_BASE\" (no $).\n51\t    #   CF_CONDA_BASE\n52\t    #       The directory where conda / micromamba and conda envs are installed. Might point to\n53\t    #       $CF_SOFTWARE_BASE/conda.\n54\t    #   CF_VENV_BASE\n55\t    #       The directory where virtual envs are installed. Might point to $CF_SOFTWARE_BASE/venvs.\n56\t    #   CF_CMSSW_BASE\n57\t    #       The directory where CMSSW releases are installed. Might point to\n58\t    #       $CF_SOFTWARE_BASE/cmssw.\n59\t    #   CF_JOB_BASE\n60\t    #       The directory where job files from batch system submissions are kept. Used in law.cfg.\n61\t    #       Might point to $CF_DATA/jobs. Queried during the interactive setup.\n62\t    #   CF_VENV_SETUP_MODE\n63\t    #       The default mode for setting up virtual envs. Queried during the interactive setup. See\n64\t    #       sandboxes/_setup_venv.sh for more info.\n65\t    #   CF_STORE_NAME\n66\t    #       The name (not path) of store directories that will be created to contain output targets,\n67\t    #       potentially both locally and remotely. Queried during the interactive setup.\n68\t    #   CF_STORE_LOCAL\n69\t    #       The default local output store path, ammended by $CF_STORE_NAME. Queried during the\n70\t    #       interactive setup.\n71\t    #   CF_CI_ENV\n72\t    #       Set to \"true\" if a CI environment is detected (e.g. GitHub actions), and \"false\"\n73\t    #       otherwise.\n74\t    #   CF_RTD_ENV\n75\t    #       Set to \"true\" if a READTHEDOCS environment is detected, and \"false\" otherwise.\n76\t    #   CF_LCG_SETUP\n77\t    #       The location of a custom LCG software setup file. See above.\n78\t    #   CF_PERSISTENT_PATH\n79\t    #       PATH fragments that should be considered by sandboxes (bash, venv, cmssw) to have\n80\t    #       precedence, e.g. to ensure that executables of local packages are priotized.\n81\t    #   CF_PERSISTENT_PYTHONPATH\n82\t    #       PYTHONPATH fragments that should be considered by sandboxes (bash, venv, cmssw) to have\n83\t    #       precedence, e.g. to ensure that python modules of local packages are priotized.\n84\t    #   CF_CONDA_PYTHONPATH\n85\t    #       PYTHONPATH fragments pointing to packages intalled by conda.\n86\t    #   CF_ORIG_PATH\n87\t    #       Copy of the $PATH variable before ammended by the setup.\n88\t    #   CF_ORIG_PYTHONPATH\n89\t    #       Copy of the $PYTHONPATH variable before ammended by the setup.\n90\t    #   CF_ORIG_PYTHON3PATH\n91\t    #       Copy of the $PYTHON3PATH variable before ammended by the setup.\n92\t    #   CF_ORIG_LD_LIBRARY_PATH\n93\t    #       Copy of the $LD_LIBRARY_PATH variable before ammended by the setup.\n94\t    #   CF_WLCG_CACHE_ROOT\n95\t    #       The directory in which remote files from WLCG locations might be cached. No caching is\n96\t    #       used when empty. Queried during the interactive setup. Used in law.cfg.\n97\t    #   CF_WLCG_USE_CACHE\n98\t    #       Saves the decision on whether WLCG file caching is used or not, based on\n99\t    #       $CF_WLCG_CACHE_ROOT. Set to \"true\" when a remote job environment is detected. Used in\n100\t    #       law.cfg.\n101\t    #   CF_WLCG_CACHE_CLEANUP\n102\t    #       Set to \"false\" when the variable is not already existing. When \"false\", caches are not\n103\t    #       cleared after programs terminate and become persistent. Set to \"true\" when a remove job\n104\t    #       environment is detected. Used in law.cfg.\n105\t    #   CF_CERN_USER\n106\t    #       The user's CERN / WLCG name. Used in law.cfg.\n107\t    #   CF_CERN_USER_FIRSTCHAR\n108\t    #       The first character of the user's CERN / WLCG name. Derived from $CF_CERN_USER. Used in\n109\t    #       law.cfg.\n110\t    #   CF_LOCAL_SCHEDULER\n111\t    #       Either \"true\" or \"false\", deciding whether the process-local luigi scheduler should be\n112\t    #       used by default. Queried during the interactive setup. Used in law.cfg.\n113\t    #   CF_SCHEDULER_HOST\n114\t    #       Set to \"127.0.0.1\" when $CF_LOCAL_SCHEDULER was set to \"true\", or otherwise queried\n115\t    #       during the interactive setup. Used in law.cfg.\n116\t    #   CF_SCHEDULER_PORT\n117\t    #       Set to \"8082\" when $CF_LOCAL_SCHEDULER was set to \"true\", or otherwise queried during\n118\t    #       the interactive setup. Used in law.cfg.\n119\t    #   CF_WORKER_KEEP_ALIVE\n120\t    #       Set to \"false\" when not already set, or when a remote ($CF_REMOTE_ENV) or CI environment\n121\t    #       ($CF_CI_ENV) is detected. Used in law.cfg.\n122\t    #   CF_HTCONDOR_FLAVOR\n123\t    #       The default htcondor flavor setting for the HTCondorWorkflow task.\n124\t    #   CF_SLURM_FLAVOR\n125\t    #       The default slurm flavor setting for the SlurmWorkflow task.\n126\t    #   CF_SLURM_PARTITION\n127\t    #       The default slurm partition setting for the SlurmWorkflow task.\n128\t    #   CF_CRAB_STORAGE_ELEMENT\n129\t    #       The storage element for storing crab job related outputs.\n130\t    #   CF_CRAB_BASE_DIRECTORY\n131\t    #       The base directory where to store crab job related outputs on CF_CRAB_STORAGE_ELEMENT.\n132\t    #   CF_SETUP\n133\t    #       A flag that is set to 1 after the setup was successful.\n134\t    #   PATH\n135\t    #       Ammended PATH variable.\n136\t    #   PYTHONPATH\n137\t    #       Ammended PYTHONPATH variable.\n138\t    #   PYTHONWARNINGS\n139\t    #       Set to \"ignore\" when not defined already.\n140\t    #   PYTHONNOUSERSITE\n141\t    #       Set to \"1\" when not defined alreedy, to prevent python from loading packages from e.g.\n142\t    #       \"$HOME/.local\", which can lead to encapsulation and debugging issues.\n143\t    #   GLOBUS_THREAD_MODEL\n144\t    #       Set to \"none\".\n145\t    #   MYPROXY_SERVER\n146\t    #       Set to \"myproxy.cern.ch\".\n147\t    #   VIRTUAL_ENV_DISABLE_PROMPT\n148\t    #       Set to \"true\" when not defined already, leading to virtual envs leaving the PS1 prompt\n149\t    #       variable unaltered.\n150\t    #   X509_USER_PROXY\n151\t    #       Set to \"/tmp/x509up_u$( id -u )\" if not already set.\n152\t    #   LAW_HOME\n153\t    #       Set to \"$CF_BASE/.law\" if not already set.\n154\t    #   LAW_CONFIG_FILE\n155\t    #       Set to \"$CF_BASE/law.cfg\" if not already set.\n156\t\n157\t    # prevent repeated setups\n158\t    if ${CF_SETUP}; then\n159\t        >&2 echo \"columnflow was already succesfully setup\"\n160\t        >&2 echo \"re-running the setup requires a new shell\"\n161\t        return \"1\"\n162\t    fi\n163\t\n164\t    #\n165\t    # prepare local variables\n166\t    #\n167\t\n168\t    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n169\t    local this_file=\"$( ${shell_is_zsh} && echo \"${(%):-%x}\" || echo \"${BASH_SOURCE[0]}\" )\"\n170\t    local this_dir=\"$( cd \"$( dirname \"${this_file}\" )\" && pwd )\"\n171\t    local orig=\"${PWD}\"\n172\t    local setup_name=\"${1:-default}\"\n173\t    local setup_is_default=\"false\"\n174\t    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n175\t\n176\t    # zsh options\n177\t    if ${shell_is_zsh}; then\n178\t        emulate -L bash\n179\t        setopt globdots\n180\t    fi\n181\t\n182\t    #\n183\t    # global variables\n184\t    # (CF = columnflow)\n185\t    #\n186\t\n187\t    # start exporting variables\n188\t    export CF_BASE=\"${this_dir}\"\n189\t    export CF_SETUP_NAME=\"${setup_name}\"\n190\t\n191\t    # interactive setup\n192\t    if ! ${CF_REMOTE_ENV}; then\n193\t        cf_setup_interactive_body() {\n194\t            # query common variables\n195\t            cf_setup_interactive_common_variables\n196\t        }\n197\t        cf_setup_interactive \"${CF_SETUP_NAME}\" \"${CF_BASE}/.setups/${CF_SETUP_NAME}.sh\" || return \"$?\"\n198\t    fi\n199\t\n200\t    # continue the fixed setup\n201\t    export CF_REPO_BASE=\"${CF_REPO_BASE:-$CF_BASE}\"\n202\t    export CF_REPO_BASE_ALIAS=\"${CF_REPO_BASE_ALIAS:-}\"\n203\t    export CF_CONDA_BASE=\"${CF_CONDA_BASE:-${CF_SOFTWARE_BASE}/conda}\"\n204\t    export CF_VENV_BASE=\"${CF_VENV_BASE:-${CF_SOFTWARE_BASE}/venvs}\"\n205\t    export CF_CMSSW_BASE=\"${CF_CMSSW_BASE:-${CF_SOFTWARE_BASE}/cmssw}\"\n206\t    export CF_ORIG_PATH=\"${PATH}\"\n207\t    export CF_ORIG_PYTHONPATH=\"${PYTHONPATH}\"\n208\t    export CF_ORIG_PYTHON3PATH=\"${PYTHON3PATH}\"\n209\t    export CF_ORIG_LD_LIBRARY_PATH=\"${LD_LIBRARY_PATH}\"\n210\t\n211\t    #\n212\t    # common variables\n213\t    #\n214\t\n215\t    cf_setup_common_variables || return \"$?\"\n216\t\n217\t    #\n218\t    # minimal local software setup\n219\t    #\n220\t\n221\t    cf_setup_software_stack \"${CF_SETUP_NAME}\" || return \"$?\"\n222\t\n223\t    #\n224\t    # additional common cf setup steps\n225\t    #\n226\t\n227\t    cf_setup_post_install || return \"$?\"\n228\t\n229\t    #\n230\t    # finalize\n231\t    #\n232\t\n233\t    export CF_SETUP=\"true\"\n234\t}\n235\t\n236\tcf_detect_envs() {\n237\t    # Uses specific environment variables to detect if the current environment is a special one, e.g. in a remote job,\n238\t    # in a CI job, or in a READTHEDOCS build.\n239\t\n240\t    # detect variables (not using cf_cast_bool since services might use different values)\n241\t    export CF_CI_ENV=\"$( [ \"$( cf_lower_case \"${GITHUB_ACTIONS}\" )\" = \"true\" ] && echo \"true\" || echo \"false\" )\"\n242\t    export CF_RTD_ENV=\"$( [ \"$( cf_lower_case \"${READTHEDOCS}\" )\" = \"true\" ] && echo \"true\" || echo \"false\" )\"\n243\t\n244\t    # store env flags\n245\t    export CF_LOCAL_ENV=\"false\"\n246\t    if ${CF_REMOTE_ENV}; then\n247\t        cf_color yellow \"detected remote job environment\"\n248\t    elif ${CF_CI_ENV}; then\n249\t        cf_color yellow \"detected CI environment\"\n250\t    elif ${CF_RTD_ENV}; then\n251\t        cf_color yellow \"detected READTHEDOCS environment\"\n252\t    else\n253\t        export CF_LOCAL_ENV=\"true\"\n254\t    fi\n255\t}\n256\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_detect_envs\n257\t\n258\tcf_setup_common_variables() {\n259\t    # Exports variables that might be commonly used across analyses, such as host and job\n260\t    # environment variables (or their defaults).\n261\t\n262\t    # detect environments\n263\t    cf_detect_envs || return \"$?\"\n264\t\n265\t    # lang defaults\n266\t    if ${CF_RTD_ENV}; then\n267\t        export LANGUAGE=\"${READTHEDOCS_LANGUAGE:-en}\"\n268\t        export LANG=\"${READTHEDOCS_LANGUAGE:-en}\"\n269\t        export LC_ALL=\"${READTHEDOCS_LANGUAGE:-en}\"\n270\t    elif ${CF_ON_GRID}; then\n271\t        : # not supported on grid\n272\t    else\n273\t        export LANGUAGE=\"${LANGUAGE:-en_US.UTF-8}\"\n274\t        export LANG=\"${LANG:-en_US.UTF-8}\"\n275\t        export LC_ALL=\"${LC_ALL:-en_US.UTF-8}\"\n276\t    fi\n277\t\n278\t    # proxy\n279\t    export X509_USER_PROXY=\"${X509_USER_PROXY:-/tmp/x509up_u$( id -u )}\"\n280\t\n281\t    # overwrite some variables in remote and ci jobs\n282\t    if ${CF_REMOTE_ENV}; then\n283\t        export CF_WLCG_USE_CACHE=\"true\"\n284\t        export CF_WLCG_CACHE_CLEANUP=\"true\"\n285\t        export CF_WORKER_KEEP_ALIVE=\"false\"\n286\t    elif ${CF_CI_ENV} || ${CF_RTD_ENV}; then\n287\t        export CF_WLCG_USE_CACHE=\"false\"\n288\t        export CF_WLCG_CACHE_CLEANUP=\"false\"\n289\t        export CF_WORKER_KEEP_ALIVE=\"false\"\n290\t    fi\n291\t\n292\t    # luigi worker and scheduler defaults (assigned in law.cfg)\n293\t    export CF_WORKER_KEEP_ALIVE=\"${CF_WORKER_KEEP_ALIVE:-false}\"\n294\t    export CF_SCHEDULER_HOST=\"${CF_SCHEDULER_HOST:-127.0.0.1}\"\n295\t    export CF_SCHEDULER_PORT=\"${CF_SCHEDULER_PORT:-8082}\"\n296\t\n297\t    # default job flavor settings (starting with naf / maxwell cluster defaults)\n298\t    # used by law.cfg and, in turn, tasks/framework/remote.py\n299\t    local cf_htcondor_flavor_default=\"naf\"\n300\t    local cf_slurm_flavor_default=\"maxwell\"\n301\t    local cf_slurm_partition_default=\"maxgpu\"\n302\t    local hname=\"$( hostname 2> /dev/null )\"\n303\t    if [ \"$?\" = \"0\" ]; then\n304\t        # lxplus\n305\t        if [[ \"${hname}\" == lx*.cern.ch ]]; then\n306\t            cf_htcondor_flavor_default=\"cern\"\n307\t        fi\n308\t    fi\n309\t    export CF_HTCONDOR_FLAVOR=\"${CF_HTCONDOR_FLAVOR:-${cf_htcondor_flavor_default}}\"\n310\t    export CF_SLURM_FLAVOR=\"${CF_SLURM_FLAVOR:-${cf_slurm_flavor_default}}\"\n311\t    export CF_SLURM_PARTITION=\"${CF_SLURM_PARTITION:-${cf_slurm_partition_default}}\"\n312\t\n313\t    # show a warning in case no CF_REPO_BASE_ALIAS is set\n314\t    if [ -z \"${CF_REPO_BASE_ALIAS}\" ]; then\n315\t        cf_color yellow \"the variable CF_REPO_BASE_ALIAS is unset\"\n316\t        cf_color yellow \"please consider setting it to the name of the variable that refers to your analysis base directory\"\n317\t    fi\n318\t\n319\t    # notification variables\n320\t    export CF_MATTERMOST_HOOK_URL=\"${CF_MATTERMOST_HOOK_URL:-}\"\n321\t    export CF_MATTERMOST_CHANNEL=\"${CF_MATTERMOST_CHANNEL:-}\"\n322\t}\n323\t\n324\tcf_show_banner() {\n325\t    local no_utf8=\"$( cf_cast_bool \"${1}\" )\"\n326\t    if ! ${no_utf8}; then\n327\t        local charmap=\"$( cf_lower_case \"$( locale charmap )\" )\"\n328\t        no_utf8=\"$( [ \"${charmap}\" = \"utf-8\" ] && echo \"false\" || echo \"true\" )\"\n329\t    fi\n330\t\n331\t    if ${no_utf8}; then\n332\t        cat << EOF\n333\t                $( cf_color green '_' )\n334\t    ___   ___  $( cf_color green '| |' ) _   _  _ __ ___   _ __\n335\t   / __| / _ \\ $( cf_color green '| |' )| | | || '_ \\` _ \\ | '_ \\\\\n336\t  | (__ | (_) |$( cf_color green '| |' )| |_| || | | | | || | | |\n337\t   \\___| \\___/ $( cf_color green '| |' ) \\__,_||_| |_| |_||_| |_|\n338\t            __ $( cf_color green '| |' )\n339\t           / _|$( cf_color green '| |' )  ___ __      __\n340\t          | |_ $( cf_color green '| |' ) / _ \\\\ \\ /\\ / /\n341\t          |  _|$( cf_color green '| |' )| (_) |\\ V  V /\n342\t          |_|  $( cf_color green '| |' ) \\___/  \\_/\\_/\n343\t               $( cf_color green '|_|' )\n344\t\n345\tEOF\n346\t    else\n347\t        cat << EOF\n348\t\n349\t  ┏┏┓$( cf_color green '┃' )╻┏┏┳┓┏┓\n350\t  ┗┗┛$( cf_color green '┃' )┗┛╹┗┗╹┗\n351\t    ┏$( cf_color green '┃' )\n352\t    ╋$( cf_color green '┃' )┏┓┓┏┏\n353\t    ┛$( cf_color green '┃' )┗┛┗┻┛\n354\t\n355\tEOF\n356\t    fi\n357\t}\n358\t\n359\tcf_setup_interactive_common_variables() {\n360\t    # Queries for common variables which should be called from called inside custom\n361\t    # cf_setup_interactive_body funtions, which in turn is called by cf_setup_interactive.\n362\t\n363\t    query CF_CERN_USER \"CERN username\" \"$( whoami )\"\n364\t    export_and_save CF_CERN_USER_FIRSTCHAR \"\\${CF_CERN_USER:0:1}\"\n365\t\n366\t    query CF_DATA \"Local data directory\" \"\\$$( [ -z \"${CF_REPO_BASE}\" ] && echo \"CF_BASE\" || echo \"CF_REPO_BASE\" )/data\" \"./data\"\n367\t    query CF_SOFTWARE_BASE \"Local directory for installing software\" \"\\$CF_DATA/software\"\n368\t    query CF_JOB_BASE \"Local directory for storing job files\" \"\\$CF_DATA/jobs\"\n369\t\n370\t    query CF_STORE_NAME \"Relative path used in store paths (see next queries)\" \"cf_store\"\n371\t    query CF_STORE_LOCAL \"Default local output store\" \"\\$CF_DATA/\\$CF_STORE_NAME\"\n372\t    query CF_WLCG_CACHE_ROOT \"Local directory for caching remote files\" \"\" \"''\"\n373\t    export_and_save CF_WLCG_USE_CACHE \"$( [ -z \"${CF_WLCG_CACHE_ROOT}\" ] && echo \"false\" || echo \"true\" )\"\n374\t    export_and_save CF_WLCG_CACHE_CLEANUP \"${CF_WLCG_CACHE_CLEANUP:-false}\"\n375\t\n376\t    query CF_VENV_SETUP_MODE_UPDATE \"Automatically update virtual envs if needed\" \"false\"\n377\t    [ \"${CF_VENV_SETUP_MODE_UPDATE}\" != \"true\" ] && export_and_save CF_VENV_SETUP_MODE \"update\"\n378\t    unset CF_VENV_SETUP_MODE_UPDATE\n379\t    query CF_INTERACTIVE_VENV_FILE \"Custom venv setup file to use for interactive work instead of 'cf_dev'\" \"\" \"''\"\n380\t\n381\t    query CF_LOCAL_SCHEDULER \"Use a local scheduler for law tasks\" \"true\"\n382\t    if [ \"${CF_LOCAL_SCHEDULER}\" != \"true\" ]; then\n383\t        query CF_SCHEDULER_HOST \"Address of a central scheduler for law tasks\" \"127.0.0.1\"\n384\t        query CF_SCHEDULER_PORT \"Port of a central scheduler for law tasks\" \"8082\"\n385\t    else\n386\t        export_and_save CF_SCHEDULER_HOST \"127.0.0.1\"\n387\t        export_and_save CF_SCHEDULER_PORT \"8082\"\n388\t    fi\n389\t\n390\t    query CF_FLAVOR \"Flavor of the columnflow setup ('', 'cms')\" \"${CF_FLAVOR:-''}\"\n391\t\n392\t    if [ \"${CF_FLAVOR}\" = \"cms\" ]; then\n393\t        query LAW_CMS_VO \"virtual orgranistion\" \"cms\"\n394\t        query CF_CRAB_STORAGE_ELEMENT \"storage element for crab specific job outputs (e.g. T2_DE_DESY)\" \"''\"\n395\t        query CF_CRAB_BASE_DIRECTORY \"base directory on storage element for crab specific job outputs\" \"/store/user/\\$CF_CERN_USER/cf_crab_outputs\"\n396\t    fi\n397\t}\n398\t\n399\tcf_setup_interactive() {\n400\t    # Starts the interactive part of the setup by querying for values of certain environment\n401\t    # variables with useful defaults. When a custom, named setup is triggered, the values of all\n402\t    # queried environment variables are stored in a file.\n403\t    #\n404\t    # The actual variables that should be queried and exported during the setup are to be defined\n405\t    # beforehand a function called \"cf_setup_interactive_body\". This function can make use of the\n406\t    # internal functions \"export_and_save\" and \"query\", defined below.\n407\t    #\n408\t    # Arguments:\n409\t    #   1. The name of the setup. \"default\" triggers a setup with good defaults, avoiding all\n410\t    #      queries to the user and the writing of a custom setup file.\n411\t    #   2. The location of the setup file when a custom, named setup was triggered.\n412\t    #\n413\t    # Optionally preconfigured environment variables:\n414\t    #   CF_SKIP_BANNER\n415\t    #       When true-ish, the \"columnflow\" banner is not shown.\n416\t\n417\t    local setup_name=\"${1}\"\n418\t    local env_file=\"${2}\"\n419\t    local env_file_tmp=\"${env_file}.tmp\"\n420\t    local setup_is_default=\"false\"\n421\t    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n422\t\n423\t    # optionally show the banner\n424\t    ${CF_SKIP_BANNER} || cf_show_banner\n425\t\n426\t    # when the setup already exists and it's not the default one,\n427\t    # source the corresponding env file and stop\n428\t    if ! ${setup_is_default}; then\n429\t        if [ -f \"${env_file}\" ]; then\n430\t            echo \"using variables for setup '$( cf_color magenta ${setup_name} )' from ${env_file}\"\n431\t            source \"${env_file}\" \"\"\n432\t            return \"$?\"\n433\t        elif [ -z \"${env_file}\" ]; then\n434\t            >&2 echo \"no env file passed as 2nd argument to cf_interactive_setup\"\n435\t            return \"1\"\n436\t        else\n437\t            echo \"no setup file ${env_file} found for setup '$( cf_color magenta ${setup_name} )'\"\n438\t        fi\n439\t    fi\n440\t\n441\t    export_and_save() {\n442\t        local varname=\"$1\"\n443\t        local value=\"$2\"\n444\t\n445\t        export $varname=\"$( eval \"echo ${value}\" )\"\n446\t        if ! ${setup_is_default}; then\n447\t            echo \"export ${varname}=\\\"${value}\\\"\" >> \"${env_file_tmp}\"\n448\t        fi\n449\t    }\n450\t\n451\t    query() {\n452\t        local varname=\"$1\"\n453\t        local text=\"$2\"\n454\t        local default=\"$3\"\n455\t        local default_text=\"${4:-${default}}\"\n456\t        local default_lower=\"$( cf_lower_case \"${default}\" )\"\n457\t\n458\t        # when the setup is the default one, use the default value when the env variable is empty,\n459\t        # otherwise, query interactively\n460\t        local value=\"${default}\"\n461\t        if ${setup_is_default}; then\n462\t            # set the variable when existing\n463\t            eval \"value=\\${$varname:-\\${value}}\"\n464\t        else\n465\t            local query_response\n466\t            local query_response_lower\n467\t\n468\t            printf \"${text} ($( cf_color default_bright ${varname} ), default $( cf_color default_bright ${default_text} )):  \"\n469\t            read query_response\n470\t            [ \"X${query_response}\" = \"X\" ] && query_response=\"${default}\"\n471\t\n472\t            # repeat for boolean flags that were not entered correctly\n473\t            while true; do\n474\t                ( [ \"${default_lower}\" != \"true\" ] && [ \"${default_lower}\" != \"false\" ] ) && break\n475\t                query_response_lower=\"$( cf_lower_case \"${query_response}\" )\"\n476\t                if ( [ \"${query_response_lower}\" = \"true\" ] || [ \"${query_response_lower}\" = \"false\" ] ); then\n477\t                    query_response=\"${query_response_lower}\"\n478\t                    break\n479\t                fi\n480\t                printf \"please enter either '$( cf_color default_bright \"true\" )' or '$( cf_color default_bright \"false\" )':  \" query_response\n481\t                read query_response\n482\t                [ \"X${query_response}\" = \"X\" ] && query_response=\"${default}\"\n483\t            done\n484\t            value=\"${query_response}\"\n485\t\n486\t            # strip \" and ' on both sides\n487\t            value=${value%\\\"}\n488\t            value=${value%\\'}\n489\t            value=${value#\\\"}\n490\t            value=${value#\\'}\n491\t        fi\n492\t\n493\t        export_and_save \"${varname}\" \"${value}\"\n494\t    }\n495\t\n496\t    # prepare the tmp env file\n497\t    if ! ${setup_is_default}; then\n498\t        rm -f \"${env_file_tmp}\"\n499\t        mkdir -p \"$( dirname \"${env_file_tmp}\" )\"\n500\t\n501\t        echo -e \"Start querying variables for setup '$( cf_color magenta ${setup_name} )', press enter to accept default values\\n\"\n502\t    fi\n503\t\n504\t    # query for variables\n505\t    cf_setup_interactive_body || return \"$?\"\n506\t\n507\t    # move the env file to the correct location for later use\n508\t    if ! ${setup_is_default}; then\n509\t        mv \"${env_file_tmp}\" \"${env_file}\"\n510\t        echo -e \"\\nvariables written to ${env_file}\"\n511\t    fi\n512\t}\n513\t\n514\tcf_setup_software_stack() {\n515\t    # Sets up the columnflow software stack as a base environment using conda (actually using the\n516\t    # free and faster micromamba interface), lightweight virtual environments on top and git\n517\t    # submodule initialization / updates.\n518\t    #\n519\t    # Arguments:\n520\t    #   1. setup_name\n521\t    #       The name of the setup.\n522\t    #\n523\t    # Required environment variables:\n524\t    #   CF_BASE\n525\t    #       The columnflow base directory.\n526\t    #   CF_CONDA_BASE\n527\t    #       The directory where conda / micromamba and conda envs will be installed.\n528\t    #   CF_VENV_BASE\n529\t    #       The base directory were virtual envs are installed.\n530\t    #\n531\t    # Optional environments variables:\n532\t    #   CF_REMOTE_ENV\n533\t    #       When true-ish, the software stack is sourced but not built.\n534\t    #   CF_LOCAL_ENV\n535\t    #       When not true-ish, the context is not meant for local development and only the \"cf_dev\" venv is built.\n536\t    #       CF_INTERACTIVE_VENV_FILE is ignored in this case.\n537\t    #   CF_INTERACTIVE_VENV_FILE\n538\t    #       IF CF_LOCAL_ENV is true-ish, the venv setup of this file is sourced to start the interactive shell. When\n539\t    #       empty, defaults to ${CF_BASE}/sandboxes/cf_dev.sh.\n540\t    #   CF_REINSTALL_SOFTWARE\n541\t    #       When true-ish, any existing software stack is removed and freshly installed.\n542\t    #   CF_CONDA_ARCH\n543\t    #       The OS / architecture for the conda installation. Defaults to \"linux-64\". For more info:\n544\t    #       https://mamba.readthedocs.io/en/latest/installation/micromamba-installation.html#linux-and-macos\n545\t\n546\t    # check global variables\n547\t    if [ -z \"${CF_BASE}\" ]; then\n548\t        >&2 echo \"CF_BASE not defined, stopping software setup\"\n549\t        return \"1\"\n550\t    fi\n551\t    if [ -z \"${CF_CONDA_BASE}\" ]; then\n552\t        >&2 echo \"CF_CONDA_BASE not defined, stopping software setup\"\n553\t        return \"2\"\n554\t    fi\n555\t    if [ -z \"${CF_VENV_BASE}\" ]; then\n556\t        >&2 echo \"CF_VENV_BASE not defined, stopping software setup\"\n557\t        return \"3\"\n558\t    fi\n559\t\n560\t    # local variables\n561\t    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n562\t    local setup_name=\"${1}\"\n563\t    local setup_is_default=\"false\"\n564\t    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n565\t    local pyv=\"${CF_PYTHON_VERSION:-3.9}\"\n566\t    local conda_arch=\"${CF_CONDA_ARCH:-linux-64}\"\n567\t    local ret\n568\t\n569\t    # zsh options\n570\t    if ${shell_is_zsh}; then\n571\t        emulate -L bash\n572\t        setopt globdots\n573\t    fi\n574\t\n575\t    # empty the PYTHONPATH, except for specific customizable paths\n576\t    export PYTHONPATH=\"${CF_INITIAL_PYTHONPATH:-}\"\n577\t\n578\t    # persistent PATH and PYTHONPATH parts that should be\n579\t    # priotized over any additions made in sandboxes\n580\t    export CF_PERSISTENT_PATH=\"${CF_BASE}/bin:${CF_BASE}/modules/law/bin\"\n581\t    export CF_PERSISTENT_PYTHONPATH=\"${CF_BASE}:${CF_BASE}/bin:${CF_BASE}/modules/law:${CF_BASE}/modules/order\"\n582\t\n583\t    # flavor specific paths\n584\t    if [ ! -z \"${CF_FLAVOR}\" ]; then\n585\t        [ -d \"${CF_BASE}/bin/${CF_FLAVOR}\" ] && export CF_PERSISTENT_PATH=\"${CF_PERSISTENT_PATH}:${CF_BASE}/bin/${CF_FLAVOR}\"\n586\t    fi\n587\t\n588\t    # prepend them\n589\t    export PATH=\"${CF_PERSISTENT_PATH}:${PATH}\"\n590\t    export PYTHONPATH=\"${CF_PERSISTENT_PYTHONPATH}:${PYTHONPATH}\"\n591\t\n592\t    # also add the python path of the venv to be installed to propagate changes to any outer venv\n593\t    export CF_CONDA_PYTHONPATH=\"${CF_CONDA_BASE}/lib/python${pyv}/site-packages\"\n594\t    export PYTHONPATH=\"${PYTHONPATH}:${CF_CONDA_PYTHONPATH}\"\n595\t\n596\t    # update paths and flags\n597\t    export MAMBA_ROOT_PREFIX=\"${CF_CONDA_BASE}\"\n598\t    export MAMBA_EXE=\"${MAMBA_ROOT_PREFIX}/bin/micromamba\"\n599\t    export PYTHONWARNINGS=\"${PYTHONWARNINGS:-ignore}\"\n600\t    export PYTHONNOUSERSITE=\"${PYTHONNOUSERSITE:-1}\"\n601\t    export GLOBUS_THREAD_MODEL=\"${GLOBUS_THREAD_MODEL:-none}\"\n602\t    export VIRTUAL_ENV_DISABLE_PROMPT=\"${VIRTUAL_ENV_DISABLE_PROMPT:-1}\"\n603\t    export MYPROXY_SERVER=\"${MYPROXY_SERVER:-myproxy.cern.ch}\"\n604\t    export X509_CERT_DIR=\"${X509_CERT_DIR:-/cvmfs/grid.cern.ch/etc/grid-security/certificates}\"\n605\t    export X509_VOMS_DIR=\"${X509_VOMS_DIR:-/cvmfs/grid.cern.ch/etc/grid-security/vomsdir}\"\n606\t    export X509_VOMSES=\"${X509_VOMSES:-/cvmfs/grid.cern.ch/etc/grid-security/vomses}\"\n607\t    export VOMS_USERCONF=\"${VOMS_USERCONF:-${X509_VOMSES}}\"\n608\t    ulimit -s unlimited\n609\t\n610\t    #\n611\t    # setup in local envs (not remote)\n612\t    #\n613\t\n614\t    if ! ${CF_REMOTE_ENV}; then\n615\t        # remote directories first if requested\n616\t        if ${CF_REINSTALL_SOFTWARE}; then\n617\t            echo \"removing conda setup at $( cf_color magenta ${CF_CONDA_BASE})\"\n618\t            rm -rf \"${CF_CONDA_BASE}\"\n619\t\n620\t            echo \"removing software virtual envs at $( cf_color magenta ${CF_VENV_BASE})\"\n621\t            rm -rf \"${CF_VENV_BASE}\"\n622\t        fi\n623\t\n624\t        #\n625\t        # conda / micromamba setup\n626\t        #\n627\t\n628\t        # only needed in local envs\n629\t        if ${CF_LOCAL_ENV}; then\n630\t            # base environment\n631\t            local conda_missing=\"$( [ -d \"${CF_CONDA_BASE}\" ] && echo \"false\" || echo \"true\" )\"\n632\t            if ${conda_missing}; then\n633\t                echo\n634\t                cf_color magenta \"installing conda with micromamba interface at ${CF_CONDA_BASE}\"\n635\t\n636\t                mkdir -p \"${CF_CONDA_BASE}/etc/profile.d\"\n637\t                curl -Ls \"https://micro.mamba.pm/api/micromamba/${conda_arch}/latest\" | tar -xvj -C \"${CF_CONDA_BASE}\" \"bin/micromamba\" > /dev/null\n638\t                2>&1 \"${CF_CONDA_BASE}/bin/micromamba\" shell hook -y --root-prefix \"$PWD\" &> micromamba.sh\n639\t                ret=\"$?\"\n640\t                if [ \"${ret}\" != \"0\" ]; then\n641\t                    [ -f \"micromamba.sh\" ] && >&2 cat micromamba.sh\n642\t                    return \"${ret}\"\n643\t                fi\n644\t                # make the setup file relocatable\n645\t                sed -i -r \"s|${CF_CONDA_BASE}|\\$\\{MAMBA_ROOT_PREFIX\\}|\" \"micromamba.sh\" || return \"$?\"\n646\t                mv \"micromamba.sh\" \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\"\n647\t                cat << EOF > \"${CF_CONDA_BASE}/.mambarc\"\n648\tchangeps1: false\n649\talways_yes: true\n650\tchannels:\n651\t  - conda-forge\n652\tEOF\n653\t            fi\n654\t\n655\t            # initialize micromamba\n656\t            source \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\" \"\" || return \"$?\"\n657\t            micromamba activate || return \"$?\"\n658\t            echo \"initialized conda with $( cf_color magenta \"micromamba\" ) interface and $( cf_color magenta \"python ${pyv}\" )\"\n659\t\n660\t            # install packages\n661\t            if ${conda_missing}; then\n662\t                echo\n663\t                cf_color cyan \"setting up conda / micromamba environment\"\n664\t                micromamba install \\\n665\t                    gcc \\\n666\t                    libgcc \\\n667\t                    bash \\\n668\t                    zsh \\\n669\t                    \"python=${pyv}\" \\\n670\t                    git \\\n671\t                    git-lfs \\\n672\t                    gfal2 \\\n673\t                    gfal2-util \\\n674\t                    python-gfal2 \\\n675\t                    myproxy \\\n676\t                    conda-pack \\\n677\t                    || return \"$?\"\n678\t                micromamba clean --yes --all\n679\t\n680\t                # add a file to conda/activate.d that handles the gfal setup transparently with conda-pack\n681\t                cat << EOF > \"${CF_CONDA_BASE}/etc/conda/activate.d/gfal_activate.sh\"\n682\texport GFAL_CONFIG_DIR=\"\\${CONDA_PREFIX}/etc/gfal2.d\"\n683\texport GFAL_PLUGIN_DIR=\"\\${CONDA_PREFIX}/lib/gfal2-plugins\"\n684\texport X509_CERT_DIR=\"${X509_CERT_DIR}\"\n685\texport X509_VOMS_DIR=\"${X509_VOMS_DIR}\"\n686\texport X509_VOMSES=\"${X509_VOMSES}\"\n687\texport VOMS_USERCONF=\"${VOMS_USERCONF}\"\n688\tEOF\n689\t                echo\n690\t            fi\n691\t        fi\n692\t\n693\t        #\n694\t        # venv setup\n695\t        #\n696\t\n697\t        # - \"cf\"     : contains the minimal stack to run tasks and is sent alongside jobs\n698\t        # - \"cf_dev\" : \"cf\" + additional python tools for local development (e.g. ipython)\n699\t        # - custom   : when CF_INTERACTIVE_VENV_FILE is set, source the venv setup from there\n700\t\n701\t        source_venv() {\n702\t            # all parameters must be given\n703\t            local venv_file=\"$1\"\n704\t            local venv_name=\"$2\"\n705\t            # must be true or false\n706\t            local use_subshell=\"$3\"\n707\t\n708\t            # source the file and catch the return code\n709\t            local ret=\"0\"\n710\t            if ${use_subshell}; then\n711\t                ( source \"${venv_file}\" \"\" \"silent\" )\n712\t                ret=\"$?\"\n713\t            else\n714\t                source \"${venv_file}\" \"\" \"silent\"\n715\t                ret=\"$?\"\n716\t            fi\n717\t\n718\t            # code 21 means \"version outdated\", all others are as usual\n719\t            if [ \"${ret}\" = \"21\" ]; then\n720\t                >&2 echo\n721\t                >&2 echo \"WARNING: your venv '${venv_name}' is not up to date, please consider updating it in a new shell with\"\n722\t                >&2 echo \"WARNING: > CF_REINSTALL_SOFTWARE=1 source setup.sh $( ${setup_is_default} || echo \"${setup_name}\" )\"\n723\t                >&2 echo\n724\t            elif [ \"${ret}\" != \"0\" ]; then\n725\t                return \"${ret}\"\n726\t            fi\n727\t\n728\t            return \"0\"\n729\t        }\n730\t\n731\t        # build the production sandbox in a subshell, only in local envs\n732\t        if ${CF_LOCAL_ENV}; then\n733\t            source_venv \"${CF_BASE}/sandboxes/cf.sh\" \"cf\" true || return \"$?\"\n734\t        fi\n735\t\n736\t        # check if a custom interactive venv should be used, check the file, but only in local envs\n737\t        local use_custom_interactive_venv=\"false\"\n738\t        if ${CF_LOCAL_ENV} && [ ! -z \"${CF_INTERACTIVE_VENV_FILE}\" ]; then\n739\t            # check existence\n740\t            if [ ! -f \"${CF_INTERACTIVE_VENV_FILE}\" ]; then\n741\t                >&2 echo \"the interactive venv setup file ${CF_INTERACTIVE_VENV_FILE} does not exist\"\n742\t                return \"2\"\n743\t            fi\n744\t            use_custom_interactive_venv=\"true\"\n745\t        fi\n746\t\n747\t        # build the dev sandbox, using a subshell if a custom venv is given that should be sourced afterwards\n748\t        source_venv \"${CF_BASE}/sandboxes/cf_dev.sh\" \"cf_dev\" \"${use_custom_interactive_venv}\" || return \"$?\"\n749\t\n750\t        # source the custom interactive venv setup file if given\n751\t        if ${use_custom_interactive_venv}; then\n752\t            echo \"activating custom interactive venv from $( cf_color magenta \"${CF_INTERACTIVE_VENV_FILE}\" )\"\n753\t            source_venv \"${CF_INTERACTIVE_VENV_FILE}\" \"$( basename \"${CF_INTERACTIVE_VENV_FILE%.*}\" )\" false || return \"$?\"\n754\t        fi\n755\t\n756\t        # initialze submodules\n757\t        if [ -e \"${CF_BASE}/.git\" ]; then\n758\t            local m\n759\t            for m in $( ls -1q \"${CF_BASE}/modules\" ); do\n760\t                cf_init_submodule \"${CF_BASE}\" \"modules/${m}\"\n761\t            done\n762\t        fi\n763\t    fi\n764\t\n765\t    #\n766\t    # setup in remote jobs\n767\t    #\n768\t\n769\t    if ${CF_REMOTE_ENV}; then\n770\t        # initialize conda\n771\t        source \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\" \"\" || return \"$?\"\n772\t        micromamba activate || return \"$?\"\n773\t        echo \"initialized conda with $( cf_color magenta \"micromamba\" ) interface and $( cf_color magenta \"python ${pyv}\" )\"\n774\t\n775\t        # source the production sandbox\n776\t        source \"${CF_BASE}/sandboxes/cf.sh\" \"\" \"no\"\n777\t    fi\n778\t}\n779\t\n780\tcf_setup_post_install() {\n781\t    # Performs additional, central setup steps after variables are set and software is installed. These steps are meant\n782\t    # to be common to all setups and that can be adjusted later on through updates of the columnflow module.\n783\t    #\n784\t    # Current steps:\n785\t    #   - setup git hooks\n786\t    #   - setup law\n787\t    #   - check size of the target tmp dir\n788\t    #\n789\t    # Required environment variables:\n790\t    #   CF_LOCAL_ENV\n791\t    #       Should be true or false, indicating if the setup is run in a local environment.\n792\t    #   CF_REPO_BASE\n793\t    #       The base directory of the analysis repository, which is used to determine the law home and config file.\n794\t    #\n795\t    # Optional environment variables:\n796\t    #   CF_SKIP_SETUP_GIT_HOOKS\n797\t    #       When set to true, the setup of git hooks is skipped.\n798\t    #   CF_SKIP_LAW_INDEX\n799\t    #       When set to true, the initial indexing of law tasks is skipped.\n800\t    #   CF_SKIP_CHECK_TMP_DIR\n801\t    #       When set to true, the check of the size of the target tmp directory is skipped.\n802\t\n803\t    #\n804\t    # git hooks\n805\t    #\n806\t\n807\t    # only in local env\n808\t    if ! ${CF_SKIP_SETUP_GIT_HOOKS} && ${CF_LOCAL_ENV}; then\n809\t        cf_setup_git_hooks || return \"$?\"\n810\t    fi\n811\t\n812\t    #\n813\t    # law setup\n814\t    #\n815\t\n816\t    if [ ! -z \"${CF_REPO_BASE}\" ]; then\n817\t        export LAW_HOME=\"${LAW_HOME:-${CF_REPO_BASE}/.law}\"\n818\t        export LAW_CONFIG_FILE=\"${LAW_CONFIG_FILE:-${CF_REPO_BASE}/law.cfg}\"\n819\t\n820\t        if ${CF_LOCAL_ENV} && which law &> /dev/null; then\n821\t            # source law's bash completion scipt\n822\t            source \"$( law completion )\" \"\"\n823\t\n824\t            # add completion to the claw command\n825\t            complete -o bashdefault -o default -F _law_complete claw\n826\t\n827\t            # silently index\n828\t            if ! ${CF_SKIP_LAW_INDEX}; then\n829\t                law index -q\n830\t            fi\n831\t        fi\n832\t    fi\n833\t\n834\t    #\n835\t    # check the tmp directory size\n836\t    #\n837\t\n838\t    if ! ${CF_SKIP_CHECK_TMP_DIR} && ${CF_LOCAL_ENV} && which law &> /dev/null; then\n839\t        cf_check_tmp_dir\n840\t    fi\n841\t\n842\t    return \"0\"\n843\t}\n844\t\n845\tcf_check_tmp_dir() {\n846\t    # Computes the size of all user-owned files in the target tmp directory and issues a warning when the size exceeds\n847\t    # certain thresholds. If a variable CF_SKIP_TMP_CHECK is set to true, the check is skipped.\n848\t\n849\t    # check if skipping\n850\t    if [ ! -z \"${CF_SKIP_TMP_CHECK}\" ] && ${CF_SKIP_TMP_CHECK}; then\n851\t        return \"0\"\n852\t    fi\n853\t\n854\t    # determine the tmp directory\n855\t    local tmp_dir=\"$( law config target.tmp_dir )\"\n856\t    local ret=\"$?\"\n857\t    if [ \"${ret}\" != \"0\" ]; then\n858\t        >&2 cf_color \"red\" \"cf_check_tmp_dir: 'law config target.tmp_dir' failed with error code ${ret}\"\n859\t        return \"${ret}\"\n860\t    elif [ -z \"${tmp_dir}\" ]; then\n861\t        >&2 cf_color \"red\" \"cf_check_tmp_dir: 'law config target.tmp_dir' must not be empty\"\n862\t        return \"2\"\n863\t    elif [ ! -d \"${tmp_dir}\" ]; then\n864\t        # nothing to do\n865\t        return \"0\"\n866\t    fi\n867\t\n868\t    # compute the size, with a notification shown if it takes too long\n869\t    ( sleep 5 && cf_color yellow \"computing the size of your files in ${tmp_dir} ...\" ) &\n870\t    local msg_pid=\"$!\"\n871\t    local tmp_size=\"$( find \"${tmp_dir}\" -maxdepth 1 -user \"$( id -u )\" -exec du -cb {} + | grep 'total$' | cut -d $'\\t' -f 1 | sort | head -n 1 )\"\n872\t    kill \"${msg_pid}\" 2> /dev/null\n873\t    wait \"${msg_pid}\" 2> /dev/null\n874\t\n875\t    # warn above 1GB with color changing when above 2GB\n876\t    local thresh1=\"1073741824\"\n877\t    local thresh2=\"2147483648\"\n878\t    if [ \"${tmp_size}\" -gt \"${thresh1}\" ]; then\n879\t        local hsize=\"$( python -c \"import law; print(law.util.human_bytes(${tmp_size}, fmt=True))\" )\"\n880\t        local color=\"$( [ \"${tmp_size}\" -lt \"${thresh2}\" ] && echo \"yellow\" || echo \"red\" )\"\n881\t        echo\n882\t        cf_color \"${color}\" \"the combined size of your files in the directory ${tmp_dir} is $( cf_color \"${color}_bright\" \"${hsize}\" )\"\n883\t        cf_color \"${color}\" \"please consider cleaning up using $( cf_color \"${color}_bright\" \"'cf_remove_tmp [all]'\" )\"\n884\t        echo\n885\t    fi\n886\t\n887\t    return \"0\"\n888\t}\n889\t\n890\tcf_setup_git_hooks() {\n891\t    # Initializes lfs and custom githooks in the local checkout for both the columnflow\n892\t    # (sub)repository, as well as the analysis repository in case a directory bin/githooks is found.\n893\t    #\n894\t    # Required environments variables:\n895\t    #   CF_REMOTE_ENV (bool)\n896\t    #       When true, no hooks are setup.\n897\t    #   CF_CI_ENV (bool)\n898\t    #       When true, no hooks are setup.\n899\t\n900\t    # do nothing when not local\n901\t    if ${CF_REMOTE_ENV} || ${CF_CI_ENV}; then\n902\t        return \"0\"\n903\t    fi\n904\t\n905\t    # helper to setup hooks\n906\t    setup_hooks() {\n907\t        local repo_dir=\"$1\"\n908\t        local src_dir=\"$2\"\n909\t        local f\n910\t\n911\t        # determine the target hooks directory\n912\t        local dst_dir=\"$( cd \"${repo_dir}\" && echo \"$( git rev-parse --git-dir )/hooks\" )\"\n913\t        if [ \"$?\" != \"0\" ] || [ ! -d \"${dst_dir}\" ]; then\n914\t            >&2 echo \"no git hooks directory found, cannot setup hooks\"\n915\t            return \"30\"\n916\t        fi\n917\t\n918\t        # remove existing hooks if requested\n919\t        local flag_file=\"${dst_dir}/.cf_hooks_setup\"\n920\t        if ${CF_REINSTALL_HOOKS}; then\n921\t            # remove hooks\n922\t            for f in $( ls -1 \"${dst_dir}\" ); do\n923\t                [ -f \"${dst_dir}/${f}\" ] && [[ \"${f}\" != *.sample ]] && rm -f \"${dst_dir}/${f}\"\n924\t            done\n925\t            # remove the flag file\n926\t            rm -f \"${flag_file}\"\n927\t        fi\n928\t\n929\t        # do nothing if hooks are already setup up\n930\t        [ -f \"${flag_file}\" ] && return \"0\"\n931\t\n932\t        # detect if lfs hooks are already installed, as identified by the pre-push\n933\t        local lfs_installed=\"false\"\n934\t        for f in $( ls -1 \"${dst_dir}\"/{pre-push,pre-push-*} 2> /dev/null || true ); do\n935\t            if [ -f \"${f}\" ] && [ ! -z \"$( cat \"${f}\" | grep \"git lfs pre-push\" )\" ]; then\n936\t                lfs_installed=\"true\"\n937\t                break\n938\t            fi\n939\t        done\n940\t\n941\t        # setup lfs if not done yet\n942\t        if ! ${lfs_installed}; then\n943\t            ( cd \"${repo_dir}\" && git lfs install > /dev/null ) || return \"$?\"\n944\t        fi\n945\t\n946\t        # move all existing hooks and replace them with combined scripts\n947\t        for f in $( ls -1 \"${dst_dir}\" ); do\n948\t            # skip samples and directories\n949\t            ( [ ! -f \"${dst_dir}/${f}\" ] || [[ \"${f}\" == *.sample ]] ) && continue\n950\t            # move the file and create the new one\n951\t            mv \"${dst_dir}/${f}\" \"${dst_dir}/${f}$( hook_postfix \"${dst_dir}\" \"${f}\" )\"\n952\t            cp \"${CF_BASE}/bin/githooks/combined_hook.sh\" \"${dst_dir}/${f}\"\n953\t        done\n954\t\n955\t        # setup all hooks in bin/githooks\n956\t        for f in $( ls -1 \"${src_dir}\" ); do\n957\t            # skip scripts and directories\n958\t            ( [ ! -f \"${src_dir}/${f}\" ] || [[ \"${f}\" == *.sh ]] ) && continue\n959\t            # link files\n960\t            ln -s \"${src_dir}/${f}\" \"${dst_dir}/${f}$( hook_postfix \"${dst_dir}\" \"${f}\" )\"\n961\t        done\n962\t\n963\t        # create the flag file\n964\t        touch \"${flag_file}\"\n965\t\n966\t        return \"0\"\n967\t    }\n968\t\n969\t    # helper to find a hook postfix number\n970\t    hook_postfix() {\n971\t        local dst_dir=\"$1\"\n972\t        local hook_name=\"$2\"\n973\t\n974\t        for i in {1..100}; do\n975\t            if [ ! -f \"${dst_dir}/${hook_name}-${i}\" ]; then\n976\t                echo \"-${i}\"\n977\t                return \"0\"\n978\t            fi\n979\t        done\n980\t\n981\t        >&2 echo \"could not determine hook postfix for ${hook_name} in ${dst_dir}\"\n982\t        return \"31\"\n983\t    }\n984\t\n985\t    # setup columnflow hooks\n986\t    setup_hooks \"${CF_BASE}\" \"${CF_BASE}/bin/githooks\"\n987\t\n988\t    # setup repository hooks\n989\t    if [ ! -z \"${CF_REPO_BASE}\" ] && [ -d \"${CF_REPO_BASE}/bin/githooks\" ]; then\n990\t        setup_hooks \"${CF_REPO_BASE}\" \"${CF_REPO_BASE}/bin/githooks\"\n991\t    fi\n992\t\n993\t    return \"0\"\n994\t}\n995\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_setup_git_hooks\n996\t\n997\tcf_init_submodule() {\n998\t    # Initializes and updates a git submodule.\n999\t    #\n1000\t    # Arguments:\n1001\t    #   1. base_path\n1002\t    #     The path of the base directory relative to which the module_path is evaluated.\n1003\t    #   2. submodule_path\n1004\t    #       The path to the submodule, relative to base_path.\n1005\t\n1006\t    # local variables\n1007\t    local base_path=\"${1}\"\n1008\t    local submodule_path=\"${2}\"\n1009\t\n1010\t    # do nothing in remote jobs\n1011\t    ${CF_REMOTE_ENV} && return \"0\"\n1012\t\n1013\t    # do nothing when the path does not exist or it is not a submodule\n1014\t    if [ ! -e \"${base_path}/${submodule_path}\" ]; then\n1015\t        return \"0\"\n1016\t    fi\n1017\t\n1018\t    # initialize the submodule when the directory is empty\n1019\t    if [ \"$( ls -1q \"${base_path}/${submodule_path}\" | wc -l )\" = \"0\" ]; then\n1020\t        ( cd \"${base_path}\" && git submodule update --init --recursive \"${submodule_path}\" )\n1021\t    else\n1022\t        # update when not on a working branch and there are no changes\n1023\t        local detached_head=\"$( ( cd \"${base_path}/${submodule_path}\"; git symbolic-ref -q HEAD &> /dev/null ) && echo \"true\" || echo \"false\" )\"\n1024\t        local changed_files=\"$( cd \"${base_path}/${submodule_path}\"; git status --porcelain=v1 2> /dev/null | wc -l )\"\n1025\t        if ! ${detached_head} && [ \"${changed_files}\" = \"0\" ]; then\n1026\t            ( cd \"${base_path}\" && git submodule update --init --recursive \"${submodule_path}\" )\n1027\t        fi\n1028\t    fi\n1029\t}\n1030\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_init_submodule\n1031\t\n1032\tcf_cast_bool() {\n1033\t    # lower case\n1034\t    local value=\"$( cf_lower_case \"$1\" )\"\n1035\t    if [ \"${value}\" = \"1\" ] || [ \"${value}\" = \"yes\" ] || [ \"${value}\" = \"true\" ]; then\n1036\t        echo \"true\"\n1037\t    else\n1038\t        echo \"false\"\n1039\t    fi\n1040\t}\n1041\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_cast_bool\n1042\t\n1043\tcf_export_bool() {\n1044\t    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n1045\t    local name=\"$1\"\n1046\t    if ${shell_is_zsh}; then\n1047\t        export \"${name}\"=\"$( cf_cast_bool \"${(P)name}\" )\"\n1048\t    else\n1049\t        export \"${name}\"=\"$( cf_cast_bool \"${!name}\" )\"\n1050\t    fi\n1051\t}\n1052\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_export_bool\n1053\t\n1054\tcf_color() {\n1055\t    # get arguments\n1056\t    local color=\"$1\"\n1057\t    local msg=\"${@:2}\"\n1058\t\n1059\t    # just echo the message as is in certain conditions\n1060\t    if ${CF_REMOTE_ENV} || ${CF_RTD_ENV} || ${CF_CI_ENV}; then\n1061\t        echo \"${msg}\"\n1062\t        return \"0\"\n1063\t    fi\n1064\t\n1065\t    # zsh options\n1066\t    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n1067\t    if ${shell_is_zsh}; then\n1068\t        emulate -L bash\n1069\t        setopt globdots\n1070\t    fi\n1071\t\n1072\t    case \"${color}\" in\n1073\t        default)\n1074\t            echo -e \"\\x1b[0;49;39m${msg}\\x1b[0m\"\n1075\t            ;;\n1076\t        red)\n1077\t            echo -e \"\\x1b[0;49;31m${msg}\\x1b[0m\"\n1078\t            ;;\n1079\t        green)\n1080\t            echo -e \"\\x1b[0;49;32m${msg}\\x1b[0m\"\n1081\t            ;;\n1082\t        yellow)\n1083\t            echo -e \"\\x1b[0;49;33m${msg}\\x1b[0m\"\n1084\t            ;;\n1085\t        blue)\n1086\t            echo -e \"\\x1b[0;49;34m${msg}\\x1b[0m\"\n1087\t            ;;\n1088\t        magenta)\n1089\t            echo -e \"\\x1b[0;49;35m${msg}\\x1b[0m\"\n1090\t            ;;\n1091\t        cyan)\n1092\t            echo -e \"\\x1b[0;49;36m${msg}\\x1b[0m\"\n1093\t            ;;\n1094\t        default_bright)\n1095\t            echo -e \"\\x1b[1;49;39m${msg}\\x1b[0m\"\n1096\t            ;;\n1097\t        red_bright)\n1098\t            echo -e \"\\x1b[1;49;31m${msg}\\x1b[0m\"\n1099\t            ;;\n1100\t        green_bright)\n1101\t            echo -e \"\\x1b[1;49;32m${msg}\\x1b[0m\"\n1102\t            ;;\n1103\t        yellow_bright)\n1104\t            echo -e \"\\x1b[1;49;33m${msg}\\x1b[0m\"\n1105\t            ;;\n1106\t        blue_bright)\n1107\t            echo -e \"\\x1b[1;49;34m${msg}\\x1b[0m\"\n1108\t            ;;\n1109\t        magenta_bright)\n1110\t            echo -e \"\\x1b[1;49;35m${msg}\\x1b[0m\"\n1111\t            ;;\n1112\t        cyan_bright)\n1113\t            echo -e \"\\x1b[1;49;36m${msg}\\x1b[0m\"\n1114\t            ;;\n1115\t        *)\n1116\t            echo \"${msg}\"\n1117\t            ;;\n1118\t    esac\n1119\t}\n1120\t[ ! -z \"${BASH_VERSION}\" ] && export -f cf_color\n1121\t\n1122\tcf_lower_case() {\n1123\t    # cross-shell lower case helper\n1124\t    echo \"$1\" | tr \"[:upper:]\" \"[:lower:]\"\n1125\t}\n1126\t\n1127\tcf_upper_case() {\n1128\t    # cross-shell upper case helper\n1129\t    echo \"$1\" | tr \"[:lower:]\" \"[:upper:]\"\n1130\t}\n1131\t\n1132\tmain() {\n1133\t    # Invokes the main action of this script, catches possible error codes and prints a message.\n1134\t\n1135\t    # run the actual setup\n1136\t    if setup_columnflow \"$@\"; then\n1137\t        cf_color green \"columnflow successfully setup\"\n1138\t        return \"0\"\n1139\t    else\n1140\t        local code=\"$?\"\n1141\t        cf_color red \"columnflow setup failed with code ${code}\"\n1142\t        return \"${code}\"\n1143\t    fi\n1144\t}\n1145\t\n1146\t# always cast expected boolean values\n1147\tfor flag_name in \\\n1148\t        CF_SETUP \\\n1149\t        CF_SKIP_SETUP \\\n1150\t        CF_REMOTE_ENV \\\n1151\t        CF_REINSTALL_SOFTWARE \\\n1152\t        CF_REINSTALL_HOOKS \\\n1153\t        CF_SKIP_BANNER \\\n1154\t        CF_SKIP_SETUP_GIT_HOOKS \\\n1155\t        CF_SKIP_LAW_INDEX \\\n1156\t        CF_SKIP_CHECK_TMP_DIR \\\n1157\t        CF_ON_HTCONDOR \\\n1158\t        CF_ON_SLURM \\\n1159\t        CF_ON_GRID \\\n1160\t        CF_RTD_ENV \\\n1161\t        CF_CI_ENV \\\n1162\t        CF_DEV \\\n1163\t        ; do\n1164\t    cf_export_bool \"${flag_name}\"\n1165\tdone\n1166\t\n1167\t# entry point\n1168\tif ! ${CF_SKIP_SETUP}; then\n1169\t    main \"$@\"\n1170\tfi\n1171\t"}]},"parent_tool_use_id":null,"session_id":"5c9e6616-16e8-4e21-b85a-de06f17f1fa1","uuid":"360cdfef-1f8d-4842-a71e-49e77878980a","timestamp":"2026-04-09T02:59:47.505Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/setup.sh","content":"#!/usr/bin/env bash\n\nsetup_columnflow() {\n    # Runs the entire project setup, leading to a collection of environment variables starting with\n    # \"CF_\", the installation of the software stack via virtual environments, and optionally an\n    # interactive setup where the user can configure certain variables.\n    #\n    # Arguments:\n    #   1. The name of the setup. \"default\" (which is itself the default when no name is set)\n    #      triggers a setup with good defaults, avoiding all queries to the user and the writing of\n    #      a custom setup file. See \"interactive_setup()\" for more info.\n    #\n    # Boolean flags are considered true-ish if they are \"1\", \"yes\" or \"true\" (case-insensitive).\n    #\n    # Optionally preconfigured environment variables:\n    #   CF_REINSTALL_SOFTWARE\n    #       When true-ish, any existing software stack is removed and freshly installed.\n    #   CF_REINSTALL_HOOKS\n    #       When true-ish, existing git hooks are removed and linked again.\n    #   CF_REMOTE_ENV\n    #       When true-ish, applies configurations for remote job. Remote jobs will set this value if needed\n    #       and there is no need to set this by hand.\n    #   CF_LCG_SETUP\n    #       The location of a custom LCG software setup file.\n    #   X509_USER_PROXY\n    #       A custom globus user proxy location.\n    #   LANGUAGE, LANG, LC_ALL\n    #       Custom language flags.\n    #\n    # Variables defined by the setup and potentially required throughout columnflow:\n    #   CF_SETUP_NAME\n    #       The name of the setup. See above.\n    #   CF_BASE\n    #       The absolute columnflow base directory. Used to infer file locations relative to it.\n    #   CF_DATA\n    #       The main data directory where outputs and software can be stored in. Internally, this\n    #       serves as a default for e.g. $CF_SOFTWARE_BASE, $CF_CMSSW_BASE, $CF_JOB_BASE and\n    #       $CF_VENV_BASE which can, however, potentially point to a different directory. Queried\n    #       during the interactive setup.\n    #   CF_SOFTWARE_BASE\n    #       The directory where general software is installed. Might point to $CF_DATA/software.\n    #       Queried during the interactive setup.\n    #   CF_REPO_BASE\n    #       The base path of the main repository invoking tasks or scripts. Used by columnflow tasks\n    #       to identify the repository that is bundled into remote jobs. Set to $CF_BASE when not\n    #       defined already.\n    #   CF_REPO_BASE_ALIAS\n    #       Name of an environment variable whose value is identical to that of CF_REPO_BASE and\n    #      that is usually used by an upstream analysis. For instance, if the analysis base is\n    #      stored in \"$MY_ANALYSIS_BASE\", CF_REPO_BASE_ALIAS should be \"MY_ANALYSIS_BASE\" (no $).\n    #   CF_CONDA_BASE\n    #       The directory where conda / micromamba and conda envs are installed. Might point to\n    #       $CF_SOFTWARE_BASE/conda.\n    #   CF_VENV_BASE\n    #       The directory where virtual envs are installed. Might point to $CF_SOFTWARE_BASE/venvs.\n    #   CF_CMSSW_BASE\n    #       The directory where CMSSW releases are installed. Might point to\n    #       $CF_SOFTWARE_BASE/cmssw.\n    #   CF_JOB_BASE\n    #       The directory where job files from batch system submissions are kept. Used in law.cfg.\n    #       Might point to $CF_DATA/jobs. Queried during the interactive setup.\n    #   CF_VENV_SETUP_MODE\n    #       The default mode for setting up virtual envs. Queried during the interactive setup. See\n    #       sandboxes/_setup_venv.sh for more info.\n    #   CF_STORE_NAME\n    #       The name (not path) of store directories that will be created to contain output targets,\n    #       potentially both locally and remotely. Queried during the interactive setup.\n    #   CF_STORE_LOCAL\n    #       The default local output store path, ammended by $CF_STORE_NAME. Queried during the\n    #       interactive setup.\n    #   CF_CI_ENV\n    #       Set to \"true\" if a CI environment is detected (e.g. GitHub actions), and \"false\"\n    #       otherwise.\n    #   CF_RTD_ENV\n    #       Set to \"true\" if a READTHEDOCS environment is detected, and \"false\" otherwise.\n    #   CF_LCG_SETUP\n    #       The location of a custom LCG software setup file. See above.\n    #   CF_PERSISTENT_PATH\n    #       PATH fragments that should be considered by sandboxes (bash, venv, cmssw) to have\n    #       precedence, e.g. to ensure that executables of local packages are priotized.\n    #   CF_PERSISTENT_PYTHONPATH\n    #       PYTHONPATH fragments that should be considered by sandboxes (bash, venv, cmssw) to have\n    #       precedence, e.g. to ensure that python modules of local packages are priotized.\n    #   CF_CONDA_PYTHONPATH\n    #       PYTHONPATH fragments pointing to packages intalled by conda.\n    #   CF_ORIG_PATH\n    #       Copy of the $PATH variable before ammended by the setup.\n    #   CF_ORIG_PYTHONPATH\n    #       Copy of the $PYTHONPATH variable before ammended by the setup.\n    #   CF_ORIG_PYTHON3PATH\n    #       Copy of the $PYTHON3PATH variable before ammended by the setup.\n    #   CF_ORIG_LD_LIBRARY_PATH\n    #       Copy of the $LD_LIBRARY_PATH variable before ammended by the setup.\n    #   CF_WLCG_CACHE_ROOT\n    #       The directory in which remote files from WLCG locations might be cached. No caching is\n    #       used when empty. Queried during the interactive setup. Used in law.cfg.\n    #   CF_WLCG_USE_CACHE\n    #       Saves the decision on whether WLCG file caching is used or not, based on\n    #       $CF_WLCG_CACHE_ROOT. Set to \"true\" when a remote job environment is detected. Used in\n    #       law.cfg.\n    #   CF_WLCG_CACHE_CLEANUP\n    #       Set to \"false\" when the variable is not already existing. When \"false\", caches are not\n    #       cleared after programs terminate and become persistent. Set to \"true\" when a remove job\n    #       environment is detected. Used in law.cfg.\n    #   CF_CERN_USER\n    #       The user's CERN / WLCG name. Used in law.cfg.\n    #   CF_CERN_USER_FIRSTCHAR\n    #       The first character of the user's CERN / WLCG name. Derived from $CF_CERN_USER. Used in\n    #       law.cfg.\n    #   CF_LOCAL_SCHEDULER\n    #       Either \"true\" or \"false\", deciding whether the process-local luigi scheduler should be\n    #       used by default. Queried during the interactive setup. Used in law.cfg.\n    #   CF_SCHEDULER_HOST\n    #       Set to \"127.0.0.1\" when $CF_LOCAL_SCHEDULER was set to \"true\", or otherwise queried\n    #       during the interactive setup. Used in law.cfg.\n    #   CF_SCHEDULER_PORT\n    #       Set to \"8082\" when $CF_LOCAL_SCHEDULER was set to \"true\", or otherwise queried during\n    #       the interactive setup. Used in law.cfg.\n    #   CF_WORKER_KEEP_ALIVE\n    #       Set to \"false\" when not already set, or when a remote ($CF_REMOTE_ENV) or CI environment\n    #       ($CF_CI_ENV) is detected. Used in law.cfg.\n    #   CF_HTCONDOR_FLAVOR\n    #       The default htcondor flavor setting for the HTCondorWorkflow task.\n    #   CF_SLURM_FLAVOR\n    #       The default slurm flavor setting for the SlurmWorkflow task.\n    #   CF_SLURM_PARTITION\n    #       The default slurm partition setting for the SlurmWorkflow task.\n    #   CF_CRAB_STORAGE_ELEMENT\n    #       The storage element for storing crab job related outputs.\n    #   CF_CRAB_BASE_DIRECTORY\n    #       The base directory where to store crab job related outputs on CF_CRAB_STORAGE_ELEMENT.\n    #   CF_SETUP\n    #       A flag that is set to 1 after the setup was successful.\n    #   PATH\n    #       Ammended PATH variable.\n    #   PYTHONPATH\n    #       Ammended PYTHONPATH variable.\n    #   PYTHONWARNINGS\n    #       Set to \"ignore\" when not defined already.\n    #   PYTHONNOUSERSITE\n    #       Set to \"1\" when not defined alreedy, to prevent python from loading packages from e.g.\n    #       \"$HOME/.local\", which can lead to encapsulation and debugging issues.\n    #   GLOBUS_THREAD_MODEL\n    #       Set to \"none\".\n    #   MYPROXY_SERVER\n    #       Set to \"myproxy.cern.ch\".\n    #   VIRTUAL_ENV_DISABLE_PROMPT\n    #       Set to \"true\" when not defined already, leading to virtual envs leaving the PS1 prompt\n    #       variable unaltered.\n    #   X509_USER_PROXY\n    #       Set to \"/tmp/x509up_u$( id -u )\" if not already set.\n    #   LAW_HOME\n    #       Set to \"$CF_BASE/.law\" if not already set.\n    #   LAW_CONFIG_FILE\n    #       Set to \"$CF_BASE/law.cfg\" if not already set.\n\n    # prevent repeated setups\n    if ${CF_SETUP}; then\n        >&2 echo \"columnflow was already succesfully setup\"\n        >&2 echo \"re-running the setup requires a new shell\"\n        return \"1\"\n    fi\n\n    #\n    # prepare local variables\n    #\n\n    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n    local this_file=\"$( ${shell_is_zsh} && echo \"${(%):-%x}\" || echo \"${BASH_SOURCE[0]}\" )\"\n    local this_dir=\"$( cd \"$( dirname \"${this_file}\" )\" && pwd )\"\n    local orig=\"${PWD}\"\n    local setup_name=\"${1:-default}\"\n    local setup_is_default=\"false\"\n    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n\n    # zsh options\n    if ${shell_is_zsh}; then\n        emulate -L bash\n        setopt globdots\n    fi\n\n    #\n    # global variables\n    # (CF = columnflow)\n    #\n\n    # start exporting variables\n    export CF_BASE=\"${this_dir}\"\n    export CF_SETUP_NAME=\"${setup_name}\"\n\n    # interactive setup\n    if ! ${CF_REMOTE_ENV}; then\n        cf_setup_interactive_body() {\n            # query common variables\n            cf_setup_interactive_common_variables\n        }\n        cf_setup_interactive \"${CF_SETUP_NAME}\" \"${CF_BASE}/.setups/${CF_SETUP_NAME}.sh\" || return \"$?\"\n    fi\n\n    # continue the fixed setup\n    export CF_REPO_BASE=\"${CF_REPO_BASE:-$CF_BASE}\"\n    export CF_REPO_BASE_ALIAS=\"${CF_REPO_BASE_ALIAS:-}\"\n    export CF_CONDA_BASE=\"${CF_CONDA_BASE:-${CF_SOFTWARE_BASE}/conda}\"\n    export CF_VENV_BASE=\"${CF_VENV_BASE:-${CF_SOFTWARE_BASE}/venvs}\"\n    export CF_CMSSW_BASE=\"${CF_CMSSW_BASE:-${CF_SOFTWARE_BASE}/cmssw}\"\n    export CF_ORIG_PATH=\"${PATH}\"\n    export CF_ORIG_PYTHONPATH=\"${PYTHONPATH}\"\n    export CF_ORIG_PYTHON3PATH=\"${PYTHON3PATH}\"\n    export CF_ORIG_LD_LIBRARY_PATH=\"${LD_LIBRARY_PATH}\"\n\n    #\n    # common variables\n    #\n\n    cf_setup_common_variables || return \"$?\"\n\n    #\n    # minimal local software setup\n    #\n\n    cf_setup_software_stack \"${CF_SETUP_NAME}\" || return \"$?\"\n\n    #\n    # additional common cf setup steps\n    #\n\n    cf_setup_post_install || return \"$?\"\n\n    #\n    # finalize\n    #\n\n    export CF_SETUP=\"true\"\n}\n\ncf_detect_envs() {\n    # Uses specific environment variables to detect if the current environment is a special one, e.g. in a remote job,\n    # in a CI job, or in a READTHEDOCS build.\n\n    # detect variables (not using cf_cast_bool since services might use different values)\n    export CF_CI_ENV=\"$( [ \"$( cf_lower_case \"${GITHUB_ACTIONS}\" )\" = \"true\" ] && echo \"true\" || echo \"false\" )\"\n    export CF_RTD_ENV=\"$( [ \"$( cf_lower_case \"${READTHEDOCS}\" )\" = \"true\" ] && echo \"true\" || echo \"false\" )\"\n\n    # store env flags\n    export CF_LOCAL_ENV=\"false\"\n    if ${CF_REMOTE_ENV}; then\n        cf_color yellow \"detected remote job environment\"\n    elif ${CF_CI_ENV}; then\n        cf_color yellow \"detected CI environment\"\n    elif ${CF_RTD_ENV}; then\n        cf_color yellow \"detected READTHEDOCS environment\"\n    else\n        export CF_LOCAL_ENV=\"true\"\n    fi\n}\n[ ! -z \"${BASH_VERSION}\" ] && export -f cf_detect_envs\n\ncf_setup_common_variables() {\n    # Exports variables that might be commonly used across analyses, such as host and job\n    # environment variables (or their defaults).\n\n    # detect environments\n    cf_detect_envs || return \"$?\"\n\n    # lang defaults\n    if ${CF_RTD_ENV}; then\n        export LANGUAGE=\"${READTHEDOCS_LANGUAGE:-en}\"\n        export LANG=\"${READTHEDOCS_LANGUAGE:-en}\"\n        export LC_ALL=\"${READTHEDOCS_LANGUAGE:-en}\"\n    elif ${CF_ON_GRID}; then\n        : # not supported on grid\n    else\n        export LANGUAGE=\"${LANGUAGE:-en_US.UTF-8}\"\n        export LANG=\"${LANG:-en_US.UTF-8}\"\n        export LC_ALL=\"${LC_ALL:-en_US.UTF-8}\"\n    fi\n\n    # proxy\n    export X509_USER_PROXY=\"${X509_USER_PROXY:-/tmp/x509up_u$( id -u )}\"\n\n    # overwrite some variables in remote and ci jobs\n    if ${CF_REMOTE_ENV}; then\n        export CF_WLCG_USE_CACHE=\"true\"\n        export CF_WLCG_CACHE_CLEANUP=\"true\"\n        export CF_WORKER_KEEP_ALIVE=\"false\"\n    elif ${CF_CI_ENV} || ${CF_RTD_ENV}; then\n        export CF_WLCG_USE_CACHE=\"false\"\n        export CF_WLCG_CACHE_CLEANUP=\"false\"\n        export CF_WORKER_KEEP_ALIVE=\"false\"\n    fi\n\n    # luigi worker and scheduler defaults (assigned in law.cfg)\n    export CF_WORKER_KEEP_ALIVE=\"${CF_WORKER_KEEP_ALIVE:-false}\"\n    export CF_SCHEDULER_HOST=\"${CF_SCHEDULER_HOST:-127.0.0.1}\"\n    export CF_SCHEDULER_PORT=\"${CF_SCHEDULER_PORT:-8082}\"\n\n    # default job flavor settings (starting with naf / maxwell cluster defaults)\n    # used by law.cfg and, in turn, tasks/framework/remote.py\n    local cf_htcondor_flavor_default=\"naf\"\n    local cf_slurm_flavor_default=\"maxwell\"\n    local cf_slurm_partition_default=\"maxgpu\"\n    local hname=\"$( hostname 2> /dev/null )\"\n    if [ \"$?\" = \"0\" ]; then\n        # lxplus\n        if [[ \"${hname}\" == lx*.cern.ch ]]; then\n            cf_htcondor_flavor_default=\"cern\"\n        fi\n    fi\n    export CF_HTCONDOR_FLAVOR=\"${CF_HTCONDOR_FLAVOR:-${cf_htcondor_flavor_default}}\"\n    export CF_SLURM_FLAVOR=\"${CF_SLURM_FLAVOR:-${cf_slurm_flavor_default}}\"\n    export CF_SLURM_PARTITION=\"${CF_SLURM_PARTITION:-${cf_slurm_partition_default}}\"\n\n    # show a warning in case no CF_REPO_BASE_ALIAS is set\n    if [ -z \"${CF_REPO_BASE_ALIAS}\" ]; then\n        cf_color yellow \"the variable CF_REPO_BASE_ALIAS is unset\"\n        cf_color yellow \"please consider setting it to the name of the variable that refers to your analysis base directory\"\n    fi\n\n    # notification variables\n    export CF_MATTERMOST_HOOK_URL=\"${CF_MATTERMOST_HOOK_URL:-}\"\n    export CF_MATTERMOST_CHANNEL=\"${CF_MATTERMOST_CHANNEL:-}\"\n}\n\ncf_show_banner() {\n    local no_utf8=\"$( cf_cast_bool \"${1}\" )\"\n    if ! ${no_utf8}; then\n        local charmap=\"$( cf_lower_case \"$( locale charmap )\" )\"\n        no_utf8=\"$( [ \"${charmap}\" = \"utf-8\" ] && echo \"false\" || echo \"true\" )\"\n    fi\n\n    if ${no_utf8}; then\n        cat << EOF\n                $( cf_color green '_' )\n    ___   ___  $( cf_color green '| |' ) _   _  _ __ ___   _ __\n   / __| / _ \\ $( cf_color green '| |' )| | | || '_ \\` _ \\ | '_ \\\\\n  | (__ | (_) |$( cf_color green '| |' )| |_| || | | | | || | | |\n   \\___| \\___/ $( cf_color green '| |' ) \\__,_||_| |_| |_||_| |_|\n            __ $( cf_color green '| |' )\n           / _|$( cf_color green '| |' )  ___ __      __\n          | |_ $( cf_color green '| |' ) / _ \\\\ \\ /\\ / /\n          |  _|$( cf_color green '| |' )| (_) |\\ V  V /\n          |_|  $( cf_color green '| |' ) \\___/  \\_/\\_/\n               $( cf_color green '|_|' )\n\nEOF\n    else\n        cat << EOF\n\n  ┏┏┓$( cf_color green '┃' )╻┏┏┳┓┏┓\n  ┗┗┛$( cf_color green '┃' )┗┛╹┗┗╹┗\n    ┏$( cf_color green '┃' )\n    ╋$( cf_color green '┃' )┏┓┓┏┏\n    ┛$( cf_color green '┃' )┗┛┗┻┛\n\nEOF\n    fi\n}\n\ncf_setup_interactive_common_variables() {\n    # Queries for common variables which should be called from called inside custom\n    # cf_setup_interactive_body funtions, which in turn is called by cf_setup_interactive.\n\n    query CF_CERN_USER \"CERN username\" \"$( whoami )\"\n    export_and_save CF_CERN_USER_FIRSTCHAR \"\\${CF_CERN_USER:0:1}\"\n\n    query CF_DATA \"Local data directory\" \"\\$$( [ -z \"${CF_REPO_BASE}\" ] && echo \"CF_BASE\" || echo \"CF_REPO_BASE\" )/data\" \"./data\"\n    query CF_SOFTWARE_BASE \"Local directory for installing software\" \"\\$CF_DATA/software\"\n    query CF_JOB_BASE \"Local directory for storing job files\" \"\\$CF_DATA/jobs\"\n\n    query CF_STORE_NAME \"Relative path used in store paths (see next queries)\" \"cf_store\"\n    query CF_STORE_LOCAL \"Default local output store\" \"\\$CF_DATA/\\$CF_STORE_NAME\"\n    query CF_WLCG_CACHE_ROOT \"Local directory for caching remote files\" \"\" \"''\"\n    export_and_save CF_WLCG_USE_CACHE \"$( [ -z \"${CF_WLCG_CACHE_ROOT}\" ] && echo \"false\" || echo \"true\" )\"\n    export_and_save CF_WLCG_CACHE_CLEANUP \"${CF_WLCG_CACHE_CLEANUP:-false}\"\n\n    query CF_VENV_SETUP_MODE_UPDATE \"Automatically update virtual envs if needed\" \"false\"\n    [ \"${CF_VENV_SETUP_MODE_UPDATE}\" != \"true\" ] && export_and_save CF_VENV_SETUP_MODE \"update\"\n    unset CF_VENV_SETUP_MODE_UPDATE\n    query CF_INTERACTIVE_VENV_FILE \"Custom venv setup file to use for interactive work instead of 'cf_dev'\" \"\" \"''\"\n\n    query CF_LOCAL_SCHEDULER \"Use a local scheduler for law tasks\" \"true\"\n    if [ \"${CF_LOCAL_SCHEDULER}\" != \"true\" ]; then\n        query CF_SCHEDULER_HOST \"Address of a central scheduler for law tasks\" \"127.0.0.1\"\n        query CF_SCHEDULER_PORT \"Port of a central scheduler for law tasks\" \"8082\"\n    else\n        export_and_save CF_SCHEDULER_HOST \"127.0.0.1\"\n        export_and_save CF_SCHEDULER_PORT \"8082\"\n    fi\n\n    query CF_FLAVOR \"Flavor of the columnflow setup ('', 'cms')\" \"${CF_FLAVOR:-''}\"\n\n    if [ \"${CF_FLAVOR}\" = \"cms\" ]; then\n        query LAW_CMS_VO \"virtual orgranistion\" \"cms\"\n        query CF_CRAB_STORAGE_ELEMENT \"storage element for crab specific job outputs (e.g. T2_DE_DESY)\" \"''\"\n        query CF_CRAB_BASE_DIRECTORY \"base directory on storage element for crab specific job outputs\" \"/store/user/\\$CF_CERN_USER/cf_crab_outputs\"\n    fi\n}\n\ncf_setup_interactive() {\n    # Starts the interactive part of the setup by querying for values of certain environment\n    # variables with useful defaults. When a custom, named setup is triggered, the values of all\n    # queried environment variables are stored in a file.\n    #\n    # The actual variables that should be queried and exported during the setup are to be defined\n    # beforehand a function called \"cf_setup_interactive_body\". This function can make use of the\n    # internal functions \"export_and_save\" and \"query\", defined below.\n    #\n    # Arguments:\n    #   1. The name of the setup. \"default\" triggers a setup with good defaults, avoiding all\n    #      queries to the user and the writing of a custom setup file.\n    #   2. The location of the setup file when a custom, named setup was triggered.\n    #\n    # Optionally preconfigured environment variables:\n    #   CF_SKIP_BANNER\n    #       When true-ish, the \"columnflow\" banner is not shown.\n\n    local setup_name=\"${1}\"\n    local env_file=\"${2}\"\n    local env_file_tmp=\"${env_file}.tmp\"\n    local setup_is_default=\"false\"\n    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n\n    # optionally show the banner\n    ${CF_SKIP_BANNER} || cf_show_banner\n\n    # when the setup already exists and it's not the default one,\n    # source the corresponding env file and stop\n    if ! ${setup_is_default}; then\n        if [ -f \"${env_file}\" ]; then\n            echo \"using variables for setup '$( cf_color magenta ${setup_name} )' from ${env_file}\"\n            source \"${env_file}\" \"\"\n            return \"$?\"\n        elif [ -z \"${env_file}\" ]; then\n            >&2 echo \"no env file passed as 2nd argument to cf_interactive_setup\"\n            return \"1\"\n        else\n            echo \"no setup file ${env_file} found for setup '$( cf_color magenta ${setup_name} )'\"\n        fi\n    fi\n\n    export_and_save() {\n        local varname=\"$1\"\n        local value=\"$2\"\n\n        export $varname=\"$( eval \"echo ${value}\" )\"\n        if ! ${setup_is_default}; then\n            echo \"export ${varname}=\\\"${value}\\\"\" >> \"${env_file_tmp}\"\n        fi\n    }\n\n    query() {\n        local varname=\"$1\"\n        local text=\"$2\"\n        local default=\"$3\"\n        local default_text=\"${4:-${default}}\"\n        local default_lower=\"$( cf_lower_case \"${default}\" )\"\n\n        # when the setup is the default one, use the default value when the env variable is empty,\n        # otherwise, query interactively\n        local value=\"${default}\"\n        if ${setup_is_default}; then\n            # set the variable when existing\n            eval \"value=\\${$varname:-\\${value}}\"\n        else\n            local query_response\n            local query_response_lower\n\n            printf \"${text} ($( cf_color default_bright ${varname} ), default $( cf_color default_bright ${default_text} )):  \"\n            read query_response\n            [ \"X${query_response}\" = \"X\" ] && query_response=\"${default}\"\n\n            # repeat for boolean flags that were not entered correctly\n            while true; do\n                ( [ \"${default_lower}\" != \"true\" ] && [ \"${default_lower}\" != \"false\" ] ) && break\n                query_response_lower=\"$( cf_lower_case \"${query_response}\" )\"\n                if ( [ \"${query_response_lower}\" = \"true\" ] || [ \"${query_response_lower}\" = \"false\" ] ); then\n                    query_response=\"${query_response_lower}\"\n                    break\n                fi\n                printf \"please enter either '$( cf_color default_bright \"true\" )' or '$( cf_color default_bright \"false\" )':  \" query_response\n                read query_response\n                [ \"X${query_response}\" = \"X\" ] && query_response=\"${default}\"\n            done\n            value=\"${query_response}\"\n\n            # strip \" and ' on both sides\n            value=${value%\\\"}\n            value=${value%\\'}\n            value=${value#\\\"}\n            value=${value#\\'}\n        fi\n\n        export_and_save \"${varname}\" \"${value}\"\n    }\n\n    # prepare the tmp env file\n    if ! ${setup_is_default}; then\n        rm -f \"${env_file_tmp}\"\n        mkdir -p \"$( dirname \"${env_file_tmp}\" )\"\n\n        echo -e \"Start querying variables for setup '$( cf_color magenta ${setup_name} )', press enter to accept default values\\n\"\n    fi\n\n    # query for variables\n    cf_setup_interactive_body || return \"$?\"\n\n    # move the env file to the correct location for later use\n    if ! ${setup_is_default}; then\n        mv \"${env_file_tmp}\" \"${env_file}\"\n        echo -e \"\\nvariables written to ${env_file}\"\n    fi\n}\n\ncf_setup_software_stack() {\n    # Sets up the columnflow software stack as a base environment using conda (actually using the\n    # free and faster micromamba interface), lightweight virtual environments on top and git\n    # submodule initialization / updates.\n    #\n    # Arguments:\n    #   1. setup_name\n    #       The name of the setup.\n    #\n    # Required environment variables:\n    #   CF_BASE\n    #       The columnflow base directory.\n    #   CF_CONDA_BASE\n    #       The directory where conda / micromamba and conda envs will be installed.\n    #   CF_VENV_BASE\n    #       The base directory were virtual envs are installed.\n    #\n    # Optional environments variables:\n    #   CF_REMOTE_ENV\n    #       When true-ish, the software stack is sourced but not built.\n    #   CF_LOCAL_ENV\n    #       When not true-ish, the context is not meant for local development and only the \"cf_dev\" venv is built.\n    #       CF_INTERACTIVE_VENV_FILE is ignored in this case.\n    #   CF_INTERACTIVE_VENV_FILE\n    #       IF CF_LOCAL_ENV is true-ish, the venv setup of this file is sourced to start the interactive shell. When\n    #       empty, defaults to ${CF_BASE}/sandboxes/cf_dev.sh.\n    #   CF_REINSTALL_SOFTWARE\n    #       When true-ish, any existing software stack is removed and freshly installed.\n    #   CF_CONDA_ARCH\n    #       The OS / architecture for the conda installation. Defaults to \"linux-64\". For more info:\n    #       https://mamba.readthedocs.io/en/latest/installation/micromamba-installation.html#linux-and-macos\n\n    # check global variables\n    if [ -z \"${CF_BASE}\" ]; then\n        >&2 echo \"CF_BASE not defined, stopping software setup\"\n        return \"1\"\n    fi\n    if [ -z \"${CF_CONDA_BASE}\" ]; then\n        >&2 echo \"CF_CONDA_BASE not defined, stopping software setup\"\n        return \"2\"\n    fi\n    if [ -z \"${CF_VENV_BASE}\" ]; then\n        >&2 echo \"CF_VENV_BASE not defined, stopping software setup\"\n        return \"3\"\n    fi\n\n    # local variables\n    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n    local setup_name=\"${1}\"\n    local setup_is_default=\"false\"\n    [ \"${setup_name}\" = \"default\" ] && setup_is_default=\"true\"\n    local pyv=\"${CF_PYTHON_VERSION:-3.9}\"\n    local conda_arch=\"${CF_CONDA_ARCH:-linux-64}\"\n    local ret\n\n    # zsh options\n    if ${shell_is_zsh}; then\n        emulate -L bash\n        setopt globdots\n    fi\n\n    # empty the PYTHONPATH, except for specific customizable paths\n    export PYTHONPATH=\"${CF_INITIAL_PYTHONPATH:-}\"\n\n    # persistent PATH and PYTHONPATH parts that should be\n    # priotized over any additions made in sandboxes\n    export CF_PERSISTENT_PATH=\"${CF_BASE}/bin:${CF_BASE}/modules/law/bin\"\n    export CF_PERSISTENT_PYTHONPATH=\"${CF_BASE}:${CF_BASE}/bin:${CF_BASE}/modules/law:${CF_BASE}/modules/order\"\n\n    # flavor specific paths\n    if [ ! -z \"${CF_FLAVOR}\" ]; then\n        [ -d \"${CF_BASE}/bin/${CF_FLAVOR}\" ] && export CF_PERSISTENT_PATH=\"${CF_PERSISTENT_PATH}:${CF_BASE}/bin/${CF_FLAVOR}\"\n    fi\n\n    # prepend them\n    export PATH=\"${CF_PERSISTENT_PATH}:${PATH}\"\n    export PYTHONPATH=\"${CF_PERSISTENT_PYTHONPATH}:${PYTHONPATH}\"\n\n    # also add the python path of the venv to be installed to propagate changes to any outer venv\n    export CF_CONDA_PYTHONPATH=\"${CF_CONDA_BASE}/lib/python${pyv}/site-packages\"\n    export PYTHONPATH=\"${PYTHONPATH}:${CF_CONDA_PYTHONPATH}\"\n\n    # update paths and flags\n    export MAMBA_ROOT_PREFIX=\"${CF_CONDA_BASE}\"\n    export MAMBA_EXE=\"${MAMBA_ROOT_PREFIX}/bin/micromamba\"\n    export PYTHONWARNINGS=\"${PYTHONWARNINGS:-ignore}\"\n    export PYTHONNOUSERSITE=\"${PYTHONNOUSERSITE:-1}\"\n    export GLOBUS_THREAD_MODEL=\"${GLOBUS_THREAD_MODEL:-none}\"\n    export VIRTUAL_ENV_DISABLE_PROMPT=\"${VIRTUAL_ENV_DISABLE_PROMPT:-1}\"\n    export MYPROXY_SERVER=\"${MYPROXY_SERVER:-myproxy.cern.ch}\"\n    export X509_CERT_DIR=\"${X509_CERT_DIR:-/cvmfs/grid.cern.ch/etc/grid-security/certificates}\"\n    export X509_VOMS_DIR=\"${X509_VOMS_DIR:-/cvmfs/grid.cern.ch/etc/grid-security/vomsdir}\"\n    export X509_VOMSES=\"${X509_VOMSES:-/cvmfs/grid.cern.ch/etc/grid-security/vomses}\"\n    export VOMS_USERCONF=\"${VOMS_USERCONF:-${X509_VOMSES}}\"\n    ulimit -s unlimited\n\n    #\n    # setup in local envs (not remote)\n    #\n\n    if ! ${CF_REMOTE_ENV}; then\n        # remote directories first if requested\n        if ${CF_REINSTALL_SOFTWARE}; then\n            echo \"removing conda setup at $( cf_color magenta ${CF_CONDA_BASE})\"\n            rm -rf \"${CF_CONDA_BASE}\"\n\n            echo \"removing software virtual envs at $( cf_color magenta ${CF_VENV_BASE})\"\n            rm -rf \"${CF_VENV_BASE}\"\n        fi\n\n        #\n        # conda / micromamba setup\n        #\n\n        # only needed in local envs\n        if ${CF_LOCAL_ENV}; then\n            # base environment\n            local conda_missing=\"$( [ -d \"${CF_CONDA_BASE}\" ] && echo \"false\" || echo \"true\" )\"\n            if ${conda_missing}; then\n                echo\n                cf_color magenta \"installing conda with micromamba interface at ${CF_CONDA_BASE}\"\n\n                mkdir -p \"${CF_CONDA_BASE}/etc/profile.d\"\n                curl -Ls \"https://micro.mamba.pm/api/micromamba/${conda_arch}/latest\" | tar -xvj -C \"${CF_CONDA_BASE}\" \"bin/micromamba\" > /dev/null\n                2>&1 \"${CF_CONDA_BASE}/bin/micromamba\" shell hook -y --root-prefix \"$PWD\" &> micromamba.sh\n                ret=\"$?\"\n                if [ \"${ret}\" != \"0\" ]; then\n                    [ -f \"micromamba.sh\" ] && >&2 cat micromamba.sh\n                    return \"${ret}\"\n                fi\n                # make the setup file relocatable\n                sed -i -r \"s|${CF_CONDA_BASE}|\\$\\{MAMBA_ROOT_PREFIX\\}|\" \"micromamba.sh\" || return \"$?\"\n                mv \"micromamba.sh\" \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\"\n                cat << EOF > \"${CF_CONDA_BASE}/.mambarc\"\nchangeps1: false\nalways_yes: true\nchannels:\n  - conda-forge\nEOF\n            fi\n\n            # initialize micromamba\n            source \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\" \"\" || return \"$?\"\n            micromamba activate || return \"$?\"\n            echo \"initialized conda with $( cf_color magenta \"micromamba\" ) interface and $( cf_color magenta \"python ${pyv}\" )\"\n\n            # install packages\n            if ${conda_missing}; then\n                echo\n                cf_color cyan \"setting up conda / micromamba environment\"\n                micromamba install \\\n                    gcc \\\n                    libgcc \\\n                    bash \\\n                    zsh \\\n                    \"python=${pyv}\" \\\n                    git \\\n                    git-lfs \\\n                    gfal2 \\\n                    gfal2-util \\\n                    python-gfal2 \\\n                    myproxy \\\n                    conda-pack \\\n                    || return \"$?\"\n                micromamba clean --yes --all\n\n                # add a file to conda/activate.d that handles the gfal setup transparently with conda-pack\n                cat << EOF > \"${CF_CONDA_BASE}/etc/conda/activate.d/gfal_activate.sh\"\nexport GFAL_CONFIG_DIR=\"\\${CONDA_PREFIX}/etc/gfal2.d\"\nexport GFAL_PLUGIN_DIR=\"\\${CONDA_PREFIX}/lib/gfal2-plugins\"\nexport X509_CERT_DIR=\"${X509_CERT_DIR}\"\nexport X509_VOMS_DIR=\"${X509_VOMS_DIR}\"\nexport X509_VOMSES=\"${X509_VOMSES}\"\nexport VOMS_USERCONF=\"${VOMS_USERCONF}\"\nEOF\n                echo\n            fi\n        fi\n\n        #\n        # venv setup\n        #\n\n        # - \"cf\"     : contains the minimal stack to run tasks and is sent alongside jobs\n        # - \"cf_dev\" : \"cf\" + additional python tools for local development (e.g. ipython)\n        # - custom   : when CF_INTERACTIVE_VENV_FILE is set, source the venv setup from there\n\n        source_venv() {\n            # all parameters must be given\n            local venv_file=\"$1\"\n            local venv_name=\"$2\"\n            # must be true or false\n            local use_subshell=\"$3\"\n\n            # source the file and catch the return code\n            local ret=\"0\"\n            if ${use_subshell}; then\n                ( source \"${venv_file}\" \"\" \"silent\" )\n                ret=\"$?\"\n            else\n                source \"${venv_file}\" \"\" \"silent\"\n                ret=\"$?\"\n            fi\n\n            # code 21 means \"version outdated\", all others are as usual\n            if [ \"${ret}\" = \"21\" ]; then\n                >&2 echo\n                >&2 echo \"WARNING: your venv '${venv_name}' is not up to date, please consider updating it in a new shell with\"\n                >&2 echo \"WARNING: > CF_REINSTALL_SOFTWARE=1 source setup.sh $( ${setup_is_default} || echo \"${setup_name}\" )\"\n                >&2 echo\n            elif [ \"${ret}\" != \"0\" ]; then\n                return \"${ret}\"\n            fi\n\n            return \"0\"\n        }\n\n        # build the production sandbox in a subshell, only in local envs\n        if ${CF_LOCAL_ENV}; then\n            source_venv \"${CF_BASE}/sandboxes/cf.sh\" \"cf\" true || return \"$?\"\n        fi\n\n        # check if a custom interactive venv should be used, check the file, but only in local envs\n        local use_custom_interactive_venv=\"false\"\n        if ${CF_LOCAL_ENV} && [ ! -z \"${CF_INTERACTIVE_VENV_FILE}\" ]; then\n            # check existence\n            if [ ! -f \"${CF_INTERACTIVE_VENV_FILE}\" ]; then\n                >&2 echo \"the interactive venv setup file ${CF_INTERACTIVE_VENV_FILE} does not exist\"\n                return \"2\"\n            fi\n            use_custom_interactive_venv=\"true\"\n        fi\n\n        # build the dev sandbox, using a subshell if a custom venv is given that should be sourced afterwards\n        source_venv \"${CF_BASE}/sandboxes/cf_dev.sh\" \"cf_dev\" \"${use_custom_interactive_venv}\" || return \"$?\"\n\n        # source the custom interactive venv setup file if given\n        if ${use_custom_interactive_venv}; then\n            echo \"activating custom interactive venv from $( cf_color magenta \"${CF_INTERACTIVE_VENV_FILE}\" )\"\n            source_venv \"${CF_INTERACTIVE_VENV_FILE}\" \"$( basename \"${CF_INTERACTIVE_VENV_FILE%.*}\" )\" false || return \"$?\"\n        fi\n\n        # initialze submodules\n        if [ -e \"${CF_BASE}/.git\" ]; then\n            local m\n            for m in $( ls -1q \"${CF_BASE}/modules\" ); do\n                cf_init_submodule \"${CF_BASE}\" \"modules/${m}\"\n            done\n        fi\n    fi\n\n    #\n    # setup in remote jobs\n    #\n\n    if ${CF_REMOTE_ENV}; then\n        # initialize conda\n        source \"${CF_CONDA_BASE}/etc/profile.d/micromamba.sh\" \"\" || return \"$?\"\n        micromamba activate || return \"$?\"\n        echo \"initialized conda with $( cf_color magenta \"micromamba\" ) interface and $( cf_color magenta \"python ${pyv}\" )\"\n\n        # source the production sandbox\n        source \"${CF_BASE}/sandboxes/cf.sh\" \"\" \"no\"\n    fi\n}\n\ncf_setup_post_install() {\n    # Performs additional, central setup steps after variables are set and software is installed. These steps are meant\n    # to be common to all setups and that can be adjusted later on through updates of the columnflow module.\n    #\n    # Current steps:\n    #   - setup git hooks\n    #   - setup law\n    #   - check size of the target tmp dir\n    #\n    # Required environment variables:\n    #   CF_LOCAL_ENV\n    #       Should be true or false, indicating if the setup is run in a local environment.\n    #   CF_REPO_BASE\n    #       The base directory of the analysis repository, which is used to determine the law home and config file.\n    #\n    # Optional environment variables:\n    #   CF_SKIP_SETUP_GIT_HOOKS\n    #       When set to true, the setup of git hooks is skipped.\n    #   CF_SKIP_LAW_INDEX\n    #       When set to true, the initial indexing of law tasks is skipped.\n    #   CF_SKIP_CHECK_TMP_DIR\n    #       When set to true, the check of the size of the target tmp directory is skipped.\n\n    #\n    # git hooks\n    #\n\n    # only in local env\n    if ! ${CF_SKIP_SETUP_GIT_HOOKS} && ${CF_LOCAL_ENV}; then\n        cf_setup_git_hooks || return \"$?\"\n    fi\n\n    #\n    # law setup\n    #\n\n    if [ ! -z \"${CF_REPO_BASE}\" ]; then\n        export LAW_HOME=\"${LAW_HOME:-${CF_REPO_BASE}/.law}\"\n        export LAW_CONFIG_FILE=\"${LAW_CONFIG_FILE:-${CF_REPO_BASE}/law.cfg}\"\n\n        if ${CF_LOCAL_ENV} && which law &> /dev/null; then\n            # source law's bash completion scipt\n            source \"$( law completion )\" \"\"\n\n            # add completion to the claw command\n            complete -o bashdefault -o default -F _law_complete claw\n\n            # silently index\n            if ! ${CF_SKIP_LAW_INDEX}; then\n                law index -q\n            fi\n        fi\n    fi\n\n    #\n    # check the tmp directory size\n    #\n\n    if ! ${CF_SKIP_CHECK_TMP_DIR} && ${CF_LOCAL_ENV} && which law &> /dev/null; then\n        cf_check_tmp_dir\n    fi\n\n    return \"0\"\n}\n\ncf_check_tmp_dir() {\n    # Computes the size of all user-owned files in the target tmp directory and issues a warning when the size exceeds\n    # certain thresholds. If a variable CF_SKIP_TMP_CHECK is set to true, the check is skipped.\n\n    # check if skipping\n    if [ ! -z \"${CF_SKIP_TMP_CHECK}\" ] && ${CF_SKIP_TMP_CHECK}; then\n        return \"0\"\n    fi\n\n    # determine the tmp directory\n    local tmp_dir=\"$( law config target.tmp_dir )\"\n    local ret=\"$?\"\n    if [ \"${ret}\" != \"0\" ]; then\n        >&2 cf_color \"red\" \"cf_check_tmp_dir: 'law config target.tmp_dir' failed with error code ${ret}\"\n        return \"${ret}\"\n    elif [ -z \"${tmp_dir}\" ]; then\n        >&2 cf_color \"red\" \"cf_check_tmp_dir: 'law config target.tmp_dir' must not be empty\"\n        return \"2\"\n    elif [ ! -d \"${tmp_dir}\" ]; then\n        # nothing to do\n        return \"0\"\n    fi\n\n    # compute the size, with a notification shown if it takes too long\n    ( sleep 5 && cf_color yellow \"computing the size of your files in ${tmp_dir} ...\" ) &\n    local msg_pid=\"$!\"\n    local tmp_size=\"$( find \"${tmp_dir}\" -maxdepth 1 -user \"$( id -u )\" -exec du -cb {} + | grep 'total$' | cut -d $'\\t' -f 1 | sort | head -n 1 )\"\n    kill \"${msg_pid}\" 2> /dev/null\n    wait \"${msg_pid}\" 2> /dev/null\n\n    # warn above 1GB with color changing when above 2GB\n    local thresh1=\"1073741824\"\n    local thresh2=\"2147483648\"\n    if [ \"${tmp_size}\" -gt \"${thresh1}\" ]; then\n        local hsize=\"$( python -c \"import law; print(law.util.human_bytes(${tmp_size}, fmt=True))\" )\"\n        local color=\"$( [ \"${tmp_size}\" -lt \"${thresh2}\" ] && echo \"yellow\" || echo \"red\" )\"\n        echo\n        cf_color \"${color}\" \"the combined size of your files in the directory ${tmp_dir} is $( cf_color \"${color}_bright\" \"${hsize}\" )\"\n        cf_color \"${color}\" \"please consider cleaning up using $( cf_color \"${color}_bright\" \"'cf_remove_tmp [all]'\" )\"\n        echo\n    fi\n\n    return \"0\"\n}\n\ncf_setup_git_hooks() {\n    # Initializes lfs and custom githooks in the local checkout for both the columnflow\n    # (sub)repository, as well as the analysis repository in case a directory bin/githooks is found.\n    #\n    # Required environments variables:\n    #   CF_REMOTE_ENV (bool)\n    #       When true, no hooks are setup.\n    #   CF_CI_ENV (bool)\n    #       When true, no hooks are setup.\n\n    # do nothing when not local\n    if ${CF_REMOTE_ENV} || ${CF_CI_ENV}; then\n        return \"0\"\n    fi\n\n    # helper to setup hooks\n    setup_hooks() {\n        local repo_dir=\"$1\"\n        local src_dir=\"$2\"\n        local f\n\n        # determine the target hooks directory\n        local dst_dir=\"$( cd \"${repo_dir}\" && echo \"$( git rev-parse --git-dir )/hooks\" )\"\n        if [ \"$?\" != \"0\" ] || [ ! -d \"${dst_dir}\" ]; then\n            >&2 echo \"no git hooks directory found, cannot setup hooks\"\n            return \"30\"\n        fi\n\n        # remove existing hooks if requested\n        local flag_file=\"${dst_dir}/.cf_hooks_setup\"\n        if ${CF_REINSTALL_HOOKS}; then\n            # remove hooks\n            for f in $( ls -1 \"${dst_dir}\" ); do\n                [ -f \"${dst_dir}/${f}\" ] && [[ \"${f}\" != *.sample ]] && rm -f \"${dst_dir}/${f}\"\n            done\n            # remove the flag file\n            rm -f \"${flag_file}\"\n        fi\n\n        # do nothing if hooks are already setup up\n        [ -f \"${flag_file}\" ] && return \"0\"\n\n        # detect if lfs hooks are already installed, as identified by the pre-push\n        local lfs_installed=\"false\"\n        for f in $( ls -1 \"${dst_dir}\"/{pre-push,pre-push-*} 2> /dev/null || true ); do\n            if [ -f \"${f}\" ] && [ ! -z \"$( cat \"${f}\" | grep \"git lfs pre-push\" )\" ]; then\n                lfs_installed=\"true\"\n                break\n            fi\n        done\n\n        # setup lfs if not done yet\n        if ! ${lfs_installed}; then\n            ( cd \"${repo_dir}\" && git lfs install > /dev/null ) || return \"$?\"\n        fi\n\n        # move all existing hooks and replace them with combined scripts\n        for f in $( ls -1 \"${dst_dir}\" ); do\n            # skip samples and directories\n            ( [ ! -f \"${dst_dir}/${f}\" ] || [[ \"${f}\" == *.sample ]] ) && continue\n            # move the file and create the new one\n            mv \"${dst_dir}/${f}\" \"${dst_dir}/${f}$( hook_postfix \"${dst_dir}\" \"${f}\" )\"\n            cp \"${CF_BASE}/bin/githooks/combined_hook.sh\" \"${dst_dir}/${f}\"\n        done\n\n        # setup all hooks in bin/githooks\n        for f in $( ls -1 \"${src_dir}\" ); do\n            # skip scripts and directories\n            ( [ ! -f \"${src_dir}/${f}\" ] || [[ \"${f}\" == *.sh ]] ) && continue\n            # link files\n            ln -s \"${src_dir}/${f}\" \"${dst_dir}/${f}$( hook_postfix \"${dst_dir}\" \"${f}\" )\"\n        done\n\n        # create the flag file\n        touch \"${flag_file}\"\n\n        return \"0\"\n    }\n\n    # helper to find a hook postfix number\n    hook_postfix() {\n        local dst_dir=\"$1\"\n        local hook_name=\"$2\"\n\n        for i in {1..100}; do\n            if [ ! -f \"${dst_dir}/${hook_name}-${i}\" ]; then\n                echo \"-${i}\"\n                return \"0\"\n            fi\n        done\n\n        >&2 echo \"could not determine hook postfix for ${hook_name} in ${dst_dir}\"\n        return \"31\"\n    }\n\n    # setup columnflow hooks\n    setup_hooks \"${CF_BASE}\" \"${CF_BASE}/bin/githooks\"\n\n    # setup repository hooks\n    if [ ! -z \"${CF_REPO_BASE}\" ] && [ -d \"${CF_REPO_BASE}/bin/githooks\" ]; then\n        setup_hooks \"${CF_REPO_BASE}\" \"${CF_REPO_BASE}/bin/githooks\"\n    fi\n\n    return \"0\"\n}\n[ ! -z \"${BASH_VERSION}\" ] && export -f cf_setup_git_hooks\n\ncf_init_submodule() {\n    # Initializes and updates a git submodule.\n    #\n    # Arguments:\n    #   1. base_path\n    #     The path of the base directory relative to which the module_path is evaluated.\n    #   2. submodule_path\n    #       The path to the submodule, relative to base_path.\n\n    # local variables\n    local base_path=\"${1}\"\n    local submodule_path=\"${2}\"\n\n    # do nothing in remote jobs\n    ${CF_REMOTE_ENV} && return \"0\"\n\n    # do nothing when the path does not exist or it is not a submodule\n    if [ ! -e \"${base_path}/${submodule_path}\" ]; then\n        return \"0\"\n    fi\n\n    # initialize the submodule when the directory is empty\n    if [ \"$( ls -1q \"${base_path}/${submodule_path}\" | wc -l )\" = \"0\" ]; then\n        ( cd \"${base_path}\" && git submodule update --init --recursive \"${submodule_path}\" )\n    else\n        # update when not on a working branch and there are no changes\n        local detached_head=\"$( ( cd \"${base_path}/${submodule_path}\"; git symbolic-ref -q HEAD &> /dev/null ) && echo \"true\" || echo \"false\" )\"\n        local changed_files=\"$( cd \"${base_path}/${submodule_path}\"; git status --porcelain=v1 2> /dev/null | wc -l )\"\n        if ! ${detached_head} && [ \"${changed_files}\" = \"0\" ]; then\n            ( cd \"${base_path}\" && git submodule update --init --recursive \"${submodule_path}\" )\n        fi\n    fi\n}\n[ ! -z \"${BASH_VERSION}\" ] && export -f cf_init_submodule\n\ncf_cast_bool() {\n    # lower case\n    local value=\"$( cf_lower_case \"$1\" )\"\n    if [ \"${value}\" = \"1\" ] || [ \"${value}\" = \"yes\" ] || [ \"${value}\" = \"true\" ]; then\n        echo \"true\"\n    else\n        echo \"false\"\n    fi\n}\n[ ! -z \"${BASH_VERSION}\" ] && export -f cf_cast_bool\n\ncf_export_bool() {\n    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n    local name=\"$1\"\n    if ${shell_is_zsh}; then\n        export \"${name}\"=\"$( cf_cast_bool \"${(P)name}\" )\"\n    else\n        export \"${name}\"=\"$( cf_cast_bool \"${!name}\" )\"\n    fi\n}\n[ ! -z \"${BASH_VERSION}\" ] && export -f cf_export_bool\n\ncf_color() {\n    # get arguments\n    local color=\"$1\"\n    local msg=\"${@:2}\"\n\n    # just echo the message as is in certain conditions\n    if ${CF_REMOTE_ENV} || ${CF_RTD_ENV} || ${CF_CI_ENV}; then\n        echo \"${msg}\"\n        return \"0\"\n    fi\n\n    # zsh options\n    local shell_is_zsh=\"$( [ -z \"${ZSH_VERSION}\" ] && echo \"false\" || echo \"true\" )\"\n    if ${shell_is_zsh}; then\n        emulate -L bash\n        setopt globdots\n    fi\n\n    case \"${color}\" in\n        default)\n            echo -e \"\\x1b[0;49;39m${msg}\\x1b[0m\"\n            ;;\n        red)\n            echo -e \"\\x1b[0;49;31m${msg}\\x1b[0m\"\n            ;;\n        green)\n            echo -e \"\\x1b[0;49;32m${msg}\\x1b[0m\"\n            ;;\n        yellow)\n            echo -e \"\\x1b[0;49;33m${msg}\\x1b[0m\"\n            ;;\n        blue)\n            echo -e \"\\x1b[0;49;34m${msg}\\x1b[0m\"\n            ;;\n        magenta)\n            echo -e \"\\x1b[0;49;35m${msg}\\x1b[0m\"\n            ;;\n        cyan)\n            echo -e \"\\x1b[0;49;36m${msg}\\x1b[0m\"\n            ;;\n        default_bright)\n            echo -e \"\\x1b[1;49;39m${msg}\\x1b[0m\"\n            ;;\n        red_bright)\n            echo -e \"\\x1b[1;49;31m${msg}\\x1b[0m\"\n            ;;\n        green_bright)\n            echo -e \"\\x1b[1;49;32m${msg}\\x1b[0m\"\n            ;;\n        yellow_bright)\n            echo -e \"\\x1b[1;49;33m${msg}\\x1b[0m\"\n            ;;\n        blue_bright)\n            echo -e \"\\x1b[1;49;34m${msg}\\x1b[0m\"\n            ;;\n        magenta_bright)\n            echo -e \"\\x1b[1;49;35m${msg}\\x1b[0m\"\n            ;;\n