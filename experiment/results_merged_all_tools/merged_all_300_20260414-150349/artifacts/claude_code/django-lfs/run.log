            \"title\" : self.title,\n            \"text\" : self.text\n        })\n\n    def form(self, **kwargs):\n        \"\"\"\n        \"\"\"\n        return TextPortletForm(instance=self, **kwargs)\n\nclass TextPortletForm(forms.ModelForm):\n    \"\"\"Form for the TextPortlet.\n    \"\"\"\n    class Meta:\n        model = TextPortlet"}}
