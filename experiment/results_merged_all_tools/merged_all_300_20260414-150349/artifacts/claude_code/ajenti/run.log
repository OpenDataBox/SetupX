{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_a07718ecd30340b68c540020","type":"tool_result","content":"1\t#! /usr/bin/env python3\n2\timport getopt\n3\timport logging\n4\timport os\n5\timport sys\n6\timport yaml\n7\timport socket\n8\t\n9\t\n10\timport aj\n11\timport aj.config\n12\timport aj.entry\n13\timport aj.log\n14\timport aj.plugins\n15\t\n16\t\n17\t# Is the ajenti virtualenv installed ?\n18\tpanel_venv = '/opt/ajenti/bin/ajenti-panel'\n19\tif os.path.isfile(panel_venv) and os.path.abspath(__file__) != panel_venv:\n20\t    logging.info('Ajenti virtualenv detected, switching to it.')\n21\t    try:\n22\t        os.execv(panel_venv, sys.argv)\n23\t    except Exception:\n24\t        logging.error('Unable to start ajenti virtualenv, continuing with global python.')\n25\t\n26\tclass AjentiConfig(aj.config.BaseConfig):\n27\t    def __init__(self, path):\n28\t        aj.config.BaseConfig.__init__(self)\n29\t        self.data = None\n30\t        self.path = os.path.abspath(path)\n31\t\n32\t    def __str__(self):\n33\t        return self.path\n34\t\n35\t    def load(self):\n36\t        if os.geteuid() == 0:\n37\t            os.chmod(self.path, 384)  # 0o600\n38\t        self.data = yaml.load(open(self.path), Loader=yaml.Loader)\n39\t\n40\t    def save(self):\n41\t        with open(self.path, 'w') as f:\n42\t            f.write(yaml.safe_dump(self.data, default_flow_style=False, encoding='utf-8', allow_unicode=True).decode('utf-8'))\n43\t\n44\t\n45\tdef usage():\n46\t    print(f\"\"\"\n47\tUsage: {sys.argv[0]} [options]\n48\tOptions:\n49\t    -c, --config <file> - Use given config file instead of default\n50\t    -v                  - Debug/verbose logging ( shortcut for --log debug )\n51\t    --dev               - Dev mode (recompile resources)\n52\t    -d, --daemon        - Run in background (daemon mode)\n53\t    --stock-plugins     - Load plugins from PYTHONPATH\n54\t    --plugins <dir>     - Load plugins from a directory\n55\t    --autologin         - Log in automatically as the running user\n56\t    --log '<level>'     - Fix log level : debug, info, warning or error\n57\t    -h, --help          - This help\n58\t    \"\"\")\n59\t\n60\t\n61\tif __name__ == '__main__':\n62\t    log_levels = {\"debug\": logging.DEBUG, \"info\": logging.INFO, \"warning\": logging.WARNING, \"error\": logging.ERROR}\n63\t    log_level = logging.INFO\n64\t    daemonize = False\n65\t    dev_mode = False\n66\t    debug_mode = False\n67\t    config_path = None\n68\t    autologin = False\n69\t    plugin_providers = []\n70\t\n71\t    try:\n72\t        opts, args = getopt.getopt(\n73\t            sys.argv[1:],\n74\t            'hc:dv',\n75\t            ['help', 'config=', 'daemon', 'dev', 'stock-plugins', 'plugins=', 'autologin', 'log=']\n76\t        )\n77\t    except getopt.GetoptError as e:\n78\t        print(str(e))\n79\t        usage()\n80\t        sys.exit(2)\n81\t\n82\t    for o, a in opts:\n83\t        if o in ('-h', '--help'):\n84\t            usage()\n85\t            sys.exit(0)\n86\t        elif o in ('-v',):\n87\t            log_level = logging.DEBUG\n88\t            debug_mode = True\n89\t        elif o in ('--dev',):\n90\t            log_level = logging.DEBUG\n91\t            debug_mode = True\n92\t            dev_mode = True\n93\t        elif o in ('--log',):\n94\t            log_level = log_levels[a]\n95\t        elif o in ('-c', '--config'):\n96\t            config_path = a\n97\t        elif o in ('-d', '--start'):\n98\t            daemonize = True\n99\t        elif o in ('--autologin',):\n100\t            autologin = True\n101\t        elif o == '--stock-plugins':\n102\t            plugin_providers.append(aj.plugins.PythonPathPluginProvider())\n103\t        elif o == '--plugins':\n104\t            plugin_providers.append(aj.plugins.DirectoryPluginProvider(a))\n105\t\n106\t    if not plugin_providers:\n107\t        plugin_providers.append(aj.plugins.PythonPathPluginProvider())\n108\t\n109\t    aj.log.init_console(log_level)\n110\t\n111\t    if autologin and not debug_mode:\n112\t        logging.error('Autologin is a dangerous option and should be used together with -v')\n113\t        sys.exit(1)\n114\t\n115\t    users_file = '/etc/ajenti/users.yml'\n116\t    smtp_file = '/etc/ajenti/smtp.yml'\n117\t\n118\t    if not os.path.exists('/etc/ajenti'):\n119\t        os.makedirs('/etc/ajenti')\n120\t\n121\t    if not os.path.exists(users_file):\n122\t        with open(users_file, 'w') as u:\n123\t            u.write(\"users: null\")\n124\t\n125\t    if not os.path.exists(smtp_file):\n126\t        with open(smtp_file, 'w') as u:\n127\t            u.write(\"\"\"smtp:\n128\t  password: ''\n129\t  port: starttls\n130\t  server: ''\n131\t  user: ''\n132\t\"\"\")\n133\t\n134\t    # Find default config file\n135\t    if not config_path:\n136\t        # Check for config file in /etc/ajenti/config.yml\n137\t        if os.path.isfile('/etc/ajenti/config.yml'):\n138\t            config_path = '/etc/ajenti/config.yml'\n139\t        elif os.path.isfile(os.path.join(sys.path[0], 'config.yml')):\n140\t            # Try local config file\n141\t            config_path = os.path.join(sys.path[0], 'config.yml')\n142\t\n143\t    if not os.path.exists(config_path):\n144\t        logging.warning(f'No config file found, creating a new one /etc/ajenti/config.yml')\n145\t\n146\t        with open(config_path, 'w') as c:\n147\t            c.write(f'''\n148\tauth:\n149\t  allow_sudo: true\n150\t  emails: {{}}\n151\t  provider: os\n152\t  users_file: {users_file}\n153\tbind:\n154\t  host: 0.0.0.0\n155\t  mode: tcp\n156\t  port: 8000\n157\tcolor: default\n158\tmax_sessions: 9\n159\ttrusted_domains: []\n160\ttrusted_proxies: []\n161\tsession_max_time: 3600\n162\tname: {socket.gethostname()}\n163\tssl:\n164\t  certificate:\n165\t  fqdn_certificate:\n166\t  force: false\n167\t  client_auth:\n168\t    certificates: []\n169\t    enable: false\n170\t    force: false\n171\t  enable: false\n172\t        ''')\n173\t\n174\t    aj.entry.start(\n175\t        config=AjentiConfig(config_path),\n176\t        dev_mode=dev_mode,\n177\t        debug_mode=debug_mode,\n178\t        autologin=autologin,\n179\t        product_name='ajenti',\n180\t        daemonize=daemonize,\n181\t        plugin_providers=plugin_providers,\n182\t        log_level=log_level,\n183\t    )\n184\t"}]},"parent_tool_use_id":null,"session_id":"d5f05358-9f10-4a0b-9283-5878122c41c0","uuid":"06682977-98f2-4a44-954c-76a7d8ed82c2","timestamp":"2026-04-08T20:24:03.772Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/ajenti-panel/ajenti-panel","content":"#! /usr/bin/env python3\nimport getopt\nimport logging\nimport os\nimport sys\nimport yaml\nimport socket\n\n\nimport aj\nimport aj.config\nimport aj.entry\nimport aj.log\nimport aj.plugins\n\n\n# Is the ajenti virtualenv installed ?\npanel_venv = '/opt/ajenti/bin/ajenti-panel'\nif os.path.isfile(panel_venv) and os.path.abspath(__file__) != panel_venv:\n    logging.info('Ajenti virtualenv detected, switching to it.')\n    try:\n        os.execv(panel_venv, sys.argv)\n    except Exception:\n        logging.error('Unable to start ajenti virtualenv, continuing with global python.')\n\nclass AjentiConfig(aj.config.BaseConfig):\n    def __init__(self, path):\n        aj.config.BaseConfig.__init__(self)\n        self.data = None\n        self.path = os.path.abspath(path)\n\n    def __str__(self):\n        return self.path\n\n    def load(self):\n        if os.geteuid() == 0:\n            os.chmod(self.path, 384)  # 0o600\n        self.data = yaml.load(open(self.path), Loader=yaml.Loader)\n\n    def save(self):\n        with open(self.path, 'w') as f:\n            f.write(yaml.safe_dump(self.data, default_flow_style=False, encoding='utf-8', allow_unicode=True).decode('utf-8'))\n\n\ndef usage():\n    print(f\"\"\"\nUsage: {sys.argv[0]} [options]\nOptions:\n    -c, --config <file> - Use given config file instead of default\n    -v                  - Debug/verbose logging ( shortcut for --log debug )\n    --dev               - Dev mode (recompile resources)\n    -d, --daemon        - Run in background (daemon mode)\n    --stock-plugins     - Load plugins from PYTHONPATH\n    --plugins <dir>     - Load plugins from a directory\n    --autologin         - Log in automatically as the running user\n    --log '<level>'     - Fix log level : debug, info, warning or error\n    -h, --help          - This help\n    \"\"\")\n\n\nif __name__ == '__main__':\n    log_levels = {\"debug\": logging.DEBUG, \"info\": logging.INFO, \"warning\": logging.WARNING, \"error\": logging.ERROR}\n    log_level = logging.INFO\n    daemonize = False\n    dev_mode = False\n    debug_mode = False\n    config_path = None\n    autologin = False\n    plugin_providers = []\n\n    try:\n        opts, args = getopt.getopt(\n            sys.argv[1:],\n            'hc:dv',\n            ['help', 'config=', 'daemon', 'dev', 'stock-plugins', 'plugins=', 'autologin', 'log=']\n        )\n    except getopt.GetoptError as e:\n        print(str(e))\n        usage()\n        sys.exit(2)\n\n    for o, a in opts:\n        if o in ('-h', '--help'):\n            usage()\n            sys.exit(0)\n        elif o in ('-v',):\n            log_level = logging.DEBUG\n            debug_mode = True\n        elif o in ('--dev',):\n            log_level = logging.DEBUG\n            debug_mode = True\n            dev_mode = True\n        elif o in ('--log',):\n            log_level = log_levels[a]\n        elif o in ('-c', '--config'):\n            config_path = a\n        elif o in ('-d', '--start'):\n            daemonize = True\n        elif o in ('--autologin',):\n            autologin = True\n        elif o == '--stock-plugins':\n            plugin_providers.append(aj.plugins.PythonPathPluginProvider())\n        elif o == '--plugins':\n            plugin_providers.append(aj.plugins.DirectoryPluginProvider(a))\n\n    if not plugin_providers:\n        plugin_providers.append(aj.plugins.PythonPathPluginProvider())\n\n    aj.log.init_console(log_level)\n\n    if autologin and not debug_mode:\n        logging.error('Autologin is a dangerous option and should be used together with -v')\n        sys.exit(1)\n\n    users_file = '/etc/ajenti/users.yml'\n    smtp_file = '/etc/ajenti/smtp.yml'\n\n    if not os.path.exists('/etc/ajenti'):\n        os.makedirs('/etc/ajenti')\n\n    if not os.path.exists(users_file):\n        with open(users_file, 'w') as u:\n            u.write(\"users: null\")\n\n    if not os.path.exists(smtp_file):\n        with open(smtp_file, 'w') as u:\n            u.write(\"\"\"smtp:\n  password: ''\n  port: starttls\n  server: ''\n  user: ''\n\"\"\")\n\n    # Find default config file\n    if not config_path:\n        # Check for config file in /etc/ajenti/config.yml\n        if os.path.isfile('/etc/ajenti/config.yml'):\n            config_path = '/etc/ajenti/config.yml'\n        elif os.path.isfile(os.path.join(sys.path[0], 'config.yml')):\n            # Try local config file\n            config_path = os.path.join(sys.path[0], 'config.yml')\n\n    if not os.path.exists(config_path):\n        logging.warning(f'No config file found, creating a new one /etc/ajenti/config.yml')\n\n        with open(config_path, 'w') as c:\n            c.write(f'''\nauth:\n  allow_sudo: true\n  emails: {{}}\n  provider: os\n  users_file: {users_file}\nbind:\n  host: 0.0.0.0\n  mode: tcp\n  port: 8000\ncolor: default\nmax_sessions: 9\ntrusted_domains: []\ntrusted_proxies: []\nsession_max_time: 3600\nname: {socket.gethostname()}\nssl:\n  certificate:\n  fqdn_certificate:\n  force: false\n  client_auth:\n    certificates: []\n    enable: false\n    force: false\n  enable: false\n        ''')\n\n    aj.entry.start(\n        config=AjentiConfig(config_path),\n        dev_mode=dev_mode,\n        debug_mode=debug_mode,\n        autologin=autologin,\n        product_name='ajenti',\n        daemonize=daemonize,\n        plugin_providers=plugin_providers,\n        log_level=log_level,\n    )\n","numLines":184,"startLine":1,"totalLines":184}}}
