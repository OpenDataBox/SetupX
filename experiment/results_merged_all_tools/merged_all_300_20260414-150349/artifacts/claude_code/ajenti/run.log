{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_cde26c8556ff40cea98dbdfc","type":"tool_result","content":"1\timport importlib.util\n2\timport logging\n3\timport os\n4\timport subprocess\n5\timport sys\n6\timport traceback\n7\timport yaml\n8\tfrom jadi import service\n9\t\n10\timport aj\n11\tfrom aj.util import public\n12\t\n13\t\n14\t@public\n15\tclass PluginProvider():\n16\t    \"\"\"\n17\t    A base class for plugin locator\n18\t    \"\"\"\n19\t\n20\t    def provide(self):\n21\t        \"\"\"\n22\t        Should return a list of found plugin paths\n23\t\n24\t        :returns: list(str)\n25\t        \"\"\"\n26\t        raise NotImplementedError()\n27\t\n28\t\n29\t@public\n30\tclass DirectoryPluginProvider(PluginProvider):\n31\t    \"\"\"\n32\t    A plugin provider that looks up plugins in a given directory.\n33\t\n34\t    :param path: directory to look for plugins in\n35\t    \"\"\"\n36\t\n37\t    def __init__(self, path):\n38\t        self.path = os.path.abspath(path)\n39\t\n40\t    def provide(self):\n41\t        found_plugins = []\n42\t        if os.path.exists(os.path.join(self.path, 'plugin.yml')):\n43\t            found_plugins.append(self.path)\n44\t\n45\t        for _dir in os.listdir(self.path):\n46\t            path = os.path.join(self.path, _dir)\n47\t            if os.path.isdir(path):\n48\t                if os.path.exists(os.path.join(path, 'plugin.yml')):\n49\t                    found_plugins.append(path)\n50\t\n51\t        return found_plugins\n52\t\n53\t\n54\t@public\n55\tclass PythonPathPluginProvider(PluginProvider):\n56\t    \"\"\"\n57\t    A plugin provider that looks up plugins on ``$PYTHONPATH``\n58\t    \"\"\"\n59\t\n60\t    def __init__(self):\n61\t        pass\n62\t\n63\t    def provide(self):\n64\t        found_plugins = []\n65\t        for path in sys.path:\n66\t            if os.path.isdir(path):\n67\t                logging.debug(f'Looking for plugins in {path}')\n68\t                found_plugins += DirectoryPluginProvider(path).provide()\n69\t        return found_plugins\n70\t\n71\t\n72\t@public\n73\tclass PluginLoadError(Exception):\n74\t    pass\n75\t\n76\t\n77\t@public\n78\tclass PluginCrashed(PluginLoadError):\n79\t    def __init__(self, exception):\n80\t        PluginLoadError.__init__(self)\n81\t        self.exception = exception\n82\t        self.traceback = traceback.format_exc()\n83\t\n84\t    def describe(self):\n85\t        return f'Crashed: {repr(self.exception)}'\n86\t\n87\t    def __str__(self):\n88\t        return f'crashed: {repr(self.exception)}'\n89\t\n90\t\n91\t@public\n92\tclass Dependency(yaml.YAMLObject):\n93\t    yaml_loader = yaml.SafeLoader\n94\t    yaml_tag = u'!Dependency'\n95\t\n96\t    class Unsatisfied(PluginLoadError):\n97\t        def __init__(self):\n98\t            PluginLoadError.__init__(self, None)\n99\t            self.dependency = None\n100\t"}]},"parent_tool_use_id":null,"session_id":"d5f05358-9f10-4a0b-9283-5878122c41c0","uuid":"4b548f7c-0a8e-40b9-98dd-8b3355ca370a","timestamp":"2026-04-08T20:30:07.976Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/ajenti-core/aj/plugins.py","content":"import importlib.util\nimport logging\nimport os\nimport subprocess\nimport sys\nimport traceback\nimport yaml\nfrom jadi import service\n\nimport aj\nfrom aj.util import public\n\n\n@public\nclass PluginProvider():\n    \"\"\"\n    A base class for plugin locator\n    \"\"\"\n\n    def provide(self):\n        \"\"\"\n        Should return a list of found plugin paths\n\n        :returns: list(str)\n        \"\"\"\n        raise NotImplementedError()\n\n\n@public\nclass DirectoryPluginProvider(PluginProvider):\n    \"\"\"\n    A plugin provider that looks up plugins in a given directory.\n\n    :param path: directory to look for plugins in\n    \"\"\"\n\n    def __init__(self, path):\n        self.path = os.path.abspath(path)\n\n    def provide(self):\n        found_plugins = []\n        if os.path.exists(os.path.join(self.path, 'plugin.yml')):\n            found_plugins.append(self.path)\n\n        for _dir in os.listdir(self.path):\n            path = os.path.join(self.path, _dir)\n            if os.path.isdir(path):\n                if os.path.exists(os.path.join(path, 'plugin.yml')):\n                    found_plugins.append(path)\n\n        return found_plugins\n\n\n@public\nclass PythonPathPluginProvider(PluginProvider):\n    \"\"\"\n    A plugin provider that looks up plugins on ``$PYTHONPATH``\n    \"\"\"\n\n    def __init__(self):\n        pass\n\n    def provide(self):\n        found_plugins = []\n        for path in sys.path:\n            if os.path.isdir(path):\n                logging.debug(f'Looking for plugins in {path}')\n                found_plugins += DirectoryPluginProvider(path).provide()\n        return found_plugins\n\n\n@public\nclass PluginLoadError(Exception):\n    pass\n\n\n@public\nclass PluginCrashed(PluginLoadError):\n    def __init__(self, exception):\n        PluginLoadError.__init__(self)\n        self.exception = exception\n        self.traceback = traceback.format_exc()\n\n    def describe(self):\n        return f'Crashed: {repr(self.exception)}'\n\n    def __str__(self):\n        return f'crashed: {repr(self.exception)}'\n\n\n@public\nclass Dependency(yaml.YAMLObject):\n    yaml_loader = yaml.SafeLoader\n    yaml_tag = u'!Dependency'\n\n    class Unsatisfied(PluginLoadError):\n        def __init__(self):\n            PluginLoadError.__init__(self, None)\n            self.dependency = None\n","numLines":100,"startLine":1,"totalLines":377}}}
