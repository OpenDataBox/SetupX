 in [fs_init, fs_views, fs_plugin_yml]:\n        if not os.path.exists(f):\n            print(f\"    FAIL: Missing {f}\")\n            sys.exit(1)\n    \n    # Check plugin.yml content\n    import yaml\n    with open(fs_plugin_yml) as fp:\n        plugin_data = yaml.safe_load(fp)\n        print(f\"    PASS: Filesystem plugin.yml valid (name={plugin_data.get('name', 'unknown')})\")\nexcept Exception as e:\n    print(f\"    FAIL: {e}\")\n    sys.exit(1)\n\n# Test 4: Check ajenti-panel script exists and is executable\nprint(\"\\n[4] Testing ajenti-panel script...\")\ntry:\n    panel_script = '/workspace/ajenti-panel/ajenti-panel'\n    if not os.path.exists(panel_script):\n        print(f\"    FAIL: {panel_script} not found\")\n        sys.exit(1)\n    print(f\"    PASS: ajenti-panel script exists\")\nexcept Exception as e:\n    print(f\"    FAIL: {e}\")\n    sys.exit(1)\n\n# Test 5: Check required dependencies\nprint(\"\\n[5] Testing required dependencies...\")\ndeps_ok = True\nrequired_deps = [\n    ('gevent', 'gevent'),\n    ('jinja2', 'jinja2'),\n    ('requests', 'requests'),\n    ('socketio', 'python-socketio'),\n    ('psutil', 'psutil'),\n    ('cryptography', 'cryptography'),\n    ('passlib', 'passlib'),\n]\nfor mod_name, pkg_name in required_deps:\n    try:\n        mod = __import__(mod_name.replace('-', '_'))\n        print(f\"    OK: {pkg_name}\")\n    except ImportError as e:\n        print(f\"    MISSING: {pkg_name}\")\n        deps_ok = False\n\nif deps_ok:\n    print(\"    PASS: All required dependencies available\")\nelse:\n    print(\"    FAIL: Some dependencies missing\")\n    sys.exit(1)\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"VERIFICATION SUMMARY\")\nprint(\"=\" * 60)\nprint(\"Core modules: OK\")\nprint(\"Plugin discovery: OK\")\nprint(\"Dependencies: OK\")\nprint(\"\\nNote: Full runtime test requires /etc/ajenti directory (needs root)\")\nprint(\"To run full test: sudo mkdir -p /etc/ajenti && ajenti-panel --plugins plugins -v\")\nprint(\"=\" * 60)\nENDSCRIPT\n\nexport PATH=\"/home/node/.local/bin:$PATH\" && python3 /tmp/ajenti-verify.py","description":"Run fixed verification script"},"id":"toolu_833fdafcf8604558b8f74ef9","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"d5f05358-9f10-4a0b-9283-5878122c41c0","uuid":"58877114-d03d-44ac-b998-fd6b01e2c6dc"}
