{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_a5b19564578949f4a0e29278","type":"tool_result","content":"1\timport inspect\n2\timport locale\n3\timport shutil\n4\timport types\n5\timport warnings\n6\tfrom copy import deepcopy\n7\tfrom pathlib import Path\n8\t\n9\timport matplotlib as mpl\n10\timport matplotlib.pyplot as plt\n11\tfrom matplotlib.testing.compare import compare_images\n12\t\n13\tfrom plotnine import ggplot, theme\n14\tfrom plotnine.composition import Beside, Compose, Stack, plot_annotation\n15\tfrom plotnine.themes.theme import DEFAULT_RCPARAMS\n16\t\n17\tTOLERANCE = 2  # Default tolerance for the tests\n18\tDPI = 72  # Default DPI for the tests\n19\t\n20\t# To get uniform test images, we use fonts that ship with matplotlib\n21\tDEFAULT_RCPARAMS[\"font.monospace\"] = [\"Dejavu Sans Mono\"]\n22\tDEFAULT_RCPARAMS[\"font.sans-serif\"] = [\"Dejavu Sans\"]\n23\tDEFAULT_RCPARAMS[\"font.serif\"] = [\"Dejavu Serif\"]\n24\t\n25\t# This partial theme modifies all themes that are used in\n26\t# the test. It is limited to setting the size of the test\n27\t# images Should a test require a larger or smaller figure\n28\t# size, the dpi or aspect_ratio should be modified.\n29\ttest_theme = theme(figure_size=(640 / DPI, 480 / DPI), dpi=DPI)\n30\t\n31\ttests_dir = Path(__file__).parent\n32\tbaseline_images_dir = tests_dir / \"baseline_images\"\n33\tresult_images_dir = tests_dir / \"result_images\"\n34\t\n35\tif not baseline_images_dir.exists():\n36\t    raise OSError(\n37\t        \"The baseline image directory does not exist. \"\n38\t        \"This is most likely because the test data is not installed. \"\n39\t        \"You may need to install plotnine from source to get the \"\n40\t        \"test data.\"\n41\t    )\n42\t\n43\t\n44\tdef raise_no_baseline_image(filename: str):\n45\t    raise Exception(f\"Baseline image {filename} is missing\")\n46\t\n47\t\n48\tdef ggplot_equals(plot: ggplot, name: str) -> bool:\n49\t    \"\"\"\n50\t    Compare ggplot object to image determined by `right`\n51\t\n52\t    Parameters\n53\t    ----------\n54\t    plot :\n55\t        ggplot object\n56\t    name :\n57\t        Identifier for the test image\n58\t\n59\t    This function is meant to monkey patch ggplot.__eq__\n60\t    so that tests can use the `assert` statement.\n61\t    \"\"\"\n62\t    test_file = inspect.stack()[1][1]\n63\t    filenames = make_test_image_filenames(name, test_file)\n64\t    # Save the figure before testing whether the original image\n65\t    # actually exists. This makes creating new tests much easier,\n66\t    # as the result image can afterwards just be copied.\n67\t    plot += test_theme\n68\t    with _test_cleanup():\n69\t        plot.save(filenames.result, verbose=False)\n70\t\n71\t    if filenames.baseline.exists():\n72\t        shutil.copyfile(filenames.baseline, filenames.expected)\n73\t    else:\n74\t        # Putting the exception in short function makes for\n75\t        #  short pytest error messages\n76\t        raise_no_baseline_image(filenames.baseline)\n77\t\n78\t    err = compare_images(\n79\t        filenames.expected, filenames.result, TOLERANCE, in_decorator=True\n80\t    )\n81\t    plot._err = err  # For the pytest error message\n82\t    return not err\n83\t\n84\t\n85\tggplot.__eq__ = ggplot_equals\n86\t\n87\t\n88\tdef draw_test(self):\n89\t    \"\"\"\n90\t    Try drawing the ggplot object\n91\t\n92\t    Parameters\n93\t    ----------\n94\t    self : ggplot\n95\t        ggplot object\n96\t\n97\t    This function is meant to monkey patch ggplot.draw_test\n98\t    so that tests can draw and not care about cleaning up\n99\t    the MPL figure.\n100\t    \"\"\"\n101\t    with _test_cleanup():\n102\t        self.draw()\n103\t\n104\t\n105\tggplot.draw_test = draw_test\n106\t\n107\t\n108\tdef build_test(self):\n109\t    \"\"\"\n110\t    Try building the ggplot object\n111\t\n112\t    Parameters\n113\t    ----------\n114\t    self : ggplot\n115\t        ggplot object\n116\t\n117\t    This function is meant to monkey patch ggplot.build_test\n118\t    so that tests can build a plot and inspect the side effects\n119\t    on the plot object.\n120\t    \"\"\"\n121\t    self = deepcopy(self)\n122\t    self._build()\n123\t    return self\n124\t\n125\t\n126\tggplot.build_test = build_test\n127\t\n128\t\n129\tdef pytest_assertrepr_compare(op, left, right):\n130\t    if (\n131\t        isinstance(left, (ggplot, Compose))\n132\t        and isinstance(right, str)\n133\t        and op == \"==\"\n134\t    ):\n135\t        msg = (\n136\t            \"images not close: {actual:s} vs. {expected:s} \"\n137\t            \"(RMS {rms:.2f})\".format(**left._err)\n138\t        )\n139\t        return [msg]\n140\t\n141\t\n142\tdef make_test_image_filenames(name, test_file):\n143\t    \"\"\"\n144\t    Create filenames for testing\n145\t\n146\t    Parameters\n147\t    ----------\n148\t    name : str\n149\t        An identifier for the specific test. This will make-up\n150\t        part of the filenames.\n151\t    test_file : str\n152\t        Full path of the test file. This will determine the\n153\t        directory structure\n154\t\n155\t    Returns\n156\t    -------\n157\t    out : types.SimpleNamespace\n158\t        Object with 3 attributes to store the generated filenames\n159\t\n160\t            - result\n161\t            - baseline\n162\t            - expected\n163\t\n164\t        `result`, is the filename for the image generated by the test.\n165\t        `baseline`, is the filename for the baseline image to which\n166\t        the result will be compared.\n167\t        `expected`, is the filename to the copy of the baseline that\n168\t        will be stored in the same directory as the result image.\n169\t        Creating a copy make comparison easier.\n170\t    \"\"\"\n171\t    name = Path(name).with_suffix(\".png\")\n172\t    expected_name = f\"{name.stem}-expected{name.suffix}\"\n173\t    subdir = Path(test_file).stem\n174\t    filenames = types.SimpleNamespace(\n175\t        baseline=baseline_images_dir / subdir / name,\n176\t        result=result_images_dir / subdir / name,\n177\t        expected=result_images_dir / subdir / expected_name,\n178\t    )\n179\t    filenames.result.parent.mkdir(parents=True, exist_ok=True)\n180\t    return filenames\n181\t\n182\t\n183\tclass _test_cleanup:\n184\t    def __enter__(self):\n185\t        # The baseline images are created in this locale, so we should use\n186\t        # it during all of the tests.\n187\t        try:\n188\t            locale.setlocale(locale.LC_ALL, \"en_US.UTF-8\")\n189\t        except locale.Error:\n190\t            try:\n191\t                locale.setlocale(locale.LC_ALL, \"English_United States.1252\")\n192\t            except locale.Error:\n193\t                warnings.warn(\n194\t                    \"Could not set locale to English/United States. \"\n195\t                    \"Some date-related tests may fail\"\n196\t                )\n197\t\n198\t        # make sure we don't carry over bad plots from former tests\n199\t        plt.close(\"all\")\n200\t        n_figs = len(plt.get_fignums())\n201\t        msg = (\n202\t            f\"No. of open figs: {n_figs}. Make sure the \"\n203\t            \"figures from the previous tests are cleaned up.\"\n204\t        )\n205\t        assert n_figs == 0, msg\n206\t\n207\t        mpl.use(\"Agg\")\n208\t        # These settings *must* be hardcoded for running the comparison\n209\t        # tests\n210\t        mpl.rcdefaults()  # Start with all defaults\n211\t        mpl.rcParams[\"text.hinting\"] = \"auto\"\n212\t        mpl.rcParams[\"text.antialiased\"] = True\n213\t        mpl.rcParams[\"text.hinting_factor\"] = 8\n214\t        return self\n215\t\n216\t    def __exit__(self, exc_type, exc_value, exc_traceback):\n217\t        plt.close(\"all\")\n218\t        warnings.resetwarnings()\n219\t\n220\t\n221\tdef composition_equals(cmp: Compose, name: str) -> bool:\n222\t    \"\"\"\n223\t    Compare plot composition to 