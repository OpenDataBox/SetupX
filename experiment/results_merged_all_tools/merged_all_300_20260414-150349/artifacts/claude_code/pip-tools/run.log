version < '3.11'\",\n46\t  # indirect dependencies\n47\t  \"setuptools\", # typically needed when pip-tools invokes setup.py\n48\t  \"wheel\", # pip plugin needed by pip-tools\n49\t\n50\t]\n51\t\n52\t[project.urls]\n53\thomepage = \"https://github.com/jazzband/pip-tools/\"\n54\tdocumentation = \"https://pip-tools.readthedocs.io/en/latest/\"\n55\trepository = \"https://github.com/jazzband/pip-tools\"\n56\tchangelog = \"https://github.com/jazzband/pip-tools/releases\"\n57\t\n58\t[project.optional-dependencies]\n59\ttesting = [\n60\t  \"pytest >= 7.2.0\",\n61\t  \"pytest-rerunfailures\",\n62\t  \"pytest-xdist\",\n63\t  \"tomli-w\",\n64\t  # build deps for tests\n65\t  \"flit_core >=2,<4\",\n66\t  \"poetry_core>=1.0.0\",\n67\t]\n68\tcoverage = [\"covdefaults\", \"pytest-cov\"]\n69\t\n70\t[project.scripts]\n71\tpip-compile = \"piptools.scripts.compile:cli\"\n72\tpip-sync = \"piptools.scripts.sync:cli\"\n73\t\n74\t[tool.isort]\n75\tprofile = \"black\"\n76\t# explicitly mark 'build' as a third-party package\n77\t# otherwise, in some executions, `isort` can mistake `piptools.build` for\n78\t# `build` and treat it as a first-party module name\n79\tknown_third_party = [\"build\"]\n80\tadd_imports = \"from __future__ import annotations\"\n81\t\n82\t[tool.mypy]\n83\tdisallow_untyped_defs = true\n84\tdisallow_any_generics = true\n85\tdisallow_incomplete_defs = true\n86\tdisallow_subclassing_any = true\n87\tdisallow_untyped_calls = true\n88\tdisallow_untyped_decorators = true\n89\tignore_missing_imports = true\n90\tno_implicit_optional = true\n91\tno_implicit_reexport = true\n92\tstrict_equality = true\n93\twarn_redundant_casts = true\n94\twarn_return_any = true\n95\twarn_unused_configs = true\n96\twarn_unused_ignores = true\n97\t# Avoid error: Duplicate module named 'setup'\n98\t# https://github.com/python/mypy/issues/4008\n99\texclude = \"^tests/test_data/\"\n100\t\n101\t[[tool.mypy.overrides]]\n102\tmodule = [\"tests.*\"]\n103\tdisallow_untyped_defs = false\n104\tdisallow_inco