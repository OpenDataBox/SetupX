{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_b3d27ed3364d45338e4c174c","type":"tool_result","content":"1\t[tox]\n2\tenvlist =\n3\t    # NOTE: keep this in sync with the env list in .github/workflows/ci.yml.\n4\t    py{39,310,311,312,313,314,314t,py3}-pip{supported,lowest,latest,main}-coverage\n5\t    pip{supported,lowest,latest,main}-coverage\n6\t    pip{supported,lowest,latest,main}\n7\t    checkqa\n8\t    readme\n9\tskip_missing_interpreters = True\n10\t\n11\t[python-cli-options]\n12\tbyte-warnings = -b\n13\tbyte-errors = -bb\n14\tmax-isolation = -E -s -I\n15\t# some-isolation = -I\n16\t# FIXME: Python 2 shim. Is this equivalent to the above?\n17\tsome-isolation = -E -s\n18\twarnings-to-errors = -Werror\n19\t\n20\t\n21\t[testenv]\n22\tdescription = run the tests with pytest\n23\textras =\n24\t    testing\n25\t    coverage: coverage\n26\tdeps =\n27\t    pipsupported: pip == 26.0\n28\t    pipsupported: setuptools <= 80.0\n29\t\n30\t    piplowest: pip == 22.2.* ; python_version < \"3.12\"\n31\t    piplowest: pip == 23.2.* ; python_version >= \"3.12\" and python_version < \"3.14\"\n32\t    piplowest: pip == 25.2.* ; python_version >= \"3.14\"\n33\t\n34\t    piplatest: pip\n35\t    pipmain: https://github.com/pypa/pip/archive/main.zip\n36\tsetenv =\n37\t    coverage: PYTEST_ADDOPTS=--strict-markers --doctest-modules --cov --cov-report=term-missing --cov-report=xml {env:PYTEST_ADDOPTS:}\n38\tcommands_pre =\n39\t    piplatest: python -m pip install -U pip\n40\t    pip --version\n41\tcommands = pytest {posargs}\n42\tpassenv =\n43\t    CI\n44\t    FORCE_COLOR\n45\t    GITHUB_ACTIONS\n46\t    MYPY_FORCE_COLOR\n47\t    PRE_COMMIT_COLOR\n48\t    PY_COLORS\n49\tpip_pre=True\n50\t\n51\t[testenv:checkqa]\n52\tdescription = format the code base and check its quality\n53\tskip_install = True\n54\tdeps = pre-commit\n55\tcommands_pre =\n56\tcommands = pre-commit run --all-files --show-diff-on-failure\n57\t\n58\t[testenv:readme]\n59\tdescription = check whether the long description will render correctly on PyPI\n60\tdeps =\n61\t    build\n62\t    twine\n63\tcommands_pre =\n64\tcommands =\n65\t    python -m build --outdir {envtmpdir} --sdist {toxinidir}\n66\t    twine check --strict {envtmpdir}{/}*\n67\tskip_install = true\n68\t\n69\t[testenv:pip-compile-docs]\n70\tdescription = compile requirements for the documentation\n71\tcommands_pre =\n72\t# compile requirements.in + pyproject.toml to get pip-tools install requirements in\n73\t# addition to doc tooling requirements *but without* putting `pip-tools` itself\n74\t# into the output\n75\tcommands =\n76\t  python -m piptools compile \\\n77\t    --strip-extras \\\n78\t    --allow-unsafe \\\n79\t    --quiet \\\n80\t    docs/requirements.in \\\n81\t    './pyproject.toml' \\\n82\t    -o docs/requirements.txt \\\n83\t    {posargs}\n84\t\n85\t[testenv:build-docs]\n86\tdescription = build the documentation\n87\tdeps =\n88\t  -r{toxinidir}/docs/requirements.txt\n89\t  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n90\t  # Ref: https://github.com/pypa/pip/issues/9243\n91\t  # -r{toxinidir}/docs/requirements.in\n92\t  # -c{toxinidir}/docs/requirements.txt\n93\tcommands_pre =\n94\t  # Retrieve possibly missing commits:\n95\t  -git fetch --unshallow\n96\t  -git fetch --tags\n97\tcommands =\n98\t  # Build the html docs with Sphinx:\n99\t  {envpython} -m sphinx \\\n100\t    -j auto \\\n101\t    -b html \\\n102\t    {tty:--color} \\\n103\t    -a \\\n104\t    -n -W --keep-going \\\n105\t    -d \"{temp_dir}/.doctrees\" \\\n106\t    . \\\n107\t    {posargs:{envdir}/docs_out}\n108\t# Print out the output docs dir and a way to serve html after the build\n109\tcommands_post =\n110\t  {envpython} -c \\\n111\t    'import pathlib;\\\n112\t    docs_dir = pathlib.Path(r\"{envdir}\") / \"docs_out\";\\\n113\t    index_file = docs_dir / \"index.html\";\\\n114\t    print(\"\\n\" + \"=\" * 120 +\\\n115\t    f\"\\n\\nDocumentation available under:\\n\\n\\\n116\t    \\tfile://\\{index_file\\}\\n\\nTo serve docs, use\\n\\n\\\n117\t    \\t$ python3 -m http.server --directory \\\n118\t    \\N\\{QUOTATION MARK\\}\\{docs_dir\\}\\N\\{QUOTATION MARK\\} 0\\n\\n\" +\\\n119\t    \"=\" * 120)'\n120\tchangedir = {toxinidir}/docs\n121\tisolated_build = true\n122\tpassenv =\n123\t  READTHEDOCS\n124\t  READTHEDOCS_VERSION_TYPE\n125\t  SSH_AUTH_SOCK\n126\tskip_install = false\n127\tallowlist_externals =\n128\t  git\n129\t\n130\t\n131\t[testenv:preview-docs]\n132\tdescription = preview the docs\n133\tdeps =\n134\t  sphinx-autobuild\n135\t  {[testenv:build-docs]deps}\n136\tcommands_pre =\n137\tcommands =\n138\t  # Retrieve possibly missing commits:\n139\t  -git fetch --unshallow\n140\t  -git fetch --tags\n141\t\n142\t  # Build the html docs with sphinx-autobuild:\n143\t  {envpython} -m sphinx_autobuild \\\n144\t    -j auto \\\n145\t    -b html \\\n146\t    -n \\\n147\t    -W \\\n148\t    -d \"{temp_dir}/.doctrees\" \\\n149\t    . \\\n150\t    --watch ../README.md \\\n151\t    --watch ../CHANGELOG.md \\\n152\t    \"{envdir}/docs_out\"\n153\t\n154\tchangedir = {[testenv:build-docs]changedir}\n155\tisolated_build = {[testenv:build-docs]isolated_build}\n156\tpassenv = {[testenv:build-docs]passenv}\n157\tskip_install = {[testenv:build-docs]skip_install}\n158\tallowlist_externals = {[testenv:build-docs]allowlist_externals}\n159\t\n160\t\n161\t[testenv:linkcheck-docs]\n162\tdescription = check links in the documentation\n163\tdeps =\n164\t  -r{toxinidir}/docs/requirements.txt\n165\t  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n166\t  # Ref: https://github.com/pypa/pip/issues/9243\n167\t  # -r{toxinidir}/docs/requirements.in\n168\t  # -c{toxinidir}/docs/requirements.txt\n169\tcommands_pre =\n170\tcommands =\n171\t  # Retrieve possibly missing commits:\n172\t  -git fetch --unshallow\n173\t  -git fetch --tags\n174\t\n175\t  # Build the html docs with Sphinx:\n176\t  {envpython} -m sphinx \\\n177\t    -j auto \\\n178\t    -b linkcheck \\\n179\t    {tty:--color} \\\n180\t    -a \\\n181\t    -n -W --keep-going \\\n182\t    -d \"{temp_dir}/.doctrees\" \\\n183\t    . \\\n184\t    \"{envdir}/docs_out\"\n185\tchangedir = {toxinidir}/docs\n186\tisolated_build = true\n187\tpassenv =\n188\t  SSH_AUTH_SOCK\n189\tskip_install = false\n190\tallowlist_externals =\n191\t  git\n192\t\n193\t[testenv:changelog-draft]\n194\tdeps =\n195\t  towncrier\n196\t  -c{toxinidir}/docs/requirements.txt\n197\tcommands_pre =\n198\t  towncrier --version\n199\t# wrap the invocation of `towncrier build --version main --draft` to discard stderr\n200\t# unfortunately, stderr gets interleaved with stdout, often mixing towncrier's draft build output\n201\t# with user messaging about the invocation\n202\tcommands =\n203\t  {envpython} -bb -I -Werror \\\n204\t    -c 'import sys, subprocess; subprocess.run([sys.executable, \"-bb\", \"-I\", \"-Werror\", \"-m\", \"towncrier\", \"build\", \"--version\", \"DRAFT_VERSION\", \"--draft\", *sys.argv[1:]], stderr=subprocess.DEVNULL)' {posargs}\n205\t\n206\t\n207\t[testenv:cleanup-dists]\n208\tdescription =\n209\t  Wipe the dist{/} folder\n210\tdeps =\n211\tcommands_pre =\n212\tcommands =\n213\t  {envpython} \\\n214\t    {[python-cli-options]byte-errors} \\\n215\t    {[python-cli-options]max-isolation} \\\n216\t    {[python-cli-options]warnings-to-errors} \\\n217\t    -c \\\n218\t      'import os, shutil, sys; \\\n219\t      dists_dir = \"{toxinidir}{/}dist{/}\"; \\\n220\t      shutil.rmtree(dists_dir, ignore_errors=True); \\\n221\t      sys.exit(os.path.exists(dists_dir))'\n222\tcommands_post =\n223\tpackage = skip\n224\t\n225\t\n226\t[testenv:build-dists]\n227\tallowlist_externals =\n228\t  env\n229\tdescription =\n230\t  Build dists with {basepython} and put them into the dist{/} folder\n231\tdepends =\n232\t  cleanup-dists\n233\tdeps =\n234\t  build\n235\tcommands_pre =\n236\tcommands =\n237\t  {envpython} \\\n238\t    {[python-cli-options]byte-errors} \\\n239\t    {[python-cli-options]max-isolation} \\\n240\t    {[python-cli-options]warnings-to-errors} \\\n241\t    -m build \\\n242\t      {posargs:}\n243\tcommands_post =\n244\tpackage = skip\n245\t\n246\t\n247\t[testenv:metadata-validation]\n248\tdescription =\n249\t  Verify that dists under the `dist{/}` dir\n250\t  have valid metadata\n251\tdepends =\n252\t  build-dists\n253\tdeps =\n254\t  twine\n255\tcommands =\n256\t  {envpython} \\\n257\t    {[python-cli-options]byte-errors} \\\n258\t    {[python-cli-options]max-isolation} \\\n259\t    {[python-cli-options]warnings-to-errors} \\\n260\t    -m twine \\\n261\t      check \\\n262\t      --strict \\\n263\t      dist{/}*\n264\tcommands_post =\n265\tpackage = skip\n266\t"}]},"parent_tool_use_id":null,"session_id":"b5305180-7b10-4a0d-8f6c-85a547bffd74","uuid":"a6f08592-408f-4a69-a87c-532441de22dd","timestamp":"2026-04-06T14:12:28.410Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tox.ini","content":"[tox]\nenvlist =\n    # NOTE: keep this in sync with the env list in .github/workflows/ci.yml.\n    py{39,310,311,312,313,314,314t,py3}-pip{supported,lowest,latest,main}-coverage\n    pip{supported,lowest,latest,main}-coverage\n    pip{supported,lowest,latest,main}\n    checkqa\n    readme\nskip_missing_interpreters = True\n\n[python-cli-options]\nbyte-warnings = -b\nbyte-errors = -bb\nmax-isolation = -E -s -I\n# some-isolation = -I\n# FIXME: Python 2 shim. Is this equivalent to the above?\nsome-isolation = -E -s\nwarnings-to-errors = -Werror\n\n\n[testenv]\ndescription = run the tests with pytest\nextras =\n    testing\n    coverage: coverage\ndeps =\n    pipsupported: pip == 26.0\n    pipsupported: setuptools <= 80.0\n\n    piplowest: pip == 22.2.* ; python_version < \"3.12\"\n    piplowest: pip == 23.2.* ; python_version >= \"3.12\" and python_version < \"3.14\"\n    piplowest: pip == 25.2.* ; python_version >= \"3.14\"\n\n    piplatest: pip\n    pipmain: https://github.com/pypa/pip/archive/main.zip\nsetenv =\n    coverage: PYTEST_ADDOPTS=--strict-markers --doctest-modules --cov --cov-report=term-missing --cov-report=xml {env:PYTEST_ADDOPTS:}\ncommands_pre =\n    piplatest: python -m pip install -U pip\n    pip --version\ncommands = pytest {posargs}\npassenv =\n    CI\n    FORCE_COLOR\n    GITHUB_ACTIONS\n    MYPY_FORCE_COLOR\n    PRE_COMMIT_COLOR\n    PY_COLORS\npip_pre=True\n\n[testenv:checkqa]\ndescription = format the code base and check its quality\nskip_install = True\ndeps = pre-commit\ncommands_pre =\ncommands = pre-commit run --all-files --show-diff-on-failure\n\n[testenv:readme]\ndescription = check whether the long description will render correctly on PyPI\ndeps =\n    build\n    twine\ncommands_pre =\ncommands =\n    python -m build --outdir {envtmpdir} --sdist {toxinidir}\n    twine check --strict {envtmpdir}{/}*\nskip_install = true\n\n[testenv:pip-compile-docs]\ndescription = compile requirements for the documentation\ncommands_pre =\n# compile requirements.in + pyproject.toml to get pip-tools install requirements in\n# addition to doc tooling requirements *but without* putting `pip-tools` itself\n# into the output\ncommands =\n  python -m piptools compile \\\n    --strip-extras \\\n    --allow-unsafe \\\n    --quiet \\\n    docs/requirements.in \\\n    './pyproject.toml' \\\n    -o docs/requirements.txt \\\n    {posargs}\n\n[testenv:build-docs]\ndescription = build the documentation\ndeps =\n  -r{toxinidir}/docs/requirements.txt\n  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n  # Ref: https://github.com/pypa/pip/issues/9243\n  # -r{toxinidir}/docs/requirements.in\n  # -c{toxinidir}/docs/requirements.txt\ncommands_pre =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\ncommands =\n  # Build the html docs with Sphinx:\n  {envpython} -m sphinx \\\n    -j auto \\\n    -b html \\\n    {tty:--color} \\\n    -a \\\n    -n -W --keep-going \\\n    -d \"{temp_dir}/.doctrees\" \\\n    . \\\n    {posargs:{envdir}/docs_out}\n# Print out the output docs dir and a way to serve html after the build\ncommands_post =\n  {envpython} -c \\\n    'import pathlib;\\\n    docs_dir = pathlib.Path(r\"{envdir}\") / \"docs_out\";\\\n    index_file = docs_dir / \"index.html\";\\\n    print(\"\\n\" + \"=\" * 120 +\\\n    f\"\\n\\nDocumentation available under:\\n\\n\\\n    \\tfile://\\{index_file\\}\\n\\nTo serve docs, use\\n\\n\\\n    \\t$ python3 -m http.server --directory \\\n    \\N\\{QUOTATION MARK\\}\\{docs_dir\\}\\N\\{QUOTATION MARK\\} 0\\n\\n\" +\\\n    \"=\" * 120)'\nchangedir = {toxinidir}/docs\nisolated_build = true\npassenv =\n  READTHEDOCS\n  READTHEDOCS_VERSION_TYPE\n  SSH_AUTH_SOCK\nskip_install = false\nallowlist_externals =\n  git\n\n\n[testenv:preview-docs]\ndescription = preview the docs\ndeps =\n  sphinx-autobuild\n  {[testenv:build-docs]deps}\ncommands_pre =\ncommands =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\n\n  # Build the html docs with sphinx-autobuild:\n  {envpython} -m sphinx_autobuild \\\n    -j auto \\\n    -b html \\\n    -n \\\n    -W \\\n    -d \"{temp_dir}/.doctrees\" \\\n    . \\\n    --watch ../README.md \\\n    --watch ../CHANGELOG.md \\\n    \"{envdir}/docs_out\"\n\nchangedir = {[testenv:build-docs]changedir}\nisolated_build = {[testenv:build-docs]isolated_build}\npassenv = {[testenv:build-docs]passenv}\nskip_install = {[testenv:build-docs]skip_install}\nallowlist_externals = {[testenv:build-docs]allowlist_externals}\n\n\n[testenv:linkcheck-docs]\ndescription = check links in the documentation\ndeps =\n  -r{toxinidir}/docs/requirements.txt\n  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n  # Ref: https://github.com/pypa/pip/issues/9243\n  # -r{toxinidir}/docs/requirements.in\n  # -c{toxinidir}/docs/requirements.txt\ncommands_pre =\ncommands =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\n\n  # Build the html docs with Sphinx:\n  {envpython} -m sphinx \\\n    -j auto \\\n    -b linkcheck \\\n    {tty:--color} \\\n    -a \\\n    -n -W --keep-going \\\n    -d \"{temp_dir}/.doctrees\" \\\n    . \\\n    \"{envdir}/docs_out\"\nchangedir = {toxinidir}/docs\nisolated_build = true\npassenv =\n  SSH_AUTH_SOCK\nskip_install = false\nallowlist_externals =\n  git\n\n[testenv:changelog-draft]\ndeps =\n  towncrier\n  -c{toxinidir}/docs/requirements.txt\ncommands_pre =\n  towncrier --version\n# wrap the invocation of `towncrier build --version main --draft` to discard stderr\n# unfortunately, stderr gets interleaved with stdout, often mixing towncrier's draft build output\n# with user messaging about the invocation\ncommands =\n  {envpython} -bb -I -Werror \\\n    -c 'import sys, subprocess; subprocess.run([sys.executable, \"-bb\", \"-I\", \"-Werror\", \"-m\", \"towncrier\", \"build\", \"--version\", \"DRAFT_VERSION\", \"--draft\", *sys.argv[1:]], stderr=subprocess.DEVNULL)' {posargs}\n\n\n[testenv:cleanup-dists]\ndescription =\n  Wipe the dist{/} folder\ndeps =\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'import os, shutil, sys; \\\n      dists_dir = \"{toxinidir}{/}dist{/}\"; \\\n      shutil.rmtree(dists_dir, ignore_errors=True); \\\n      sys.exit(os.path.exists(dists_dir))'\ncommands_post =\npackage = skip\n\n\n[testenv:build-dists]\nallowlist_externals =\n  env\ndescription =\n  Build dists with {basepython} and put them into the dist{/} folder\ndepends =\n  cleanup-dists\ndeps =\n  build\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -m build \\\n      {posargs:}\ncommands_post =\npackage = skip\n\n\n[testenv:metadata-validation]\ndescription =\n  Verify that dists under the `dist{/}` dir\n  have valid metadata\ndepends =\n  build-dists\ndeps =\n  twine\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -m twine \\\n      check \\\n      --strict \\\n      dist{/}*\ncommands_post =\npackage = skip\n","numLines":266,"startLine":1,"totalLines":266}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_539e15d9282b447eb8d4803b","type":"tool_result","content":"1\tname: CI\n2\t\n3\ton:\n4\t  merge_group:\n5\t  pull_request:\n6\t  push:\n7\t    branches:\n8\t      - main\n9\t    tags:\n10\t      - v*\n11\t  workflow_call:\n12\t    inputs:\n13\t      cpython-pip-version:\n14\t        description: >-\n15\t          A JSON string with pip versions\n16\t          to test against under CPython.\n17\t        required: false\n18\t        type: string\n19\t      cpython-versions:\n20\t        description: >-\n21\t          A JSON string with CPython versions\n22\t          to test against.\n23\t        required: false\n24\t        type: string\n25\t      release-version:\n26\t        description: >-\n27\t          Target PEP440-compliant version to release.\n28\t          Any leading `v` will be stripped off.\n29\t        required: false\n30\t        type: string\n31\t      release-committish:\n32\t        default: ''\n33\t        description: >-\n34\t          The commit to be released to PyPI and tagged\n35\t          in Git as `release-version`. Normally, you\n36\t          should keep this empty.\n37\t        type: string\n38\t\n39\t    outputs:\n40\t      dists-artifact-name:\n41\t        description: Workflow artifact name containing dists.\n42\t        value: ${{ jobs.pre-setup.outputs.dists-artifact-name }}\n43\t      is-upstream-repository:\n44\t        description: >-\n45\t          A flag representing whether the workflow runs in the upstream\n46\t          repository or a fork.\n47\t        value: ${{ jobs.pre-setup.outputs.is-upstream-repository }}\n48\t      project-name:\n49\t        description: PyPI project name.\n50\t        value: ${{ jobs.pre-setup.outputs.project-name }}\n51\t      project-version:\n52\t        description: PyPI project version string.\n53\t        value: ${{ jobs.pre-setup.outputs.dist-version }}\n54\t\n55\tconcurrency:\n56\t  group: ${{ github.workflow }}-${{ github.event.pull_request.number || github.sha }}\n57\t  cancel-in-progress: true\n58\t\n59\tenv:\n60\t  FORCE_COLOR: 1 # Request colored output from CLI tools supporting it\n61\t  MYPY_FORCE_COLOR: 1 # MyPy's color enforcement\n62\t  PIP_DISABLE_PIP_VERSION_CHECK: 1\n63\t  PIP_NO_PYTHON_VERSION_WARNING: 1\n64\t  PIP_NO_WARN_SCRIPT_LOCATION: 1\n65\t  PRE_COMMIT_COLOR: 1\n66\t  PY_COLORS: 1 # Recognized by the `py` package, dependency of `pytest`\n67\t  TOX_PARALLEL_NO_SPINNER: 1\n68\t  TOX_TESTENV_PASSENV: >-\n69\t    FORCE_COLOR\n70\t    MYPY_FORCE_COLOR\n71\t    NO_COLOR\n72\t    PY_COLORS\n73\t    PYTEST_THEME\n74\t    PYTEST_THEME_MODE\n75\t    PRE_COMMIT_COLOR\n76\t  UPSTREAM_REPOSITORY_ID: >-\n77\t    5746963\n78\t\n79\tjobs:\n80\t  pre-setup:\n81\t    name: ⚙️ Pre-set global build settings\n82\t\n83\t    runs-on: ubuntu-24.04\n84\t\n85\t    timeout-minutes: 2  # network is slow sometimes when fetching from Git\n86\t\n87\t    defaults:\n88\t      run:\n89\t        shell: python\n90\t\n91\t    outputs:\n92\t      # NOTE: These aren't env vars because the `${{ env }}` context is\n93\t      # NOTE: inaccessible when passing inputs to reusable workflows.\n94\t      dists-artifact-name: python-package-distributions\n95\t      dist-version: >-\n96\t        ${{ steps.normalize-dist-version.outputs.dist-version }}\n97\t      project-name: ${{ steps.metadata.outputs.project-name }}\n98\t      release-requested: >-\n99\t        ${{\n100\t            steps.request-check.outputs.release-requested || false\n101\t        }}\n102\t      cache-key-for-dep-files: >-\n103\t        ${{ steps.calc-cache-key-files.outputs.cache-key-for-dep-files }}\n104\t      sdist-artifact-name: ${{ steps.artifact-name.outputs.sdist }}\n105\t      wheel-artifact-name: ${{ steps.artifact-name.outputs.wheel }}\n106\t      is-upstream-repository: >-\n107\t        ${{ toJSON(env.UPSTREAM_REPOSITORY_ID == github.repository_id) }}\n108\t\n109\t    steps:\n110\t    - name: Switch to using Python 3.14 by default\n111\t      uses: actions/setup-python@v6\n112\t      with:\n113\t        python-version: 3.14\n114\t    - name: >-\n115\t        Mark the build as untagged '${{\n116\t            github.event.repository.default_branch\n117\t        }}' branch build\n118\t      id: untagged-check\n119\t      if: >-\n120\t        github.event_name == 'push' &&\n121\t        github.ref_type == 'branch' &&\n122\t        github.ref_name == github.event.repository.default_branch\n123\t      run: |\n124\t        from os import environ\n125\t        from pathlib import Path\n126\t\n127\t        FILE_APPEND_MODE = 'a'\n128\t\n129\t        with Path(environ['GITHUB_OUTPUT']).open(\n130\t                mode=FILE_APPEND_MODE,\n131\t        ) as outputs_file:\n132\t            print('is-untagged-devel=true', file=outputs_file)\n133\t    - name: Mark the build as \"release request\"\n134\t      id: request-check\n135\t      if: inputs.release-version != ''\n136\t      run: |\n137\t        from os import environ\n138\t        from pathlib import Path\n139\t\n140\t        FILE_APPEND_MODE = 'a'\n141\t\n142\t        with Path(environ['GITHUB_OUTPUT']).open(\n143\t                mode=FILE_APPEND_MODE,\n144\t        ) as outputs_file:\n145\t            print('release-requested=true', file=outputs_file)\n146\t    - name: Check out src from Git\n147\t      uses: actions/checkout@v4\n148\t      with:\n149\t        fetch-depth: >-\n150\t          ${{\n151\t            steps.request-check.outputs.release-requested == 'true'\n152\t            && 1 || 0\n153\t          }}\n154\t        ref: ${{ inputs.release-committish }}\n155\t    - name: Scan static PEP 621 core packaging metadata\n156\t      id: metadata\n157\t      run: |\n158\t        from os import environ\n159\t        from pathlib import Path\n160\t        from tomllib import loads as parse_toml_from_string\n161\t\n162\t        FILE_APPEND_MODE = 'a'\n163\t\n164\t        pyproject_toml_txt = Path('pyproject.toml').read_text()\n165\t        metadata = parse_toml_from_string(pyproject_toml_txt)['project']\n166\t        project_name = metadata[\"name\"]\n167\t\n168\t        with Path(environ['GITHUB_OUTPUT']).open(\n169\t                mode=FILE_APPEND_MODE,\n170\t        ) as outputs_file:\n171\t            print(f'project-name={project_name}', file=outputs_file)\n172\t    - name: >-\n173\t        Calculate dependency files' combined hash value\n174\t        for use in the cache key\n175\t      if: >-\n176\t        steps.request-check.outputs.release-requested != 'true'\n177\t      id: calc-cache-key-files\n178\t      uses: ./.github/actions/cache-keys\n179\t    - name: Set up pip cache\n180\t      if: >-\n181\t        steps.request-check.outputs.release-requested != 'true'\n182\t      uses: re-actors/cache-python-deps@release/v1\n183\t      with:\n184\t        cache-key-for-dependency-files: >-\n185\t          ${{ steps.calc-cache-key-files.outputs.cache-key-for-dep-files }}\n186\t    - name: Drop Git tags from HEAD for non-release requests\n187\t      if: >-\n188\t        steps.request-check.outputs.release-requested != 'true'\n189\t      run: >-\n190\t        git tag --points-at HEAD\n191\t        |\n192\t        xargs git tag --delete\n193\t      shell: bash -eEuxo pipefail {0}\n194\t    - name: Set up versioning prerequisites\n195\t      if: >-\n196\t        steps.request-check.outputs.release-requested != 'true'\n197\t      run: >-\n198\t        python -m\n199\t        pip install\n200\t        --user\n201\t        setuptools-scm\n202\t      shell: bash -eEuxo pipefail {0}\n203\t    - name: Set the current dist version from Git\n204\t      if: steps.request-check.outputs.release-requested != 'true'\n205\t      id: scm-version\n206\t      run: |\n207\t        from os import environ\n208\t        from pathlib import Path\n209\t\n210\t        import setuptools_scm\n211\t\n212\t        FILE_APPEND_MODE = 'a'\n213\t\n214\t        ver = setuptools_scm.get_version(local_scheme='dirty-tag')\n215\t        with Path(environ['GITHUB_OUTPUT']).open(\n216\t                mode=FILE_APPEND_MODE,\n217\t        ) as outputs_file:\n218\t            print(f'dist-version={ver}', file=outputs_file)\n219\t            print(\n220\t                f'dist-version-for-filenames={ver.replace(\"+\", \"-\")}',\n221\t                file=outputs_file,\n222\t            )\n223\t    - name: Normalize dist version\n224\t      id: normalize-dist-version\n225\t      run: |\n226\t        from os import environ\n227\t        from pathlib import Path\n228\t\n229\t        FILE_APPEND_MODE = 'a'\n230\t\n231\t        dist_version = \"${{\n232\t            steps.request-check.outputs.release-requested == 'true'\n233\t            && inputs.release-version\n234\t            || steps.scm-version.outputs.dist-version\n235\t        }}\".lstrip(\"v\")\n236\t\n237\t        with Path(environ['GITHUB_OUTPUT']).open(\n238\t                mode=FILE_APPEND_MODE,\n239\t        ) as outputs_file:\n240\t            print(\n241\t                f\"dist-version={dist_version}\",\n242\t                file=outputs_file,\n243\t            )\n244\t    - name: Set the expected dist artifact names\n245\t      id: artifact-name\n246\t      env:\n247\t        PROJECT_NAME: ${{ steps.metadata.outputs.project-name }}\n248\t      run: |\n249\t        from os import environ\n250\t        from pathlib import Path\n251\t\n252\t        FILE_APPEND_MODE = 'a'\n253\t\n254\t        whl_file_prj_base_name = environ['PROJECT_NAME'].replace('-', '_')\n255\t        sdist_file_prj_base_name = (\n256\t            whl_file_prj_base_name.\n257\t            replace('.', '_').\n258\t            lower()\n259\t        )\n260\t        dist_version = \"${{ steps.normalize-dist-version.outputs.dist-version }}\"\n261\t\n262\t        with Path(environ['GITHUB_OUTPUT']).open(\n263\t                mode=FILE_APPEND_MODE,\n264\t        ) as outputs_file:\n265\t            print(\n266\t                f\"sdist={sdist_file_prj_base_name !s}-{dist_version}.tar.gz\",\n267\t                file=outputs_file,\n268\t            )\n269\t            print(\n270\t                f\"wheel={whl_file_prj_base_name !s}-{dist_version}-py3-none-any.whl\",\n271\t                file=outputs_file,\n272\t            )\n273\t\n274\t  build:\n275\t    name: >-\n276\t      📦 Build dists\n277\t    needs:\n278\t    - pre-setup  # transitive, for accessing settings\n279\t\n280\t    uses: tox-dev/workflow/.github/workflows/reusable-tox.yml@617ca35caa695c572377861016677905e58a328c  # yamllint disable-line rule:line-length\n281\t    with:\n282\t      cache-key-for-dependency-files: >-\n283\t        ${{ needs.pre-setup.outputs.cache-key-for-dep-files }}\n284\t      check-name: Build dists under 🐍3.12\n285\t      checkout-src-git-committish: >-\n286\t        ${{ inputs.release-committish }}\n287\t      checkout-src-git-fetch-depth: >-\n288\t        ${{\n289\t          fromJSON(needs.pre-setup.outputs.release-requested)\n290\t          && 1\n291\t          || 0\n292\t        }}\n293\t      job-dependencies-context: >-  # context for hooks\n294\t        ${{ toJSON(needs) }}\n295\t      python-version: 3.12\n296\t      runner-vm-os: ubuntu-24.04\n297\t      timeout-minutes: 2\n298\t      toxenv: build-dists\n299\t      xfail: false\n300\t\n301\t  linters:\n302\t    name: Linters\n303\t    uses: ./.github/workflows/reusable-qa.yml\n304\t\n305\t  test:\n306\t    name: ${{ matrix.runner-vm }} / ${{ matrix.python-version }} / ${{ matrix.pip-version }}\n307\t    runs-on: ${{ matrix.runner-vm }}\n308\t    timeout-minutes: 15\n309\t    strategy:\n310\t      fail-fast: false\n311\t      matrix:\n312\t        runner-vm:\n313\t          - ubuntu-24.04\n314\t          - windows-2025\n315\t          - macos-26\n316\t          - macos-15-intel\n317\t        python-version: >-\n318\t          ${{\n319\t            fromJSON(\n320\t              inputs.cpython-versions\n321\t              && inputs.cpython-versions\n322\t              ||\n323\t              '[\"3.9\", \"3.10\", \"3.11\", \"3.12\", \"3.13\", \"3.14\", \"3.14t\"]'\n324\t            )\n325\t          }}\n326\t        pip-version: >-\n327\t          ${{\n328\t            fromJSON(\n329\t              inputs.cpython-pip-version\n330\t              && inputs.cpython-pip-version\n331\t              || '[\"supported\", \"lowest\"]'\n332\t            )\n333\t          }}\n334\t    env:\n335\t      TOXENV: >-\n336\t        pip${{ matrix.pip-version }}${{\n337\t          !inputs.cpython-pip-version\n338\t          && '-coverage'\n339\t          || ''\n340\t        }}\n341\t    steps:\n342\t      - uses: actions/checkout@v5\n343\t      - name: Set up Python ${{ matrix.python-version }} from GitHub\n344\t        id: python-install\n345\t        if: \"!endsWith(matrix.python-version, '-dev')\"\n346\t        uses: actions/setup-python@v6\n347\t        with:\n348\t          python-version: ${{ matrix.python-version }}\n349\t      - name: Set up Python ${{ matrix.python-version }} from deadsnakes\n350\t        if: endsWith(matrix.python-version, '-dev')\n351\t        uses: deadsnakes/action@v2.1.1\n352\t        with:\n353\t          python-version: ${{ matrix.python-version }}\n354\t      - name: Log python version info (${{ matrix.python-version }})\n355\t        run: python --version --version\n356\t      - name: Get pip cache dir\n357\t        id: pip-cache\n358\t        shell: bash\n359\t        run: |\n360\t          echo \"dir=$(pip cache dir)\" >> \"${GITHUB_OUTPUT}\"\n361\t      - name: Pip cache\n362\t        uses: actions/cache@v4\n363\t        with:\n364\t          path: ${{ steps.pip-cache.outputs.dir }}\n365\t          key: >-\n366\t            ${{ runner.os }}-pip-${{ hashFiles('setup.cfg') }}-${{\n367\t            hashFiles('pyproject.toml') }}-${{ hashFiles('tox.ini') }}-${{\n368\t            hashFiles('.pre-commit-config.yaml') }}\n369\t          restore-keys: |\n370\t            ${{ runner.os }}-pip-\n371\t            ${{ runner.os }}-\n372\t      - name: Install test dependencies\n373\t        run: python -m pip install -U tox virtualenv\n374\t      - name: Prepare test environment\n375\t        # NOTE: `--parallel-live` is a workaround for the regression in\n376\t        # NOTE: the upstream tox project that made the\n377\t        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n378\t        # NOTE: and disable output from the tox environments.\n379\t        #\n380\t        # Ref: https://github.com/tox-dev/tox/issues/3193\n381\t        run: tox -vv --notest -p auto --parallel-live\n382\t      - name: Test pip ${{ matrix.pip-version }}\n383\t        # NOTE: `--parallel-live` is a workaround for the regression in\n384\t        # NOTE: the upstream tox project that made the\n385\t        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n386\t        # NOTE: and disable output from the tox environments.\n387\t        #\n388\t        # Ref: https://github.com/tox-dev/tox/issues/3193\n389\t        run: tox --skip-pkg-install --parallel-live\n390\t      - name: Re-run the failing tests with maximum verbosity\n391\t        if: >-\n392\t          !cancelled()\n393\t          && failure()\n394\t        run: >-  # `exit 1` makes sure that the job remains red with flaky runs\n395\t          python -Xutf8 -Im\n396\t          tox\n397\t          --parallel=auto\n398\t          --parallel-live\n399\t          --skip-missing-interpreters=false\n400\t          --skip-pkg-install\n401\t          -vvvvv\n402\t          --\n403\t          --continue-on-collection-errors\n404\t          --full-trace\n405\t          --last-failed\n406\t          ${{ !inputs.cpython-pip-version && '--no-cov' || '' }}\n407\t          --numprocesses=0\n408\t          --showlocals\n409\t          --trace-config\n410\t          -rA\n411\t          -vvvvv\n412\t          && exit 1\n413\t        shell: bash\n414\t      - name: Upload coverage to Codecov\n415\t        if: >-\n416\t          !cancelled()\n417\t          && !inputs.cpython-pip-version\n418\t        uses: codecov/codecov-action@v5\n419\t        with:\n420\t          files: ./coverage.xml\n421\t          flags: >-\n422\t            CI-GHA,\n423\t            OS-${{ runner.os }},\n424\t            VM-${{ matrix.runner-vm }},\n425\t            Py-${{ steps.python-install.outputs.python-version }},\n426\t            Pip-${{ matrix.pip-version }}\n427\t          name: >-\n428\t            OS-${{ runner.os }},\n429\t            VM-${{ matrix.runner-vm }},\n430\t            Py-${{ steps.python-install.outputs.python-version }},\n431\t            Pip-${{ matrix.pip-version }}\n432\t\n433\t  pypy:\n434\t    name: ${{ matrix.runner-vm }} / ${{ matrix.python-version }} / ${{ matrix.pip-version }}\n435\t    runs-on: ${{ matrix.runner-vm }}\n436\t    timeout-minutes: 9\n437\t    strategy:\n438\t      fail-fast: false\n439\t      matrix:\n440\t        runner-vm:\n441\t          - ubuntu-24.04\n442\t          - macos-26\n443\t          - macos-26-intel\n444\t          - windows-2025\n445\t        python-version:\n446\t          - pypy-3.10\n447\t        pip-version:\n448\t          - supported\n449\t    env:\n450\t      TOXENV: pip${{ matrix.pip-version }}\n451\t    steps:\n452\t      - uses: actions/checkout@v5\n453\t      - name: Set up Python ${{ matrix.python-version }}\n454\t        uses: actions/setup-python@v6\n455\t        with:\n456\t          python-version: ${{ matrix.python-version }}\n457\t      - name: Get pip cache dir\n458\t        id: pip-cache\n459\t        shell: bash\n460\t        run: |\n461\t          echo \"dir=$(pip cache dir)\" >> \"${GITHUB_OUTPUT}\"\n462\t      - name: Pip cache\n463\t        uses: actions/cache@v4\n464\t        with:\n465\t          path: ${{ steps.pip-cache.outputs.dir }}\n466\t          key: >-\n467\t            ${{ runner.os }}-pip-${{ hashFiles('setup.cfg') }}-${{\n468\t            hashFiles('pyproject.toml') }}-${{ hashFiles('tox.ini') }}-${{\n469\t            hashFiles('.pre-commit-config.yaml') }}\n470\t          restore-keys: |\n471\t            ${{ runner.os }}-pip-\n472\t            ${{ runner.os }}-\n473\t      - name: Install tox\n474\t        run: pip install tox\n475\t      - name: Prepare test environment\n476\t        # NOTE: `--parallel-live` is a workaround for the regression in\n477\t        # NOTE: the upstream tox project that made the\n478\t        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n479\t        # NOTE: and disable output from the tox environments.\n480\t        #\n481\t        # Ref: https://github.com/tox-dev/tox/issues/3193\n482\t        run: tox --notest -p auto --parallel-live\n483\t      - name: Test pip ${{ matrix.pip-version }}\n484\t        # NOTE: `--parallel-live` is a workaround for the regression in\n485\t        # NOTE: the upstream tox project that made the\n486\t        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n487\t        # NOTE: and disable output from the tox environments.\n488\t        #\n489\t        # Ref: https://github.com/tox-dev/tox/issues/3193\n490\t        run: tox --skip-pkg-install --parallel-live\n491\t      - name: Re-run the failing tests with maximum verbosity\n492\t        if: >-\n493\t          !cancelled()\n494\t          && failure()\n495\t        run: >-  # `exit 1` makes sure that the job remains red with flaky runs\n496\t          python -Xutf8 -Im\n497\t          tox\n498\t          --parallel=auto\n499\t          --parallel-live\n500\t          --skip-missing-interpreters=false\n501\t          --skip-pkg-install\n502\t          -vvvvv\n503\t          --\n504\t          --continue-on-collection-errors\n505\t          --full-trace\n506\t          --last-failed\n507\t          --numprocesses=0\n508\t          --showlocals\n509\t          --trace-config\n510\t          -rA\n511\t          -vvvvv\n512\t          && exit 1\n513\t        shell: bash\n514\t\n515\t  coverage-summary:\n516\t    name: Coverage processing\n517\t    if: >-\n518\t      !cancelled()\n519\t    runs-on: ubuntu-24.04\n520\t    timeout-minutes: 1\n521\t    needs:\n522\t      - test\n523\t    steps:\n524\t      - name: Notify Codecov that all coverage reports have been uploaded\n525\t        if: >-\n526\t          !cancelled()\n527\t        uses: codecov/codecov-action@v5\n528\t        with:\n529\t          fail_ci_if_error: true\n530\t          run_command: send-notifications\n531\t\n532\t  zizmor:\n533\t    name: 🌈 zizmor\n534\t    permissions:\n535\t      security-events: write\n536\t\n537\t    # yamllint disable-line rule:line-length\n538\t    uses: zizmorcore/workflow/.github/workflows/reusable-zizmor.yml@1e20adb0862e932363a4d85d68c92e5cc6fcb5d4\n539\t\n540\t  check: # This job does nothing and is only used for the branch protection\n541\t    if: always()\n542\t\n543\t    needs:\n544\t      - linters\n545\t      - pypy\n546\t      - test\n547\t      - zizmor\n548\t\n549\t    runs-on: ubuntu-24.04\n550\t\n551\t    timeout-minutes: 1\n552\t\n553\t    steps:\n554\t      - name: Decide whether the needed jobs succeeded or failed\n555\t        uses: re-actors/alls-green@afee1c1eac2a506084c274e9c02c8e0687b48d9e\n556\t        with:\n557\t          jobs: ${{ toJSON(needs) }}\n558\t"}]},"parent_tool_use_id":null,"session_id":"b5305180-7b10-4a0d-8f6c-85a547bffd74","uuid":"19654299-a375-4a78-908b-e966e5d9e29d","timestamp":"2026-04-06T14:12:28.412Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.github/workflows/ci.yml","content":"name: CI\n\non:\n  merge_group:\n  pull_request:\n  push:\n    branches:\n      - main\n    tags:\n      - v*\n  workflow_call:\n    inputs:\n      cpython-pip-version:\n        description: >-\n          A JSON string with pip versions\n          to test against under CPython.\n        required: false\n        type: string\n      cpython-versions:\n        description: >-\n          A JSON string with CPython versions\n          to test against.\n        required: false\n        type: string\n      release-version:\n        description: >-\n          Target PEP440-compliant version to release.\n          Any leading `v` will be stripped off.\n        required: false\n        type: string\n      release-committish:\n        default: ''\n        description: >-\n          The commit to be released to PyPI and tagged\n          in Git as `release-version`. Normally, you\n          should keep this empty.\n        type: string\n\n    outputs:\n      dists-artifact-name:\n        description: Workflow artifact name containing dists.\n        value: ${{ jobs.pre-setup.outputs.dists-artifact-name }}\n      is-upstream-repository:\n        description: >-\n          A flag representing whether the workflow runs in the upstream\n          repository or a fork.\n        value: ${{ jobs.pre-setup.outputs.is-upstream-repository }}\n      project-name:\n        description: PyPI project name.\n        value: ${{ jobs.pre-setup.outputs.project-name }}\n      project-version:\n        description: PyPI project version string.\n        value: ${{ jobs.pre-setup.outputs.dist-version }}\n\nconcurrency:\n  group: ${{ github.workflow }}-${{ github.event.pull_request.number || github.sha }}\n  cancel-in-progress: true\n\nenv:\n  FORCE_COLOR: 1 # Request colored output from CLI tools supporting it\n  MYPY_FORCE_COLOR: 1 # MyPy's color enforcement\n  PIP_DISABLE_PIP_VERSION_CHECK: 1\n  PIP_NO_PYTHON_VERSION_WARNING: 1\n  PIP_NO_WARN_SCRIPT_LOCATION: 1\n  PRE_COMMIT_COLOR: 1\n  PY_COLORS: 1 # Recognized by the `py` package, dependency of `pytest`\n  TOX_PARALLEL_NO_SPINNER: 1\n  TOX_TESTENV_PASSENV: >-\n    FORCE_COLOR\n    MYPY_FORCE_COLOR\n    NO_COLOR\n    PY_COLORS\n    PYTEST_THEME\n    PYTEST_THEME_MODE\n    PRE_COMMIT_COLOR\n  UPSTREAM_REPOSITORY_ID: >-\n    5746963\n\njobs:\n  pre-setup:\n    name: ⚙️ Pre-set global build settings\n\n    runs-on: ubuntu-24.04\n\n    timeout-minutes: 2  # network is slow sometimes when fetching from Git\n\n    defaults:\n      run:\n        shell: python\n\n    outputs:\n      # NOTE: These aren't env vars because the `${{ env }}` context is\n      # NOTE: inaccessible when passing inputs to reusable workflows.\n      dists-artifact-name: python-package-distributions\n      dist-version: >-\n        ${{ steps.normalize-dist-version.outputs.dist-version }}\n      project-name: ${{ steps.metadata.outputs.project-name }}\n      release-requested: >-\n        ${{\n            steps.request-check.outputs.release-requested || false\n        }}\n      cache-key-for-dep-files: >-\n        ${{ steps.calc-cache-key-files.outputs.cache-key-for-dep-files }}\n      sdist-artifact-name: ${{ steps.artifact-name.outputs.sdist }}\n      wheel-artifact-name: ${{ steps.artifact-name.outputs.wheel }}\n      is-upstream-repository: >-\n        ${{ toJSON(env.UPSTREAM_REPOSITORY_ID == github.repository_id) }}\n\n    steps:\n    - name: Switch to using Python 3.14 by default\n      uses: actions/setup-python@v6\n      with:\n        python-version: 3.14\n    - name: >-\n        Mark the build as untagged '${{\n            github.event.repository.default_branch\n        }}' branch build\n      id: untagged-check\n      if: >-\n        github.event_name == 'push' &&\n        github.ref_type == 'branch' &&\n        github.ref_name == github.event.repository.default_branch\n      run: |\n        from os import environ\n        from pathlib import Path\n\n        FILE_APPEND_MODE = 'a'\n\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print('is-untagged-devel=true', file=outputs_file)\n    - name: Mark the build as \"release request\"\n      id: request-check\n      if: inputs.release-version != ''\n      run: |\n        from os import environ\n        from pathlib import Path\n\n        FILE_APPEND_MODE = 'a'\n\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print('release-requested=true', file=outputs_file)\n    - name: Check out src from Git\n      uses: actions/checkout@v4\n      with:\n        fetch-depth: >-\n          ${{\n            steps.request-check.outputs.release-requested == 'true'\n            && 1 || 0\n          }}\n        ref: ${{ inputs.release-committish }}\n    - name: Scan static PEP 621 core packaging metadata\n      id: metadata\n      run: |\n        from os import environ\n        from pathlib import Path\n        from tomllib import loads as parse_toml_from_string\n\n        FILE_APPEND_MODE = 'a'\n\n        pyproject_toml_txt = Path('pyproject.toml').read_text()\n        metadata = parse_toml_from_string(pyproject_toml_txt)['project']\n        project_name = metadata[\"name\"]\n\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print(f'project-name={project_name}', file=outputs_file)\n    - name: >-\n        Calculate dependency files' combined hash value\n        for use in the cache key\n      if: >-\n        steps.request-check.outputs.release-requested != 'true'\n      id: calc-cache-key-files\n      uses: ./.github/actions/cache-keys\n    - name: Set up pip cache\n      if: >-\n        steps.request-check.outputs.release-requested != 'true'\n      uses: re-actors/cache-python-deps@release/v1\n      with:\n        cache-key-for-dependency-files: >-\n          ${{ steps.calc-cache-key-files.outputs.cache-key-for-dep-files }}\n    - name: Drop Git tags from HEAD for non-release requests\n      if: >-\n        steps.request-check.outputs.release-requested != 'true'\n      run: >-\n        git tag --points-at HEAD\n        |\n        xargs git tag --delete\n      shell: bash -eEuxo pipefail {0}\n    - name: Set up versioning prerequisites\n      if: >-\n        steps.request-check.outputs.release-requested != 'true'\n      run: >-\n        python -m\n        pip install\n        --user\n        setuptools-scm\n      shell: bash -eEuxo pipefail {0}\n    - name: Set the current dist version from Git\n      if: steps.request-check.outputs.release-requested != 'true'\n      id: scm-version\n      run: |\n        from os import environ\n        from pathlib import Path\n\n        import setuptools_scm\n\n        FILE_APPEND_MODE = 'a'\n\n        ver = setuptools_scm.get_version(local_scheme='dirty-tag')\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print(f'dist-version={ver}', file=outputs_file)\n            print(\n                f'dist-version-for-filenames={ver.replace(\"+\", \"-\")}',\n                file=outputs_file,\n            )\n    - name: Normalize dist version\n      id: normalize-dist-version\n      run: |\n        from os import environ\n        from pathlib import Path\n\n        FILE_APPEND_MODE = 'a'\n\n        dist_version = \"${{\n            steps.request-check.outputs.release-requested == 'true'\n            && inputs.release-version\n            || steps.scm-version.outputs.dist-version\n        }}\".lstrip(\"v\")\n\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print(\n                f\"dist-version={dist_version}\",\n                file=outputs_file,\n            )\n    - name: Set the expected dist artifact names\n      id: artifact-name\n      env:\n        PROJECT_NAME: ${{ steps.metadata.outputs.project-name }}\n      run: |\n        from os import environ\n        from pathlib import Path\n\n        FILE_APPEND_MODE = 'a'\n\n        whl_file_prj_base_name = environ['PROJECT_NAME'].replace('-', '_')\n        sdist_file_prj_base_name = (\n            whl_file_prj_base_name.\n            replace('.', '_').\n            lower()\n        )\n        dist_version = \"${{ steps.normalize-dist-version.outputs.dist-version }}\"\n\n        with Path(environ['GITHUB_OUTPUT']).open(\n                mode=FILE_APPEND_MODE,\n        ) as outputs_file:\n            print(\n                f\"sdist={sdist_file_prj_base_name !s}-{dist_version}.tar.gz\",\n                file=outputs_file,\n            )\n            print(\n                f\"wheel={whl_file_prj_base_name !s}-{dist_version}-py3-none-any.whl\",\n                file=outputs_file,\n            )\n\n  build:\n    name: >-\n      📦 Build dists\n    needs:\n    - pre-setup  # transitive, for accessing settings\n\n    uses: tox-dev/workflow/.github/workflows/reusable-tox.yml@617ca35caa695c572377861016677905e58a328c  # yamllint disable-line rule:line-length\n    with:\n      cache-key-for-dependency-files: >-\n        ${{ needs.pre-setup.outputs.cache-key-for-dep-files }}\n      check-name: Build dists under 🐍3.12\n      checkout-src-git-committish: >-\n        ${{ inputs.release-committish }}\n      checkout-src-git-fetch-depth: >-\n        ${{\n          fromJSON(needs.pre-setup.outputs.release-requested)\n          && 1\n          || 0\n        }}\n      job-dependencies-context: >-  # context for hooks\n        ${{ toJSON(needs) }}\n      python-version: 3.12\n      runner-vm-os: ubuntu-24.04\n      timeout-minutes: 2\n      toxenv: build-dists\n      xfail: false\n\n  linters:\n    name: Linters\n    uses: ./.github/workflows/reusable-qa.yml\n\n  test:\n    name: ${{ matrix.runner-vm }} / ${{ matrix.python-version }} / ${{ matrix.pip-version }}\n    runs-on: ${{ matrix.runner-vm }}\n    timeout-minutes: 15\n    strategy:\n      fail-fast: false\n      matrix:\n        runner-vm:\n          - ubuntu-24.04\n          - windows-2025\n          - macos-26\n          - macos-15-intel\n        python-version: >-\n          ${{\n            fromJSON(\n              inputs.cpython-versions\n              && inputs.cpython-versions\n              ||\n              '[\"3.9\", \"3.10\", \"3.11\", \"3.12\", \"3.13\", \"3.14\", \"3.14t\"]'\n            )\n          }}\n        pip-version: >-\n          ${{\n            fromJSON(\n              inputs.cpython-pip-version\n              && inputs.cpython-pip-version\n              || '[\"supported\", \"lowest\"]'\n            )\n          }}\n    env:\n      TOXENV: >-\n        pip${{ matrix.pip-version }}${{\n          !inputs.cpython-pip-version\n          && '-coverage'\n          || ''\n        }}\n    steps:\n      - uses: actions/checkout@v5\n      - name: Set up Python ${{ matrix.python-version }} from GitHub\n        id: python-install\n        if: \"!endsWith(matrix.python-version, '-dev')\"\n        uses: actions/setup-python@v6\n        with:\n          python-version: ${{ matrix.python-version }}\n      - name: Set up Python ${{ matrix.python-version }} from deadsnakes\n        if: endsWith(matrix.python-version, '-dev')\n        uses: deadsnakes/action@v2.1.1\n        with:\n          python-version: ${{ matrix.python-version }}\n      - name: Log python version info (${{ matrix.python-version }})\n        run: python --version --version\n      - name: Get pip cache dir\n        id: pip-cache\n        shell: bash\n        run: |\n          echo \"dir=$(pip cache dir)\" >> \"${GITHUB_OUTPUT}\"\n      - name: Pip cache\n        uses: actions/cache@v4\n        with:\n          path: ${{ steps.pip-cache.outputs.dir }}\n          key: >-\n            ${{ runner.os }}-pip-${{ hashFiles('setup.cfg') }}-${{\n            hashFiles('pyproject.toml') }}-${{ hashFiles('tox.ini') }}-${{\n            hashFiles('.pre-commit-config.yaml') }}\n          restore-keys: |\n            ${{ runner.os }}-pip-\n            ${{ runner.os }}-\n      - name: Install test dependencies\n        run: python -m pip install -U tox virtualenv\n      - name: Prepare test environment\n        # NOTE: `--parallel-live` is a workaround for the regression in\n        # NOTE: the upstream tox project that made the\n        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n        # NOTE: and disable output from the tox environments.\n        #\n        # Ref: https://github.com/tox-dev/tox/issues/3193\n        run: tox -vv --notest -p auto --parallel-live\n      - name: Test pip ${{ matrix.pip-version }}\n        # NOTE: `--parallel-live` is a workaround for the regression in\n        # NOTE: the upstream tox project that made the\n        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n        # NOTE: and disable output from the tox environments.\n        #\n        # Ref: https://github.com/tox-dev/tox/issues/3193\n        run: tox --skip-pkg-install --parallel-live\n      - name: Re-run the failing tests with maximum verbosity\n        if: >-\n          !cancelled()\n          && failure()\n        run: >-  # `exit 1` makes sure that the job remains red with flaky runs\n          python -Xutf8 -Im\n          tox\n          --parallel=auto\n          --parallel-live\n          --skip-missing-interpreters=false\n          --skip-pkg-install\n          -vvvvv\n          --\n          --continue-on-collection-errors\n          --full-trace\n          --last-failed\n          ${{ !inputs.cpython-pip-version && '--no-cov' || '' }}\n          --numprocesses=0\n          --showlocals\n          --trace-config\n          -rA\n          -vvvvv\n          && exit 1\n        shell: bash\n      - name: Upload coverage to Codecov\n        if: >-\n          !cancelled()\n          && !inputs.cpython-pip-version\n        uses: codecov/codecov-action@v5\n        with:\n          files: ./coverage.xml\n          flags: >-\n            CI-GHA,\n            OS-${{ runner.os }},\n            VM-${{ matrix.runner-vm }},\n            Py-${{ steps.python-install.outputs.python-version }},\n            Pip-${{ matrix.pip-version }}\n          name: >-\n            OS-${{ runner.os }},\n            VM-${{ matrix.runner-vm }},\n            Py-${{ steps.python-install.outputs.python-version }},\n            Pip-${{ matrix.pip-version }}\n\n  pypy:\n    name: ${{ matrix.runner-vm }} / ${{ matrix.python-version }} / ${{ matrix.pip-version }}\n    runs-on: ${{ matrix.runner-vm }}\n    timeout-minutes: 9\n    strategy:\n      fail-fast: false\n      matrix:\n        runner-vm:\n          - ubuntu-24.04\n          - macos-26\n          - macos-26-intel\n          - windows-2025\n        python-version:\n          - pypy-3.10\n        pip-version:\n          - supported\n    env:\n      TOXENV: pip${{ matrix.pip-version }}\n    steps:\n      - uses: actions/checkout@v5\n      - name: Set up Python ${{ matrix.python-version }}\n        uses: actions/setup-python@v6\n        with:\n          python-version: ${{ matrix.python-version }}\n      - name: Get pip cache dir\n        id: pip-cache\n        shell: bash\n        run: |\n          echo \"dir=$(pip cache dir)\" >> \"${GITHUB_OUTPUT}\"\n      - name: Pip cache\n        uses: actions/cache@v4\n        with:\n          path: ${{ steps.pip-cache.outputs.dir }}\n          key: >-\n            ${{ runner.os }}-pip-${{ hashFiles('setup.cfg') }}-${{\n            hashFiles('pyproject.toml') }}-${{ hashFiles('tox.ini') }}-${{\n            hashFiles('.pre-commit-config.yaml') }}\n          restore-keys: |\n            ${{ runner.os }}-pip-\n            ${{ runner.os }}-\n      - name: Install tox\n        run: pip install tox\n      - name: Prepare test environment\n        # NOTE: `--parallel-live` is a workaround for the regression in\n        # NOTE: the upstream tox project that made the\n        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n        # NOTE: and disable output from the tox environments.\n        #\n        # Ref: https://github.com/tox-dev/tox/issues/3193\n        run: tox --notest -p auto --parallel-live\n      - name: Test pip ${{ matrix.pip-version }}\n        # NOTE: `--parallel-live` is a workaround for the regression in\n        # NOTE: the upstream tox project that made the\n        # NOTE: `TOX_PARALLEL_NO_SPINNER=1` env var auto-enable parallelism\n        # NOTE: and disable output from the tox environments.\n        #\n        # Ref: https://github.com/tox-dev/tox/issues/3193\n        run: tox --skip-pkg-install --parallel-live\n      - name: Re-run the failing tests with maximum verbosity\n        if: >-\n          !cancelled()\n          && failure()\n        run: >-  # `exit 1` makes sure that the job remains red with flaky runs\n          python -Xutf8 -Im\n          tox\n          --parallel=auto\n          --parallel-live\n          --skip-missing-interpreters=false\n          --skip-pkg-install\n          -vvvvv\n          --\n          --continue-on-collection-errors\n          --full-trace\n          --last-failed\n          --numprocesses=0\n          --showlocals\n          --trace-config\n          -rA\n          -vvvvv\n          && exit 1\n        shell: bash\n\n  coverage-summary:\n    name: Coverage processing\n    if: >-\n      !cancelled()\n    runs-on: ubuntu-24.04\n    timeout-minutes: 1\n    needs:\n      - test\n    steps:\n      - name: Notify Codecov that all coverage reports have been uploaded\n        if: >-\n          !cancelled()\n        uses: codecov/codecov-action@v5\n        with:\n          fail_ci_if_error: true\n          run_command: send-notifications\n\n  zizmor:\n    name: 🌈 zizmor\n    permissions:\n      security-events: write\n\n    # yamllint disable-line rule:line-length\n    uses: zizmorcore/workflow/.github/workflows/reusable-zizmor.yml@1e20adb0862e932363a4d85d68c92e5cc6fcb5d4\n\n  check: # This job does nothing and is only used for the branch protection\n    if: always()\n\n    needs:\n      - linters\n      - pypy\n      - test\n      - zizmor\n\n    runs-on: ubuntu-24.04\n\n    timeout-minutes: 1\n\n    steps:\n      - name: Decide whether the needed jobs succeeded or failed\n        uses: re-actors/alls-green@afee1c1eac2a506084c274e9c02c8e0687b48d9e\n        with:\n          jobs: ${{ toJSON(needs) }}\n","numLines":558,"startLine":1,"totalLines":558}}}
