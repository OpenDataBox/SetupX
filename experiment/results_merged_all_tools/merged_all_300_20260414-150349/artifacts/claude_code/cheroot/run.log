{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_e15302496ccb409a9a206664","type":"tool_result","content":"1\t[tox]\n2\tenvlist = python\n3\tminversion = 4\n4\t\n5\t[python-cli-options]\n6\tbyte-warnings = -b\n7\tbyte-errors = -bb\n8\tmax-isolation = -E -s -I\n9\t# some-isolation = -I\n10\t# FIXME: Python 2 shim. Is this equivalent to the above?\n11\tsome-isolation = -E -s\n12\twarnings-to-errors = -Werror\n13\t\n14\t\n15\t[testenv]\n16\tdeps =\n17\t  -rdependencies{/}tests.in\n18\tcommands_pre =\n19\t  {envpython} \\\n20\t    {[python-cli-options]byte-errors} \\\n21\t    {[python-cli-options]some-isolation} \\\n22\t    -m \\\n23\t      OpenSSL.debug\n24\tcommands =\n25\t  {envpython} \\\n26\t    {[python-cli-options]byte-errors} \\\n27\t    {[python-cli-options]some-isolation} \\\n28\t    -m pytest \\\n29\t      {tty:--color=yes} \\\n30\t      {posargs:--cov-report=html:{envtmpdir}{/}htmlcov{/}}\n31\tcommands_post =\n32\t  -{envpython} \\\n33\t    {[python-cli-options]byte-errors} \\\n34\t    {[python-cli-options]max-isolation} \\\n35\t    {[python-cli-options]warnings-to-errors} \\\n36\t    -c \\\n37\t      'import atexit, os, sys; \\\n38\t      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n39\t      import coverage; \\\n40\t      gh_summary_fd = open(\\\n41\t        os.environ[\"GITHUB_STEP_SUMMARY\"], encoding=\"utf-8\", mode=\"a\",\\\n42\t      ); \\\n43\t      atexit.register(gh_summary_fd.close); \\\n44\t      cov = coverage.Coverage(); \\\n45\t      cov.load(); \\\n46\t      cov.report(file=gh_summary_fd, output_format=\"markdown\")'\n47\t  {envpython} \\\n48\t    {[python-cli-options]byte-errors} \\\n49\t    {[python-cli-options]max-isolation} \\\n50\t    {[python-cli-options]warnings-to-errors} \\\n51\t    -c \\\n52\t      'import os, pathlib, sys; \\\n53\t      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n54\t      cov_report_arg_prefix = \"--cov-report=xml:\"; \\\n55\t      test_report_arg_prefix = \"--junitxml=\"; \\\n56\t      cov_reports = [\\\n57\t        arg[len(cov_report_arg_prefix):] for arg in sys.argv \\\n58\t        if arg.startswith(cov_report_arg_prefix)\\\n59\t      ]; \\\n60\t      test_reports = [\\\n61\t        arg[len(test_report_arg_prefix):] for arg in sys.argv \\\n62\t        if arg.startswith(test_report_arg_prefix)\\\n63\t      ]; \\\n64\t      cov_report_file = cov_reports[-1] if cov_reports else None; \\\n65\t      test_report_file = test_reports[-1] if test_reports else None; \\\n66\t      gh_output_fd = open(\\\n67\t        os.environ[\"GITHUB_OUTPUT\"], encoding=\"utf-8\", mode=\"a\",\\\n68\t      ); \\\n69\t      cov_report_file and \\\n70\t        print(f\"cov-report-files={cov_report_file !s}\", file=gh_output_fd); \\\n71\t      test_report_file and \\\n72\t        print(f\"test-result-files={test_report_file !s}\", file=gh_output_fd); \\\n73\t      print(\"codecov-flags=pytest\", file=gh_output_fd); \\\n74\t      gh_output_fd.close()' \\\n75\t    {posargs}\n76\t  # Print out the output coverage dir and a way to serve html:\n77\t  {envpython} \\\n78\t    {[python-cli-options]byte-errors} \\\n79\t    {[python-cli-options]max-isolation} \\\n80\t    {[python-cli-options]warnings-to-errors} \\\n81\t    -c\\\n82\t      'import pathlib, shlex, sys; \\\n83\t      cov_html_report_arg_prefix = \"--cov-report=html:\"; \\\n84\t      cov_html_reports = [\\\n85\t        arg[len(cov_html_report_arg_prefix):] for arg in sys.argv \\\n86\t        if arg.startswith(cov_html_report_arg_prefix)\\\n87\t      ]; \\\n88\t      cov_html_reports or sys.exit(); \\\n89\t      cov_html_report_dir = pathlib.Path(cov_html_reports[-1]); \\\n90\t      index_file = cov_html_report_dir / \"index.html\";\\\n91\t      index_file.exists() or sys.exit(); \\\n92\t      html_url = f\"file://\\{index_file\\}\";\\\n93\t      browse_cmd = shlex.join((\"python3\", \"-Im\", \"webbrowser\", html_url)); \\\n94\t      serve_cmd = shlex.join((\\\n95\t        \"python3\", \"-Im\", \"http.server\", \\\n96\t        \"--directory\", str(cov_html_report_dir), \"0\", \\\n97\t      )); \\\n98\t      print(f\"\\nTo open the HTML coverage report, run\\n\\n\\\n99\t      \\t\\{browse_cmd !s\\}\\n\");\\\n100\t      print(f\"To serve \\\n101\t      the HTML coverage report with a local web server, use\\n\\n\\\n102\t      \\t\\{serve_cmd !s\\}\\n\")' \\\n103\t    {posargs:--cov-report=html:{envtmpdir}{/}htmlcov{/}}\n104\tinstall_command =\n105\t  {envpython} \\\n106\t    {[python-cli-options]byte-errors} \\\n107\t    {[python-cli-options]some-isolation} \\\n108\t    {toxinidir}{/}bin{/}pip-wrapper \\\n109\t    '{envname}' \\\n110\t    '{toxinidir}{/}dependencies{/}' \\\n111\t    install {opts} {packages}\n112\tuse_develop = True\n113\t\n114\tpass_env =\n115\t  WEBTEST_INTERACTIVE\n116\t  CI\n117\t  TRAVIS\n118\t  TRAVIS_*\n119\t  APPVEYOR\n120\t  APPVEYOR_*\n121\t  CIRCLECI\n122\t  CIRCLE_*\n123\t  PYTHONDONTWRITEBYTECODE\n124\t  PYTHONTRACEMALLOC\n125\t  PYTEST_*\n126\t  SSH_AUTH_SOCK\n127\t  GITHUB_*\n128\t  CODECOV_TOKEN\n129\tset_env =\n130\t  CRYPTOGRAPHY_ALLOW_OPENSSL_102=x\n131\t  PYTHONDONTWRITEBYTECODE=x\n132\t  WEBTEST_INTERACTIVE=false\n133\t\n134\t\n135\t[dists]\n136\tset_env =\n137\t  PIP_CONSTRAINT = {toxinidir}{/}dependencies{/}dist-build-constraints.txt\n138\t  PEP517_OUT_DIR = {env:PEP517_OUT_DIR:{toxinidir}{/}dist}\n139\t\n140\t\n141\t[testenv:build-docs]\n142\tallowlist_externals =\n143\t  git\n144\tdescription = Build The Docs\n145\tchange_dir = docs\n146\tcommands_pre =\n147\t  # Retrieve possibly missing commits:\n148\t  -git fetch --unshallow\n149\t  -git fetch --tags\n150\tcommands =\n151\t  # Build docs site:\n152\t  {envpython} \\\n153\t    {[python-cli-options]byte-errors} \\\n154\t    {[python-cli-options]some-isolation} \\\n155\t    -m sphinx \\\n156\t      -j auto \\\n157\t      -b html \\\n158\t      {tty:--color} \\\n159\t      -a \\\n160\t      -n \\\n161\t      -W --keep-going \\\n162\t      -d \"{temp_dir}{/}.doctrees\" \\\n163\t      . \\\n164\t      {posargs:\"{env_dir}{/}docs_out\"}\n165\t\n166\t  # Print out the output docs dir and a way to serve html:\n167\t  -{envpython} \\\n168\t  {[python-cli-options]byte-errors} \\\n169\t  {[python-cli-options]some-isolation} \\\n170\t  -c\\\n171\t  'import pathlib;\\\n172\t  docs_dir = pathlib.Path(r\"{env_dir}\") / \"docs_out\";\\\n173\t  index_file = docs_dir / \"index.html\";\\\n174\t  print(f\"\\nDocumentation available under \\\n175\t  `file://\\{index_file\\}`\\n\\nTo serve docs, use \\\n176\t  `python3 -m http.server --directory \\\n177\t  \\N\\{QUOTATION MARK\\}\\{docs_dir\\}\\N\\{QUOTATION MARK\\} 0`\\n\")'\n178\tcommands_post =\n179\tdepends =\n180\t  make-changelog\n181\tdeps =\n182\t  -rdependencies{/}tox-docs.in\n183\tenv_dir = {toxworkdir}/build-docs\n184\t\n185\t[testenv:doctest-docs]\n186\tallowlist_externals =\n187\t  {[testenv:build-docs]allowlist_externals}\n188\tdescription = Doctest The Docs\n189\tchange_dir = {[testenv:build-docs]change_dir}\n190\tcommands_pre =\n191\tcommands =\n192\t  # Retrieve possibly missing commits:\n193\t  -git fetch --unshallow\n194\t  -git fetch --tags\n195\t\n196\t  # Doctest docs site:\n197\t  {envpython} \\\n198\t    {[python-cli-options]byte-errors} \\\n199\t    {[python-cli-options]some-isolation} \\\n200\t    -m sphinx \\\n201\t      -j auto \\\n202\t      -a -n -W \\\n203\t      --keep-going \\\n204\t      -b doctest --color \\\n205\t      -d \"{temp_dir}{/}.doctrees\" \\\n206\t      . \"{toxworkdir}{/}docs_out\"\n207\tcommands_post =\n208\tdeps =\n209\t  -rdependencies{/}tox-doctest-docs.in\n210\tenv_dir = {[testenv:build-docs]env_dir}\n211\t\n212\t[testenv:linkcheck-docs]\n213\tallowlist_externals =\n214\t  {[testenv:build-docs]allowlist_externals}\n215\tdescription = Linkcheck The Docs\n216\tchange_dir = {[testenv:build-docs]change_dir}\n217\tcommands_pre =\n218\tcommands =\n219\t  # Retrieve possibly missing commits:\n220\t  -git fetch --unshallow\n221\t  -git fetch --tags\n222\t\n223\t  # Linkcheck docs site:\n224\t  {envpython} \\\n225\t    {[python-cli-options]byte-errors} \\\n226\t    {[python-cli-options]some-isolation} \\\n227\t    -m sphinx \\\n228\t      -j auto \\\n229\t      -a -n -W \\\n230\t      --keep-going \\\n231\t      -b linkcheck --color \\\n232\t      -d \"{temp_dir}{/}.doctrees\" \\\n233\t      . \"{toxworkdir}{/}docs_out\"\n234\tcommands_post =\n235\tdeps =\n236\t  -rdependencies{/}tox-docs-linkcheck.in\n237\tenv_dir = {[testenv:build-docs]env_dir}\n238\t\n239\t[testenv:spellcheck-docs]\n240\tallowlist_externals =\n241\t  {[testenv:build-docs]allowlist_externals}\n242\tdescription = Spellcheck The Docs\n243\tchange_dir = {[testenv:build-docs]change_dir}\n244\tcommands_pre =\n245\tcommands =\n246\t  # Retrieve possibly missing commits:\n247\t  -git fetch --unshallow\n248\t  -git fetch --tags\n249\t\n250\t  # Spellcheck docs site:\n251\t  {envpython} \\\n252\t    {[python-cli-options]byte-errors} \\\n253\t    {[python-cli-options]some-isolation} \\\n254\t    -m sphinx \\\n255\t      -j auto \\\n256\t      -a -n -W \\\n257\t      --keep-going \\\n258\t      -b spelling --color \\\n259\t      -d \"{temp_dir}{/}.doctrees\" \\\n260\t      . \"{toxworkdir}{/}docs_out\"\n261\tcommands_post =\n262\tdeps =\n263\t  -rdependencies{/}tox-docs-spellcheck.in\n264\tenv_dir = {[testenv:build-docs]env_dir}\n265\t\n266\t[testenv:watch]\n267\tcommands = ptw --runner=pytest\n268\tcommands_post =\n269\t\n270\t\n271\t[testenv:check-changelog]\n272\tbase_python = {[testenv:make-changelog]base_python}\n273\tdescription =\n274\t  Check Towncrier change notes\n275\tcommands_pre =\n276\tcommands =\n277\t  {envpython} \\\n278\t    {[python-cli-options]byte-errors} \\\n279\t    {[python-cli-options]some-isolation} \\\n280\t    -m towncrier.check \\\n281\t      --compare-with origin/devel {posargs:}\n282\tcommands_post =\n283\tdeps =\n284\t  {[testenv:make-changelog]deps}\n285\tenv_dir = {[testenv:make-changelog]env_dir}\n286\tisolated_build = {[testenv:make-changelog]isolated_build}\n287\tskip_install = {[testenv:make-changelog]skip_install}\n288\t\n289\t\n290\t[testenv:make-changelog]\n291\tbase_python = python3\n292\tdepends =\n293\t  check-changelog\n294\tdescription =\n295\t  Generate a changelog from fragments using Towncrier. Getting an\n296\t  unreleased changelog preview does not require extra arguments.\n297\t  When invoking to update the changelog, pass the desired version as an\n298\t  argument after `--`. For example, `tox -e {envname} -- 1.3.2`.\n299\tenv_dir = {[testenv:build-docs]env_dir}\n300\tcommands_pre =\n301\tcommands =\n302\t  {envpython} \\\n303\t    {[python-cli-options]byte-errors} \\\n304\t    {[python-cli-options]some-isolation} \\\n305\t    -m towncrier.build \\\n306\t      --version \\\n307\t      {posargs:'[UNRELEASED DRAFT]' --draft}\n308\tcommands_post =\n309\tdeps =\n310\t  {[testenv:build-docs]deps}\n311\t  # -r{toxinidir}/docs/requirements.txt\n312\t  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n313\t  # Ref: https://github.com/pypa/pip/issues/9243\n314\t  # towncrier\n315\t  # -r{toxinidir}/docs/requirements.in\n316\t  # -c{toxinidir}/docs/requirements.txt\n317\tisolated_build = true\n318\tskip_install = true\n319\t\n320\t\n321\t[testenv:draft-changelog]\n322\tallowlist_externals =\n323\t  sh\n324\tbase_python = {[testenv:make-changelog]base_python}\n325\tdescription =\n326\t  Print out the Towncrier-managed change notes\n327\t  draft for the next release to stdout\n328\tcommands_pre =\n329\tcommands =\n330\t  # NOTE: `sh` invocation is required to suppress stderr from\n331\t  # NOTE: towncrier since it does not have own CLI flags for\n332\t  # NOTE: doing this.\n333\t  sh -c \"2>/dev/null \\\n334\t    {envpython} \\\n335\t    {[python-cli-options]byte-errors} \\\n336\t    {[python-cli-options]some-isolation} \\\n337\t    -m towncrier.build \\\n338\t      --version '[UNRELEASED DRAFT]' \\\n339\t      --draft\"\n340\tcommands_post =\n341\tenv_dir = {[testenv:make-changelog]env_dir}\n342\tdeps =\n343\t  {[testenv:make-changelog]deps}\n344\tisolated_build = {[testenv:make-changelog]isolated_build}\n345\tskip_install = {[testenv:make-changelog]skip_install}\n346\t\n347\t\n348\t[testenv:cleanup-dists]\n349\tdescription =\n350\t  Wipe the the dist{/} folder\n351\tuse_develop = false\n352\tskip_install = true\n353\tdeps =\n354\tset_env =\n355\t  {[dists]set_env}\n356\tcommands_pre =\n357\tcommands =\n358\t  {envpython} \\\n359\t  {[python-cli-options]byte-errors} \\\n360\t  {[python-cli-options]some-isolation} \\\n361\t  -c \\\n362\t    'import os, shutil, sys; dists_dir = os.getenv(\"PEP517_OUT_DIR\"); shutil.rmtree(dists_dir, ignore_errors=True); sys.exit(os.path.exists(dists_dir))'\n363\tcommands_post =\n364\t\n365\t\n366\t[testenv:build-dists]\n367\tallowlist_externals =\n368\t  env\n369\tdescription =\n370\t  Build dists and put them into\n371\t  the `{env:PEP517_OUT_DIR}{/}` folder\n372\tdepends =\n373\t  cleanup-dists\n374\tplatform = darwin|linux\n375\t# NOTE: The custom command is here to allow resetting the global\n376\t# NOTE: pip constraints env var.\n377\tinstall_command =\n378\t  env PIP_CONSTRAINT= \\\n379\t    {envpython} \\\n380\t    {[python-cli-options]byte-errors} \\\n381\t    {[python-cli-options]some-isolation} \\\n382\t    {toxinidir}{/}bin{/}pip-wrapper \\\n383\t    '{envname}' \\\n384\t    '{toxinidir}{/}dependencies{/}' \\\n385\t    install {opts} {packages}\n386\tisolated_build = true\n387\t# `use_develop = true` overrides `skip_install` instruction, it's unwanted\n388\tuse_develop = false\n389\tskip_install = true\n390\tdeps =\n391\t  -rdependencies{/}tox-build-dists.in\n392\tpass_env =\n393\t  PEP517_BUILD_ARGS\n394\tset_env =\n395\t  {[dists]set_env}\n396\tcommands_pre =\n397\tcommands =\n398\t  # Starting with build v0.5.0, it builds wheel from sdist\n399\t  # if no format arguments are passed. This makes sure that\n400\t  # wheels are not dependent on the Git repo or anything\n401\t  # external what may be missing from sdist.\n402\t  {envpython} \\\n403\t    {[python-cli-options]byte-errors} \\\n404\t    {[python-cli-options]some-isolation} \\\n405\t    -m build \\\n406\t      --outdir '{env:PEP517_OUT_DIR}{/}' \\\n407\t      {posargs:{env:PEP517_BUILD_ARGS:}} \\\n408\t      '{toxinidir}'\n409\tcommands_post =\n410\t\n411\t\n412\t[testenv:pre-commit]\n413\tdescription =\n414\t  Run the quality checks under {base_python}; run as\n415\t  `SKIP=check-id1,check-id2 tox r -e pre-commit` to instruct the underlying\n416\t  `pre-commit` invocation avoid running said checks; Use\n417\t  `tox r -e pre-commit -- check-id1 --all-files` to select checks matching IDs\n418\t  aliases{:} `tox r -e pre-commit -- mypy --all-files` will run 3 MyPy\n419\t  invocations, but `tox r -e pre-commit -- mypy-py313 --all-files` runs one.\n420\tcommands_pre =\n421\tcommands =\n422\t  {envpython} \\\n423\t    {[python-cli-options]byte-errors} \\\n424\t    {[python-cli-options]max-isolation} \\\n425\t    {[python-cli-options]warnings-to-errors} \\\n426\t    -m pre_commit \\\n427\t      run \\\n428\t      --color=always \\\n429\t      --show-diff-on-failure \\\n430\t      {posargs:--all-files}\n431\tcommands_post =\n432\t  # Print out the advice on how to install pre-commit from this env into Git:\n433\t  -{envpython} \\\n434\t    {[python-cli-options]byte-errors} \\\n435\t    {[python-cli-options]max-isolation} \\\n436\t    {[python-cli-options]warnings-to-errors} \\\n437\t    -c \\\n438\t      'cmd = \"{envpython} -m pre_commit install\"; \\\n439\t      scr_width = len(cmd) + 10; \\\n440\t      sep = \"=\" * scr_width; \\\n441\t      cmd_str = \"    $ \\{cmd\\}\";' \\\n442\t      'print(f\"\\n\\{sep\\}\\nTo install pre-commit hooks into the Git repo, run:\\\n443\t      \\n\\n\\{cmd_str\\}\\n\\n\\{sep\\}\\n\")'\n444\t  {envpython} \\\n445\t    {[python-cli-options]byte-errors} \\\n446\t    {[python-cli-options]max-isolation} \\\n447\t    {[python-cli-options]warnings-to-errors} \\\n448\t    -c \\\n449\t      'import os, pathlib, sys; \\\n450\t      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n451\t      project_root_path = pathlib.Path(r\"{toxinidir}\"); \\\n452\t      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n453\t      coverage_result_files = \",\".join(\\\n454\t        str(xml_path.relative_to(project_root_path)) \\\n455\t        for xml_path in test_results_dir.glob(\"mypy--py-*{/}cobertura.xml\")\\\n456\t      ); \\\n457\t      gh_output_fd = open(\\\n458\t        os.environ[\"GITHUB_OUTPUT\"], encoding=\"utf-8\", mode=\"a\",\\\n459\t      ); \\\n460\t      print(\\\n461\t        f\"cov-report-files={coverage_result_files !s}\", file=gh_output_fd\\\n462\t      ); \\\n463\t      print(\"codecov-flags=MyPy\", file=gh_output_fd); \\\n464\t      gh_output_fd.close()'\n465\t  {envpython} \\\n466\t    {[python-cli-options]byte-errors} \\\n467\t    {[python-cli-options]max-isolation} \\\n468\t    {[python-cli-options]warnings-to-errors} \\\n469\t    -c \\\n470\t      'import itertools, os, pathlib, shlex, sys; \\\n471\t      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n472\t      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n473\t      text_and_json_reports = itertools.chain( \\\n474\t        test_results_dir.glob(\"mypy--py-*{/}*.json\"), \\\n475\t        test_results_dir.glob(\"mypy--py-*{/}*.txt\"), \\\n476\t      ); \\\n477\t      report_contents = { \\\n478\t        report{:} report.read_text() \\\n479\t        for report in text_and_json_reports \\\n480\t      }; \\\n481\t      reports_summary_text_blob = \"\\n\\n\".join( \\\n482\t        f\"\\N\\{NUMBER SIGN\\}\\N\\{NUMBER SIGN\\} {report_path.parent.name}{:} \" \\\n483\t        f\"`{report_path.name}`\\n\\n\" \\\n484\t        f\"```{report_path.suffix[1:]}\\n{report_text}\\n```\\n\" \\\n485\t        for report_path, report_text in report_contents.items() \\\n486\t      ); \\\n487\t      gh_summary_fd = open( \\\n488\t        os.environ[\"GITHUB_STEP_SUMMARY\"], encoding=\"utf-8\", mode=\"a\", \\\n489\t      ); \\\n490\t      print(reports_summary_text_blob, file=gh_summary_fd); \\\n491\t      gh_summary_fd.close()'\n492\t  # Print out the output coverage dir and a way to serve html:\n493\t  {envpython} \\\n494\t    {[python-cli-options]byte-errors} \\\n495\t    {[python-cli-options]max-isolation} \\\n496\t    {[python-cli-options]warnings-to-errors} \\\n497\t    -c\\\n498\t      'import os, pathlib, sys; \\\n499\t      os.getenv(\"GITHUB_ACTIONS\") == \"true\" and sys.exit(); \\\n500\t      len(sys.argv) >= 3 and all(\\\n501\t        arg != \"mypy\" and not arg.startswith(\"mypy-py3\") \\\n502\t        for arg in sys.argv \\\n503\t      ) and sys.exit(); \\\n504\t      project_root_path = pathlib.Path(r\"{toxinidir}\"); \\\n505\t      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n506\t      coverage_html_report_urls = [\\\n507\t        f\"file://\\{xml_path !s\\}\" \\\n508\t        for xml_path in test_results_dir.glob(\"mypy--py-*{/}index.html\")\\\n509\t      ]; \\\n510\t      coverage_html_report_open_cmds = [\\\n511\t      f\"python3 -Im webbrowser \\N\\{QUOTATION MARK\\}\\{html_url !s\\}\\N\\{QUOTATION MARK\\}\" \\\n512\t      for html_url in coverage_html_report_urls\\\n513\t      ]; \\\n514\t      coverage_html_report_open_cmds_blob = \"\\n\\n\\t\".join(\\\n515\t        coverage_html_report_open_cmds,\\\n516\t      ); \\\n517\t      print(\\\n518\t        f\"\\nTo open the HTML coverage reports, run\\n\\n\\\n519\t        \\t\\{coverage_html_report_open_cmds_blob !s\\}\\n\"\\\n520\t      ); \\\n521\t      print(\\\n522\t        f\"[*] Find rest of JSON and text reports, are in the same directories.\"\\\n523\t      )\\\n524\t      ' \\\n525\t    {posargs:--all-files}\n526\tdeps =\n527\t  -rdependencies{/}tox-pre-commit.in\n528\tpackage = skip\n529\tpass_env =\n530\t  {[testenv]pass_env}\n531\t  SKIP  # set this variable\n532\tskip_install = true\n533\t\n534\t\n535\t[testenv:metadata-validation]\n536\tdescription =\n537\t  Verify that dists under the `{env:PEP517_OUT_DIR}{/}` dir\n538\t  have valid metadata\n539\tdepends =\n540\t  build-dists\n541\tdeps =\n542\t  setuptools-scm\n543\t  twine\n544\tuse_develop = false\n545\tskip_install = true\n546\tcommands_pre =\n547\t  {envpython} \\\n548\t    {[python-cli-options]byte-errors} \\\n549\t    {[python-cli-options]some-isolation} \\\n550\t    -m setuptools_scm ls\n551\tset_env =\n552\t  {[dists]set_env}\n553\tcommands =\n554\t  {envpython} \\\n555\t    {[python-cli-options]byte-errors} \\\n556\t    {[python-cli-options]some-isolation} \\\n557\t    -m twine check \\\n558\t      --strict \\\n559\t      {env:PEP517_OUT_DIR}{/}*\n560\tcommands_post =\n561\t\n562\t[testenv:release]\n563\tskip_install = True\n564\tdeps =\n565\t  pep517>=0.5\n566\t  twine>=1.13\n567\t  path.py\n568\tpass_env =\n569\t  TWINE_PASSWORD\n570\tset_env =\n571\t  TWINE_USERNAME = {env:TWINE_USERNAME:__token__}\n572\tcommands_pre =\n573\tcommands =\n574\t  {envpython} \\\n575\t    {[python-cli-options]byte-errors} \\\n576\t    {[python-cli-options]some-isolation} \\\n577\t    -c \"import path; path.Path('dist').rmtree_p()\"\n578\t  {envpython} \\\n579\t    {[python-cli-options]byte-errors} \\\n580\t    {[python-cli-options]some-isolation} -m pep517.build .\n581\t  {envpython} \\\n582\t    {[python-cli-options]byte-errors} \\\n583\t    {[python-cli-options]some-isolation} -m twine upload dist{/}*\n584\tcommands_post =\n585\t"}]},"parent_tool_use_id":null,"session_id":"e8280077-5ace-4aad-88d8-c3d13feed2b0","uuid":"b52c4ae9-2631-437d-bec7-268493c090db","timestamp":"2026-04-13T17:48:11.781Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tox.ini","content":"[tox]\nenvlist = python\nminversion = 4\n\n[python-cli-options]\nbyte-warnings = -b\nbyte-errors = -bb\nmax-isolation = -E -s -I\n# some-isolation = -I\n# FIXME: Python 2 shim. Is this equivalent to the above?\nsome-isolation = -E -s\nwarnings-to-errors = -Werror\n\n\n[testenv]\ndeps =\n  -rdependencies{/}tests.in\ncommands_pre =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m \\\n      OpenSSL.debug\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m pytest \\\n      {tty:--color=yes} \\\n      {posargs:--cov-report=html:{envtmpdir}{/}htmlcov{/}}\ncommands_post =\n  -{envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'import atexit, os, sys; \\\n      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n      import coverage; \\\n      gh_summary_fd = open(\\\n        os.environ[\"GITHUB_STEP_SUMMARY\"], encoding=\"utf-8\", mode=\"a\",\\\n      ); \\\n      atexit.register(gh_summary_fd.close); \\\n      cov = coverage.Coverage(); \\\n      cov.load(); \\\n      cov.report(file=gh_summary_fd, output_format=\"markdown\")'\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'import os, pathlib, sys; \\\n      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n      cov_report_arg_prefix = \"--cov-report=xml:\"; \\\n      test_report_arg_prefix = \"--junitxml=\"; \\\n      cov_reports = [\\\n        arg[len(cov_report_arg_prefix):] for arg in sys.argv \\\n        if arg.startswith(cov_report_arg_prefix)\\\n      ]; \\\n      test_reports = [\\\n        arg[len(test_report_arg_prefix):] for arg in sys.argv \\\n        if arg.startswith(test_report_arg_prefix)\\\n      ]; \\\n      cov_report_file = cov_reports[-1] if cov_reports else None; \\\n      test_report_file = test_reports[-1] if test_reports else None; \\\n      gh_output_fd = open(\\\n        os.environ[\"GITHUB_OUTPUT\"], encoding=\"utf-8\", mode=\"a\",\\\n      ); \\\n      cov_report_file and \\\n        print(f\"cov-report-files={cov_report_file !s}\", file=gh_output_fd); \\\n      test_report_file and \\\n        print(f\"test-result-files={test_report_file !s}\", file=gh_output_fd); \\\n      print(\"codecov-flags=pytest\", file=gh_output_fd); \\\n      gh_output_fd.close()' \\\n    {posargs}\n  # Print out the output coverage dir and a way to serve html:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c\\\n      'import pathlib, shlex, sys; \\\n      cov_html_report_arg_prefix = \"--cov-report=html:\"; \\\n      cov_html_reports = [\\\n        arg[len(cov_html_report_arg_prefix):] for arg in sys.argv \\\n        if arg.startswith(cov_html_report_arg_prefix)\\\n      ]; \\\n      cov_html_reports or sys.exit(); \\\n      cov_html_report_dir = pathlib.Path(cov_html_reports[-1]); \\\n      index_file = cov_html_report_dir / \"index.html\";\\\n      index_file.exists() or sys.exit(); \\\n      html_url = f\"file://\\{index_file\\}\";\\\n      browse_cmd = shlex.join((\"python3\", \"-Im\", \"webbrowser\", html_url)); \\\n      serve_cmd = shlex.join((\\\n        \"python3\", \"-Im\", \"http.server\", \\\n        \"--directory\", str(cov_html_report_dir), \"0\", \\\n      )); \\\n      print(f\"\\nTo open the HTML coverage report, run\\n\\n\\\n      \\t\\{browse_cmd !s\\}\\n\");\\\n      print(f\"To serve \\\n      the HTML coverage report with a local web server, use\\n\\n\\\n      \\t\\{serve_cmd !s\\}\\n\")' \\\n    {posargs:--cov-report=html:{envtmpdir}{/}htmlcov{/}}\ninstall_command =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    {toxinidir}{/}bin{/}pip-wrapper \\\n    '{envname}' \\\n    '{toxinidir}{/}dependencies{/}' \\\n    install {opts} {packages}\nuse_develop = True\n\npass_env =\n  WEBTEST_INTERACTIVE\n  CI\n  TRAVIS\n  TRAVIS_*\n  APPVEYOR\n  APPVEYOR_*\n  CIRCLECI\n  CIRCLE_*\n  PYTHONDONTWRITEBYTECODE\n  PYTHONTRACEMALLOC\n  PYTEST_*\n  SSH_AUTH_SOCK\n  GITHUB_*\n  CODECOV_TOKEN\nset_env =\n  CRYPTOGRAPHY_ALLOW_OPENSSL_102=x\n  PYTHONDONTWRITEBYTECODE=x\n  WEBTEST_INTERACTIVE=false\n\n\n[dists]\nset_env =\n  PIP_CONSTRAINT = {toxinidir}{/}dependencies{/}dist-build-constraints.txt\n  PEP517_OUT_DIR = {env:PEP517_OUT_DIR:{toxinidir}{/}dist}\n\n\n[testenv:build-docs]\nallowlist_externals =\n  git\ndescription = Build The Docs\nchange_dir = docs\ncommands_pre =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\ncommands =\n  # Build docs site:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m sphinx \\\n      -j auto \\\n      -b html \\\n      {tty:--color} \\\n      -a \\\n      -n \\\n      -W --keep-going \\\n      -d \"{temp_dir}{/}.doctrees\" \\\n      . \\\n      {posargs:\"{env_dir}{/}docs_out\"}\n\n  # Print out the output docs dir and a way to serve html:\n  -{envpython} \\\n  {[python-cli-options]byte-errors} \\\n  {[python-cli-options]some-isolation} \\\n  -c\\\n  'import pathlib;\\\n  docs_dir = pathlib.Path(r\"{env_dir}\") / \"docs_out\";\\\n  index_file = docs_dir / \"index.html\";\\\n  print(f\"\\nDocumentation available under \\\n  `file://\\{index_file\\}`\\n\\nTo serve docs, use \\\n  `python3 -m http.server --directory \\\n  \\N\\{QUOTATION MARK\\}\\{docs_dir\\}\\N\\{QUOTATION MARK\\} 0`\\n\")'\ncommands_post =\ndepends =\n  make-changelog\ndeps =\n  -rdependencies{/}tox-docs.in\nenv_dir = {toxworkdir}/build-docs\n\n[testenv:doctest-docs]\nallowlist_externals =\n  {[testenv:build-docs]allowlist_externals}\ndescription = Doctest The Docs\nchange_dir = {[testenv:build-docs]change_dir}\ncommands_pre =\ncommands =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\n\n  # Doctest docs site:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m sphinx \\\n      -j auto \\\n      -a -n -W \\\n      --keep-going \\\n      -b doctest --color \\\n      -d \"{temp_dir}{/}.doctrees\" \\\n      . \"{toxworkdir}{/}docs_out\"\ncommands_post =\ndeps =\n  -rdependencies{/}tox-doctest-docs.in\nenv_dir = {[testenv:build-docs]env_dir}\n\n[testenv:linkcheck-docs]\nallowlist_externals =\n  {[testenv:build-docs]allowlist_externals}\ndescription = Linkcheck The Docs\nchange_dir = {[testenv:build-docs]change_dir}\ncommands_pre =\ncommands =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\n\n  # Linkcheck docs site:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m sphinx \\\n      -j auto \\\n      -a -n -W \\\n      --keep-going \\\n      -b linkcheck --color \\\n      -d \"{temp_dir}{/}.doctrees\" \\\n      . \"{toxworkdir}{/}docs_out\"\ncommands_post =\ndeps =\n  -rdependencies{/}tox-docs-linkcheck.in\nenv_dir = {[testenv:build-docs]env_dir}\n\n[testenv:spellcheck-docs]\nallowlist_externals =\n  {[testenv:build-docs]allowlist_externals}\ndescription = Spellcheck The Docs\nchange_dir = {[testenv:build-docs]change_dir}\ncommands_pre =\ncommands =\n  # Retrieve possibly missing commits:\n  -git fetch --unshallow\n  -git fetch --tags\n\n  # Spellcheck docs site:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m sphinx \\\n      -j auto \\\n      -a -n -W \\\n      --keep-going \\\n      -b spelling --color \\\n      -d \"{temp_dir}{/}.doctrees\" \\\n      . \"{toxworkdir}{/}docs_out\"\ncommands_post =\ndeps =\n  -rdependencies{/}tox-docs-spellcheck.in\nenv_dir = {[testenv:build-docs]env_dir}\n\n[testenv:watch]\ncommands = ptw --runner=pytest\ncommands_post =\n\n\n[testenv:check-changelog]\nbase_python = {[testenv:make-changelog]base_python}\ndescription =\n  Check Towncrier change notes\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m towncrier.check \\\n      --compare-with origin/devel {posargs:}\ncommands_post =\ndeps =\n  {[testenv:make-changelog]deps}\nenv_dir = {[testenv:make-changelog]env_dir}\nisolated_build = {[testenv:make-changelog]isolated_build}\nskip_install = {[testenv:make-changelog]skip_install}\n\n\n[testenv:make-changelog]\nbase_python = python3\ndepends =\n  check-changelog\ndescription =\n  Generate a changelog from fragments using Towncrier. Getting an\n  unreleased changelog preview does not require extra arguments.\n  When invoking to update the changelog, pass the desired version as an\n  argument after `--`. For example, `tox -e {envname} -- 1.3.2`.\nenv_dir = {[testenv:build-docs]env_dir}\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m towncrier.build \\\n      --version \\\n      {posargs:'[UNRELEASED DRAFT]' --draft}\ncommands_post =\ndeps =\n  {[testenv:build-docs]deps}\n  # -r{toxinidir}/docs/requirements.txt\n  # FIXME: re-enable the \"-r\" + \"-c\" paradigm once the pip bug is fixed.\n  # Ref: https://github.com/pypa/pip/issues/9243\n  # towncrier\n  # -r{toxinidir}/docs/requirements.in\n  # -c{toxinidir}/docs/requirements.txt\nisolated_build = true\nskip_install = true\n\n\n[testenv:draft-changelog]\nallowlist_externals =\n  sh\nbase_python = {[testenv:make-changelog]base_python}\ndescription =\n  Print out the Towncrier-managed change notes\n  draft for the next release to stdout\ncommands_pre =\ncommands =\n  # NOTE: `sh` invocation is required to suppress stderr from\n  # NOTE: towncrier since it does not have own CLI flags for\n  # NOTE: doing this.\n  sh -c \"2>/dev/null \\\n    {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m towncrier.build \\\n      --version '[UNRELEASED DRAFT]' \\\n      --draft\"\ncommands_post =\nenv_dir = {[testenv:make-changelog]env_dir}\ndeps =\n  {[testenv:make-changelog]deps}\nisolated_build = {[testenv:make-changelog]isolated_build}\nskip_install = {[testenv:make-changelog]skip_install}\n\n\n[testenv:cleanup-dists]\ndescription =\n  Wipe the the dist{/} folder\nuse_develop = false\nskip_install = true\ndeps =\nset_env =\n  {[dists]set_env}\ncommands_pre =\ncommands =\n  {envpython} \\\n  {[python-cli-options]byte-errors} \\\n  {[python-cli-options]some-isolation} \\\n  -c \\\n    'import os, shutil, sys; dists_dir = os.getenv(\"PEP517_OUT_DIR\"); shutil.rmtree(dists_dir, ignore_errors=True); sys.exit(os.path.exists(dists_dir))'\ncommands_post =\n\n\n[testenv:build-dists]\nallowlist_externals =\n  env\ndescription =\n  Build dists and put them into\n  the `{env:PEP517_OUT_DIR}{/}` folder\ndepends =\n  cleanup-dists\nplatform = darwin|linux\n# NOTE: The custom command is here to allow resetting the global\n# NOTE: pip constraints env var.\ninstall_command =\n  env PIP_CONSTRAINT= \\\n    {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    {toxinidir}{/}bin{/}pip-wrapper \\\n    '{envname}' \\\n    '{toxinidir}{/}dependencies{/}' \\\n    install {opts} {packages}\nisolated_build = true\n# `use_develop = true` overrides `skip_install` instruction, it's unwanted\nuse_develop = false\nskip_install = true\ndeps =\n  -rdependencies{/}tox-build-dists.in\npass_env =\n  PEP517_BUILD_ARGS\nset_env =\n  {[dists]set_env}\ncommands_pre =\ncommands =\n  # Starting with build v0.5.0, it builds wheel from sdist\n  # if no format arguments are passed. This makes sure that\n  # wheels are not dependent on the Git repo or anything\n  # external what may be missing from sdist.\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m build \\\n      --outdir '{env:PEP517_OUT_DIR}{/}' \\\n      {posargs:{env:PEP517_BUILD_ARGS:}} \\\n      '{toxinidir}'\ncommands_post =\n\n\n[testenv:pre-commit]\ndescription =\n  Run the quality checks under {base_python}; run as\n  `SKIP=check-id1,check-id2 tox r -e pre-commit` to instruct the underlying\n  `pre-commit` invocation avoid running said checks; Use\n  `tox r -e pre-commit -- check-id1 --all-files` to select checks matching IDs\n  aliases{:} `tox r -e pre-commit -- mypy --all-files` will run 3 MyPy\n  invocations, but `tox r -e pre-commit -- mypy-py313 --all-files` runs one.\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -m pre_commit \\\n      run \\\n      --color=always \\\n      --show-diff-on-failure \\\n      {posargs:--all-files}\ncommands_post =\n  # Print out the advice on how to install pre-commit from this env into Git:\n  -{envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'cmd = \"{envpython} -m pre_commit install\"; \\\n      scr_width = len(cmd) + 10; \\\n      sep = \"=\" * scr_width; \\\n      cmd_str = \"    $ \\{cmd\\}\";' \\\n      'print(f\"\\n\\{sep\\}\\nTo install pre-commit hooks into the Git repo, run:\\\n      \\n\\n\\{cmd_str\\}\\n\\n\\{sep\\}\\n\")'\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'import os, pathlib, sys; \\\n      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n      project_root_path = pathlib.Path(r\"{toxinidir}\"); \\\n      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n      coverage_result_files = \",\".join(\\\n        str(xml_path.relative_to(project_root_path)) \\\n        for xml_path in test_results_dir.glob(\"mypy--py-*{/}cobertura.xml\")\\\n      ); \\\n      gh_output_fd = open(\\\n        os.environ[\"GITHUB_OUTPUT\"], encoding=\"utf-8\", mode=\"a\",\\\n      ); \\\n      print(\\\n        f\"cov-report-files={coverage_result_files !s}\", file=gh_output_fd\\\n      ); \\\n      print(\"codecov-flags=MyPy\", file=gh_output_fd); \\\n      gh_output_fd.close()'\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c \\\n      'import itertools, os, pathlib, shlex, sys; \\\n      os.getenv(\"GITHUB_ACTIONS\") == \"true\" or sys.exit(); \\\n      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n      text_and_json_reports = itertools.chain( \\\n        test_results_dir.glob(\"mypy--py-*{/}*.json\"), \\\n        test_results_dir.glob(\"mypy--py-*{/}*.txt\"), \\\n      ); \\\n      report_contents = { \\\n        report{:} report.read_text() \\\n        for report in text_and_json_reports \\\n      }; \\\n      reports_summary_text_blob = \"\\n\\n\".join( \\\n        f\"\\N\\{NUMBER SIGN\\}\\N\\{NUMBER SIGN\\} {report_path.parent.name}{:} \" \\\n        f\"`{report_path.name}`\\n\\n\" \\\n        f\"```{report_path.suffix[1:]}\\n{report_text}\\n```\\n\" \\\n        for report_path, report_text in report_contents.items() \\\n      ); \\\n      gh_summary_fd = open( \\\n        os.environ[\"GITHUB_STEP_SUMMARY\"], encoding=\"utf-8\", mode=\"a\", \\\n      ); \\\n      print(reports_summary_text_blob, file=gh_summary_fd); \\\n      gh_summary_fd.close()'\n  # Print out the output coverage dir and a way to serve html:\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]max-isolation} \\\n    {[python-cli-options]warnings-to-errors} \\\n    -c\\\n      'import os, pathlib, sys; \\\n      os.getenv(\"GITHUB_ACTIONS\") == \"true\" and sys.exit(); \\\n      len(sys.argv) >= 3 and all(\\\n        arg != \"mypy\" and not arg.startswith(\"mypy-py3\") \\\n        for arg in sys.argv \\\n      ) and sys.exit(); \\\n      project_root_path = pathlib.Path(r\"{toxinidir}\"); \\\n      test_results_dir = pathlib.Path(r\"{temp_dir}\") / \".test-results\"; \\\n      coverage_html_report_urls = [\\\n        f\"file://\\{xml_path !s\\}\" \\\n        for xml_path in test_results_dir.glob(\"mypy--py-*{/}index.html\")\\\n      ]; \\\n      coverage_html_report_open_cmds = [\\\n      f\"python3 -Im webbrowser \\N\\{QUOTATION MARK\\}\\{html_url !s\\}\\N\\{QUOTATION MARK\\}\" \\\n      for html_url in coverage_html_report_urls\\\n      ]; \\\n      coverage_html_report_open_cmds_blob = \"\\n\\n\\t\".join(\\\n        coverage_html_report_open_cmds,\\\n      ); \\\n      print(\\\n        f\"\\nTo open the HTML coverage reports, run\\n\\n\\\n        \\t\\{coverage_html_report_open_cmds_blob !s\\}\\n\"\\\n      ); \\\n      print(\\\n        f\"[*] Find rest of JSON and text reports, are in the same directories.\"\\\n      )\\\n      ' \\\n    {posargs:--all-files}\ndeps =\n  -rdependencies{/}tox-pre-commit.in\npackage = skip\npass_env =\n  {[testenv]pass_env}\n  SKIP  # set this variable\nskip_install = true\n\n\n[testenv:metadata-validation]\ndescription =\n  Verify that dists under the `{env:PEP517_OUT_DIR}{/}` dir\n  have valid metadata\ndepends =\n  build-dists\ndeps =\n  setuptools-scm\n  twine\nuse_develop = false\nskip_install = true\ncommands_pre =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m setuptools_scm ls\nset_env =\n  {[dists]set_env}\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -m twine check \\\n      --strict \\\n      {env:PEP517_OUT_DIR}{/}*\ncommands_post =\n\n[testenv:release]\nskip_install = True\ndeps =\n  pep517>=0.5\n  twine>=1.13\n  path.py\npass_env =\n  TWINE_PASSWORD\nset_env =\n  TWINE_USERNAME = {env:TWINE_USERNAME:__token__}\ncommands_pre =\ncommands =\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} \\\n    -c \"import path; path.Path('dist').rmtree_p()\"\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} -m pep517.build .\n  {envpython} \\\n    {[python-cli-options]byte-errors} \\\n    {[python-cli-options]some-isolation} -m twine upload dist{/}*\ncommands_post =\n","numLines":585,"startLine":1,"totalLines":585}}}
