{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_62cd8c0dfed6411883d547b2","type":"tool_result","content":"1\timport json\n2\timport pathlib\n3\timport unittest\n4\tfrom typing import Callable\n5\t\n6\tfrom recipe_scrapers import SCRAPERS, scrape_html\n7\tfrom recipe_scrapers._exceptions import StaticValueException\n8\tfrom recipe_scrapers._grouping_utils import IngredientGroup\n9\t\n10\tMANDATORY_TESTS = [\n11\t    \"author\",\n12\t    \"canonical_url\",\n13\t    \"host\",\n14\t    \"image\",\n15\t    \"ingredients\",\n16\t    \"instructions_list\",\n17\t    \"language\",\n18\t    \"site_name\",\n19\t    \"title\",\n20\t    \"total_time\",\n21\t    \"yields\",\n22\t]\n23\t\n24\tOPTIONAL_TESTS = [\n25\t    \"ingredient_groups\",\n26\t    \"instructions\",\n27\t    \"category\",\n28\t    \"description\",\n29\t    \"cook_time\",\n30\t    \"cuisine\",\n31\t    \"nutrients\",\n32\t    \"prep_time\",\n33\t    \"cooking_method\",\n34\t    \"keywords\",\n35\t    \"ratings\",\n36\t    \"equipment\",\n37\t    \"ratings_count\",\n38\t    \"dietary_restrictions\",\n39\t]\n40\t\n41\t\n42\tclass RecipeTestCase(unittest.TestCase):\n43\t    maxDiff = None\n44\t    been_wild = False\n45\t\n46\t\n47\tdef test_func_factory(\n48\t    host: str, testhtml: pathlib.Path, testjson: pathlib.Path\n49\t) -> Callable:\n50\t    \"\"\"\n51\t    Factory function to create a test function that asserts the actual output from\n52\t    the scraper matches the expected output.\n53\t\n54\t    Parameters\n55\t    ----------\n56\t    host : str\n57\t        Host of the site, used to identify the correct scraper to use*\n58\t    testhtml : pathlib.Path\n59\t        Path to testhtml file that the scraper will parse..\n60\t    testjson : pathlib.Path\n61\t        Path to testjson file that contains the expected output from the scraper\n62\t        for the testhtml file.\n63\t\n64\t\n65\t    * We can't use the canonical url from the expected output to determine the scraper\n66\t    that should be used because some website that aggregate recipes from others site will\n67\t    set the canonical url to the site the recipe came from. tastykitchen.com is an example\n68\t    of this.\n69\t\n70\t\n71\t    Returns\n72\t    -------\n73\t    Callable\n74\t        Function that asserts the expected output from the scraper matches the\n75\t        actual output.\n76\t    \"\"\"\n77\t\n78\t    def test_func(self):\n79\t        with open(testjson, encoding=\"utf-8\") as f:\n80\t            expect = json.load(f)\n81\t            expect[\"ingredient_groups\"] = (\n82\t                [\n83\t                    IngredientGroup(**group)\n84\t                    for group in expect.get(\"ingredient_groups\", [])\n85\t                ]\n86\t                if \"ingredient_groups\" in expect\n87\t                else [IngredientGroup(expect[\"ingredients\"], purpose=None)]\n88\t            )\n89\t        supported_only = host in SCRAPERS\n90\t        actual = scrape_html(\n91\t            html=testhtml.read_text(encoding=\"utf-8\"),\n92\t            org_url=host,\n93\t            online=False,\n94\t            supported_only=supported_only,\n95\t        )\n96\t        if not supported_only:\n97\t            self.assertFalse(self.been_wild, \"Only one wild mode test should occur.\")\n98\t            type(self).been_wild = True\n99\t\n100\t        # Mandatory tests\n101\t        # If the key isn't present, check an assertion is raised\n102\t        for key in MANDATORY_TESTS:\n103\t            with self.subTest(key):\n104\t                scraper_func = getattr(actual, key)\n105\t                if key in expect.keys():\n106\t                    try:\n107\t                        return_value = scraper_func()\n108\t                    except StaticValueException as e:\n109\t                        return_value = e.return_value\n110\t\n111\t                    self.assertEqual(\n112\t                        expect[key],\n113\t                        return_value,\n114\t                        msg=f\"The actual value for .{key}() did not match the expected value.\",\n115\t                    )\n116\t                else:\n117\t                    with self.assertRaises(\n118\t                        Exception,\n119\t                        msg=f\".{key}() was expected to raise an exception but it did not.\",\n120\t                    ):\n121\t                        scraper_func()\n122\t\n123\t        # Optional tests\n124\t        for key in OPTIONAL_TESTS:\n125\t            if key not in expect:\n126\t                continue  # If the key isn't present, skip\n127\t            with self.subTest(key):\n128\t                scraper_func = getattr(actual, key)\n129\t                try:\n130\t                    return_value = scraper_func()\n131\t                except StaticValueException as e:\n132\t                    return_value = e.return_value\n133\t\n134\t                self.assertEqual(\n135\t                    expect[key],\n136\t                    return_value,\n137\t                    msg=f\"The actual value for .{key}() did not match the expected value.\",\n138\t                )\n139\t\n140\t        grouped = []\n141\t        for group in actual.ingredient_groups():\n142\t            grouped.extend(group.ingredients)\n143\t\n144\t        with self.subTest(\"ingredient_groups\"):\n145\t            self.assertEqual(sorted(actual.ingredients()), sorted(grouped))\n146\t\n147\t        if \"instructions_list\" in expect:\n148\t            list_instructions_normalized = [\n149\t                line.strip() for line in expect[\"instructions_list\"] if line.strip()\n150\t            ]\n151\t\n152\t            string_instructions_normalized = [\n153\t                instruction.strip()\n154\t                for instruction in actual.instructions().split(\"\\n\")\n155\t                if instruction.strip()\n156\t            ]\n157\t\n158\t            with self.subTest(\"instructions_list vs instructions comparison\"):\n159\t                self.assertEqual(\n160\t                    string_instructions_normalized,\n161\t                    list_instructions_normalized,\n162\t                    msg=\"The actual value for .instructions() did not match the value from instructions_list.\",\n163\t                )\n164\t\n165\t    return test_func\n166\t\n167\t\n168\tdef prepare_test_cases():\n169\t    \"\"\"\n170\t    This function dynamically generates the class definition for RecipeTestCase by adding\n171\t    a test function for each pair of testhtml and testjson files found in the\n172\t    tests/test_data directory.\n173\t    \"\"\"\n174\t    test_dir = pathlib.Path(\"tests/test_data\")\n175\t    for host in test_dir.iterdir():\n176\t        if not host.is_dir():\n177\t            continue\n178\t\n179\t        for testhtml in host.glob(\"*.testhtml\"):\n180\t            testjson = testhtml.with_suffix(\".json\")\n181\t            if not testjson.is_file():\n182\t                continue\n183\t\n184\t            # Add a new function to RecipeTestCase class to test this scraper\n185\t            # The name of this function the path to the testjson file.\n186\t            setattr(\n187\t                RecipeTestCase,\n188\t                str(testjson),\n189\t                test_func_factory(host.name, testhtml, testjson),\n190\t            )\n191\t\n192\t\n193\tprepare_test_cases()\n194\t\n195\t\n196\tdef load_tests(\n197\t    loader: unittest.TestLoader, standard_tests: unittest.TestSuite, pattern: str\n198\t) -> unittest.TestSuite:\n199\t    \"\"\"\n200\t    Customise the loading of tests. This function is automatically picked up by the\n201\t    unittest test loader.\n202\t\n203\t    This also includes the library tests from the tests/library folder as well.\n204\t\n205\t\n206\t    Parameters\n207\t    ----------\n208\t    loader : unittest.TestLoader\n209\t        The instance of TestLoader loading the tests when unittest is run\n210\t    standard_tests : unittest.TestSuite\n211\t        The tests found by loader by loading the tests from the tests module.\n212\t        This is empty and unused.\n213\t    pattern : str\n214\t        Pattern used to identify tests to load.\n215\t        This is unused.\n216\t\n217\t    Returns\n218\t    -------\n219\t    unittest.TestSuite\n220\t        A TestSuite object populated with tests from the pairs of testhtml and testjson\n221\t        files, and the library tests.\n222\t    \"\"\"\n223\t\n224\t    # Create a test suite and load all tests from the RecipeTestClass definition\n225\t    suite = unittest.TestSuite()\n226\t    tests = loader.loadTestsFromTestCase(RecipeTestCase)\n227\t    suite.addTest(tests)\n228\t\n229\t    # Add library tests to test suite\n230\t    library_tests = loader.discover(\"tests/library\")\n231\t    suite.addTests(library_tests)\n232\t\n233\t    return suite\n234\t"}]},"parent_tool_use_id":null,"session_id":"f465c12b-50e3-4f5d-a2ba-1b51a6f19ce8","uuid":"ad062b78-3da7-4b71-bc47-2fe4a5819e79","timestamp":"2026-04-09T04:08:59.695Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tests/__init__.py","content":"import json\nimport pathlib\nimport unittest\nfrom typing import Callable\n\nfrom recipe_scrapers import SCRAPERS, scrape_html\nfrom recipe_scrapers._exceptions import StaticValueException\nfrom recipe_scrapers._grouping_utils import IngredientGroup\n\nMANDATORY_TESTS = [\n    \"author\",\n    \"canonical_url\",\n    \"host\",\n    \"image\",\n    \"ingredients\",\n    \"instructions_list\",\n    \"language\",\n    \"site_name\",\n    \"title\",\n    \"total_time\",\n    \"yields\",\n]\n\nOPTIONAL_TESTS = [\n    \"ingredient_groups\",\n    \"instructions\",\n    \"category\",\n    \"description\",\n    \"cook_time\",\n    \"cuisine\",\n    \"nutrients\",\n    \"prep_time\",\n    \"cooking_method\",\n    \"keywords\",\n    \"ratings\",\n    \"equipment\",\n    \"ratings_count\",\n    \"dietary_restrictions\",\n]\n\n\nclass RecipeTestCase(unittest.TestCase):\n    maxDiff = None\n    been_wild = False\n\n\ndef test_func_factory(\n    host: str, testhtml: pathlib.Path, testjson: pathlib.Path\n) -> Callable:\n    \"\"\"\n    Factory function to create a test function that asserts the actual output from\n    the scraper matches the expected output.\n\n    Parameters\n    ----------\n    host : str\n        Host of the site, used to identify the correct scraper to use*\n    testhtml : pathlib.Path\n        Path to testhtml file that the scraper will parse..\n    testjson : pathlib.Path\n        Path to testjson file that contains the expected output from the scraper\n        for the testhtml file.\n\n\n    * We can't use the canonical url from the expected output to determine the scraper\n    that should be used because some website that aggregate recipes from others site will\n    set the canonical url to the site the recipe came from. tastykitchen.com is an example\n    of this.\n\n\n    Returns\n    -------\n    Callable\n        Function that asserts the expected output from the scraper matches the\n        actual output.\n    \"\"\"\n\n    def test_func(self):\n        with open(testjson, encoding=\"utf-8\") as f:\n            expect = json.load(f)\n            expect[\"ingredient_groups\"] = (\n                [\n                    IngredientGroup(**group)\n                    for group in expect.get(\"ingredient_groups\", [])\n                ]\n                if \"ingredient_groups\" in expect\n                else [IngredientGroup(expect[\"ingredients\"], purpose=None)]\n            )\n        supported_only = host in SCRAPERS\n        actual = scrape_html(\n            html=testhtml.read_text(encoding=\"utf-8\"),\n            org_url=host,\n            online=False,\n            supported_only=supported_only,\n        )\n        if not supported_only:\n            self.assertFalse(self.been_wild, \"Only one wild mode test should occur.\")\n            type(self).been_wild = True\n\n        # Mandatory tests\n        # If the key isn't present, check an assertion is raised\n        for key in MANDATORY_TESTS:\n            with self.subTest(key):\n                scraper_func = getattr(actual, key)\n                if key in expect.keys():\n                    try:\n                        return_value = scraper_func()\n                    except StaticValueException as e:\n                        return_value = e.return_value\n\n                    self.assertEqual(\n                        expect[key],\n                        return_value,\n                        msg=f\"The actual value for .{key}() did not match the expected value.\",\n                    )\n                else:\n                    with self.assertRaises(\n                        Exception,\n                        msg=f\".{key}() was expected to raise an exception but it did not.\",\n                    ):\n                        scraper_func()\n\n        # Optional tests\n        for key in OPTIONAL_TESTS:\n            if key not in expect:\n                continue  # If the key isn't present, skip\n            with self.subTest(key):\n                scraper_func = getattr(actual, key)\n                try:\n                    return_value = scraper_func()\n                except StaticValueException as e:\n                    return_value = e.return_value\n\n                self.assertEqual(\n                    expect[key],\n                    return_value,\n                    msg=f\"The actual value for .{key}() did not match the expected value.\",\n                )\n\n        grouped = []\n        for group in actual.ingredient_groups():\n            grouped.extend(group.ingredients)\n\n        with self.subTest(\"ingredient_groups\"):\n            self.assertEqual(sorted(actual.ingredients()), sorted(grouped))\n\n        if \"instructions_list\" in expect:\n            list_instructions_normalized = [\n                line.strip() for line in expect[\"instructions_list\"] if line.strip()\n            ]\n\n            string_instructions_normalized = [\n                instruction.strip()\n                for instruction in actual.instructions().split(\"\\n\")\n                if instruction.strip()\n            ]\n\n            with self.subTest(\"instructions_list vs instructions comparison\"):\n                self.assertEqual(\n                    string_instructions_normalized,\n                    list_instructions_normalized,\n                    msg=\"The actual value for .instructions() did not match the value from instructions_list.\",\n                )\n\n    return test_func\n\n\ndef prepare_test_cases():\n    \"\"\"\n    This function dynamically generates the class definition for RecipeTestCase by adding\n    a test function for each pair of testhtml and testjson files found in the\n    tests/test_data directory.\n    \"\"\"\n    test_dir = pathlib.Path(\"tests/test_data\")\n    for host in test_dir.iterdir():\n        if not host.is_dir():\n            continue\n\n        for testhtml in host.glob(\"*.testhtml\"):\n            testjson = testhtml.with_suffix(\".json\")\n            if not testjson.is_file():\n                continue\n\n            # Add a new function to RecipeTestCase class to test this scraper\n            # The name of this function the path to the testjson file.\n            setattr(\n                RecipeTestCase,\n                str(testjson),\n                test_func_factory(host.name, testhtml, testjson),\n            )\n\n\nprepare_test_cases()\n\n\ndef load_tests(\n    loader: unittest.TestLoader, standard_tests: unittest.TestSuite, pattern: str\n) -> unittest.TestSuite:\n    \"\"\"\n    Customise the loading of tests. This function is automatically picked up by the\n    unittest test loader.\n\n    This also includes the library tests from the tests/library folder as well.\n\n\n    Parameters\n    ----------\n    loader : unittest.TestLoader\n        The instance of TestLoader loading the tests when unittest is run\n    standard_tests : unittest.TestSuite\n        The tests found by loader by loading the tests from the tests module.\n        This is empty and unused.\n    pattern : str\n        Pattern used to identify tests to load.\n        This is unused.\n\n    Returns\n    -------\n    unittest.TestSuite\n        A TestSuite object populated with tests from the pairs of testhtml and testjson\n        files, and the library tests.\n    \"\"\"\n\n    # Create a test suite and load all tests from the RecipeTestClass definition\n    suite = unittest.TestSuite()\n    tests = loader.loadTestsFromTestCase(RecipeTestCase)\n    suite.addTest(tests)\n\n    # Add library tests to test suite\n    library_tests = loader.discover(\"tests/library\")\n    suite.addTests(library_tests)\n\n    return suite\n","numLines":234,"startLine":1,"totalLines":234}}}
