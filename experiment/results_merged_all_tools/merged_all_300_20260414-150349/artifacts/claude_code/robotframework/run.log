{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_a8734bfde6dc40e3abd1f9d9","type":"tool_result","content":"1\t#!/usr/bin/env python\n2\t\n3\t\"\"\"Helper script to run all Robot Framework's unit tests.\n4\t\n5\tusage: utest/run.py [options] [directory]\n6\t\n7\toptions:\n8\t    -q, --quiet     Minimal output\n9\t    -v, --verbose   Verbose output\n10\t    -d, --doc       Show test's doc string instead of name and class\n11\t                    (implies verbosity)\n12\t    -h, --help      Show help\n13\t\n14\t`directory` is the path of the directory under the `utest` folder to execute.\n15\tIf no value is given all tests are run\n16\t\n17\texamples:\n18\t$ utest/run.py -q output\n19\tThis will run only the unit tests in the subdirectory output\n20\t\"\"\"\n21\t\n22\timport argparse\n23\timport os\n24\timport re\n25\timport sys\n26\timport unittest\n27\timport warnings\n28\t\n29\tif not sys.warnoptions:\n30\t    warnings.simplefilter(\"always\")\n31\t    if sys.version_info >= (3, 10):\n32\t        warnings.simplefilter(\"error\", EncodingWarning)  # noqa: F821\n33\t\n34\t\n35\tbase = os.path.abspath(os.path.normpath(os.path.split(sys.argv[0])[0]))\n36\tfor path in [\"../src\", \"../atest/testresources/testlibs\", \"../utest/resources\"]:\n37\t    path = os.path.join(base, path.replace(\"/\", os.sep))\n38\t    if path not in sys.path:\n39\t        sys.path.insert(0, path)\n40\t\n41\ttestfile = re.compile(r\"^test_.*\\.py$\", re.IGNORECASE)\n42\timported = {}\n43\t\n44\t\n45\tdef get_tests(directory=None):\n46\t    if directory is None:\n47\t        directory = base\n48\t    else:\n49\t        directory = os.path.join(base, directory)\n50\t    sys.path.insert(0, directory)\n51\t    tests = []\n52\t    for name in sorted(os.listdir(directory)):\n53\t        if name.startswith(\".\"):\n54\t            continue\n55\t        fullname = os.path.join(directory, name)\n56\t        if os.path.isdir(fullname):\n57\t            tests.extend(get_tests(fullname))\n58\t        elif testfile.match(name):\n59\t            modname = os.path.splitext(name)[0]\n60\t            if modname in imported:\n61\t                print(\n62\t                    f\"Test module '{modname}' imported both as '{imported[modname]}' \"\n63\t                    f\"and '{os.path.join(directory, name)}'. Rename one or fix test \"\n64\t                    f\"discovery.\",\n65\t                    file=sys.stderr,\n66\t                )\n67\t                sys.exit(1)\n68\t            module = __import__(modname)\n69\t            imported[modname] = module.__file__\n70\t            tests.append(unittest.defaultTestLoader.loadTestsFromModule(module))\n71\t    return tests\n72\t\n73\t\n74\tdef usage_exit(msg=None):\n75\t    print(__doc__)\n76\t    if msg is None:\n77\t        rc = 251\n78\t    else:\n79\t        print(\"\\nError:\", msg)\n80\t        rc = 252\n81\t    sys.exit(rc)\n82\t\n83\t\n84\tif __name__ == \"__main__\":\n85\t    parser = argparse.ArgumentParser(add_help=False, description=__doc__)\n86\t    parser.add_argument(\"-I\", \"--interpreter\", default=sys.executable)\n87\t    parser.add_argument(\"-h\", \"--help\", action=\"store_true\")\n88\t    parser.add_argument(\"-q\", \"--quiet\", dest=\"vrbst\", action=\"store_const\", const=0)\n89\t    parser.add_argument(\"-v\", \"--verbose\", dest=\"vrbst\", action=\"store_const\", const=2)\n90\t    parser.add_argument(\"-d\", \"--doc\", dest=\"docs\", action=\"store_true\")\n91\t    parser.add_argument(\"-x\", \"--exit-on-failure\", dest=\"failfast\", action=\"store_true\")\n92\t    parser.add_argument(dest=\"directory\", nargs=\"?\", action=\"store\", default=None)\n93\t    parser.set_defaults(vrbst=1)\n94\t\n95\t    args = parser.parse_args()\n96\t    if args.docs:\n97\t        args.vrbst = 2\n98\t    if args.help:\n99\t        usage_exit()\n100\t"}]},"parent_tool_use_id":null,"session_id":"4994e1f6-1805-4261-a830-b70345874940","uuid":"2619e7cb-abff-4df6-af0b-a54de6e31cd9","timestamp":"2026-04-09T02:40:07.197Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/utest/run.py","content":"#!/usr/bin/env python\n\n\"\"\"Helper script to run all Robot Framework's unit tests.\n\nusage: utest/run.py [options] [directory]\n\noptions:\n    -q, --quiet     Minimal output\n    -v, --verbose   Verbose output\n    -d, --doc       Show test's doc string instead of name and class\n                    (implies verbosity)\n    -h, --help      Show help\n\n`directory` is the path of the directory under the `utest` folder to execute.\nIf no value is given all tests are run\n\nexamples:\n$ utest/run.py -q output\nThis will run only the unit tests in the subdirectory output\n\"\"\"\n\nimport argparse\nimport os\nimport re\nimport sys\nimport unittest\nimport warnings\n\nif not sys.warnoptions:\n    warnings.simplefilter(\"always\")\n    if sys.version_info >= (3, 10):\n        warnings.simplefilter(\"error\", EncodingWarning)  # noqa: F821\n\n\nbase = os.path.abspath(os.path.normpath(os.path.split(sys.argv[0])[0]))\nfor path in [\"../src\", \"../atest/testresources/testlibs\", \"../utest/resources\"]:\n    path = os.path.join(base, path.replace(\"/\", os.sep))\n    if path not in sys.path:\n        sys.path.insert(0, path)\n\ntestfile = re.compile(r\"^test_.*\\.py$\", re.IGNORECASE)\nimported = {}\n\n\ndef get_tests(directory=None):\n    if directory is None:\n        directory = base\n    else:\n        directory = os.path.join(base, directory)\n    sys.path.insert(0, directory)\n    tests = []\n    for name in sorted(os.listdir(directory)):\n        if name.startswith(\".\"):\n            continue\n        fullname = os.path.join(directory, name)\n        if os.path.isdir(fullname):\n            tests.extend(get_tests(fullname))\n        elif testfile.match(name):\n            modname = os.path.splitext(name)[0]\n            if modname in imported:\n                print(\n                    f\"Test module '{modname}' imported both as '{imported[modname]}' \"\n                    f\"and '{os.path.join(directory, name)}'. Rename one or fix test \"\n                    f\"discovery.\",\n                    file=sys.stderr,\n                )\n                sys.exit(1)\n            module = __import__(modname)\n            imported[modname] = module.__file__\n            tests.append(unittest.defaultTestLoader.loadTestsFromModule(module))\n    return tests\n\n\ndef usage_exit(msg=None):\n    print(__doc__)\n    if msg is None:\n        rc = 251\n    else:\n        print(\"\\nError:\", msg)\n        rc = 252\n    sys.exit(rc)\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser(add_help=False, description=__doc__)\n    parser.add_argument(\"-I\", \"--interpreter\", default=sys.executable)\n    parser.add_argument(\"-h\", \"--help\", action=\"store_true\")\n    parser.add_argument(\"-q\", \"--quiet\", dest=\"vrbst\", action=\"store_const\", const=0)\n    parser.add_argument(\"-v\", \"--verbose\", dest=\"vrbst\", action=\"store_const\", const=2)\n    parser.add_argument(\"-d\", \"--doc\", dest=\"docs\", action=\"store_true\")\n    parser.add_argument(\"-x\", \"--exit-on-failure\", dest=\"failfast\", action=\"store_true\")\n    parser.add_argument(dest=\"directory\", nargs=\"?\", action=\"store\", default=None)\n    parser.set_defaults(vrbst=1)\n\n    args = parser.parse_args()\n    if args.docs:\n        args.vrbst = 2\n    if args.help:\n        usage_exit()\n","numLines":100,"startLine":1,"totalLines":113}}}
