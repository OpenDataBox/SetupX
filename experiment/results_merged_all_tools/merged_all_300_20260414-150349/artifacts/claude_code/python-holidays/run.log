{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_e0bd54e67cf549f890b8a44c","type":"tool_result","content":"1\t.DEFAULT_GOAL := help\n2\t\n3\t.PHONY: help\n4\t\n5\thelp:\n6\t\t@echo \"Usage: make <target>\"\n7\t\t@echo \"    archive-links update URLs using Wayback Machine\"\n8\t\t@echo \"    check         run pre-commit and tests\"\n9\t\t@echo \"    doc           run documentation build process\"\n10\t\t@echo \"    doc-serve     serve documentation locally\"\n11\t\t@echo \"    help          show summary of available commands\"\n12\t\t@echo \"    icalendar     generate JSON and ICS data files\"\n13\t\t@echo \"    l10n          update .pot and .po files\"\n14\t\t@echo \"    package       build package distribution\"\n15\t\t@echo \"    pre-commit    run pre-commit against all files\"\n16\t\t@echo \"    setup         setup development environment\"\n17\t\t@echo \"    test          run tests (in parallel)\"\n18\t\t@echo \"    upgrade       run dependency upgrade\"\n19\t\n20\tarchive-links:\n21\t\tuv run --no-sync scripts/archive_links.py\n22\t\n23\tcheck:\n24\t\tmake l10n\n25\t\tmake pre-commit\n26\t\tmake doc\n27\t\tmake test\n28\t\n29\tclean:\n30\t\t@for ext in mo pot pyc; do \\\n31\t\t\tfind . -type f -name \"*.$$ext\" -delete; \\\n32\t\tdone\n33\t\t@rm -rf .mypy_cache .pytest_cache dist\n34\t\n35\tdoc:\n36\t\tuv run --no-sync properdocs build -f .properdocs.yml\n37\t\n38\tdoc-serve:\n39\t\tuv run --no-sync properdocs serve -f .properdocs.yml\n40\t\n41\ticalendar:\n42\t\tuv run --no-sync scripts/l10n/generate_mo_files.py\n43\t\tuv run --no-sync scripts/generate_site_assets.py\n44\t\n45\tl10n:\n46\t\tfind . -type f -name \"*.pot\" -delete\n47\t\tuv run --no-sync scripts/l10n/generate_po_files.py 2>/dev/null\n48\t\tuv run --no-sync scripts/l10n/generate_mo_files.py\n49\t\n50\tpackage:\n51\t\tuv run --no-sync scripts/l10n/generate_mo_files.py\n52\t\tuv build\n53\t\n54\tpre-commit:\n55\t\tuv run --no-sync pre-commit run --all-files\n56\t\n57\trelease-notes:\n58\t\tuv run --no-sync scripts/generate_release_notes.py\n59\t\n60\tsbom:\n61\t\tuv tool run --from cyclonedx-bom cyclonedx-py environment \"$(uv python find)\"\n62\t\n63\tsetup:\n64\t\tuv venv --clear --python 3.14\n65\t\tuv sync --all-groups\n66\t\tuv run --no-sync pre-commit install --hook-type pre-commit\n67\t\tuv run --no-sync pre-commit install --hook-type pre-push\n68\t\tmake l10n\n69\t\tmake package\n70\t\n71\tsnapshot:\n72\t\tuv run --no-sync scripts/l10n/generate_mo_files.py\n73\t\tuv run --no-sync scripts/generate_snapshots.py\n74\t\n75\ttest:\n76\t\tuv run --no-sync scripts/l10n/generate_mo_files.py\n77\t\tuv run --no-sync pytest --cov=. --cov-config=pyproject.toml --cov-report term-missing --cov-report xml --durations 10 --durations-min=0.75 --dist loadscope --no-cov-on-fail --numprocesses auto\n78\t\n79\tupgrade:\n80\t\tpre-commit autoupdate\n81\t\tuv lock --upgrade\n82\t\tuv sync --all-groups\n83\t"}]},"parent_tool_use_id":null,"session_id":"4b73d48e-1532-4e08-8752-4be5dff1b453","uuid":"36c981fe-d7c0-43d2-ae08-e8851cb9e01f","timestamp":"2026-04-07T00:14:32.800Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/Makefile","content":".DEFAULT_GOAL := help\n\n.PHONY: help\n\nhelp:\n\t@echo \"Usage: make <target>\"\n\t@echo \"    archive-links update URLs using Wayback Machine\"\n\t@echo \"    check         run pre-commit and tests\"\n\t@echo \"    doc           run documentation build process\"\n\t@echo \"    doc-serve     serve documentation locally\"\n\t@echo \"    help          show summary of available commands\"\n\t@echo \"    icalendar     generate JSON and ICS data files\"\n\t@echo \"    l10n          update .pot and .po files\"\n\t@echo \"    package       build package distribution\"\n\t@echo \"    pre-commit    run pre-commit against all files\"\n\t@echo \"    setup         setup development environment\"\n\t@echo \"    test          run tests (in parallel)\"\n\t@echo \"    upgrade       run dependency upgrade\"\n\narchive-links:\n\tuv run --no-sync scripts/archive_links.py\n\ncheck:\n\tmake l10n\n\tmake pre-commit\n\tmake doc\n\tmake test\n\nclean:\n\t@for ext in mo pot pyc; do \\\n\t\tfind . -type f -name \"*.$$ext\" -delete; \\\n\tdone\n\t@rm -rf .mypy_cache .pytest_cache dist\n\ndoc:\n\tuv run --no-sync properdocs build -f .properdocs.yml\n\ndoc-serve:\n\tuv run --no-sync properdocs serve -f .properdocs.yml\n\nicalendar:\n\tuv run --no-sync scripts/l10n/generate_mo_files.py\n\tuv run --no-sync scripts/generate_site_assets.py\n\nl10n:\n\tfind . -type f -name \"*.pot\" -delete\n\tuv run --no-sync scripts/l10n/generate_po_files.py 2>/dev/null\n\tuv run --no-sync scripts/l10n/generate_mo_files.py\n\npackage:\n\tuv run --no-sync scripts/l10n/generate_mo_files.py\n\tuv build\n\npre-commit:\n\tuv run --no-sync pre-commit run --all-files\n\nrelease-notes:\n\tuv run --no-sync scripts/generate_release_notes.py\n\nsbom:\n\tuv tool run --from cyclonedx-bom cyclonedx-py environment \"$(uv python find)\"\n\nsetup:\n\tuv venv --clear --python 3.14\n\tuv sync --all-groups\n\tuv run --no-sync pre-commit install --hook-type pre-commit\n\tuv run --no-sync pre-commit install --hook-type pre-push\n\tmake l10n\n\tmake package\n\nsnapshot:\n\tuv run --no-sync scripts/l10n/generate_mo_files.py\n\tuv run --no-sync scripts/generate_snapshots.py\n\ntest:\n\tuv run --no-sync scripts/l10n/generate_mo_files.py\n\tuv run --no-sync pytest --cov=. --cov-config=pyproject.toml --cov-report term-missing --cov-report xml --durations 10 --durations-min=0.75 --dist loadscope --no-cov-on-fail --numprocesses auto\n\nupgrade:\n\tpre-commit autoupdate\n\tuv lock --upgrade\n\tuv sync --all-groups\n","numLines":83,"startLine":1,"totalLines":83}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0da8b8dbbaaf433da4cdd7a7","type":"tool_result","content":"1\t# Contributing\n2\t\n3\t## Basics\n4\t\n5\tWhen contributing with fixes and new features, please start forking/branching from the [dev\n6\tbranch](https://github.com/vacanza/holidays/tree/dev) to work on the latest code and reduce merging\n7\tissues. If you add/change holiday official dates or names, your code must include references to all\n8\tsources (government sites, archived web pages, wiki pages, etc.) you've used while working on this\n9\tPR. That could be done either as a `References` section update or as a comment on the relevant part\n10\tof the code. Contributed [PRs](https://github.com/vacanza/holidays/pulls) are required to include\n11\t100% test coverage in order to be merged. Please don't hesitate to ask for help if you need one\n12\twith the tests.\n13\t\n14\tThanks a lot for your support.\n15\t\n16\t## Running tests\n17\t\n18\tFirst step is setting up the development environment and installing all the required dependencies\n19\twith, once you have [`uv`](https://docs.astral.sh/uv/getting-started/installation/#installation-methods) setup:\n20\t\n21\t<!-- markdownlint-disable MD046 -->\n22\t=== \"macOS and Linux\"\n23\t\n24\t    ``` shell\n25\t    make setup\n26\t    ```\n27\t\n28\t=== \"Windows\"\n29\t\n30\t    ``` shell\n31\t    .\\make setup\n32\t    ```\n33\t\n34\t> [!note]\n35\t> **WSL Windows File Permission Fix**\n36\t>\n37\t> If you're a Windows-based developer setting this up via WSL for the first time and encounter\n38\t> file permission errors (e.g., `[Errno 1] Operation not permitted`) where `ls -l` shows files\n39\t> owned by root like `-rwxrwxrwx 1 root root ...`, follow these steps:\n40\t>\n41\t> **Step 1**: Edit the WSL configuration file:\n42\t>\n43\t> ``` shell\n44\t> sudo nano /etc/wsl.conf\n45\t> ```\n46\t>\n47\t> **Step 2**: Add the following section at the bottom of `wsl.conf`, then save (Ctrl+O, Enter) and exit (Ctrl+X):\n48\t>\n49\t> ``` ini\n50\t> [automount]\n51\t> enabled = true\n52\t> options = \"metadata,umask=22,fmask=11\"\n53\t> ```\n54\t>\n55\t> **Step 3**: Close your WSL session, open PowerShell, then restart WSL:\n56\t>\n57\t> ``` powershell\n58\t> wsl --shutdown\n59\t> wsl ~\n60\t> ```\n61\t>\n62\t> After this, running `ls -l` on your local `holidays` installation should show:\n63\t>\n64\t> ``` console\n65\t> drwxr-xr-x 1 username username ...\n66\t> ```\n67\t>\n68\t> You're good to go!\n69\t\n70\tThe project provides automated style, tests and coverage checks:\n71\t\n72\t=== \"macOS and Linux\"\n73\t\n74\t    ``` shell\n75\t    make check\n76\t    ```\n77\t\n78\t=== \"Windows\"\n79\t\n80\t    ``` shell\n81\t    .\\make check\n82\t    ```\n83\t\n84\tYou can run them separately:\n85\t\n86\t=== \"macOS and Linux\"\n87\t\n88\t    ``` shell\n89\t    make pre-commit\n90\t    make test\n91\t    ```\n92\t\n93\t=== \"Windows\"\n94\t\n95\t    ``` shell\n96\t    .\\make pre-commit\n97\t    .\\make test\n98\t    ```\n99\t\n100\tIt'll retrieve uncovered lines too.\n101\t\n102\tYou can run specific tests using the `pytest` command:\n103\t\n104\t``` shell\n105\tpytest tests/countries/test_argentina.py\n106\t```\n107\t\n108\tOr even more granular:\n109\t\n110\t``` shell\n111\tpytest tests/countries/test_argentina.py::TestArgentina::test_country_aliases\n112\t```\n113\t\n114\tDue to how pytest-xdist is implemented, the -s/--capture=no option [doesn't\n115\twork](https://pytest-xdist.readthedocs.io/en/latest/known-limitations.html#output-stdout-and-stderr-from-workers).\n116\tUse pytest directly if you need `-s` option:\n117\t\n118\t``` shell\n119\tpytest -s tests/countries/test_argentina.py\n120\t```\n121\t\n122\t## Localization\n123\t\n124\tIn order to add or update existing holiday names translation you'll need to generate pygettext\n125\t.pot file first:\n126\t\n127\t=== \"macOS and Linux\"\n128\t\n129\t    ``` shell\n130\t    make l10n\n131\t    ```\n132\t\n133\t=== \"Windows\"\n134\t\n135\t    ``` shell\n136\t    .\\make l10n\n137\t    ```\n138\t\n139\tIf the template file is empty, make sure that the country/market entity has the `default_language`\n140\tattribute set, and all holiday names are wrapped with `tr`/`self.tr` helpers. Use [ISO 639-1\n141\tcodes](https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes) when adding new languages. Copy the\n142\tgenerated template to all locale folders you're going to translate this country holiday names into\n143\t(e.g., for Argentina: holidays/locale/en/LC_MESSAGES/AR.po - note the file extension difference\n144\there). Also copy the template to the default country or market language folder (e.g., for\n145\tArgentina `holidays/locale/es/LC_MESSAGES`) and leave holiday-name `msgstr` entries empty. After\n146\tcopying the `.po` files, open them with your favorite `.po` file editor and translate the\n147\t**non-default** locales only. Don't forget to fill in the translation file headers. Finally, update\n148\tthe list of supported translations for the country in the README.md.\n149\t\n150\t> [!note]\n151\t> **Default language `.po` files**\n152\t>\n153\t> In this project, the `.po` file for each country or market's **default** language (the one that\n154\t> matches that entity's `default_language` attribute) **intentionally** keeps `msgstr` values\n155\t> empty for those messages. Holiday names are already authored in that language in the source\n156\t> code; the catalog is still required for tooling and consistency. Please do not treat empty\n157\t> `msgstr` lines there as missing work or duplicate the `msgid` text into `msgstr` unless\n158\t> maintainers explicitly ask for a change.\n159\t\n160\tIf the translation already exists you'll just need to update it with the new template entries\n161\t(your .po file editor may help you to do that with no hassle).\n162\t\n163\tPlease also add tests (see already translated countries tests for examples). The .mo files are\n164\tgenerated automatically for the tests and the holidays package, so you shouldn't worry about it.\n165\tJust don't forget to initialize the `setUpClass` properly:\n166\t\n167\t``` python\n168\t@classmethod\n169\tdef setUpClass(cls):\n170\t    super().setUpClass(Argentina)\n171\t```\n172\t\n173\t## Build ProperDocs Documentation\n174\t\n175\tThe project provides ProperDocs documentation under `./docs`, published online on\n176\t[readthedocs.io](https://holidays.readthedocs.io/).\n177\t\n178\tGreat documentation is absolutely key in any project. ProperDocs is a fork of MkDocs,\n179\tso if you are not familiar with writing Markdown for ProperDocs, here you can read a\n180\t[ProperDocs Primer](https://properdocs.org/user-guide/writing-your-docs/).\n181\t\n182\t## GitHub Actions\n183\t\n184\tAll new GitHub actions must use commit SHAs instead of version tags. When updating an action, contributors should explicitly use the commit SHA from the latest release.\n185\t\n186\t### Example\n187\t\n188\tAllowed:\n189\t\n190\t```yaml\n191\tuses: actions/checkout@8fdb40e56baf9c5dc24e3ab5bc2a91db65f39f21\n192\t```\n193\t\n194\tNot allowed:\n195\t\n196\t```yaml\n197\tuses: actions/checkout@v4\n198\t```\n199\t\n200\t## Contributors\n201\t\n202\tIn order to keep the list of contributors up to date, we encourage you add your name (in\n203\talphabetical order) to the [CONTRIBUTORS](https://github.com/vacanza/holidays/blob/dev/CONTRIBUTORS)\n204\tfile if it's not there yet. Thanks for your contribution!\n205\t\n206\t[![contributors](https://img.shields.io/github/contributors/vacanza/holidays)](https://github.com/vacanza/holidays/graphs/contributors)\n207\t"}]},"parent_tool_use_id":null,"session_id":"4b73d48e-1532-4e08-8752-4be5dff1b453","uuid":"e47bf28b-be23-4fef-9572-959e2097d103","timestamp":"2026-04-07T00:14:32.801Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/CONTRIBUTING.md","content":"# Contributing\n\n## Basics\n\nWhen contributing with fixes and new features, please start forking/branching from the [dev\nbranch](https://github.com/vacanza/holidays/tree/dev) to work on the latest code and reduce merging\nissues. If you add/change holiday official dates or names, your code must include references to all\nsources (government sites, archived web pages, wiki pages, etc.) you've used while working on this\nPR. That could be done either as a `References` section update or as a comment on the relevant part\nof the code. Contributed [PRs](https://github.com/vacanza/holidays/pulls) are required to include\n100% test coverage in order to be merged. Please don't hesitate to ask for help if you need one\nwith the tests.\n\nThanks a lot for your support.\n\n## Running tests\n\nFirst step is setting up the development environment and installing all the required dependencies\nwith, once you have [`uv`](https://docs.astral.sh/uv/getting-started/installation/#installation-methods) setup:\n\n<!-- markdownlint-disable MD046 -->\n=== \"macOS and Linux\"\n\n    ``` shell\n    make setup\n    ```\n\n=== \"Windows\"\n\n    ``` shell\n    .\\make setup\n    ```\n\n> [!note]\n> **WSL Windows File Permission Fix**\n>\n> If you're a Windows-based developer setting this up via WSL for the first time and encounter\n> file permission errors (e.g., `[Errno 1] Operation not permitted`) where `ls -l` shows files\n> owned by root like `-rwxrwxrwx 1 root root ...`, follow these steps:\n>\n> **Step 1**: Edit the WSL configuration file:\n>\n> ``` shell\n> sudo nano /etc/wsl.conf\n> ```\n>\n> **Step 2**: Add the following section at the bottom of `wsl.conf`, then save (Ctrl+O, Enter) and exit (Ctrl+X):\n>\n> ``` ini\n> [automount]\n> enabled = true\n> options = \"metadata,umask=22,fmask=11\"\n> ```\n>\n> **Step 3**: Close your WSL session, open PowerShell, then restart WSL:\n>\n> ``` powershell\n> wsl --shutdown\n> wsl ~\n> ```\n>\n> After this, running `ls -l` on your local `holidays` installation should show:\n>\n> ``` console\n> drwxr-xr-x 1 username username ...\n> ```\n>\n> You're good to go!\n\nThe project provides automated style, tests and coverage checks:\n\n=== \"macOS and Linux\"\n\n    ``` shell\n    make check\n    ```\n\n=== \"Windows\"\n\n    ``` shell\n    .\\make check\n    ```\n\nYou can run them separately:\n\n=== \"macOS and Linux\"\n\n    ``` shell\n    make pre-commit\n    make test\n    ```\n\n=== \"Windows\"\n\n    ``` shell\n    .\\make pre-commit\n    .\\make test\n    ```\n\nIt'll retrieve uncovered lines too.\n\nYou can run specific tests using the `pytest` command:\n\n``` shell\npytest tests/countries/test_argentina.py\n```\n\nOr even more granular:\n\n``` shell\npytest tests/countries/test_argentina.py::TestArgentina::test_country_aliases\n```\n\nDue to how pytest-xdist is implemented, the -s/--capture=no option [doesn't\nwork](https://pytest-xdist.readthedocs.io/en/latest/known-limitations.html#output-stdout-and-stderr-from-workers).\nUse pytest directly if you need `-s` option:\n\n``` shell\npytest -s tests/countries/test_argentina.py\n```\n\n## Localization\n\nIn order to add or update existing holiday names translation you'll need to generate pygettext\n.pot file first:\n\n=== \"macOS and Linux\"\n\n    ``` shell\n    make l10n\n    ```\n\n=== \"Windows\"\n\n    ``` shell\n    .\\make l10n\n    ```\n\nIf the template file is empty, make sure that the country/market entity has the `default_language`\nattribute set, and all holiday names are wrapped with `tr`/`self.tr` helpers. Use [ISO 639-1\ncodes](https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes) when adding new languages. Copy the\ngenerated template to all locale folders you're going to translate this country holiday names into\n(e.g., for Argentina: holidays/locale/en/LC_MESSAGES/AR.po - note the file extension difference\nhere). Also copy the template to the default country or market language folder (e.g., for\nArgentina `holidays/locale/es/LC_MESSAGES`) and leave holiday-name `msgstr` entries empty. After\ncopying the `.po` files, open them with your favorite `.po` file editor and translate the\n**non-default** locales only. Don't forget to fill in the translation file headers. Finally, update\nthe list of supported translations for the country in the README.md.\n\n> [!note]\n> **Default language `.po` files**\n>\n> In this project, the `.po` file for each country or market's **default** language (the one that\n> matches that entity's `default_language` attribute) **intentionally** keeps `msgstr` values\n> empty for those messages. Holiday names are already authored in that language in the source\n> code; the catalog is still required for tooling and consistency. Please do not treat empty\n> `msgstr` lines there as missing work or duplicate the `msgid` text into `msgstr` unless\n> maintainers explicitly ask for a change.\n\nIf the translation already exists you'll just need to update it with the new template entries\n(your .po file editor may help you to do that with no hassle).\n\nPlease also add tests (see already translated countries tests for examples). The .mo files are\ngenerated automatically for the tests and the holidays package, so you shouldn't worry about it.\nJust don't forget to initialize the `setUpClass` properly:\n\n``` python\n@classmethod\ndef setUpClass(cls):\n    super().setUpClass(Argentina)\n```\n\n## Build ProperDocs Documentation\n\nThe project provides ProperDocs documentation under `./docs`, published online on\n[readthedocs.io](https://holidays.readthedocs.io/).\n\nGreat documentation is absolutely key in any project. ProperDocs is a fork of MkDocs,\nso if you are not familiar with writing Markdown for ProperDocs, here you can read a\n[ProperDocs Primer](https://properdocs.org/user-guide/writing-your-docs/).\n\n## GitHub Actions\n\nAll new GitHub actions must use commit SHAs instead of version tags. When updating an action, contributors should explicitly use the commit SHA from the latest release.\n\n### Example\n\nAllowed:\n\n```yaml\nuses: actions/checkout@8fdb40e56baf9c5dc24e3ab5bc2a91db65f39f21\n```\n\nNot allowed:\n\n```yaml\nuses: actions/checkout@v4\n```\n\n## Contributors\n\nIn order to keep the list of contributors up to date, we encourage you add your name (in\nalphabetical order) to the [CONTRIBUTORS](https://github.com/vacanza/holidays/blob/dev/CONTRIBUTORS)\nfile if it's not there yet. Thanks for your contribution!\n\n[![contributors](https://img.shields.io/github/contributors/vacanza/holidays)](https://github.com/vacanza/holidays/graphs/contributors)\n","numLines":207,"startLine":1,"totalLines":207}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_d8c53b7a5b144ce8b164a93e","type":"tool_result","content":"1\t# Holidays\n2\t\n3\tA fast, efficient Python library for generating country- and subdivision- (e.g. state or province)\n4\tspecific sets of government-designated holidays on the fly. It aims to make determining whether a\n5\tspecific date is a holiday as fast and flexible as possible.\n6\t\n7\t<!-- markdownlint-disable MD033 -->\n8\t<table>\n9\t  <tr>\n10\t    <td>PyPI</td>\n11\t    <td>\n12\t      <a href=\"https://pypi.org/project/holidays\"><img src=\"https://img.shields.io/badge/dynamic/yaml?url=https%3A%2F%2Fraw.githubusercontent.com%2Fvacanza%2Faux%2Frefs%2Fheads%2Fmain%2Fbadges%2Fdownloads%2Fpepy.tech.yaml&query=%24.previous_month_downloads_human&suffix=%2Fmonth&style=flat&label=downloads&color=41B5BE&cacheSeconds=86400\" alt=\"PyPI monthly downloads\"></a>&nbsp;<a href=\"https://pypi.org/project/holidays\"><img src=\"https://img.shields.io/pypi/v/holidays?color=41B5BE&label=version&style=flat\" alt=\"PyPI version\"></a>&nbsp;<a href=\"https://github.com/vacanza/holidays/releases\"><img src=\"https://img.shields.io/github/release-date/vacanza/holidays?color=41B5BE&style=flat\" alt=\"Latest release date\"></a>\n13\t    </td>\n14\t  </tr>\n15\t  <tr>\n16\t    <td>CI/CD</td>\n17\t    <td>\n18\t      <a href=\"https://github.com/vacanza/holidays/actions/workflows/ci-cd.yml?query=branch%3Adev\"><img src=\"https://img.shields.io/github/actions/workflow/status/vacanza/holidays/ci-cd.yml?branch=dev&color=41B5BE&style=flat\" alt=\"CI/CD status\"></a>&nbsp;<a href=\"https://holidays.readthedocs.io/en/latest/?badge=latest\"><img src=\"https://img.shields.io/readthedocs/holidays?color=41B5BE&style=flat&label=documentation\" alt=\"Documentation build status\"></a>&nbsp;<a href=\"https://security.snyk.io/package/pip/holidays/\"><img alt=\"Open World Holidays Package Health Score\" src=\"https://img.shields.io/badge/dynamic/regex?url=https%3A%2F%2Fsecurity.snyk.io%2Fpackage%2Fpip%2Fholidays%2F&search=(class%3D%22score-number%22.*%3F%3E)(%5Cd%7B1%2C3%7D%2F%5Cd%7B1%2C3%7D)&replace=%242&style=flat&label=snyk&color=41B5BE\"></a>\n19\t    </td>\n20\t  </tr>\n21\t  <tr>\n22\t    <td>Code</td>\n23\t    <td>\n24\t      <a href=\"https://github.com/vacanza/holidays/blob/dev/LICENSE\"><img src=\"https://img.shields.io/github/license/vacanza/holidays?color=41B5BE&style=flat\" alt=\"License\"></a>&nbsp;<a href=\"https://pypi.org/project/holidays\"><img src=\"https://img.shields.io/pypi/pyversions/holidays?label=python&color=41B5BE&style=flat\" alt=\"Python supported versions\"></a>&nbsp;<a href=\"https://github.com/astral-sh/ruff\"><img src=\"https://img.shields.io/badge/style-ruff-41B5BE?style=flat\" alt=\"Code style\"></a>&nbsp;<a href=\"https://app.codecov.io/gh/vacanza/holidays\"><img src=\"https://img.shields.io/codecov/c/github/vacanza/holidays/dev?color=41B5BE&style=flat\" alt=\"Code coverage\"></a>\n25\t    </td>\n26\t  </tr>\n27\t  <tr>\n28\t    <td>Docs</td>\n29\t    <td>\n30\t      <a href=\"https://holidays.readthedocs.io/en/latest/\"><img src=\"https://img.shields.io/badge/documentation-readthedocs.io-41B5BE?style=flat\" alt=\"Documentation on Read the Docs\"></a>&nbsp;<a href=\"https://deepwiki.com/vacanza/holidays\"><img src=\"https://img.shields.io/badge/documentation-deepwiki.com-41B5BE?style=flat\" alt=\"Documentation on DeepWiki\"></a>\n31\t    </td>\n32\t  </tr>\n33\t  <tr>\n34\t    <td>GitHub</td>\n35\t    <td>\n36\t      <a href=\"https://github.com/vacanza/holidays/stargazers\"><img src=\"https://img.shields.io/github/stars/vacanza/holidays?color=41B5BE&style=flat\" alt=\"GitHub stars\"></a>&nbsp;<a href=\"https://github.com/vacanza/holidays/forks\"><img src=\"https://img.shields.io/github/forks/vacanza/holidays?color=41B5BE&style=flat\" alt=\"GitHub forks\"></a>&nbsp;<a href=\"https://github.com/vacanza/holidays/graphs/contributors\"><img src=\"https://img.shields.io/github/contributors/vacanza/holidays?color=41B5BE&style=flat\" alt=\"GitHub contributors\"></a>&nbsp;<a href=\"https://github.com/vacanza/holidays/commits/dev\"><img src=\"https://img.shields.io/github/last-commit/vacanza/holidays/dev?color=41B5BE&style=flat\" alt=\"GitHub last commit\"></a>\n37\t    </td>\n38\t  </tr>\n39\t  <tr>\n40\t    <td>Citation</td>\n41\t    <td>\n42\t      <a href=\"https://doi.org/10.5281/zenodo.14884702\"><img src=\"https://img.shields.io/badge/DOI-10.5281/zenodo.14884702-41B5BE?style=flat\" alt=\"Open World Holidays Framework DOI\"></a>\n43\t    </td>\n44\t  </tr>\n45\t</table>\n46\t\n47\t## Install\n48\t\n49\tThe latest stable version can always be installed or updated via pip:\n50\t\n51\t``` shell\n52\tpip install --upgrade holidays\n53\t```\n54\t\n55\tThe latest development (dev) version can be installed directly from GitHub:\n56\t\n57\t``` shell\n58\tpip install --upgrade https://github.com/vacanza/holidays/tarball/dev\n59\t```\n60\t\n61\tAll new features are always first pushed to dev branch, then released on main branch upon official\n62\tversion upgrades.\n63\t\n64\t## Documentation\n65\t\n66\tThe documentation is hosted on [Read the Docs](https://holidays.readthedocs.io).\n67\t\n68\t## ICS Exports\n69\t\n70\tHoliday calendars can be exported as `.ics` files via the [download page](https://holidays.readthedocs.io/en/latest/downloads/).\n71\t\n72\t## Quick Start\n73\t\n74\t``` python\n75\tfrom datetime import date\n76\timport holidays\n77\t\n78\tus_holidays = holidays.US()  # this is a dict-like object\n79\t# the below is the same, but takes a string:\n80\tus_holidays = holidays.country_holidays('US')  # this is a dict-like object\n81\t\n82\tnyse_holidays = holidays.NYSE()  # this is a dict-like object\n83\t# the below is the same, but takes a string:\n84\tnyse_holidays = holidays.financial_holidays('NYSE')  # this is a dict-like object\n85\t\n86\tdate(2015, 1, 1) in us_holidays  # True\n87\tdate(2015, 1, 2) in us_holidays  # False\n88\tus_holidays.get('2014-01-01')  # \"New Year's Day\"\n89\t```\n90\t\n91\tThe HolidayBase dict-like class will also recognize date strings and Unix timestamps:\n92\t\n93\t``` python\n94\t'2014-01-01' in us_holidays  # True\n95\t'1/1/2014' in us_holidays    # True\n96\t1388597445 in us_holidays    # True\n97\t```\n98\t\n99\tSome holidays may be only present in parts of a country:\n100\t\n101\t``` python\n102\tus_pr_holidays = holidays.country_holidays('US', subdiv='PR')\n103\t'2018-01-06' in us_holidays     # False\n104\t'2018-01-06' in us_pr_holidays  # True\n105\t```\n106\t\n107\tPlease see the [holidays documentation](https://holidays.readthedocs.io/) for additional examples\n108\tand detailed information.\n109\t\n110\t## Available Countries\n111\t\n112\tWe currently support 250 country codes, which primarily follow [ISO 3166-1](https://www.iso.org/iso-3166-country-codes.html), with a small number of widely used user-assigned or reserved codes (for example, `XK` for Kosovo).\n113\tIn general, the standard way to refer to a country is by using its [ISO 3166-1 alpha-2 code](https://en.wikipedia.org/wiki/List_of_ISO_3166_country_codes),\n114\tthe same used for domain names, and for a subdivision its [ISO 3166-2\n115\tcode](https://en.wikipedia.org/wiki/ISO_3166-2). Some countries have common or foreign names or\n116\tabbreviations as aliases for their subdivisions. These are defined in the (optional)\n117\t`subdivisions_aliases` attribute.\n118\t\n119\t> [!note]\n120\t> **Subdivisions aliases**\n121\t>\n122\t> **Aliases are optional.** When present, `subdivisions_aliases`\n123\t> cover only a subset of subdivisions - commonly used or officially\n124\t> recognized alternative names. Supported subdivisions and their\n125\t> aliases (where available) are listed in the `Subdivisions` column\n126\t> of the table below.\n127\t\n128\tSome of the countries support more than one language for holiday names output. A default language is defined by `default_language` (optional) attribute for each\n129\tentity and is used as a fallback when neither user specified language nor user locale language\n130\tavailable. The default language code is a [ISO 639-1\n131\tcode](https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes). A list of all languages supported by\n132\tcountry is defined by `supported_languages` (optional) attribute. If there is no designated [ISO\n133\t639-1 code](https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes) then [ISO 639-2\n134\tcode](https://en.wikipedia.org/wiki/List_of_ISO_639-2_codes) can be used.\n135\t\n136\tMany countries have other categories of holidays in addition to common (national-wide) holidays:\n137\tbank holidays, school holidays, additional (paid or non-paid) holidays, holidays of state or public\n138\temployees, religious holidays (valid only for these religions followers). A list of all categories\n139\tsupported by country is defined by `supported_categories` (optional) attribute.\n140\t\n141\tThe following is a list of supported countries, their subdivisions followed by their aliases (if\n142\tany) in brackets, available languages and additional holiday categories. All countries support\n143\t**PUBLIC** holidays category by default. All other default values are highlighted with bold:\n144\t\n145\t<table style=\"width: 100%\">\n146\t<colgroup>\n147\t<col style=\"width: 20.0%\" />\n148\t<col style=\"width: 4.0%\" />\n149\t<col style=\"width: 46.0%\" />\n150\t<col style=\"width: 20.0%\" />\n151\t<col style=\"width: 10.0%\" />\n152\t</colgroup>\n153\t<thead>\n154\t<tr>\n155\t<th>Country</th>\n156\t<th>Code</th>\n157\t<th>Subdivisions</th>\n158\t<th>Supported Languages</th>\n159\t<th>Supported Categories</th>\n160\t</tr>\n161\t</thead>\n162\t<tbody>\n163\t<tr>\n164\t<td>Afghanistan</td>\n165\t<td>AF</td>\n166\t<td></td>\n167\t<td>en_US, <strong>fa_AF</strong>, ps_AF</td>\n168\t<td></td>\n169\t</tr>\n170\t<tr>\n171\t<td>Åland Islands</td>\n172\t<td>AX</td>\n173\t<td>Can also be loaded as country FI, subdivision 01</td>\n174\t<td>en_US, <strong>fi</strong>, sv_FI, th, uk</td>\n175\t<td>UNOFFICIAL, WORKDAY</td>\n176\t</tr>\n177\t<tr>\n178\t<td>Albania</td>\n179\t<td>AL</td>\n180\t<td></td>\n181\t<td>en_US, <strong>sq</strong>, uk</td>\n182\t<td></td>\n183\t</tr>\n184\t<tr>\n185\t<td>Algeria</td>\n186\t<td>DZ</td>\n187\t<td></td>\n188\t<td><strong>ar</strong>, en_US, fr</td>\n189\t<td>CHRISTIAN, HEBREW</td>\n190\t</tr>\n191\t<tr>\n192\t<td>American Samoa</td>\n193\t<td>AS</td>\n194\t<td>Can also be loaded as country US, subdivision AS</td>\n195\t<td><strong>en_US</strong>, th</td>\n196\t<td>UNOFFICIAL</td>\n197\t</tr>\n198\t<tr>\n199\t<td>Andorra</td>\n200\t<td>AD</td>\n201\t<td>Parishes: 02 (Canillo), 03 (Encamp), 04 (La Massana), 05 (Ordino), 06 (Sant Julià de Lòria), 07 (Andorra la Vella), 08 (Escaldes-Engordany)</td>\n202\t<td><strong>ca</strong>, en_US, uk</td>\n203\t<td>GOVERNMENT</td>\n204\t</tr>\n205\t<tr>\n206\t<td>Angola</td>\n207\t<td>AO</td>\n208\t<td></td>\n209\t<td>en_US, <strong>pt_AO</strong>, uk</td>\n210\t<td></td>\n211\t</tr>\n212\t<tr>\n213\t<td>Anguilla</td>\n214\t<td>AI</td>\n215\t<td></td>\n216\t<td><strong>en_AI</strong>, en_US</td>\n217\t<td></td>\n218\t</tr>\n219\t<tr>\n220\t<td>Antarctica</td>\n221\t<td>AQ</td>\n222\t<td></td>\n223\t<td></td>\n224\t<td></td>\n225\t</tr>\n226\t<tr>\n227\t<td>Antigua and Barbuda</td>\n228\t<td>AG</td>\n229\t<td></td>\n230\t<td></td>\n231\t<td></td>\n232\t</tr>\n233\t<tr>\n234\t<td>Argentina</td>\n235\t<td>AR</td>\n236\t<td>Provinces: A (Salta), B (Buenos Aires), C (Ciudad Autónoma de Buenos Aires), D (San Luis), E (Entre Ríos), F (La Rioja), G (Santiago del Estero), H (Chaco), J (San Juan), K (Catamarca), L (La Pampa), M (Mendoza), N (Misiones), P (Formosa), Q (Neuquén), R (Río Negro), S (Santa Fe), T (Tucumán), U (Chubut), V (Tierra del Fuego), W (Corrientes), X (Córdoba), Y (Jujuy), Z (Santa Cruz)</td>\n237\t<td>en_US, <strong>es</strong>, uk</td>\n238\t<td>ARMENIAN, BANK, GOVERNMENT, HEBREW, ISLAMIC</td>\n239\t</tr>\n240\t<tr>\n241\t<td>Armenia</td>\n242\t<td>AM</td>\n243\t<td>Regions: AG (Aragac̣otn, Aragatsotn), AR (Ararat), AV (Armavir), ER (Erevan), GR (Geġark'unik', Gegharkunik), KT (Kotayk', Kotayk), LO (Loṙi, Lori), SH (Širak, Shirak), SU (Syunik', Syunik), TV (Tavuš, Tavush), VD (Vayoć Jor, Vayots Dzor)</td>\n244\t<td>en_US, <strong>hy</strong></td>\n245\t<td>WORKDAY</td>\n246\t</tr>\n247\t<tr>\n248\t<td>Aruba</td>\n249\t<td>AW</td>\n250\t<td></td>\n251\t<td>en_US, nl, <strong>pap_AW</strong>, uk</td>\n252\t<td></td>\n253\t</tr>\n254\t<tr>\n255\t<td>Australia</td>\n256\t<td>AU</td>\n257\t<td>States and territories: ACT (Australian Capital Territory), NSW (New South Wales), NT (Northern Territory), QLD (Queensland), SA (South Australia), TAS (Tasmania), VIC (Victoria), WA (Western Australia)</td>\n258\t<td><strong>en_AU</strong>, en_US, th</td>\n259\t<td>BANK, HALF_DAY</td>\n260\t</tr>\n261\t<tr>\n262\t<td>Austria</td>\n263\t<td>AT</td>\n264\t<td>States: 1 (Burgenland, Bgld, B), 2 (Kärnten, Ktn, K), 3 (Niederösterreich, NÖ, N), 4 (Oberösterreich, OÖ, O), 5 (Salzburg, Sbg, S), 6 (Steiermark, Stmk, St), 7 (Tirol, T), 8 (Vorarlberg, Vbg, V), 9 (Wien, W)</td>\n265\t<td><strong>de</strong>, en_US, uk</td>\n266\t<td>BANK</td>\n267\t</tr>\n268\t<tr>\n269\t<td>Azerbaijan</td>\n270\t<td>AZ</td>\n271\t<td></td>\n272\t<td><strong>az</strong>, en_US, uk</td>\n273\t<td>WORKDAY</td>\n274\t</tr>\n275\t<tr>\n276\t<td>Bahamas</td>\n277\t<td>BS</td>\n278\t<td></td>\n279\t<td></td>\n280\t<td></td>\n281\t</tr>\n282\t<tr>\n283\t<td>Bahrain</td>\n284\t<td>BH</td>\n285\t<td></td>\n286\t<td><strong>ar</strong>, en_US</td>\n287\t<td></td>\n288\t</tr>\n289\t<tr>\n290\t<td>Bangladesh</td>\n291\t<td>BD</td>\n292\t<td></td>\n293\t<td>ar, <strong>bn</strong>, en_US</td>\n294\t<td></td>\n295\t</tr>\n296\t<tr>\n297\t<td>Barbados</td>\n298\t<td>BB</td>\n299\t<td></td>\n300\t<td></td>\n301\t<td></td>\n302\t</tr>\n303\t<tr>\n304\t<td>Belarus</td>\n305\t<td>BY</td>\n306\t<td></td>\n307\t<td><strong>be</strong>, en_US, ru, th</td>\n308\t<td>WORKDAY</td>\n309\t</tr>\n310\t<tr>\n311\t<td>Belgium</td>\n312\t<td>BE</td>\n313\t<td></td>\n314\t<td>de, en_US, fr, <strong>nl</strong>, uk</td>\n315\t<td>BANK</td>\n316\t</tr>\n317\t<tr>\n318\t<td>Belize</td>\n319\t<td>BZ</td>\n320\t<td></td>\n321\t<td></td>\n322\t<td></td>\n323\t</tr>\n324\t<tr>\n325\t<td>Benin</td>\n326\t<td>BJ</td>\n327\t<td></td>\n328\t<td>en_US, <strong>fr_BJ</strong></td>\n329\t<td>WORKDAY</td>\n330\t</tr>\n331\t<tr>\n332\t<td>Bermuda</td>\n333\t<td>BM</td>\n334\t<td></td>\n335\t<td><strong>en_BM</strong>, en_US</td>\n336\t<td></td>\n337\t</tr>\n338\t<tr>\n339\t<td>Bhutan</td>\n340\t<td>BT</td>\n341\t<td>Administrative Subdivisions: 11 (Paro), 12 (Chhukha), 13 (Haa), 14 (Samtse), 15 (Thimphu), 21 (Tsirang), 22 (Dagana), 23 (Punakha), 24 (Wangdue Phodrang), 31 (Sarpang), 32 (Trongsa), 33 (Bumthang), 34 (Zhemgang), 41 (Trashigang), 42 (Monggar), 43 (Pema Gatshel), 44 (Lhuentse), 45 (Samdrup Jongkhar), GA (Gasa), TY (Trashi Yangtse)</td>\n342\t<td></td>\n343\t<td></td>\n344\t</tr>\n345\t<tr>\n346\t<td>Bolivia</td>\n347\t<td>BO</td>\n348\t<td>Departments: B (El Beni), C (Cochabamba), H (Chuquisaca), L (La Paz), N (Pando), O (Oruro), P (Potosí), S (Santa Cruz), T (Tarija)</td>\n349\t<td>en_US, <strong>es</strong>, uk</td>\n350\t<td></td>\n351\t</tr>\n352\t<tr>\n353\t<td>Bonaire, Sint Eustatius and Saba</td>\n354\t<td>BQ</td>\n355\t<td>Subdivisions: BON (Bonaire), SAB (Saba), STA (Sint Eustatius)</td>\n356\t<td>en_BQ, en_US, <strong>nl</strong>, pap_BQ</td>\n357\t<td></td>\n358\t</tr>\n359\t<tr>\n360\t<td>Bosnia and Herzegovina</td>\n361\t<td>BA</td>\n362\t<td>Entities and district: BIH (Federacija Bosne i Hercegovine, FBiH), BRC (Brčko distrikt, BD), SRP (Republika Srpska, RS)</td>\n363\t<td><strong>bs</strong>, en_US, sr, uk</td>\n364\t<td></td>\n365\t</tr>\n366\t<tr>\n367\t<td>Botswana</td>\n368\t<td>BW</td>\n369\t<td></td>\n370\t<td></td>\n371\t<td></td>\n372\t</tr>\n373\t<tr>\n374\t<td>Bouvet Island</td>\n375\t<td>B