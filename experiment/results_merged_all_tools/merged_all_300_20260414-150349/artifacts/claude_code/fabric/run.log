{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_5e0d5b61304a4fff85b6d676","type":"tool_result","content":"1\tfrom os import getcwd\n2\timport sys\n3\t\n4\tfrom invocations import ci\n5\tfrom invocations import checks\n6\tfrom invocations.docs import docs, www, sites, watch_docs\n7\tfrom invocations.pytest import (\n8\t    test,\n9\t    integration as integration_,\n10\t    coverage as coverage_,\n11\t)\n12\tfrom invocations.packaging import release\n13\t\n14\tfrom invoke import Collection, task\n15\t\n16\t\n17\t@task\n18\tdef safety_test_v1_to_v2_shim(c):\n19\t    \"\"\"\n20\t    Run some very quick in-process safety checks on a dual fabric1-v-2 env.\n21\t\n22\t    Assumes Fabric 2+ is already installed as 'fabric2'.\n23\t    \"\"\"\n24\t    c.run(\"pip install 'fabric<2'\")\n25\t    # Make darn sure the two copies of fabric are coming from install root, not\n26\t    # local directory - which would result in 'fabric' always being v2!\n27\t    for serious in (getcwd(), \"\"):\n28\t        if serious in sys.path:  # because why would .remove be idempotent?!\n29\t            sys.path.remove(serious)\n30\t\n31\t    from fabric.api import env\n32\t    from fabric2 import Connection\n33\t\n34\t    env.gateway = \"some-gateway\"\n35\t    env.no_agent = True\n36\t    env.password = \"sikrit\"\n37\t    env.user = \"admin\"\n38\t    env.host_string = \"localghost\"\n39\t    env.port = \"2222\"\n40\t    cxn = Connection.from_v1(env)\n41\t    config = cxn.config\n42\t    assert config.run.pty is True\n43\t    assert config.gateway == \"some-gateway\"\n44\t    assert config.connect_kwargs.password == \"sikrit\"\n45\t    assert config.sudo.password == \"sikrit\"\n46\t    assert cxn.host == \"localghost\"\n47\t    assert cxn.user == \"admin\"\n48\t    assert cxn.port == 2222\n49\t\n50\t\n51\t# TODO: as usual, this just wants a good pattern for \"that other task, with a\n52\t# tweaked default arg value\"\n53\t@task\n54\tdef integration(\n55\t    c,\n56\t    opts=None,\n57\t    pty=True,\n58\t    x=False,\n59\t    k=None,\n60\t    verbose=True,\n61\t    color=True,\n62\t    capture=\"no\",\n63\t    module=None,\n64\t):\n65\t    return integration_(c, opts, pty, x, k, verbose, color, capture, module)\n66\t\n67\t\n68\t# NOTE: copied from invoke's tasks.py\n69\t@task\n70\tdef coverage(c, report=\"term\", opts=\"\", codecov=False):\n71\t    \"\"\"\n72\t    Run pytest in coverage mode. See `invocations.pytest.coverage` for details.\n73\t    \"\"\"\n74\t    # Use our own test() instead of theirs.\n75\t    # Also add integration test so this always hits both.\n76\t    coverage_(\n77\t        c,\n78\t        report=report,\n79\t        opts=opts,\n80\t        tester=test,\n81\t        additional_testers=[integration],\n82\t        codecov=codecov,\n83\t    )\n84\t\n85\t\n86\tns = Collection(\n87\t    checks.blacken,  # backwards compat\n88\t    checks,\n89\t    ci,\n90\t    coverage,\n91\t    docs,\n92\t    integration,\n93\t    release,\n94\t    sites,\n95\t    test,\n96\t    watch_docs,\n97\t    www,\n98\t    safety_test_v1_to_v2_shim,\n99\t)\n100\tns.configure(\n101\t    {\n102\t        \"packaging\": {\n103\t            # NOTE: this is currently for identifying the source directory.\n104\t            # Should it get used for actual releasing, needs changing.\n105\t            \"package\": \"fabric\",\n106\t            \"sign\": False,\n107\t            \"wheel\": True,\n108\t            \"check_desc\": True,\n109\t            \"changelog_file\": \"sites/www/changelog.rst\",\n110\t            \"rebuild_with_env\": dict(PACKAGE_AS_FABRIC2=\"yes\"),\n111\t        }\n112\t    }\n113\t)\n114\t"}]},"parent_tool_use_id":null,"session_id":"9485fbff-0532-4f53-ae2a-c630e896dc24","uuid":"230005ad-4908-40d6-99f8-14ddd233ccc7","timestamp":"2026-04-08T20:55:34.968Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tasks.py","content":"from os import getcwd\nimport sys\n\nfrom invocations import ci\nfrom invocations import checks\nfrom invocations.docs import docs, www, sites, watch_docs\nfrom invocations.pytest import (\n    test,\n    integration as integration_,\n    coverage as coverage_,\n)\nfrom invocations.packaging import release\n\nfrom invoke import Collection, task\n\n\n@task\ndef safety_test_v1_to_v2_shim(c):\n    \"\"\"\n    Run some very quick in-process safety checks on a dual fabric1-v-2 env.\n\n    Assumes Fabric 2+ is already installed as 'fabric2'.\n    \"\"\"\n    c.run(\"pip install 'fabric<2'\")\n    # Make darn sure the two copies of fabric are coming from install root, not\n    # local directory - which would result in 'fabric' always being v2!\n    for serious in (getcwd(), \"\"):\n        if serious in sys.path:  # because why would .remove be idempotent?!\n            sys.path.remove(serious)\n\n    from fabric.api import env\n    from fabric2 import Connection\n\n    env.gateway = \"some-gateway\"\n    env.no_agent = True\n    env.password = \"sikrit\"\n    env.user = \"admin\"\n    env.host_string = \"localghost\"\n    env.port = \"2222\"\n    cxn = Connection.from_v1(env)\n    config = cxn.config\n    assert config.run.pty is True\n    assert config.gateway == \"some-gateway\"\n    assert config.connect_kwargs.password == \"sikrit\"\n    assert config.sudo.password == \"sikrit\"\n    assert cxn.host == \"localghost\"\n    assert cxn.user == \"admin\"\n    assert cxn.port == 2222\n\n\n# TODO: as usual, this just wants a good pattern for \"that other task, with a\n# tweaked default arg value\"\n@task\ndef integration(\n    c,\n    opts=None,\n    pty=True,\n    x=False,\n    k=None,\n    verbose=True,\n    color=True,\n    capture=\"no\",\n    module=None,\n):\n    return integration_(c, opts, pty, x, k, verbose, color, capture, module)\n\n\n# NOTE: copied from invoke's tasks.py\n@task\ndef coverage(c, report=\"term\", opts=\"\", codecov=False):\n    \"\"\"\n    Run pytest in coverage mode. See `invocations.pytest.coverage` for details.\n    \"\"\"\n    # Use our own test() instead of theirs.\n    # Also add integration test so this always hits both.\n    coverage_(\n        c,\n        report=report,\n        opts=opts,\n        tester=test,\n        additional_testers=[integration],\n        codecov=codecov,\n    )\n\n\nns = Collection(\n    checks.blacken,  # backwards compat\n    checks,\n    ci,\n    coverage,\n    docs,\n    integration,\n    release,\n    sites,\n    test,\n    watch_docs,\n    www,\n    safety_test_v1_to_v2_shim,\n)\nns.configure(\n    {\n        \"packaging\": {\n            # NOTE: this is currently for identifying the source directory.\n            # Should it get used for actual releasing, needs changing.\n            \"package\": \"fabric\",\n            \"sign\": False,\n            \"wheel\": True,\n            \"check_desc\": True,\n            \"changelog_file\": \"sites/www/changelog.rst\",\n            \"rebuild_with_env\": dict(PACKAGE_AS_FABRIC2=\"yes\"),\n        }\n    }\n)\n","numLines":114,"startLine":1,"totalLines":114}}}
