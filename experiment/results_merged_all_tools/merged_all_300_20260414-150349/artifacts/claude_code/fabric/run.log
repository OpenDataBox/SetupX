{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_ec32fc1d05064f638338e8aa","type":"tool_result","content":"1\t# flake8: noqa\n2\tfrom os.path import isfile, expanduser\n3\tfrom unittest.mock import patch\n4\t\n5\tfrom pytest import fixture\n6\t\n7\t# Set up icecream globally for convenience.\n8\tfrom icecream import install as install_icecream\n9\t\n10\tfrom fabric.testing.fixtures import client, remote, sftp, sftp_objs, transfer\n11\t\n12\t\n13\tinstall_icecream()\n14\t\n15\t\n16\t# TODO: does this want to end up in the public fixtures module too?\n17\t@fixture(autouse=True)\n18\tdef no_user_ssh_config():\n19\t    \"\"\"\n20\t    Cowardly refuse to ever load what looks like user SSH config paths.\n21\t\n22\t    Prevents the invoking user's real config from gumming up test results or\n23\t    inflating test runtime (eg if it sets canonicalization on, which will incur\n24\t    DNS lookups for nearly all of this suite's bogus names).\n25\t    \"\"\"\n26\t    # An ugly, but effective, hack. I am not proud. I also don't see anything\n27\t    # that's >= as bulletproof and less ugly?\n28\t    # TODO: ideally this should expand to cover system config paths too, but\n29\t    # that's even less likely to be an issue.\n30\t    def no_config_for_you(path):\n31\t        if path == expanduser(\"~/.ssh/config\"):\n32\t            return False\n33\t        return isfile(path)\n34\t\n35\t    with patch(\"fabric.config.os.path.isfile\", no_config_for_you):\n36\t        yield\n37\t"}]},"parent_tool_use_id":null,"session_id":"9485fbff-0532-4f53-ae2a-c630e896dc24","uuid":"ba6f7ff1-3978-47fb-aba5-148068f018d8","timestamp":"2026-04-08T20:55:37.382Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tests/conftest.py","content":"# flake8: noqa\nfrom os.path import isfile, expanduser\nfrom unittest.mock import patch\n\nfrom pytest import fixture\n\n# Set up icecream globally for convenience.\nfrom icecream import install as install_icecream\n\nfrom fabric.testing.fixtures import client, remote, sftp, sftp_objs, transfer\n\n\ninstall_icecream()\n\n\n# TODO: does this want to end up in the public fixtures module too?\n@fixture(autouse=True)\ndef no_user_ssh_config():\n    \"\"\"\n    Cowardly refuse to ever load what looks like user SSH config paths.\n\n    Prevents the invoking user's real config from gumming up test results or\n    inflating test runtime (eg if it sets canonicalization on, which will incur\n    DNS lookups for nearly all of this suite's bogus names).\n    \"\"\"\n    # An ugly, but effective, hack. I am not proud. I also don't see anything\n    # that's >= as bulletproof and less ugly?\n    # TODO: ideally this should expand to cover system config paths too, but\n    # that's even less likely to be an issue.\n    def no_config_for_you(path):\n        if path == expanduser(\"~/.ssh/config\"):\n            return False\n        return isfile(path)\n\n    with patch(\"fabric.config.os.path.isfile\", no_config_for_you):\n        yield\n","numLines":37,"startLine":1,"totalLines":37}}}
