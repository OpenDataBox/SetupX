{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_8eaa37b61bf6493b881a91e1","type":"tool_result","content":"1\tname: Reference Python Package\n2\t\n3\ton:\n4\t  [push, pull_request]\n5\t\n6\tjobs:\n7\t  build:\n8\t      uses: ./.github/workflows/build-ast.yml\n9\t\n10\t  tests:\n11\t    name: ANTLR AST tests\n12\t    needs: build\n13\t    runs-on: ubuntu-latest\n14\t    strategy:\n15\t      fail-fast: false\n16\t      matrix:\n17\t        include:\n18\t            # Build on the oldest and latest supported Pythons\n19\t            # and on the oldest and latest ANTLR version supported\n20\t            # by each of those Pythons:\n21\t            - python-version: '3.9'\n22\t              antlr-version: '4.7'\n23\t            - python-version: '3.9'\n24\t              antlr-version: '4.13'\n25\t            - python-version: '3.13'\n26\t              antlr-version: '4.9'\n27\t            - python-version: '3.13'\n28\t              antlr-version: '4.13'\n29\t    defaults:\n30\t      run:\n31\t        working-directory: source/openqasm\n32\t\n33\t    steps:\n34\t      - uses: actions/checkout@v6\n35\t        with:\n36\t          fetch-depth: 0\n37\t\n38\t      - uses: actions/setup-python@v6\n39\t        with:\n40\t          python-version: ${{ matrix.python-version }}\n41\t\n42\t      - uses: actions/download-artifact@v8\n43\t        with:\n44\t          name: openqasm3-python-wheel\n45\t          path: ./source/openqasm/\n46\t\n47\t      - name: Install package\n48\t        run: |\n49\t          set -e\n50\t          pip install --upgrade pip wheel\n51\t          pip install -r requirements-dev.txt\n52\t          pip install 'antlr4_python3_runtime==${{ matrix.antlr-version }}'\n53\t          pip install \"$(echo openqasm3-*.whl)[all]\"\n54\t\n55\t      - name: Run tests\n56\t        run: |\n57\t          # Swap into the testing directory so the imported `openqasm3` is the\n58\t          # wheel version not the current-directory version.  The\n59\t          # `--import-mode=importlib` stops pytest from modifying the path to\n60\t          # accidentally put the checked-out version (with no ANTLR) back.\n61\t          cd tests\n62\t          pytest -vv --color=yes --import-mode=importlib .\n63\t\n64\t  style:\n65\t    name: Check AST style\n66\t    runs-on: ubuntu-latest\n67\t    defaults:\n68\t      run:\n69\t        working-directory: source/openqasm\n70\t    steps:\n71\t      - uses: actions/checkout@v6\n72\t        with:\n73\t          fetch-depth: 0\n74\t\n75\t      - uses: actions/setup-python@v6\n76\t        with:\n77\t          python-version: '3.12'\n78\t\n79\t      - name: Prepare environment\n80\t        run: |\n81\t          set -e\n82\t          python -m pip install --upgrade pip wheel\n83\t          python -m pip install -r requirements-dev.txt\n84\t\n85\t      - name: Check formatting\n86\t        run: black --check --diff openqasm3 tests\n87\t\n88\t      - name: Check lint\n89\t        run: pylint openqasm3 tests\n90\t\n91\t      - name: Check types\n92\t        run: mypy --ignore-missing-imports openqasm3 tests\n93\t\n94\t  docs:\n95\t    name: AST documentation build\n96\t    needs: build\n97\t    runs-on: ubuntu-latest\n98\t    defaults:\n99\t      run:\n100\t        working-directory: source/openqasm\n101\t\n102\t    steps:\n103\t      - uses: actions/checkout@v6\n104\t\n105\t      - uses: actions/setup-python@v6\n106\t        with:\n107\t          python-version: ${{ matrix.python-version }}\n108\t\n109\t      - uses: actions/download-artifact@v8\n110\t        with:\n111\t          name: openqasm3-python-wheel\n112\t          path: ./source/openqasm/\n113\t\n114\t      - name: Install package\n115\t        run: |\n116\t          set -e\n117\t          pip install --upgrade pip wheel\n118\t          pip install -r requirements-dev.txt\n119\t          pip install \"$(echo openqasm3-*.whl)[all]\"\n120\t\n121\t      - name: Build documentation\n122\t        working-directory: source/openqasm/docs\n123\t        run: make html\n124\t\n125\t      - uses: actions/upload-artifact@v7\n126\t        with:\n127\t          name: openqasm3-html-documentation\n128\t          path: source/openqasm/docs/_build/html/*\n129\t          if-no-files-found: error\n130\t"}]},"parent_tool_use_id":null,"session_id":"a86eb93f-f467-41bb-b000-58bd3ded6194","uuid":"218ef771-8ceb-4706-be9e-e0b607bdc7b6","timestamp":"2026-04-09T00:25:23.165Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.github/workflows/tests-ast.yml","content":"name: Reference Python Package\n\non:\n  [push, pull_request]\n\njobs:\n  build:\n      uses: ./.github/workflows/build-ast.yml\n\n  tests:\n    name: ANTLR AST tests\n    needs: build\n    runs-on: ubuntu-latest\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n            # Build on the oldest and latest supported Pythons\n            # and on the oldest and latest ANTLR version supported\n            # by each of those Pythons:\n            - python-version: '3.9'\n              antlr-version: '4.7'\n            - python-version: '3.9'\n              antlr-version: '4.13'\n            - python-version: '3.13'\n              antlr-version: '4.9'\n            - python-version: '3.13'\n              antlr-version: '4.13'\n    defaults:\n      run:\n        working-directory: source/openqasm\n\n    steps:\n      - uses: actions/checkout@v6\n        with:\n          fetch-depth: 0\n\n      - uses: actions/setup-python@v6\n        with:\n          python-version: ${{ matrix.python-version }}\n\n      - uses: actions/download-artifact@v8\n        with:\n          name: openqasm3-python-wheel\n          path: ./source/openqasm/\n\n      - name: Install package\n        run: |\n          set -e\n          pip install --upgrade pip wheel\n          pip install -r requirements-dev.txt\n          pip install 'antlr4_python3_runtime==${{ matrix.antlr-version }}'\n          pip install \"$(echo openqasm3-*.whl)[all]\"\n\n      - name: Run tests\n        run: |\n          # Swap into the testing directory so the imported `openqasm3` is the\n          # wheel version not the current-directory version.  The\n          # `--import-mode=importlib` stops pytest from modifying the path to\n          # accidentally put the checked-out version (with no ANTLR) back.\n          cd tests\n          pytest -vv --color=yes --import-mode=importlib .\n\n  style:\n    name: Check AST style\n    runs-on: ubuntu-latest\n    defaults:\n      run:\n        working-directory: source/openqasm\n    steps:\n      - uses: actions/checkout@v6\n        with:\n          fetch-depth: 0\n\n      - uses: actions/setup-python@v6\n        with:\n          python-version: '3.12'\n\n      - name: Prepare environment\n        run: |\n          set -e\n          python -m pip install --upgrade pip wheel\n          python -m pip install -r requirements-dev.txt\n\n      - name: Check formatting\n        run: black --check --diff openqasm3 tests\n\n      - name: Check lint\n        run: pylint openqasm3 tests\n\n      - name: Check types\n        run: mypy --ignore-missing-imports openqasm3 tests\n\n  docs:\n    name: AST documentation build\n    needs: build\n    runs-on: ubuntu-latest\n    defaults:\n      run:\n        working-directory: source/openqasm\n\n    steps:\n      - uses: actions/checkout@v6\n\n      - uses: actions/setup-python@v6\n        with:\n          python-version: ${{ matrix.python-version }}\n\n      - uses: actions/download-artifact@v8\n        with:\n          name: openqasm3-python-wheel\n          path: ./source/openqasm/\n\n      - name: Install package\n        run: |\n          set -e\n          pip install --upgrade pip wheel\n          pip install -r requirements-dev.txt\n          pip install \"$(echo openqasm3-*.whl)[all]\"\n\n      - name: Build documentation\n        working-directory: source/openqasm/docs\n        run: make html\n\n      - uses: actions/upload-artifact@v7\n        with:\n          name: openqasm3-html-documentation\n          path: source/openqasm/docs/_build/html/*\n          if-no-files-found: error\n","numLines":130,"startLine":1,"totalLines":130}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_1003068511174a1b8d9add27","type":"tool_result","content":"1\tname: Tests (Grammar)\n2\t\n3\ton:\n4\t  [push, pull_request]\n5\t\n6\tjobs:\n7\t  tests:\n8\t    name: ANTLR grammar tests\n9\t    runs-on: ubuntu-latest\n10\t    strategy:\n11\t      fail-fast: false\n12\t      matrix:\n13\t        antlr-version: ['4.9.2']\n14\t    defaults:\n15\t      run:\n16\t        working-directory: source/grammar\n17\t\n18\t    steps:\n19\t      - uses: actions/checkout@v6\n20\t\n21\t      - uses: actions/setup-python@v6\n22\t        with:\n23\t          python-version: '3.9'\n24\t\n25\t      - uses: actions/setup-java@v5\n26\t        with:\n27\t          java-version: '15'\n28\t          distribution: 'adopt'\n29\t\n30\t      - name: Update pip\n31\t        run: python -mpip install --upgrade pip\n32\t\n33\t      - name: Install ANTLR4\n34\t        run: curl -O https://www.antlr.org/download/antlr-${{ matrix.antlr-version }}-complete.jar\n35\t\n36\t      - name: Install ANTLR4 Python runtime\n37\t        run: python -mpip install antlr4-python3-runtime==${{ matrix.antlr-version }}\n38\t\n39\t      - name: Generate grammar\n40\t        run: java -Xmx500M -jar antlr-${{ matrix.antlr-version }}-complete.jar -o openqasm_reference_parser -Dlanguage=Python3 qasm3Lexer.g4 qasm3Parser.g4\n41\t\n42\t      - name: Install Python package\n43\t        run: python -mpip install -e .[all]\n44\t\n45\t      - name: Run tests\n46\t        run: pytest -vv --color=yes tests\n47\t"}]},"parent_tool_use_id":null,"session_id":"a86eb93f-f467-41bb-b000-58bd3ded6194","uuid":"0d1cc3d1-24dd-41cc-b2c2-43e3ba5b0747","timestamp":"2026-04-09T00:25:23.166Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/.github/workflows/tests-grammar.yml","content":"name: Tests (Grammar)\n\non:\n  [push, pull_request]\n\njobs:\n  tests:\n    name: ANTLR grammar tests\n    runs-on: ubuntu-latest\n    strategy:\n      fail-fast: false\n      matrix:\n        antlr-version: ['4.9.2']\n    defaults:\n      run:\n        working-directory: source/grammar\n\n    steps:\n      - uses: actions/checkout@v6\n\n      - uses: actions/setup-python@v6\n        with:\n          python-version: '3.9'\n\n      - uses: actions/setup-java@v5\n        with:\n          java-version: '15'\n          distribution: 'adopt'\n\n      - name: Update pip\n        run: python -mpip install --upgrade pip\n\n      - name: Install ANTLR4\n        run: curl -O https://www.antlr.org/download/antlr-${{ matrix.antlr-version }}-complete.jar\n\n      - name: Install ANTLR4 Python runtime\n        run: python -mpip install antlr4-python3-runtime==${{ matrix.antlr-version }}\n\n      - name: Generate grammar\n        run: java -Xmx500M -jar antlr-${{ matrix.antlr-version }}-complete.jar -o openqasm_reference_parser -Dlanguage=Python3 qasm3Lexer.g4 qasm3Parser.g4\n\n      - name: Install Python package\n        run: python -mpip install -e .[all]\n\n      - name: Run tests\n        run: pytest -vv --color=yes tests\n","numLines":47,"startLine":1,"totalLines":47}}}
