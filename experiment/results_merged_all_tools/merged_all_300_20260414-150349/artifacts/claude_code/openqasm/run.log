{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_abfca4b8e1cc4920968cdd2f","type":"tool_result","content":"1\timport pytest\n2\tfrom openqasm3 import parse_version\n3\t\n4\tLINE_ENDINGS = [\"\", \"\\n\", \"  \", \"// comment\\n\", \"\\t\", \"/* OPENQASM 1.0 */\", \"/* \\n\\n */\"]\n5\t\n6\t\n7\t@pytest.mark.parametrize(\"prefix\", LINE_ENDINGS)\n8\t@pytest.mark.parametrize(\"infix\", LINE_ENDINGS)\n9\tdef test_ignore_spaces(prefix, infix):\n10\t    prog = f\"{prefix}OPENQASM{infix}3.0;\"\n11\t    assert parse_version(prog) == (3, 0)\n12\t\n13\t\n14\t@pytest.mark.parametrize(\n15\t    [\"version_str\", \"version_parts\"],\n16\t    [\n17\t        (\"3\", (3,)),\n18\t        (\"3.0\", (3, 0)),\n19\t        (\"2\", (2,)),\n20\t        (\"2.0\", (2, 0)),\n21\t        (\"3.1\", (3, 1)),\n22\t        (\"3.2.3.5\", (3, 2, 3, 5)),\n23\t    ],\n24\t)\n25\tdef test_versions(version_str, version_parts):\n26\t    prog = f\"OPENQASM {version_str};\"\n27\t    assert parse_version(prog) == version_parts\n28\t\n29\t\n30\tdef test_no_version_valid_program():\n31\t    prog = \"\"\"\n32\t        include \"stdgates.inc\";\n33\t        qubit[2] q;\n34\t        cx q[0], q[1];\n35\t    \"\"\"\n36\t    assert parse_version(prog) is None\n37\t\n38\t\n39\tdef test_ignore_non_syntactic_version():\n40\t    # The version number has to be the first non-comment line.\n41\t    prog = \"\"\"\n42\t        include \"stdgates.inc\";\n43\t        OPENQASM 3.0;\n44\t    \"\"\"\n45\t    assert parse_version(prog) is None\n46\t\n47\t\n48\tdef test_ignore_invalid_version_statement():\n49\t    prog = \"OPENQASM invalid;\"\n50\t    assert parse_version(prog) is None\n51\t"}]},"parent_tool_use_id":null,"session_id":"a86eb93f-f467-41bb-b000-58bd3ded6194","uuid":"69b96dee-4c4f-4c6d-9d7c-040cac6b6456","timestamp":"2026-04-09T00:28:11.246Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/source/openqasm/tests/test_version.py","content":"import pytest\nfrom openqasm3 import parse_version\n\nLINE_ENDINGS = [\"\", \"\\n\", \"  \", \"// comment\\n\", \"\\t\", \"/* OPENQASM 1.0 */\", \"/* \\n\\n */\"]\n\n\n@pytest.mark.parametrize(\"prefix\", LINE_ENDINGS)\n@pytest.mark.parametrize(\"infix\", LINE_ENDINGS)\ndef test_ignore_spaces(prefix, infix):\n    prog = f\"{prefix}OPENQASM{infix}3.0;\"\n    assert parse_version(prog) == (3, 0)\n\n\n@pytest.mark.parametrize(\n    [\"version_str\", \"version_parts\"],\n    [\n        (\"3\", (3,)),\n        (\"3.0\", (3, 0)),\n        (\"2\", (2,)),\n        (\"2.0\", (2, 0)),\n        (\"3.1\", (3, 1)),\n        (\"3.2.3.5\", (3, 2, 3, 5)),\n    ],\n)\ndef test_versions(version_str, version_parts):\n    prog = f\"OPENQASM {version_str};\"\n    assert parse_version(prog) == version_parts\n\n\ndef test_no_version_valid_program():\n    prog = \"\"\"\n        include \"stdgates.inc\";\n        qubit[2] q;\n        cx q[0], q[1];\n    \"\"\"\n    assert parse_version(prog) is None\n\n\ndef test_ignore_non_syntactic_version():\n    # The version number has to be the first non-comment line.\n    prog = \"\"\"\n        include \"stdgates.inc\";\n        OPENQASM 3.0;\n    \"\"\"\n    assert parse_version(prog) is None\n\n\ndef test_ignore_invalid_version_statement():\n    prog = \"OPENQASM invalid;\"\n    assert parse_version(prog) is None\n","numLines":51,"startLine":1,"totalLines":51}}}
