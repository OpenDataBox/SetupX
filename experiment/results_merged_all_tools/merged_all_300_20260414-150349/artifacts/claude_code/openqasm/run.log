{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_97a6779b7cd645f6ae73cc28","type":"tool_result","content":"1\t\"\"\"\n2\t=============================\n3\tParser (``openqasm3.parser``)\n4\t=============================\n5\t\n6\tTools for parsing OpenQASM 3 programs into the :obj:`reference AST <openqasm3.ast>`.\n7\t\n8\tThe quick-start interface is simply to call ``openqasm3.parse``:\n9\t\n10\t.. currentmodule:: openqasm3\n11\t.. autofunction:: openqasm3.parse\n12\t\n13\tThe rest of this module provides some lower-level internals of the parser.\n14\t\n15\t.. currentmodule:: openqasm3.parser\n16\t.. autofunction:: span\n17\t.. autofunction:: add_span\n18\t.. autofunction:: combine_span\n19\t.. autofunction:: get_span\n20\t.. autoclass:: QASMNodeVisitor\n21\t\"\"\"\n22\t\n23\t# pylint: disable=wrong-import-order\n24\t\n25\t__all__ = [\n26\t    \"parse\",\n27\t    \"get_span\",\n28\t    \"add_span\",\n29\t    \"combine_span\",\n30\t    \"span\",\n31\t    \"QASMNodeVisitor\",\n32\t    \"QASM3ParsingError\",\n33\t    \"get_comments\",\n34\t]\n35\t\n36\timport re\n37\tfrom contextlib import contextmanager\n38\tfrom typing import Union, TypeVar, List, Optional, Protocol, Tuple, cast\n39\t\n40\ttry:\n41\t    from antlr4 import (\n42\t        CommonTokenStream,\n43\t        InputStream,\n44\t        ParserRuleContext,\n45\t        RecognitionException,\n46\t    )\n47\t    from antlr4.error.Errors import ParseCancellationException\n48\t    from antlr4.error.ErrorStrategy import BailErrorStrategy\n49\t    from antlr4.tree.Tree import TerminalNode\n50\t    from antlr4.error.ErrorListener import ErrorListener\n51\texcept ImportError as exc:\n52\t    raise ImportError(\n53\t        \"Parsing is not available unless the [parser] extra is installed,\"\n54\t        \" such as by 'pip install openqasm3[parser]'.\"\n55\t    ) from exc\n56\t\n57\tfrom ._antlr.qasm3Lexer import qasm3Lexer  # type: ignore[import-not-found]\n58\tfrom ._antlr.qasm3Parser import qasm3Parser  # type: ignore[import-not-found]\n59\tfrom ._antlr.qasm3ParserVisitor import qasm3ParserVisitor  # type: ignore[import-not-found]\n60\tfrom . import ast\n61\t\n62\t_TYPE_NODE_INIT = {\n63\t    \"int\": ast.IntType,\n64\t    \"uint\": ast.UintType,\n65\t    \"float\": ast.FloatType,\n66\t    \"angle\": ast.AngleType,\n67\t}\n68\t\n69\t\n70\tclass QASM3ParsingError(Exception):\n71\t    \"\"\"An error raised by the AST visitor during the AST-generation phase.  This is raised in cases where the\n72\t    given program could not be correctly parsed.\"\"\"\n73\t\n74\t    def __init__(\n75\t        self, message: str, line: Optional[int] = None, column: Optional[int] = None\n76\t    ) -> None:\n77\t        if line is not None and column is not None:\n78\t            prefix = f\"L{line}:C{column}: \"\n79\t        elif line is not None:\n80\t            prefix = f\"L{line}: \"\n81\t        else:\n82\t            prefix = \"\"\n83\t\n84\t        super().__init__(f\"{prefix}{message}\")\n85\t        self.line = line\n86\t        self.column = column\n87\t\n88\t\n89\tclass _RaiseOnErrorListener(ErrorListener):\n90\t    \"\"\"Raises exception for all errors handled by this listener.\"\"\"\n91\t\n92\t    def syntaxError(\n93\t        self,\n94\t        recognizer: object,\n95\t        offendingSymbol: object,\n96\t        line: int,\n97\t        column: int,\n98\t        msg: str,\n99\t        exc: RecognitionException,\n100\t    ):"}]},"parent_tool_use_id":null,"session_id":"a86eb93f-f467-41bb-b000-58bd3ded6194","uuid":"e9416a3c-807e-4497-aa45-1a57ff3e4d22","timestamp":"2026-04-09T00:31:24.965Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/source/openqasm/openqasm3/parser.py","content":"\"\"\"\n=============================\nParser (``openqasm3.parser``)\n=============================\n\nTools for parsing OpenQASM 3 programs into the :obj:`reference AST <openqasm3.ast>`.\n\nThe quick-start interface is simply to call ``openqasm3.parse``:\n\n.. currentm