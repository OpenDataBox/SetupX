{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_265a3986d54c4f0cbf8b1dc1","type":"tool_result","content":"1\t# Copyright (c) 2011-2022 Berkeley Model United Nations. All rights reserved.\n2\t# Use of this source code is governed by a BSD License (see LICENSE).\n3\t\n4\timport uuid\n5\t\n6\tfrom django.conf import settings\n7\tfrom django.core.exceptions import PermissionDenied\n8\t\n9\tfrom huxley.accounts.models import User\n10\tfrom huxley.core.constants import ContactGender, ContactType, ProgramTypes\n11\t\n12\tfrom huxley.core.models import School, Committee, CommitteeFeedback, Country, Delegate, Assignment, Registration, Conference, PositionPaper, Rubric, SecretariatMember, Note\n13\t\n14\tif not settings.TESTING:\n15\t    raise PermissionDenied\n16\t\n17\t\n18\tdef new_user(**kwargs):\n19\t    username = kwargs.pop('username', None) or str(uuid.uuid4())\n20\t    u = User(username=username, email=kwargs.pop('email', 'test@user.in'))\n21\t\n22\t    password = kwargs.pop('password', 'test')\n23\t    u.set_password(password)\n24\t    u.PASSWORD_FOR_TESTS_ONLY = password\n25\t\n26\t    u.first_name = kwargs.pop('first_name', 'Test')\n27\t    u.last_name = kwargs.pop('last_name', 'User')\n28\t\n29\t    for attr, value in kwargs.items():\n30\t        setattr(u, attr, value)\n31\t\n32\t    u.save()\n33\t    return u\n34\t\n35\t\n36\tdef new_superuser(*args, **kwargs):\n37\t    kwargs['is_superuser'] = True\n38\t    kwargs['is_staff'] = True\n39\t    return new_user(**kwargs)\n40\t\n41\t\n42\tdef new_school(**kwargs):\n43\t    s = School(name=kwargs.pop('name', 'Test School'),\n44\t               address=kwargs.pop('address', '1 Schoolhouse Road'),\n45\t               city=kwargs.pop('city', 'Berkeley'),\n46\t               state=kwargs.pop('state', 'CA'),\n47\t               zip_code=kwargs.pop('zip_code', '94024'),\n48\t               country=kwargs.pop('country', 'United States of America'),\n49\t               primary_name=kwargs.pop('primary_name', 'first'),\n50\t               primary_gender=kwargs.pop('primary_gender', ContactGender.MALE),\n51\t               primary_email=kwargs.pop('primary_email', 'e@mail.com'),\n52\t               primary_phone=kwargs.pop('primary_phone', '1234567890'),\n53\t               primary_type=kwargs.pop('primary_type', ContactType.FACULTY),\n54\t               secondary_name=kwargs.pop('secondary_name', ''),\n55\t               secondary_gender=kwargs.pop('secondary_gender',\n56\t                                           ContactGender.MALE),\n57\t               secondary_email=kwargs.pop('secondary_email', ''),\n58\t               secondary_phone=kwargs.pop('secondary_phone', ''),\n59\t               secondary_type=kwargs.pop('secondary_type',\n60\t                                         ContactType.FACULTY),\n61\t               program_type=kwargs.pop('program_type', ProgramTypes.CLUB),\n62\t               times_attended=kwargs.pop('times_attended', 0))\n63\t\n64\t    user = kwargs.pop('user', None)\n65\t    for attr, value in kwargs.items():\n66\t        setattr(s, attr, value)\n67\t\n68\t    s.save()\n69\t\n70\t    if user is None:\n71\t        committee = new_committee()\n72\t        new_user(username=str(uuid.uuid4()), school=s, committee=committee)\n73\t    else:\n74\t        user.school = s\n75\t        user.save()\n76\t\n77\t    return s\n78\t\n79\t\n80\tdef new_committee(**kwargs):\n81\t    c = Committee(name=kwargs.pop('name', 'testCommittee'),\n82\t                  full_name=kwargs.pop('fullName', 'testCommittee'),\n83\t                  delegation_size=kwargs.pop('delegation_size', 10),\n84\t                  special=kwargs.pop('special', False))\n85\t    c.save()\n86\t\n87\t    user = kwargs.pop('user', None)\n88\t    for attr, value in kwargs.items():\n89\t        setattr(c, attr, value)\n90\t\n91\t    c.save()\n92\t\n93\t    if user is None:\n94\t        new_user(username=str(uuid.uuid4()),\n95\t                 committee=c,\n96\t                 use