{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_5fa1fa8698b34d98b744a55e","type":"tool_result","content":"1\tset windows-shell := [\"powershell.exe\", \"-NoLogo\", \"-Command\"]\n2\t\n3\t[private]\n4\t@default:\n5\t    just --list\n6\t\n7\t# prepare venv and repo for developing\n8\t@bootstrap:\n9\t    pip install -r requirements/pre.txt\n10\t    uv pip install -e .\n11\t    uv pip install -r requirements/dev.txt\n12\t    prek\n13\t    prek install\n14\t\n15\t# sync version of installed packages\n16\t@venv-sync:\n17\t    uv pip sync requirements/pre.txt requirements/dev.txt\n18\t    uv pip install -e .\n19\t\n20\t# run all linters\n21\t@lint:\n22\t    tox -e lint\n23\t\n24\t# run basic tests on all python versions\n25\t@test:\n26\t    tox -e $(tox list --no-desc | grep '^py' | grep 'new$' | tr '\\n' ',')\n27\t\n28\t# run all tests on all python versions\n29\t@test-all-seq:\n30\t    tox -e $(tox list --no-desc | grep '^py' | sort -r | tr '\\n' ',')\n31\t\n32\t# run all tests on all python versions parallelly\n33\t@test-all:\n34\t    tox -e $(tox list --no-desc | grep '^py' | sort -r | tr '\\n' ',') -p auto\n35\t\n36\tinv := \"inv -r scripts -c invoke_tasks\"\n37\t\n38\t@cov output='coverage.xml':\n39\t    {{ inv }} cov \\\n40\t      --env-list $(tox list --no-desc | grep -e '^py' | grep -v '^pypy' | sort -r | tr '\\n' ',') \\\n41\t      --output {{ output }} \\\n42\t      --parallel\n43\t\n44\t@deps-compile:\n45\t    {{ inv }} deps-compile\n46\t\n47\t@deps-compile-upgrade:\n48\t    {{ inv }} deps-compile --upgrade\n49\t\n50\tdoc_source := \"docs\"\n51\tdoc_target := \"docs-build\"\n52\t\n53\t# build documentation\n54\t@doc:\n55\t    sphinx-build -M html {{ doc_source }} {{ doc_target }}\n56\t    echo \"Open file://`pwd`/{{ doc_target }}/html/index.html\"\n57\t\n58\t# clean generated documentation and build cache\n59\t@doc-clean:\n60\t    sphinx-build -M clean {{ doc_source }} {{ doc_target }}\n61\t\n62\t\n63\t@changelog version='Preview':\n64\