oject.optional-dependencies]\n50\tdev = [\n51\t    # testing\n52\t    \"pytest\",\n53\t    \"pytest-cov\",\n54\t    \"coverage [toml]\",\n55\t    # code style\n56\t    \"ruff==0.11.*\",\n57\t    \"mypy\",\n58\t    \"types-docutils\",\n59\t    \"scipy-stubs\",\n60\t    \"typos\",\n61\t    # docs\n62\t    \"mkdocs\",\n63\t    \"mkdocs-material\",\n64\t    \"mkdocs-exclude\",\n65\t    \"mkdocs-redirects\",\n66\t    \"mkdocstrings-python\",\n67\t    \"mike\",\n68\t    \"mkdocs-jupyter\",\n69\t    \"black\",\n70\t    # release\n71\t    \"bump-my-version\",\n72\t]\n73\tpublishing = [\"build\", \"twine\", \"wheel\"]\n74\trl = [\"stable-baselines3>=2.3.2\", \"sb3-contrib\"]\n75\tnotebooks = [\"nbmake\", \"tensorflow\"]\n76\t\n77\t[project.urls]\n78\tRepository = \"https://github.com/neurogym/neurogym\"\n79\tIssues = \"https://github.com/neurogym/neurogym\"\n80\tDocumentation = \"https://neurogym.github.io/neurogym\"\n81\tChangelog = \"https://github.com/neurogym/neurogym/CHANGELOG.md\"\n82\t\n83\t[tool.pytest.ini_options]\n84\ttestpaths = [\"tests\"]\n85\t\n86\t[tool.coverage.run]\n87\tbranch = true\n88\tsource = [\"neurogym\"]\n89\tcommand_line = \"-m pytest\"\n90\t\n91\t# For completeness, until we move to an src-based layouts\n92\t[tool.setuptools.packages.find]\n93\tinclude = [\"neurogym*\"]\n94\texclude = [\"tests*\"]\n95\t\n96\t[tool.mypy]\n97\tpython_version = \"3.11\"\n98\twarn_return_any = true\n99\twarn_unused_configs = true\n100\tshow_error_codes = true\n101\texclude = \"build/.*\"\n102\t\n103\t[[tool.mypy.overrides]]\n104\tmodule = \"psychopy\"\n105\tignore_missing_imports = true\n106\t\n107\t[tool.coverage.report]\n108\texclude_also = [\n109\t    \"if TYPE_CHECKING:\",\n110\t    \"def __repr__\",\n111\t    \"def __str__\",\n112\t    \"raise NotImplementedError\",\n113\t]\n114\t\n115\t[tool.typos]\n116\tdefault.extend-ignore-words-re = [\n117\t    \"arange\", # common numpy function\n118\t]\n119\tfiles.ignore-hidden = false\n120\tfiles.extend-exclude = [\".git/*\"]\n121\t"}]},"parent_tool_use_id":null,"session_id":"e1e87e6a-5271-47d5-b324-95db215d5e4d","uuid":"8e6ba7da-3124-4760-8004-87fa6757476d","timestamp":"2026-04-07T06:07:58.981Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pyproject.toml","content":"[build-system]\nrequires = [\"setuptools>=64.0.0\", \"setuptools-scm\", \"wheel\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nauthors = [\n    { name = \"Giulia Crocioni\", email = \"g.crocioni@esciencecenter.nl\" },\n    { name = \"Dani Bodor\", email = \"d.bodor@esciencecenter.nl\" },\n    { name = \"Nathan Cloos\", email = \"cloosnathan@gmail.com\" },\n    { name = \"Alexander Hadjiivanov\", email = \"a.hadjiivanov@esciencecenter.nl\" },\n    { name = \"Guangyu Robert Yang\", email = \"gyyang.neuro@gmail.com\" },\n    { name = \"Jorge Mejias\", email = \"j.f.mejias@uva.nl\" },\n    { name = \"Manuel Molano Mazon\", email = \"manuelmolanomazon@gmail.com\" },\n]\nclassifiers = [\n    \"License :: OSI Approved :: Apache Software License\",\n    \"Natural Language :: English\",\n    \"Programming Language :: Python :: 3.10\",\n    \"Programming Language :: Python :: 3.11\",\n    \"Programming Language :: Python :: 3.12\",\n    \"Programming Language :: Python :: 3.13\",\n    \"Programming Language :: Python :: 3.14\",\n]\ndependencies = [\n    \"pydantic-settings\",\n    \"loguru\",\n    \"tqdm\",\n    \"tomlkit\",\n    \"numpy==2.2.*\",\n    \"gymnasium==0.29.*\",\n    \"matplotlib==3.10.*\",\n    \"scipy\",\n    \"natsort\"\n]\ndescription = \"NeuroGym: Gymnasium-style Cognitive Neuroscience Tasks\"\nkeywords = [\n    \"neuroscience\",\n    \"neural networks\",\n    \"supervised learning\",\n    \"reinforcement learning\",\n    \"synthetic data\",\n]\nlicense = { text = \"Apache-2.0 License\" }\nname = \"neurogym\"\nreadme = { file = \"README.md\", content-type = \"text/markdown\" }\nrequires-python = \">=3.10\"\nversion = \"2.3.1\"\n\n[project.optional-dependencies]\ndev = [\n    # testing\n    \"pytest\",\n    \"pytest-cov\",\n    \"coverage [toml]\",\n    # code style\n    \"ruff==0.11.*\",\n    \"mypy\",\n    \"types-docutils\",\n    \"scipy-stubs\",\n    \"typos\",\n    # docs\n    \"mkdocs\",\n    \"mkdocs-material\",\n    \"mkdocs-exclude\",\n    \"mkdocs-redirects\",\n    \"mkdocstrings-python\",\n    \"mike\",\n    \"mkdocs-jupyter\",\n    \"black\",\n    # release\n    \"bump-my-version\",\n]\npublishing = [\"build\", \"twine\", \"wheel\"]\nrl = [\"stable-baselines3>=2.3.2\", \"sb3-contrib\"]\nnotebooks = [\"nbmake\", \"tensorflow\"]\n\n[project.urls]\nRepository = \"https://github.com/neurogym/neurogym\"\nIssues = \"https://github.com/neurogym/neurogym\"\nDocumentation = \"https://neurogym.github.io/neurogym\"\nChangelog = \"https://github.com/neurogym/neurogym/CHANGELOG.md\"\n\n[tool.pytest.ini_options]\ntestpaths = [\"tests\"]\n\n[tool.coverage.run]\nbranch = true\nsource = [\"neurogym\"]\ncommand_line = \"-m pytest\"\n\n# For completeness, until we move to an src-based layouts\n[tool.setuptools.packages.find]\ninclude = [\"neurogym*\"]\nexclude = [\"tests*\"]\n\n[tool.mypy]\npython_version = \"3.11\"\nwarn_return_any = true\nwarn_unused_configs = true\nshow_error_codes = true\nexclude = \"build/.*\"\n\n[[tool.mypy.overrides]]\nmodule = \"psychopy\"\nignore_missing_imports = true\n\n[tool.coverage.report]\nexclude_also = [\n    \"if TYPE_CHECKING:\",\n    \"def __repr__\",\n    \"def __str__\",\n    \"raise NotImplementedError\",\n]\n\n[tool.typos]\ndefault.extend-ignore-words-re = [\n    \"arange\", # common numpy function\n]\nfiles.ignore-hidden = false\nfiles.extend-exclude = [\".git/*\"]\n","numLines":121,"startLine":1,"totalLines":121}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_a3b4c4397ca242a79d8dd165","type":"tool_result","content":"1\t# NeuroGym\n2\t\n3\t|     Badges     |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |\n4\t| :------------: | ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------