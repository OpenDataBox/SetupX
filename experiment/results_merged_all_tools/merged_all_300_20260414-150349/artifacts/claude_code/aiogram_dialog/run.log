{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_edf73265b6fd4631a317f562","type":"tool_result","content":"1\t[build-system]\n2\trequires = [\n3\t    \"setuptools==80.9.0\",\n4\t    \"setuptools-scm[simple]==9.2.0\",\n5\t]\n6\tbuild-backend = \"setuptools.build_meta\"\n7\t\n8\t[tool.setuptools.packages.find]\n9\twhere = [\"src\"]\n10\t\n11\t[project]\n12\tname = \"aiogram_dialog\"\n13\tdynamic = [\"version\"]\n14\treadme = \"README.md\"\n15\tauthors = [\n16\t    { name = \"Andrey Tikhonov\", email = \"17@itishka.org\" },\n17\t]\n18\tlicense = \"Apache-2.0\"\n19\tlicense-files = [\"LICENSE\"]\n20\tdescription = \"Telegram bot UI framework on top of aiogram\"\n21\trequires-python = \">=3.10\"\n22\tclassifiers = [\n23\t    \"Programming Language :: Python :: 3\",\n24\t    \"Programming Language :: Python :: 3.10\",\n25\t    \"Programming Language :: Python :: 3.11\",\n26\t    \"Programming Language :: Python :: 3.12\",\n27\t    \"Programming Language :: Python :: 3.13\",\n28\t    \"Programming Language :: Python :: 3.14\",\n29\t    \"Intended Audience :: Developers\",\n30\t    \"Operating System :: OS Independent\",\n31\t]\n32\tdependencies = [\n33\t    \"aiogram>=3.14.0\",\n34\t    \"jinja2\",\n35\t    \"cachetools>=4.0.0,<6.0.0\",\n36\t]\n37\t\n38\t[project.optional-dependencies]\n39\ttools = [\n40\t    \"diagrams\",\n41\t    \"aiohttp\",\n42\t]\n43\t\n44\t[project.urls]\n45\t\"Homepage\" = \"https://github.com/tishka17/aiogram_dialog\"\n46\t\"Documentation\" = \"https://aiogram-dialog.readthedocs.org\"\n47\t\"Bug Tracker\" = \"https://github.com/tishka17/aiogram_dialog/issues\"\n48\t\n49\t[project.scripts]\n50\taiogram-dialog-preview = \"aiogram_dialog.tools.web_preview:main\"\n51\t\n52\t[tool.setuptools_scm]\n53\tversion_file = \"src/aiogram_dialog/_version.py\"\n54\tversion_file_template = \"\"\"\\\n55\t# This file auto generated!\n56\t# DO NOT EDIT MANUALLY!\n57\t\n58\tversion: str = \"{version}\"\n59\t__version__: str = \"{version}\"\n60\