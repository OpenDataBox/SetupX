{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_fc6a1c278f3f4f95a0f6132c","type":"tool_result","content":"1\t#!/usr/bin/env python\n2\timport argparse\n3\timport os\n4\timport sys\n5\timport warnings\n6\t\n7\tfrom django.core.management import execute_from_command_line\n8\t\n9\tos.environ['DJANGO_SETTINGS_MODULE'] = 'wagtailmenus.settings.testing'\n10\t\n11\t\n12\tdef make_parser():\n13\t    parser = argparse.ArgumentParser()\n14\t    parser.add_argument(\n15\t        '--deprecation',\n16\t        choices=['all', 'pending', 'imminent', 'none'],\n17\t        default='imminent'\n18\t    )\n19\t    return parser\n20\t\n21\t\n22\tdef parse_args(args=None):\n23\t    return make_parser().parse_known_args(args)\n24\t\n25\t\n26\tdef runtests():\n27\t    parsed_args, unparsed_args = parse_args()\n28\t\n29\t    only_wagtailmenus = r'^wagtailmenus(\\.|$)'\n30\t    if parsed_args.deprecation == 'all':\n31\t        # Show all deprecation warnings from all packages\n32\t        warnings.simplefilter('default', category=DeprecationWarning)\n33\t        warnings.simplefilter('default', category=PendingDeprecationWarning)\n34\t    elif parsed_args.deprecation == 'pending':\n35\t        # Show all deprecation warnings\n36\t        warnings.filterwarnings('default', category=DeprecationWarning, module=only_wagtailmenus)\n37\t        warnings.filterwarnings('default', category=PendingDeprecationWarning, module=only_wagtailmenus)\n38\t    elif parsed_args.deprecation == 'imminent':\n39\t        # Show only imminent deprecation warnings\n40\t        warnings.filterwarnings('default', category=DeprecationWarning, module=only_wagtailmenus)\n41\t    elif parsed_args.deprecation == 'none':\n42\t        # Deprecation warnings are ignored\n43\t        pass\n44\t\n45\t    argv = [sys.argv[0], 'test'] + unparsed_args\n46\t    return execute_from_command_line(argv)\n47\t\n48\tif __name__ == '__main__':\n49\t    sys.exit(runtests())\n50\t"}]},"parent_tool_use_id":null,"session_id":"b73115a4-54ae-4c03-b70b-1bd129608a46","uuid":"6eed209a-dec0-45e4-af29-76332b471a77","timestamp":"2026-04-08T21:31:52.391Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/runtests.py","content":"#!/usr/bin/env python\nimport argparse\nimport os\nimport sys\nimport warnings\n\nfrom django.core.management import execute_from_command_line\n\nos.environ['DJANGO_SETTINGS_MODULE'] = 'wagtailmenus.settings.testing'\n\n\ndef make_parser():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\n        '--deprecation',\n        choices=['all', 'pending', 'imminent', 'none'],\n        default='imminent'\n    )\n    return parser\n\n\ndef parse_args(args=None):\n    return make_parser().parse_known_args(args)\n\n\ndef runtests():\n    parsed_args, unparsed_args = parse_args()\n\n    only_wagtailmenus = r'^wagtailmenus(\\.|$)'\n    if parsed_args.deprecation == 'all':\n        # Show all deprecation warnings from all packages\n        warnings.simplefilter('default', category=DeprecationWarning)\n        warnings.simplefilter('default', category=PendingDeprecationWarning)\n    elif parsed_args.deprecation == 'pending':\n        # Show all deprecation warnings\n        warnings.filterwarnings('default', category=DeprecationWarning, module=only_wagtailmenus)\n        warnings.filterwarnings('default', category=PendingDeprecationWarning, module=only_wagtailmenus)\n    elif parsed_args.deprecation == 'imminent':\n        # Show only imminent deprecation warnings\n        warnings.filterwarnings('default', category=DeprecationWarning, module=only_wagtailmenus)\n    elif parsed_args.deprecation == 'none':\n        # Deprecation warnings are ignored\n        pass\n\n    argv = [sys.argv[0], 'test'] + unparsed_args\n    return execute_from_command_line(argv)\n\nif __name__ == '__main__':\n    sys.exit(runtests())\n","numLines":50,"startLine":1,"totalLines":50}}}
