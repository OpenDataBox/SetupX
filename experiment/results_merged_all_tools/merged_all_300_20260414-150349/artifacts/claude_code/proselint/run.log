    # flake8-builtins\n58\t\t\"ANN\",  # flake8-annotations\n59\t\t\"ARG\",  # flake8-unused-arguments\n60\t\t\"B\",    # Bugbear\n61\t\t\"COM\",  # flake8-commas\n62\t\t\"C4\",   # flake8-comprehensions\n63\t\t\"DTZ\",  # flake8-datetimez\n64\t\t\"D\",    # pydocstyle\n65\t\t\"E\",    # pycodestyle errors\n66\t\t\"F\",    # pyflakes\n67\t\t\"FA\",   # flake8-future-annotations\n68\t\t\"FBT\",  # boolean traps\n69\t\t\"FLY\",  # flynt\n70\t\t\"FURB\", # refurb\n71\t\t\"G\",    # flake8-logging-format\n72\t\t\"I\",    # incomplete isort\n73\t\t\"INP\",  # flake8-no-pep420\n74\t\t\"LOG\",  # flake8-logging\n75\t\t\"N\",    # naming\n76\t\t\"NPY\",  # NumPy-specific rules\n77\t\t\"PD\",   # pandas-vet\n78\t\t\"PERF\", # Perflint\n79\t\t\"PL\",   # Pylint\n80\t\t\"PTH\",  # flake8-use-pathlib\n81\t\t\"PYI\",  # flake8-pyi\n82\t\t\"RET\",  # flake8-return\n83\t\t\"RUF\",  # Ruff-specific rules\n84\t\t\"S\",    # bandit, security\n85\t\t\"SLF\",  # flake8-self\n86\t\t\"SIM\",  # flake8-simplify\n87\t\t\"TID\",  # flake8-tidy-imports\n88\t\t\"TCH\",  # flake8-type-checking\n89\t\t\"T10\",  # flake8-print\n90\t\t\"UP\",   # pyupgrade\n91\t\t\"W\",    # pycodestyle warnings\n92\t\t\"YTT\",  # flake8-2020\n93\t]\n94\tignore = [\n95\t\t\"COM812\", # trailing comma -> done by formatter\n96\t\t\"D203\",   # no blank lines between classes and documentation\n97\t\t\"D212\",   # consistent start level for multi-line edocumentation\n98\t\t\"D415\",   # first line of docs should end with a period\n99\t]\n100\tpreview = true\n101\t\n102\t[tool.ruff.lint.per-file-ignores]\n103\t\"tests/**\" = [\"S101\", \"SLF001\", \"PLC2701\"]\n104\t\"proselint/checks/**\" = [\"RUF001\"]\n105\t\"proselint/registry/checks/engine.py\" = [\n106\t\t\"D102\",\n107\t] # docs are inherited from base classes\n108\t"}]},"parent_tool_use_id":null,"session_id":"9b27b3bf-dbb4-4875-9866-3bff8f3c05f2","uuid":"8aeb8bd3-3336-48be-934a-9bf738d67888","timestamp":"2026-04-06T19:54:03.436Z","tool_use_result":{"type":"tex