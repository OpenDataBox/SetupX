rix]]\n125\tdeps = [ \"pre\" ]\n126\tpython = [ \"3.14\" ]\n127\t\n128\t[[tool.hatch.envs.hatch-test.overrides.matrix.deps.env-vars]]\n129\tkey = \"UV_PRERELEASE\"\n130\tvalue = \"allow\"\n131\tif = [ \"pre\" ]\n132\t\n133\t[tool.hatch.envs.docs]\n134\tdependency-groups = [ \"docs\" ]\n135\tscripts.build = \"sphinx-build -M html docs docs/_build {args}\"\n136\tscripts.open = \"python -m webbrowser -t docs/_build/html/index.html\"\n137\tscripts.clean = \"git clean -fdX -- {args:docs}\"\n138\tscripts.auto = \"sphinx-autobuild docs docs/_build/html --open-browser --watch README.md {args}\"\n139\t\n140\t[tool.ruff]\n141\tline-length = 120\n142\tsrc = [ \"src\" ]\n143\t\n144\tformat.docstring-code-format = true\n145\tlint.select = [\n146\t  \"B\",   # flake8-bugbear\n147\t  \"BLE\", # flake8-blind-except\n148\t  \"C4\",  # flake8-comprehensions\n149\t  \"D\",   # flake8-docstrings\n150\t  \"E\",   # pycodestyle\n151\t  \"F\",   # pyflakes\n152\t  \"I\",   # isort\n153\t  \"NPY\", # NumPy-specific rules\n154\t  \"PT\",  # flake8-pytest-style\n155\t  \"Q\",   # flake8-quotes\n156\t  \"RET\", # flake8-raise\n157\t  \"SIM\", # flake8-simplify\n158\t  \"T20\", # flake8-print\n159\t  \"TID\", # flake8-tidy-imports\n160\t  \"UP\",  # pyupgrade\n161\t  \"W\",   # pycodestyle\n162\t]\n163\tlint.ignore = [\n164\t  # `zip()` without an explicit `strict=` parameter (67 pre-existing, fix separately)\n165\t  \"B905\",\n166\t  # Missing docstring in public module\n167\t  \"D100\",\n168\t  # Missing docstring in public package\n169\t  \"D104\",\n170\t  # Missing docstring in magic method\n171\t  \"D105\",\n172\t  # Missing docstring in __init__\n173\t  \"D107\",\n174\t  # Do not assign a lambda expression, use a def -> lambda expression assignments are convenient\n175\t  \"E731\",\n176\t  # allow I, O, l as variable names -> I is the identity matrix, i, j, k, l is reasonable indexing notation\n177\t  \"E741\",\n178\t  \"PT011\", # TODO/\n179\t  # Do not implicitly `return None` in funct