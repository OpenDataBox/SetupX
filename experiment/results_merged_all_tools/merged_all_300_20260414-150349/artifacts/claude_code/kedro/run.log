erage[toml]\",\n55\t    \"detect-secrets~=1.5.0\",\n56\t    \"import-linter>=2.5.2,<3.0\",\n57\t    \"ipylab>=1.0.0\",\n58\t    \"ipython>=8.10,<10.0\",\n59\t    \"jupyterlab_server>=2.11.1\",\n60\t    \"jupyterlab>=3,<5\",\n61\t    \"jupyter~=1.0\",\n62\t    \"kedro-datasets\",\n63\t    \"mypy~=1.0\",\n64\t    \"pandas>=2.0,<4.0\",\n65\t    \"pluggy>=1.0\",\n66\t    \"pre-commit>=2.9.2,<5.0\",  # The hook `mypy` requires pre-commit version 2.9.2.\n67\t    \"pydantic\",\n68\t    \"pytest-cov>=3,<8\",\n69\t    \"pytest-mock>=1.7.1,<4.0\",\n70\t    \"pytest-xdist[psutil]>=2.2.1,<4.0\",\n71\t    \"pytest>=7.2,<10.0\",\n72\t    \"requests_mock\",\n73\t    \"s3fs>=2021.4,<2026.5\",\n74\t    # mypy related dependencies\n75\t    \"pandas-stubs\",\n76\t    \"types-PyYAML\",\n77\t    \"types-requests\",\n78\t]\n79\tdocs = [\n80\t    \"mkdocs>=1.6.1\",\n81\t    \"mkdocs-material>=9.6.11\",\n82\t    \"mkdocs-material-extensions>=1.3.1\",\n83\t    \"mkdocs-mermaid2-plugin>=1.2.1\",\n84\t    \"mkdocs-autorefs>=1.4.1\",\n85\t    \"mkdocs-get-deps>=0.2.0\",\n86\t    \"mkdocstrings>=0.29.1\",\n87\t    \"mkdocstrings-python>=0.29.1\",\n88\t    \"mkdocs-click\",\n89\t    \"mkdocs-redirects\",\n90\t    \"griffe\",  # Required by mkdocstrings-python for API documentation generation.\n91\t    \"mkdocs-llmstxt\" # Required to generate the llm.txt file\n92\t]\n93\tjupyter = [\n94\t    \"ipylab>=1.0.0\",\n95\t    \"notebook>=7.0.0\"  # requires the new share backend of notebook and labs\"\n96\t]\n97\tbenchmark = [\n98\t    \"asv\"\n99\t]\n100\tall = [ \"kedro[test,docs,jupyter,benchmark]\" ]\n101\t\n102\t[project.urls]\n103\tHomepage = \"https://kedro.org\"\n104\tSource = \"https://github.com/kedro-org/kedro\"\n105\tDocumentation = \"https://docs.kedro.org\"\n106\tTracker = \"https://github.com/kedro-org/kedro/issues\"\n107\t\n108\t[project.scripts]\n109\tkedro = \"kedro.framework.cli:main\"\n110\t\n111\t[tool.setuptools]\n112\tzip-safe = false\n113\t\n114\t[tool.setuptools.packages.find]\