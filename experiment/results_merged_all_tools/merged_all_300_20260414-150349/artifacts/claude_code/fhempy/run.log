{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_da7865098fea4971bf66496e","type":"tool_result","content":"1\timport functools\n2\t\n3\timport pytest\n4\tfrom fhempy.lib import utils\n5\t\n6\t\n7\tdef test_local_ip():\n8\t    ip = utils.get_local_ip()\n9\t    assert ip != \"127.0.0.1\"\n10\t\n11\t\n12\tdef test_encrypt_decrypt():\n13\t    teststring = \"This is a test string\"\n14\t    fhem_unique_id = \"a3e36c8ec8622a0de0e11191dc430a34\"\n15\t    encrypted_string = utils.encrypt_string(teststring, fhem_unique_id)\n16\t    decrypted_string = utils.decrypt_string(encrypted_string, fhem_unique_id)\n17\t    assert teststring == decrypted_string\n18\t    return decrypted_string\n19\t\n20\t\n21\t@pytest.mark.asyncio\n22\tasync def test_run_blocking():\n23\t    test_string = await utils.run_blocking(functools.partial(test_encrypt_decrypt))\n24\t    assert \"This is a test string\" == test_string\n25\t\n26\t\n27\t@pytest.mark.asyncio\n28\tasync def test_run_blocking_task():\n29\t    foo = None\n30\t\n31\t    def set_foo():\n32\t        nonlocal foo\n33\t        foo = \"bar\"\n34\t\n35\t    task = utils.run_blocking_task(functools.partial(set_foo))\n36\t    await task\n37\t    assert foo == \"bar\"\n38\t\n39\t\n40\t@pytest.mark.asyncio\n41\tasync def test_handle_define_attr(mocker):\n42\t    async def setDevAttrList(hashname, attrlist):\n43\t        assert hashname == \"test\"\n44\t        assert str(attrlist) == \"attr1 attr2 attr3 attr4 attr5:on,off,test\"\n45\t\n46\t    async def AttrVal(hashname, attr, default):\n47\t        if attr == \"attr3\":\n48\t            return \"test33\"\n49\t        return \"\"\n50\t\n51\t    mocker.patch(\"fhempy.lib.fhem.setDevAttrList\", setDevAttrList)\n52\t    mocker.patch(\"fhempy.lib.fhem.AttrVal\", AttrVal)\n53\t\n54\t    class TestClass:\n55\t        async def set_attr(self, hash):\n56\t            assert self._attr_attr4 == \"test4\"\n57\t\n58\t    testinstance = TestClass()\n59\t    attr_conf = {\n60\t        \"attr1\": {},\n61\t        \"attr2\": {\"default\": 1, \"format\": \"int\"},\n62\t        \"attr3\": {\"default\": \"test3\"},\n63\t        \"attr4\": {\"default\": \"test4\", \"function\": \"set_attr\"},\n64\t        \"attr5\": {\"default\": \"test5\", \"options\": \"on,off,test\"},\n65\t    }\n66\t    hash = {\"NAME\": \"test\"}\n67\t    await utils.handle_define_attr(attr_conf, testinstance, hash)\n68\t    assert testinstance._attr_attr1 == \"\"\n69\t    assert testinstance._attr_attr2 == 1\n70\t    assert testinstance._attr_attr3 == \"test33\"\n71\t    assert testinstance._attr_attr4 == \"test4\"\n72\t    assert testinstance._attr_attr5 == \"test5\"\n73\t\n74\t\n75\t@pytest.mark.asyncio\n76\tasync def test_handle_attr():\n77\t    class TestClass:\n78\t        async def set_attr(self, hash):\n79\t            assert self._attr_attr4 == \"asdf\"\n80\t\n81\t    testinstance = TestClass()\n82\t    attr_conf = {\n83\t        \"attr1\": {},\n84\t        \"attr2\": {\"default\": 1, \"format\": \"int\"},\n85\t        \"attr3\": {\"default\": \"test3\"},\n86\t        \"attr4\": {\"default\": \"test4\", \"function\": \"set_attr\"},\n87\t        \"attr5\": {\"default\": \"test5\", \"options\": \"on,off,test\"},\n88\t    }\n89\t    hash = {\"NAME\": \"test\"}\n90\t    # set new value\n91\t    await utils.handle_attr(\n92\t        attr_conf, testinstance, hash, [\"set\", \"test\", \"attr1\", \"NEWVALUE\"], {}\n93\t    )\n94\t    assert testinstance._attr_attr1 == \"NEWVALUE\"\n95\t\n96\t    # set integer\n97\t    await utils.handle_attr(\n98\t        attr_conf, testinstance, hash, [\"set\", \"test\", \"attr2\", \"2\"], {}\n99\t    )\n100\t    assert testinstance._attr_attr2 == 2\n101\t\n102\t    # del attribute\n103\t    await utils.handle_attr(\n104\t        attr_conf, testinstance, hash, [\"del\", \"test\", \"attr2\", \"\"], {}\n105\t    )\n106\t    assert testinstance._attr_attr2 == 1\n107\t\n108\t    await utils.handle_attr(\n109\t        attr_conf, testinstance, hash, [\"set\", \"test\", \"attr4\", \"asdf\"], {}\n110\t    )\n111\t    assert testinstance._attr_attr4 == \"asdf\"\n112\t\n113\t\n114\tdef test_flatten_json():\n115\t    json = {\"asdf\": {\"nested\": {\"nested2\": \"x\"}}}\n116\t    flat_json = utils.flatten_json(json)\n117\t    for element in flat_json:\n118\t        assert element == \"asdf_nested_nested2\"\n119\t        assert flat_json[element] == \"x\"\n120\t\n121\t\n122\tdef test_convert2format():\n123\t    listdef = {\"format\": \"int\"}\n124\t    newval = utils.convert2format(\"3\", listdef)\n125\t    assert newval == 3\n126\t\n127\t    listdef = {\"format\": \"int\"}\n128\t    newval = utils.convert2format(\"3\", listdef)\n129\t    assert newval == 3\n130\t    assert isinstance(newval, int) == True\n131\t\n132\t    listdef = {\"format\": \"str\"}\n133\t    newval = utils.convert2format(\"3\", listdef)\n134\t    assert newval == \"3\"\n135\t    assert isinstance(newval, str) == True\n136\t\n137\t    listdef = {\"format\": \"float\"}\n138\t    newval = utils.convert2format(\"3\", listdef)\n139\t    assert newval == 3.0\n140\t    assert isinstance(newval, float) == True\n141\t\n142\t    listdef = {}\n143\t    newval = utils.convert2format(\"3\", listdef)\n144\t    assert newval == \"3\"\n145\t\n146\t    listdef = {}\n147\t    newval = utils.convert2format(3, listdef)\n148\t    assert newval == 3\n149\t\n150\t\n151\t@pytest.mark.asyncio\n152\tasync def test_handle_set():\n153\t    set_list_conf = {\n154\t        \"mode\": {\n155\t            \"args\": [\"mode\"],\n156\t            \"argsh\": [\"mode\"],\n157\t            \"params\": {\"mode\": {\"optional\": False}},\n158\t            \"options\": \"eco,comfort\",\n159\t        },\n160\t        \"desiredTemp\": {\"args\": [\"temperature\"], \"options\": \"slider,10,1,30\"},\n161\t        \"holidayMode\": {\n162\t            \"args\": [\"temperature\", \"till\", \"end\"],\n163\t            \"params\": {\"till\": {\"default\": \"31.12.2030\"}, \"end\": {\"default\": \"23:59\"}},\n164\t        },\n165\t        \"on\": {\n166\t            \"args\": [\"seconds\"],\n167\t            \"params\": {\"seconds\": {\"optional\": True, \"format\": \"int\"}},\n168\t        },\n169\t        \"off\": {},\n170\t    }\n171\t\n172\t    newstate = None\n173\t\n174\t    class TestClass:\n175\t        def __init__(self):\n176\t            pass\n177\t\n178\t        async def set_on(self, hash, params):\n179\t            nonlocal newstate\n180\t            if len(params) == 0:\n181\t                newstate = \"on\"\n182\t            else:\n183\t                newstate = params\n184\t\n185\t        async def set_off(self, hash, params):\n186\t            assert hash[\"NAME\"] == \"testhash\"\n187\t            nonlocal newstate\n188\t            newstate = \"off\"\n189\t\n190\t        async def set_mode(self, hash, params):\n191\t            nonlocal newstate\n192\t            newstate = params\n193\t\n194\t        async def set_holidayMode(self, hash, params):\n195\t            nonlocal newstate\n196\t            newstate = params\n197\t\n198\t    testhash = {\"NAME\": \"testhash\", \"FHEMPYTYPE\": \"testtype\"}\n199\t\n200\t    testinstance = TestClass()\n201\t    retval = await utils.handle_set(\n202\t        set_list_conf, testinstance, testhash, [\"testhash\"], {}\n203\t    )\n204\t    assert (\n205\t        retval\n206\t        == \"Unknown argument ?, choose one of mode:eco,comfort desiredTemp:slider,10,1,30 holidayMode on off:noArg\"\n207\t    )\n208\t\n209\t    retval = await utils.handle_set(\n210\t        set_list_conf, testinstance, testhash, [\"testhash\", \"?\"], {}\n211\t    )\n212\t    assert (\n213\t        retval\n214\t        == \"Unknown argument ?, choose one of mode:eco,comfort desiredTemp:slider,10,1,30 holidayMode on off:noArg\"\n215\t    )\n216\t\n217\t    retval = await utils.handle_set(\n218\t        set_list_conf,\n219\t        testinstance,\n220\t        testhash,\n221\t        [\"testhash\", \"mode\"],\n222\t        {