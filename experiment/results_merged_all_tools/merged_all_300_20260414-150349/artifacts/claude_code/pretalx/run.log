CENSES/BSD-2-Clause.txt","LICENSES/AGPL-3.0-only.txt","LICENSES/CC-BY-4.0.txt","LICENSES/EUPL-1.2.txt","LICENSES/0BSD.txt","LICENSES/CC0-1.0.txt","LICENSES/Apache-2.0.txt","LICENSES/OFL-1.1.txt","LICENSES/LicenseRef-Pretalx-AGPL-3.0-Terms.txt","LICENSES/ISC.txt","LICENSES/MIT.txt","doc/api/schema.yml","doc/spelling_wordlist.txt","pyproject.toml","doc/user/review-assignments.json","src/pretalx.example.cfg","src/pretalx/frontend/schedule-editor/locales/en/translation.json","src/pretalx/frontend/schedule-editor/package-lock.json","src/pretalx/frontend/schedule-editor/package.json","src/pretalx/locale/translation_percentages.json","src/pretalx/schedule/templates/schedule/speaker_notification.txt","src/tests/ci_postgres.cfg","src/tests/ci_sqlite.cfg","src/tests/fixtures/schedule.json"],"durationMs":14,"numFiles":38,"truncated":false}}
