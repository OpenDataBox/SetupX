{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_1fb55536584a4a2da109998e","type":"tool_result","content":"1\t# SPDX-FileCopyrightText: 2023-present Tobias Kunze\n2\t# SPDX-License-Identifier: Apache-2.0\n3\t\n4\t[project]\n5\tname = \"pretalx\"\n6\tdynamic = [\"version\"]\n7\tdescription = \"Conference organisation: CfPs, scheduling, much more\"\n8\treadme = \"README.rst\"\n9\tlicense = \"AGPL-3.0-only\"\n10\t# SHOULD be the following, but Python does not support SPDX v3 (yet?)\n11\t#license = \"AGPL-3.0-only WITH AdditionRef-Pretalx-AGPL-3.0-Terms\"\n12\tlicense-files = [\"LICENSE\"]\n13\trequires-python = \">=3.12\"\n14\tkeywords = [\"conference\", \"event\", \"schedule\", \"talk\", \"cfp\"]\n15\tauthors = [\n16\t  {name = \"Tobias Kunze\", email = \"r@rixx.de\"},\n17\t]\n18\tmaintainers = [\n19\t  {name = \"Tobias Kunze\", email = \"r@rixx.de\"},\n20\t]\n21\tclassifiers = [\n22\t  \"Development Status :: 5 - Production/Stable\",\n23\t  \"Environment :: Web Environment\",\n24\t  \"Framework :: Django :: 6.0\",\n25\t  \"Intended Audience :: Developers\",\n26\t  \"Intended Audience :: Other Audience\",\n27\t  \"Programming Language :: Python :: 3.12\",\n28\t  \"Programming Language :: Python :: 3.13\",\n29\t  \"Programming Language :: Python :: 3.14\",\n30\t  \"Topic :: Internet :: WWW/HTTP :: Dynamic Content\",\n31\t]\n32\t\n33\tdependencies = [\n34\t  \"beautifulsoup4[lxml]~=4.14.0\",\n35\t  \"bleach~=6.3.0\",\n36\t  \"celery~=5.6.0\",\n37\t  \"css_inline~=0.20.0\",\n38\t  \"cssutils~=2.11.0\",\n39\t  \"defusedcsv~=3.0.0\",\n40\t  \"defusedxml~=0.7.0\",\n41\t  \"diff-match-patch==20241021\",\n42\t  \"Django[argon2]~=6.0.0\",\n43\t  \"django-context-decorator\",\n44\t  \"django-csp~=4.0.0\",\n45\t  \"django-filter==25.2\",\n46\t  \"django-formtools~=2.5.1\",\n47\t  \"django-hierarkey~=2.0.1\",\n48\t  \"django-i18nfield~=1.11.0\",\n49\t  \"django-minify-html~=1.14.0\",\n50\t  \"django-scopes~=2.0.0\",\n51\t  \"django-tables2~=2.8.0\",\n52\t  \"djangorestframework~=3.17.0\",\n53\t  \"drf-flex-fields~=1.0.0\",\n54\t  \"Markdown~=3.10.0\",\n55\t  \"Pillow~=12.1.0\",\n56\t  \"publicsuffixlist~=1.0.0\",\n57\t  \"python-dateutil~=2.9.0\",\n58\t  \"qrcode~=8.0\",\n59\t  \"reportlab~=4.4.0\",\n60\t  \"requests~=2.33.0\",\n61\t  \"rules~=3.5.0\",\n62\t  \"urlman~=2.0.1\",\n63\t  \"vobject~=0.9.0\",\n64\t  \"whitenoise[brotli]~=6.12.0\",\n65\t  \"zxcvbn~=4.5.0\",\n66\t]\n67\t\n68\t[project.optional-dependencies]\n69\tdev = [\n70\t  \"build\",\n71\t  \"check-manifest\",\n72\t  \"coverage\",\n73\t  \"django-watchfiles\",\n74\t  \"djhtml\",\n75\t  \"drf-spectacular\",\n76\t  \"factory_boy\",\n77\t  \"freezegun\",\n78\t  \"jsonschema\",\n79\t  \"polib\",\n80\t  \"pytest\",\n81\t  \"pytest-cov\",\n82\t  \"pytest-django\",\n83\t  \"pytest-mock\",\n84\t  \"pytest-sugar\",\n85\t  \"pytest-xdist\",\n86\t  \"responses\",\n87\t  \"ruff\",\n88\t  \"twine\",\n89\t  \"urllib3\",\n90\t]\n91\tdevdocs = [\n92\t  \"drf-spectacular\",\n93\t  \"sphinx\",\n94\t  \"sphinx-autobuild\",\n95\t  \"sphinx-autodoc-typehints\",\n96\t  \"sphinx-copybutton\",\n97\t  \"sphinxcontrib-django\",\n98\t  \"sphinxcontrib-httpdomain\",\n99\t  \"sphinxcontrib-spelling\",\n100\t]\n101\tpostgres = [\"psycopg2-binary~=2.9.0\"]\n102\tredis = [\"redis~=7.4.0\"]\n103\t\n104\t[build-system]\n105\tbuild-backend = \"setuptools.build_meta\"\n106\trequires = [\"setuptools\", \"wheel\"]\n107\t\n108\t[project.urls]\n109\tHomepage = \"https://pretalx.com\"\n110\tDocumentation = \"https://docs.pretalx.org\"\n111\tRepository = \"https://github.com/pretalx/pretalx\"\n112\tChangelog = \"https://docs.pretalx.org/changelog/\"\n113\tIssues = \"https://github.com/pretalx/pretalx/issues\"\n114\t\n115\t[tool.setuptools]\n116\tinclude-package-data = true\n117\t\n118\t[tool.setuptools.dynamic]\n119\tversion = {attr = \"pretalx.__version__\"}\n120\t\n121\t[tool.setuptools.packages.find]\n122\twhere = [\"src\"]\n123\tinclude = [\"pretalx*\"]\n124\texclude = [\"pretalx/frontend/node_modules\"]\n125\t\n126\t[tool.check-manifest]\n127\tignore = [\n128\t  \".*\",\n129\t  \"assets/*\",\n130\t  \"CODE_OF_CONDUCT.md\",\n131\t  \"CONTRIBUTORS\",\n132\t  \"docs/*\",\n133\t  \"src/local/*\",\n134\t  \"src/tests\",\n135\t  \"src/tests/*\",\n136\t  \"SECURITY.md\",\n137\t]\n138\t\n139\t[tool.pytest.ini_options]\n140\tDJANGO_SETTINGS_MODULE = \"pretalx.common.settings.test_settings\"\n141\ttestpaths = \"src/tests\"\n142\tpythonpath = \"src\"\n143\tfilterwarnings = [\n144\t    # Turn all unfiltered warnings into errors (processed last due to insertion order)\n145\t    \"error\",\n146\t    # 2026-03: drf-spectacular 0.29.0 uses _UnionGenericAlias, deprecated in Python 3.17\n147\t    \"ignore:._UnionGenericAlias.:DeprecationWarning\",\n148\t    # Unclosed FieldFile handles during GC — per-test markers can't cover session/worker cleanup\n149\t    \"ignore::pytest.PytestUnraisableExceptionWarning\",\n150\t]\n151\taddopts = \"-p no:doctest -p no:pastebin -p no:nose\"\n152\tmarkers = [\n153\t    \"unit: Unit tests\",\n154\t    \"integration: Integration tests\",\n155\t    \"e2e: End-to-end tests\",\n156\t    \"slow: Tests that are inherently slow (network timeouts, heavy DB setup). Skip with -m 'not slow'\",\n157\t]\n158\t\n159\t[tool.coverage.run]\n160\tbranch = true\n161\tomit = [\n162\t  \"*/__init__.py\",\n163\t  \"*/__main__.py\",\n164\t  \"*/celery_app.py\",\n165\t  \"*/legacy.py\",\n166\t  \"*/legacy-tests/*\",\n167\t  \"*/local/*\",\n168\t  \"*/manage.py\",\n169\t  \"*/management/commands/devserver.py\",\n170\t  \"*/management/commands/makemessages.py\",\n171\t  \"*/management/commands/rebuild.py\",\n172\t  \"*/migrations/*\",\n173\t  \"*/screenshots/*\",\n174\t  \"*/settings*\",\n175\t  \"*/shims.py\",\n176\t  \"*/test_settings*\",\n177\t  \"*/urls.py\",\n178\t  \"*/wsgi.py\",\n179\t]\n180\trelative_files = true\n181\t\n182\t[tool.coverage.report]\n183\tfail_under = 100\n184\texclude_also = [\n185\t  \"def __repr__\",\n186\t  \"def __str__\",\n187\t  \"if settings.DEBUG\",\n188\t  \"NOQA\",\n189\t  \"noqa\",\n190\t  \"NotImplementedError\",\n191\t]\n192\t\n193\t[tool.ruff.format]\n194\tskip-magic-trailing-comma = true\n195\t\n196\t[tool.ruff.lint]\n197\tselect = [\"ALL\"]\n198\tignore = [\n199\t  \"ANN\",     # We do not do annotations\n200\t  \"ARG\",     # Unused method arguments are often ok\n201\t  \"C901\",    # We do do complexity\n202\t  \"COM812\",  # Trailing commas are formatter territory\n203\t  \"D\",       # We do not enforce docstyles\n204\t  \"DJ001\",   # We live in a state of sin\n205\t  \"E501\",    # Long lines are formatter territory\n206\t  \"EM\",      # Formatting strings is fine, actually\n207\t  \"FBT\",     # Booleans are fine, actually\n208\t  \"FIX\",     # TODO comments are fine, actually\n209\t  \"PLR\",     # Refactoring: Too many branches, arguments, statements, etc\n210\t  \"RET502\",  # Just returning is fine, actually\n211\t  \"RET503\",  # Just not returning is fine, actually\n212\t  \"RUF012\",  # Mutable default in class attribute is just how django rolls\n213\t  \"RUF100\",  # Unused noqa; problematic when run in isolation\n214\t  \"TRY003\",  # Error messages are fine, actually\n215\t]\n216\tallowed-confusables = [\"–\", \"’\", \"×\"]\n217\t\n218\t[tool.ruff.lint.per-file-ignores]\n219\t\"tools/**.py\" = [\n220\t  \"E741\",    # Ambiguous variable names are fine in scripts\n221\t  \"EXE001\",  # Shebang without executable bit is fine for uv run scripts\n222\t  \"PTH\",     # os.path is fine in standalone scripts\n223\t  \"RUF015\",  # next() vs [0] is a style nit\n224\t  \"T201\",    # print() is the primary output mechanism in CLI tools\n225\t]\n226\t\"src/tests/**.py\" = [\n227\t  \"DTZ\",     # TODO: do not use naive datetimes in tests\n228\t  \"RUF\",     # Ignore ambiguous characters in tests, may be security tests\n229\t  \"S\",       # Tests do not need cryptographic randomness and other security features\n230\t  \"S101\",    # Ignore `assert` rules in tests\n231\t