{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_be41ecad397d4b43bea84c5d","type":"tool_result","content":"1\t#!/usr/bin/env python\n2\t# -*- coding: utf-8 -*-\n3\t\n4\t# pylint: skip-file\n5\t\n6\tfrom setuptools import find_packages, setup\n7\t\n8\t##### Dependencies of GPflow\n9\t\n10\trequirements = [\n11\t    \"check_shapes>=1.0.0\",\n12\t    \"deprecated\",\n13\t    \"multipledispatch>=0.6\",\n14\t    \"numpy<2\",\n15\t    \"packaging\",\n16\t    \"scipy\",\n17\t    \"setuptools>=41.0.0\",  # to satisfy dependency constraints\n18\t    \"tabulate\",\n19\t    \"tensorflow-probability[tf]>=0.12.0\",\n20\t    \"tensorflow>=2.4.0; platform_system!='Darwin' or platform_machine!='arm64'\",\n21\t    # NOTE: Support of Apple Silicon MacOS platforms is in an experimental mode\n22\t    \"tensorflow-macos>=2.4.0; platform_system=='Darwin' and platform_machine=='arm64'\",\n23\t    # NOTE: once we require tensorflow-probability>=0.12, we can remove our custom deepcopy handling\n24\t    \"typing_extensions\",\n25\t]\n26\t\n27\t\n28\tdef read_file(filename: str) -> str:\n29\t    with open(filename, encoding=\"utf-8\") as f:\n30\t        return f.read().strip()\n31\t\n32\t\n33\tversion = read_file(\"VERSION\")\n34\treadme_text = read_file(\"README.md\")\n35\t\n36\tpackages = find_packages(\".\", exclude=[\"tests\"])\n37\t\n38\tsetup(\n39\t    name=\"gpflow\",\n40\t    version=version,\n41\t    author=\"James Hensman, Alex Matthews\",\n42\t    author_email=\"james.hensman@gmail.com\",\n43\t    description=\"Gaussian process methods in TensorFlow\",\n44\t    long_description=readme_text,\n45\t    long_description_content_type=\"text/markdown\",\n46\t    license=\"Apache License 2.0\",\n47\t    keywords=\"machine-learning gaussian-processes kernels tensorflow\",\n48\t    url=\"https://www.gpflow.org\",\n49\t    project_urls={\n50\t        \"Source on GitHub\": \"https://github.com/GPflow/GPflow\",\n51\t        \"Documentation\": \"https://gpflow.github.io/GPflow/\",\n52\t    },\n53\t    packages=packages,\n54\t    package_data={\"\": [\"*.lark\"]},\n55\t    include_package_data=True,\n56\t    install_requires=requirements,\n57\t    extras_require={\"ImageToTensorBoard\": [\"matplotlib\"]},\n58\t    python_requires=\">=3.7\",\n59\t    classifiers=[\n60\t        \"Development Status :: 5 - Production/Stable\",\n61\t        \"Environment :: GPU :: NVIDIA CUDA\",\n62\t        \"Intended Audience :: Developers\",\n63\t        \"Intended Audience :: Education\",\n64\t        \"Intended Audience :: Science/Research\",\n65\t        \"License :: OSI Approved :: Apache Software License\",\n66\t        \"Natural Language :: English\",\n67\t        \"Operating System :: MacOS :: MacOS X\",\n68\t        \"Operating System :: Microsoft :: Windows\",\n69\t        \"Operating System :: POSIX :: Linux\",\n70\t        \"Programming Language :: Python :: 3.7\",\n71\t        \"Programming Language :: Python :: 3.8\",\n72\t        \"Programming Language :: Python :: 3.9\",\n73\t        \"Programming Language :: Python :: 3.10\",\n74\t        \"Topic :: Scientific/Engineering :: Artificial Intelligence\",\n75\t        \"Typing :: Typed\",\n76\t    ],\n77\t)\n78\t"}]},"parent_tool_use_id":null,"session_id":"fdaf30fb-efc0-4f75-80ee-0c67cf34a71a","uuid":"9f4cdf37-8243-48f5-9714-6d620518c561","timestamp":"2026-04-08T17:07:21.334Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/setup.py","content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\n# pylint: skip-file\n\nfrom setuptools import find_packages, setup\n\n##### Dependencies of GPflow\n\nrequirements = [\n    \"check_shapes>=1.0.0\",\n    \"deprecated\",\n    \"multipledispatch>=0.6\",\n    \"numpy<2\",\n    \"packaging\",\n    \"scipy\",\n    \"setuptools>=41.0.0\",  # to satisfy dependency constraints\n    \"tabulate\",\n    \"tensorflow-probability[tf]>=0.12.0\",\n    \"tensorflow>=2.4.0; platform_system!='Darwin' or platform_machine!='arm64'\",\n    # NOTE: Support of Apple Silicon MacOS platforms is in an experimental mode\n    \"tensorflow-macos>=2.4.0; platform_system=='Darwin' and platform_machine=='arm64'\",\n    # NOTE: once we require tensorflow-probability>=0.12, we can remove our custom deepcopy handling\n    \"typing_extensions\",\n]\n\n\ndef read_file(filename: str) -> str:\n    with open(filename, encoding=\"utf-8\") as f:\n        return f.read().strip()\n\n\nversion = read_file(\"VERSION\")\nreadme_text = read_file(\"README.md\")\n\npackages = find_packages(\".\", exclude=[\"tests\"])\n\nsetup(\n    name=\"gpflow\",\n    version=version,\n    author=\"James Hensman, Alex Matthews\",\n    author_email=\"james.hensman@gmail.com\",\n    description=\"Gaussian process methods in TensorFlow\",\n    long_description=readme_text,\n    long_description_content_type=\"text/markdown\",\n    license=\"Apache License 2.0\",\n    keywords=\"machine-learning gaussian-processes kernels tensorflow\",\n    url=\"https://www.gpflow.org\",\n    project_urls={\n        \"Source on GitHub\": \"https://github.com/GPflow/GPflow\",\n        \"Documentation\": \"https://gpflow.github.io/GPflow/\",\n    },\n    packages=packages,\n    package_data={\"\": [\"*.lark\"]},\n    include_package_data=True,\n    install_requires=requirements,\n    extras_require={\"ImageToTensorBoard\": [\"matplotlib\"]},\n    python_requires=\">=3.7\",\n    classifiers=[\n        \"Development Status :: 5 - Production/Stable\",\n        \"Environment :: GPU :: NVIDIA CUDA\",\n        \"Intended Audience :: Developers\",\n        \"Intended Audience :: Education\",\n        \"Intended Audience :: Science/Research\",\n        \"License :: OSI Approved :: Apache Software License\",\n        \"Natural Language :: English\",\n        \"Operating System :: MacOS :: MacOS X\",\n        \"Operating System :: Microsoft :: Windows\",\n        \"Operating System :: POSIX :: Linux\",\n        \"Programming Language :: Python :: 3.7\",\n        \"Programming Language :: Python :: 3.8\",\n        \"Programming Language :: Python :: 3.9\",\n        \"Programming Language :: Python :: 3.10\",\n        \"Topic :: Scientific/Engineering :: Artificial Intelligence\",\n        \"Typing :: Typed\",\n    ],\n)\n","numLines":78,"startLine":1,"totalLines":78}}}
