{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_091143f139494df297d93eeb","type":"tool_result","content":"1\timport os\n2\timport sys\n3\tfrom functools import cache\n4\tfrom importlib import import_module\n5\tfrom inspect import Parameter, signature\n6\tfrom types import GeneratorType, ModuleType\n7\tfrom typing import Any, Iterable, Type\n8\t\n9\timport yaml\n10\t\n11\tsys.path.append(\n12\t    os.path.join(os.path.dirname(__file__), \"..\")\n13\t)  # isort:skip # noqa: E402\n14\tfrom update_docu_links import (  # isort:skip # noqa: E402\n15\t    BLACK_LIST,\n16\t    COUNTRYCODES,\n17\t    LANGUAGES,\n18\t)\n19\t\n20\tSOURCES_NO_COUNTRY = [g.split(\"/\")[-1].removesuffix(\".md\") for g in BLACK_LIST]\n21\tSOURCES_TO_EXCLUDE = [\"__init__.py\", \"example.py\"]\n22\tSOURCES_EXCLUDE_TEST_CASE_CHECK = [\"multiple\"]\n23\t\n24\t\n25\tEXTRA_INFO_TYPES: dict[str, Type] = {\n26\t    \"title\": str,\n27\t    \"url\": str,\n28\t    \"country\": str,\n29\t    \"default_params\": dict,\n30\t}\n31\tEXTRA_INFO_KEYS = list(EXTRA_INFO_TYPES.keys())\n32\t\n33\t\n34\tSOURCE_PATH = os.path.join(\n35\t    os.path.dirname(__file__),\n36\t    \"../custom_components/waste_collection_schedule/waste_collection_schedule/source\",\n37\t)\n38\tSOURCE_MD_PATH = os.path.join(os.path.dirname(__file__), \"../doc/source/\")\n39\tICS_YAML_PATH = os.path.join(os.path.dirname(__file__), \"../doc/ics/yaml\")\n40\tICS_MD_PATH = os.path.join(os.path.dirname(__file__), \"../doc/ics\")\n41\t\n42\t\n43\tdef _get_module(source: str) -> ModuleType:\n44\t    sys.path.append(\n45\t        os.path.join(\n46\t            os.path.dirname(__file__), \"../custom_components/waste_collection_schedule\"\n47\t        )\n48\t    )\n49\t    return import_module(f\"waste_collection_schedule.source.{source}\")\n50\t\n51\t\n52\tICS_MODULE = _get_module(\"ics\")\n53\t\n54\t\n55\t@cache\n56\tdef _get_sources() -> list[str]:\n57\t    sources = []\n58\t    for file in os.listdir(SOURCE_PATH):\n59\t    