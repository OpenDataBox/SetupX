ber 31\n49\t    assert source._is_date_in_season(date(2025, 6, 15), season) is True\n50\t\n51\t\n52\tdef test_is_date_in_season_start_boundary(source):\n53\t    \"\"\"Test date on season start boundary.\"\"\"\n54\t    season = ((1, 4), (31, 10))\n55\t    assert source._is_date_in_season(date(2025, 4, 1), season) is True\n56\t\n57\t\n58\tdef test_is_date_in_season_end_boundary(source):\n59\t    \"\"\"Test date on season end boundary.\"\"\"\n60\t    season = ((1, 4), (31, 10))\n61\t    assert source._is_date_in_season(date(2025, 10, 31), season) is True\n62\t\n63\t\n64\tdef test_is_date_in_season_outside(source):\n65\t    \"\"\"Test date outside a normal season range.\"\"\"\n66\t    season = ((1, 4), (31, 10))  # April 1 to October 31\n67\t    assert source._is_date_in_season(date(2025, 12, 15), season) is False\n68\t\n69\t\n70\tdef test_is_date_in_season_year_spanning_winter(source):\n71\t    \"\"\"Test date in winter season that spans year boundary.\"\"\"\n72\t    season = ((1, 11), (28, 2))  # November 1 to February 28\n73\t    # December should be in winter season\n74\t    assert source._is_date_in_season(date(2025, 12, 15), season) is True\n75\t    # January should be in winter season\n76\t    assert source._is_date_in_season(date(2025, 1, 15), season) is True\n77\t\n78\t\n79\tdef test_is_date_in_season_year_spanning_outside(source):\n80\t    \"\"\"Test date outside a year-spanning season.\"\"\"\n81\t    season = ((1, 11), (28, 2))  # November 1 to February 28\n82\t    # June should not be in winter season\n83\t    assert source._is_date_in_season(date(2025, 6, 15), season) is False\n84\t\n85\t\n86\t# =============================================================================\n87\t# Tests for _generate_collection_dates - biweekly patterns\n88\t# =============================================================================\n89\t\n90\t\n91\tdef test_generate_dates_every_week(source, monkeypatch):\n92\t    \"\"\"Test generating dates for every week pickup [4,4] (Thursday every week).\"\"\"\n93\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n94\t\n95\t    dates = source._generate_collection_dates(\"[4,4]\", None)\n96\t\n97\t    # Should have Thursdays for 90 days\n98\t    assert len(dates) > 0\n99\t    # All dates should be Thursdays (isoweekday 4)\n100\t    for d in dates:\n101\t        assert d.isoweekday() == 4\n102\t\n103\t\n104\tdef test_generate_dates_odd_week_only(source, monkeypatch):\n105\t    \"\"\"Test generating dates for odd week only pickup [5,-].\"\"\"\n106\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n107\t\n108\t    dates = source._generate_collection_dates(\"[5,-]\", None)\n109\t\n110\t    # All dates should be Fridays in odd weeks\n111\t    for d in dates:\n112\t        assert d.isoweekday() == 5\n113\t        assert d.isocalendar()[1] % 2 == 1  # Odd week\n114\t\n115\t\n116\tdef test_generate_dates_even_week_only(source, monkeypatch):\n117\t    \"\"\"Test generating dates for even week only pickup [-,1].\"\"\"\n118\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n119\t\n120\t    dates = source._generate_collection_dates(\"[-,1]\", None)\n121\t\n122\t    # All dates should be Mondays in even weeks\n123\t    for d in dates:\n124\t        assert d.isoweekday() == 1\n125\t        assert d.isocalendar()[1] % 2 == 0  # Even week\n126\t\n127\t\n128\tdef test_generate_dates_different_days(source, monkeypatch):\n129\t    \"\"\"Test generating dates with different days for odd/even weeks [1,5].\"\"\"\n130\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n131\t\n132\t    dates = source._generate_collection_dates(\"[1,5]\", None)\n133\t\n134\t    for d in dates:\n135\t        week_num = d.isocalendar()[1]\n136\t        if week_num % 2 == 0:\n137\t            assert d.isoweekday() == 5  # Friday on even weeks\n138\t        else:\n139\t            assert d.isoweekday() == 1  # Monday on odd weeks\n140\t\n141\t\n142\tdef test_generate_dates_empty_frequency(so