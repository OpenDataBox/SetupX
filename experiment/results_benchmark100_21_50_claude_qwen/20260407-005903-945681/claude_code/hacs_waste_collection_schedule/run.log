rn [-,-,-,5] (Friday in weeks where (week-1)%4 == 3).\"\"\"\n285\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n286\t\n287\t    dates = source._generate_collection_dates(\"[-,-,-,5]\", None)\n288\t\n289\t    assert len(dates) > 0\n290\t    for d in dates:\n291\t        assert d.isoweekday() == 5  # Friday\n292\t        assert (d.isocalendar()[1] - 1) % 4 == 3  # Position 3 in 4-week cycle\n293\t\n294\t\n295\tdef test_generate_dates_4week_positions_0_and_2(source, monkeypatch):\n296\t    \"\"\"Test 4-week cycle pattern [2,-,2,-] (Tuesday in positions 0 and 2).\"\"\"\n297\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n298\t\n299\t    dates = source._generate_collection_dates(\"[2,-,2,-]\", None)\n300\t\n301\t    assert len(dates) > 0\n302\t    for d in dates:\n303\t        assert d.isoweekday() == 2  # Tuesday\n304\t        pos = (d.isocalendar()[1] - 1) % 4\n305\t        assert pos in [0, 2]  # Position 0 or 2 in 4-week cycle\n306\t\n307\t\n308\t# =============================================================================\n309\t# Tests for _generate_collection_dates - seasonal patterns\n310\t# =============================================================================\n311\t\n312\t\n313\tdef test_generate_dates_seasonal(source, monkeypatch):\n314\t    \"\"\"Test generating dates with seasonal frequency.\"\"\"\n315\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n316\t\n317\t    # Thursday in summer, Friday in winter\n318\t    dates = source._generate_collection_dates(\"[4,4];[5,5]\", \"01/04-31/10, 01/11-31/03\")\n319\t\n320\t    # December 2 is in winter, so we should get Fridays\n321\t    # Filter to just December dates for testing\n322\t    dec_dates = [d for d in dates if d.month == 12]\n323\t    for d in dec_dates:\n324\t        assert d.isoweekday() == 5  # Friday in winter\n325\t\n326\t\n327\t# =============================================================================\n328\t# Tests for WASTE_TYPES mapping