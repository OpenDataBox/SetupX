\n189\t    assert len(dates) > 0\n190\t    for d in dates:\n191\t        assert d.isoweekday() in [1, 3, 5]\n192\t\n193\t\n194\tdef test_generate_dates_multi_day_odd_only(source, monkeypatch):\n195\t    \"\"\"Test generating dates for multi-day pattern [135,-] (Mon, Wed, Fri on odd weeks only).\"\"\"\n196\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n197\t\n198\t    dates = source._generate_collection_dates(\"[135,-]\", None)\n199\t\n200\t    assert len(dates) > 0\n201\t    for d in dates:\n202\t        assert d.isoweekday() in [1, 3, 5]\n203\t        assert d.isocalendar()[1] % 2 == 1  # All should be odd weeks\n204\t\n205\t\n206\tdef test_generate_dates_multi_day_mixed(source, monkeypatch):\n207\t    \"\"\"Test generating dates for mixed pattern [13,25] (Mon/Wed on odd, Tue/Fri on even).\"\"\"\n208\t    monkeypatch.setattr(olo_sk.datetime, \"date\", FixedDate)\n209\t\n210\t    dates = source._generate_collection_dates(\"[13,25]\", None)\n211\t\n212\t    assert len(dates) > 0\n213\t    for d in dates:\n214\t        week_num = d.isocalendar()[1]\n215\t        if week_num % 2 == 1:  # Odd week\n216\t            assert d.isoweekday() in [1, 3]  # Monday or Wednesday\n217\t        else:  # Even week\n218\t            assert d.isoweekday() in [2, 5]  # Tuesday or Friday\n219\t\n220\t\n221\t# =============================================================================\n222\t# Tests for _generate_collection_dates - 4-week cycle patterns\n223\t# =============================================================================\n224\t\n225\t\n226\tdef test_generate_dates_4week_known_value_jan13(source, monkeypatch):\n227\t    \"\"\"Regression test: [-,-,2,-] should return Jan 13, 2026.\n228\t\n229\t    Verified against OLO website for registration 2318337.\n230\t    Jan 13, 2026 is Tuesday in ISO week 3, (3-1)%4 == 2.\n231\t    \"\"\"\n232\t\n233\t    class Jan1_2026(date):\n234\t        @classmethod\n235\t        def today(cls):\n236\t            return date(