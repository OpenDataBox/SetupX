{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_36f4aba018a14336b722462f","type":"tool_result","content":"1\t# Shortcuts for various tasks (UNIX only).\n2\t# To use a specific Python version run:\n3\t# \t$ make install PYTHON=python3.7\n4\t# To run a specific test:\n5\t# \t$ make test ARGS=\"-v -s tests/test_functional.py::TestIPv6MixedEnvironment::test_port_v4\"\n6\t\n7\t# Configurable\n8\tPYTHON = python3\n9\tARGS =\n10\t\n11\t# In not in a virtualenv, add --user options for install commands.\n12\tSETUP_INSTALL_ARGS = `$(PYTHON) -c \\\n13\t\t\"import sys; print('' if hasattr(sys, 'real_prefix') or hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix else '--user')\"`\n14\tPYTHON_ENV_VARS = PYTHONWARNINGS=always PYTHONUNBUFFERED=1 PYTEST_DISABLE_PLUGIN_AUTOLOAD=1\n15\tPIP_INSTALL_ARGS = --trusted-host files.pythonhosted.org --trusted-host pypi.org --upgrade\n16\t\n17\t# if make is invoked with no arg, default to `make help`\n18\t.DEFAULT_GOAL := help\n19\t\n20\t# install git hook\n21\t_ := $(shell mkdir -p .git/hooks/ && ln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)\n22\t\n23\t# ===================================================================\n24\t# Install\n25\t# ===================================================================\n26\t\n27\tclean:  ## Remove all build files.\n28\t\t@rm -rfv `find . \\\n29\t\t\t-type d -name __pycache__ \\\n30\t\t\t-o -type f -name \\*.bak \\\n31\t\t\t-o -type f -name \\*.orig \\\n32\t\t\t-o -type f -name \\*.pyc \\\n33\t\t\t-o -type f -name \\*.pyd \\\n34\t\t\t-o -type f -name \\*.pyo \\\n35\t\t\t-o -type f -name \\*.rej \\\n36\t\t\t-o -type f -name \\*.so \\\n37\t\t\t-o -type f -name \\*.~ \\\n38\t\t\t-o -type f -name \\*\\$testfn`\n39\t\t@rm -rfv \\\n40\t\t\t*.core \\\n41\t\t\t*.egg-info \\\n42\t\t\t*\\$testfile* \\\n43\t\t\t.coverage \\\n44\t\t\t.failed-tests.txt \\\n45\t\t\t.pytest_cache \\\n46\t\t\t.ruff_cache/ \\\n47\t\t\tbuild/ \\\n48\t\t\tdist/ \\\n49\t\t\tdocs/_build/ \\\n50\t\t\thtmlcov/ \\\n51\t\t\tpyftpd-tmp-* \\\n52\t\t\ttmp/\n53\t\n54\tinstall:  ## Install this package.\n55\t\t$(PYTHON) -m pip install -e . $(SETUP_INSTALL_ARGS)\n56\t\n57\tuninstall:  ## Uninstall this package.\n58\t\tcd ..; $(PYTHON) -m pip uninstall -y -v pyftpdlib || true\n59\t\t$(PYTHON) scripts/internal/purge_installation.py\n60\t\n61\tinstall-pip:  ## Install pip (no-op if already installed).\n62\t\t$(PYTHON) scripts/internal/install_pip.py\n63\t\n64\tinstall-pydeps-test:  ## Install python deps necessary to run unit tests.\n65\t\t${MAKE} install-pip\n66\t\t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n67\t\t$(PYTHON) -c \\\n68\t\t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'])\"\n69\t\n70\tinstall-pydeps-dev:  ## Install python deps meant for local development.\n71\t\t${MAKE} install-git-hooks\n72\t\t${MAKE} install-pip\n73\t\t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n74\t\t$(PYTHON) -c \\\n75\t\t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'] + d['dev'])\"\n76\t\n77\tinstall-git-hooks:  ## Install GIT pre-commit hook.\n78\t\tln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit\n79\t\tchmod +x .git/hooks/pre-commit\n80\t\n81\t# ===================================================================\n82\t# Tests\n83\t# ===================================================================\n84\t\n85\ttest:  ## Run all tests. To run a specific test: do \"make test ARGS=pyftpdlib.test.test_functional.TestFtpStoreData\"\n86\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS)\n87\t\n88\ttest-parallel:  ## Run all tests in parallel.\n89\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest -n auto --dist loadgroup $(ARGS)\n90\t\n91\ttest-functional:  ## Run functional FTP tests.\n92\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional.py\n93\t\n94\ttest-functional-ssl:  ## Run functional FTPS tests.\n95\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional_ssl.py\n96\t\n97\ttest-servers:  ## Run tests for FTPServer and its subclasses.\n98\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_servers.py\n99\t\n100\ttest-authorizers:  ## Run tests for authorizers.\n101\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_authorizers.py\n102\t\n103\ttest-filesystems:  ## Run filesystem tests.\n104\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_filesystems.py\n105\t\n106\ttest-ioloop:  ## Run IOLoop tests.\n107\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_ioloop.py\n108\t\n109\ttest-cli:  ## Run miscellaneous tests.\n110\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_cli.py\n111\t\n112\ttest-lastfailed:  ## Run previously failed tests\n113\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest --last-failed $(ARGS)\n114\t\n115\ttest-coverage:  ## Run test coverage.\n116\t\trm -rf .coverage htmlcov\n117\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m coverage run -m pytest $(ARGS)\n118\t\t$(PYTHON) -m coverage report\n119\t\t@echo \"writing results to htmlcov/index.html\"\n120\t\t$(PYTHON) -m coverage html\n121\t\t$(PYTHON) -m webbrowser -t htmlcov/index.html\n122\t\n123\t# ===================================================================\n124\t# Linters\n125\t# ===================================================================\n126\t\n127\tblack:  ## Python files linting (via black)\n128\t\t@git ls-files '*.py' | xargs $(PYTHON) -m black --check --safe\n129\t\n130\truff:  ## Run ruff linter.\n131\t\t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --output-format=concise\n132\t\n133\t_pylint:  ## Python pylint (not mandatory, just run it from time to time)\n134\t\t@git ls-files '*.py' | xargs $(PYTHON) -m pylint --rcfile=pyproject.toml --jobs=0 $(ARGS)\n135\t\n136\tlint-rst:  ## Run RsT linter.\n137\t\t@git ls-files '*.rst' | xargs rstcheck --config=pyproject.toml\n138\t\n139\tlint-toml:  ## Linter for pyproject.toml\n140\t\t@git ls-files '*.toml' | xargs toml-sort --check\n141\t\n142\tlint-all:  ## Run all linters\n143\t\t${MAKE} black\n144\t\t${MAKE} ruff\n145\t\t${MAKE} lint-rst\n146\t\t${MAKE} lint-toml\n147\t\n148\t# ===================================================================\n149\t# Fixers\n150\t# ===================================================================\n151\t\n152\tfix-black:\n153\t\tgit ls-files '*.py' | xargs $(PYTHON) -m black\n154\t\n155\tfix-ruff:\n156\t\t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --fix --output-format=concise $(ARGS)\n157\t\n158\tfix-toml:  ## Fix pyproject.toml\n159\t\t@git ls-files '*.toml' | xargs toml-sort\n160\t\n161\tfix-all:  ## Run all code fixers.\n162\t\t${MAKE} fix-black\n163\t\t${MAKE} fix-ruff\n164\t\t${MAKE} fix-toml\n165\t\n166\t# ===================================================================\n167\t# Distribution\n168\t# ===================================================================\n169\t\n170\t# --- create\n171\t\n172\tgenerate-manifest:  ## Generates MANIFEST.in file.\n173\t\t$(PYTHON) scripts/internal/generate_manifest.py > MANIFEST.in\n174\t\n175\tcreate-sdist:  ## Create tar.gz source distribution.\n176\t\t$(MAKE) generate-manifest\n177\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --sdist\n178\t\n179\tcreate-wheels:  ## Create .whl distribution.\n180\t\t$(MAKE) generate-manifest\n181\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --wheel\n182\t\n183\tcreate-dist:  ## Create .tar.gz + .whl distribution.\n184\t\t$(MAKE) create-sdist\n185\t\t$(MAKE) create-wheels\n186\t\n187\t# --- check\n188\t\n189\tcheck-manifest:  ## Check sanity of MANIFEST.in file.\n190\t\t$(PYTHON) -m check_manifest -v\n191\t\n192\tcheck-pyproject:  ## Check sanity of pyproject.toml file.\n193\t\t$(PYTHON) -m validate_pyproject -v pyproject.toml\n194\t\n195\tcheck-sdist:  ## Check sanity of source distribution.\n196\t\t$(PYTHON_ENV_VARS) $(PYTHON) -m virtualenv --clear --no-wheel --quiet build/venv\n197\t\t$(PYTHON_ENV_VARS) build/venv/bin/python -m pip install -v --isolated --quiet dist/*.tar.gz\n198\t\t$(PYTHON_ENV_VARS) build/venv/bin/python -c \"import os; os.chdir('build/venv'); import pyftpdlib\"\n199\t\t$(PYTHON) -m twine check --strict dist/*.tar.gz\n200\t\n201\tcheck-wheels:  ## Check sanity of wheels.\n202\t\t$(PYTHON) -m abi3audit --verbose --strict dist/*-abi3-*.whl\n203\t\t$(PYTHON) -m twine check --strict dist/*.whl\n204\t\n205\tcheck-dist:  ## Run all sanity checks re. to the package distribution.\n206\t\t$(MAKE) check-manifest\n207\t\t$(MAKE) check-pyproject\n208\t\t$(MAKE) check-sdist\n209\t\t$(MAKE) check-wheels\n210\t\n211\t# --- release\n212\t\n213\tpre-release:  ## Check if we're ready to produce a new release.\n214\t\t$(MAKE) clean\n215\t\t$(MAKE) create-dist\n216\t\t$(MAKE) check-dist\n217\t\t$(MAKE) install\n218\t\t@$(PYTHON) -c \\\n219\t\t\t\"import requests, sys; \\\n220\t\t\tfrom packaging.version import parse; \\\n221\t\t\tfrom pyftpdlib import __ver__; \\\n222\t\t\tres = requests.get('https://pypi.org/pypi/pyftpdlib/json', timeout=5); \\\n223\t\t\tversions = sorted(res.json()['releases'], key=parse, reverse=True); \\\n224\t\t\tsys.exit('version %r already exists on PYPI' % __ver__) if __ver__ in versions else 0\"\n225\t\t@$(PYTHON) -c \\\n226\t\t\t\"from pyftpdlib import __ver__ as ver; \\\n227\t\t\thistory = open('HISTORY.rst').read(); \\\n228\t\t\tassert ver in history, '%r not found in HISTORY.rst' % ver; \\\n229\t\t\tassert 'IN DEVELOPMENT' not in history, 'IN DEVELOPMENT found in HISTORY.rst';\"\n230\t\n231\trelease:  ## Upload a new release.\n232\t\t$(PYTHON) -m twine upload dist/*.tar.gz\n233\t\t$(PYTHON) -m twine upload dist/*.whl\n234\t\t$(MAKE) git-tag-release\n235\t\n236\tgit-tag-release:  ## Git-tag a new release.\n237\t\tgit tag -a release-`$(PYTHON) -c \"import pyftpdlib; print(pyftpdlib.__ver__)\"` -m `git rev-list HEAD --count`:`git rev-parse --short HEAD`\n238\t\tgit push --follow-tags\n239\t\n240\tprint-announce:  ## Print announce of new release.\n241\t\t@$(PYTHON) scripts/internal/print_announce.py\n242\t\n243\t# ===================================================================\n244\t# Misc\n245\t# ===================================================================\n246\t\n247\tgrep-todos:  ## Look for TODOs in source files.\n248\t\tgit grep -EIn \"TODO|FIXME|XXX\"\n249\t\n250\tcheck-broken-links:  ## Look for broken links in source files.\n251\t\tgit ls-files | xargs $(PYTHON) -Wa scripts/internal/check_broken_links.py\n252\t\n253\thelp: ## Display callable targets.\n254\t\t@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = \":.*?## \"}; {printf \"\\033[36m%-20s\\033[0m %s\\n\", $$1, $$2}'\n255\t"}]},"parent_tool_use_id":null,"session_id":"f79157cc-9e88-4e11-b284-6901db0a6656","uuid":"38b6700c-63bf-401a-ad17-bd054dd1d845","timestamp":"2026-04-07T00:09:40.682Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/Makefile","content":"# Shortcuts for various tasks (UNIX only).\n# To use a specific Python version run:\n# \t$ make install PYTHON=python3.7\n# To run a specific test:\n# \t$ make test ARGS=\"-v -s tests/test_functional.py::TestIPv6MixedEnvironment::test_port_v4\"\n\n# Configurable\nPYTHON = python3\nARGS =\n\n# In not in a virtualenv, add --user options for install commands.\nSETUP_INSTALL_ARGS = `$(PYTHON) -c \\\n\t\"import sys; print('' if hasattr(sys, 'real_prefix') or hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix else '--user')\"`\nPYTHON_ENV_VARS = PYTHONWARNINGS=always PYTHONUNBUFFERED=1 PYTEST_DISABLE_PLUGIN_AUTOLOAD=1\nPIP_INSTALL_ARGS = --trusted-host files.pythonhosted.org --trusted-host pypi.org --upgrade\n\n# if make is invoked with no arg, default to `make help`\n.DEFAULT_GOAL := help\n\n# install git hook\n_ := $(shell mkdir -p .git/hooks/ && ln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)\n\n# ===================================================================\n# Install\n# ===================================================================\n\nclean:  ## Remove all build files.\n\t@rm -rfv `find . \\\n\t\t-type d -name __pycache__ \\\n\t\t-o -type f -name \\*.bak \\\n\t\t-o -type f -name \\*.orig \\\n\t\t-o -type f -name \\*.pyc \\\n\t\t-o -type f -name \\*.pyd \\\n\t\t-o -type f -name \\*.pyo \\\n\t\t-o -type f -name \\*.rej \\\n\t\t-o -type f -name \\*.so \\\n\t\t-o -type f -name \\*.~ \\\n\t\t-o -type f -name \\*\\$testfn`\n\t@rm -rfv \\\n\t\t*.core \\\n\t\t*.egg-info \\\n\t\t*\\$testfile* \\\n\t\t.coverage \\\n\t\t.failed-tests.txt \\\n\t\t.pytest_cache \\\n\t\t.ruff_cache/ \\\n\t\tbuild/ \\\n\t\tdist/ \\\n\t\tdocs/_build/ \\\n\t\thtmlcov/ \\\n\t\tpyftpd-tmp-* \\\n\t\ttmp/\n\ninstall:  ## Install this package.\n\t$(PYTHON) -m pip install -e . $(SETUP_INSTALL_ARGS)\n\nuninstall:  ## Uninstall this package.\n\tcd ..; $(PYTHON) -m pip uninstall -y -v pyftpdlib || true\n\t$(PYTHON) scripts/internal/purge_installation.py\n\ninstall-pip:  ## Install pip (no-op if already installed).\n\t$(PYTHON) scripts/internal/install_pip.py\n\ninstall-pydeps-test:  ## Install python deps necessary to run unit tests.\n\t${MAKE} install-pip\n\t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n\t$(PYTHON) -c \\\n\t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'])\"\n\ninstall-pydeps-dev:  ## Install python deps meant for local development.\n\t${MAKE} install-git-hooks\n\t${MAKE} install-pip\n\t$(PYTHON) -m pip install $(PIP_INSTALL_ARGS) pip setuptools\n\t$(PYTHON) -c \\\n\t\t\"import tomllib, subprocess, sys; c = tomllib.load(open('pyproject.toml', 'rb')); d = c['project']['optional-dependencies']; subprocess.check_call([sys.executable, '-m', 'pip', 'install'] + '$(PIP_INSTALL_ARGS)'.split() + d['test'] + d['dev'])\"\n\ninstall-git-hooks:  ## Install GIT pre-commit hook.\n\tln -sf ../../scripts/internal/git_pre_commit.py .git/hooks/pre-commit\n\tchmod +x .git/hooks/pre-commit\n\n# ===================================================================\n# Tests\n# ===================================================================\n\ntest:  ## Run all tests. To run a specific test: do \"make test ARGS=pyftpdlib.test.test_functional.TestFtpStoreData\"\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS)\n\ntest-parallel:  ## Run all tests in parallel.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest -n auto --dist loadgroup $(ARGS)\n\ntest-functional:  ## Run functional FTP tests.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional.py\n\ntest-functional-ssl:  ## Run functional FTPS tests.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_functional_ssl.py\n\ntest-servers:  ## Run tests for FTPServer and its subclasses.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_servers.py\n\ntest-authorizers:  ## Run tests for authorizers.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_authorizers.py\n\ntest-filesystems:  ## Run filesystem tests.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_filesystems.py\n\ntest-ioloop:  ## Run IOLoop tests.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_ioloop.py\n\ntest-cli:  ## Run miscellaneous tests.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest $(ARGS) tests/test_cli.py\n\ntest-lastfailed:  ## Run previously failed tests\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m pytest --last-failed $(ARGS)\n\ntest-coverage:  ## Run test coverage.\n\trm -rf .coverage htmlcov\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m coverage run -m pytest $(ARGS)\n\t$(PYTHON) -m coverage report\n\t@echo \"writing results to htmlcov/index.html\"\n\t$(PYTHON) -m coverage html\n\t$(PYTHON) -m webbrowser -t htmlcov/index.html\n\n# ===================================================================\n# Linters\n# ===================================================================\n\nblack:  ## Python files linting (via black)\n\t@git ls-files '*.py' | xargs $(PYTHON) -m black --check --safe\n\nruff:  ## Run ruff linter.\n\t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --output-format=concise\n\n_pylint:  ## Python pylint (not mandatory, just run it from time to time)\n\t@git ls-files '*.py' | xargs $(PYTHON) -m pylint --rcfile=pyproject.toml --jobs=0 $(ARGS)\n\nlint-rst:  ## Run RsT linter.\n\t@git ls-files '*.rst' | xargs rstcheck --config=pyproject.toml\n\nlint-toml:  ## Linter for pyproject.toml\n\t@git ls-files '*.toml' | xargs toml-sort --check\n\nlint-all:  ## Run all linters\n\t${MAKE} black\n\t${MAKE} ruff\n\t${MAKE} lint-rst\n\t${MAKE} lint-toml\n\n# ===================================================================\n# Fixers\n# ===================================================================\n\nfix-black:\n\tgit ls-files '*.py' | xargs $(PYTHON) -m black\n\nfix-ruff:\n\t@git ls-files '*.py' | xargs $(PYTHON) -m ruff check --fix --output-format=concise $(ARGS)\n\nfix-toml:  ## Fix pyproject.toml\n\t@git ls-files '*.toml' | xargs toml-sort\n\nfix-all:  ## Run all code fixers.\n\t${MAKE} fix-black\n\t${MAKE} fix-ruff\n\t${MAKE} fix-toml\n\n# ===================================================================\n# Distribution\n# ===================================================================\n\n# --- create\n\ngenerate-manifest:  ## Generates MANIFEST.in file.\n\t$(PYTHON) scripts/internal/generate_manifest.py > MANIFEST.in\n\ncreate-sdist:  ## Create tar.gz source distribution.\n\t$(MAKE) generate-manifest\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --sdist\n\ncreate-wheels:  ## Create .whl distribution.\n\t$(MAKE) generate-manifest\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m build . --wheel\n\ncreate-dist:  ## Create .tar.gz + .whl distribution.\n\t$(MAKE) create-sdist\n\t$(MAKE) create-wheels\n\n# --- check\n\ncheck-manifest:  ## Check sanity of MANIFEST.in file.\n\t$(PYTHON) -m check_manifest -v\n\ncheck-pyproject:  ## Check sanity of pyproject.toml file.\n\t$(PYTHON) -m validate_pyproject -v pyproject.toml\n\ncheck-sdist:  ## Check sanity of source distribution.\n\t$(PYTHON_ENV_VARS) $(PYTHON) -m virtualenv --clear --no-wheel --quiet build/venv\n\t$(PYTHON_ENV_VARS) build/venv/bin/python -m pip install -v --isolated --quiet dist/*.tar.gz\n\t$(PYTHON_ENV_VARS) build/venv/bin/python -c \"import os; os.chdir('build/venv'); import pyftpdlib\"\n\t$(PYTHON) -m twine check --strict dist/*.tar.gz\n\ncheck-wheels:  ## Check sanity of wheels.\n\t$(PYTHON) -m abi3audit --verbose --strict dist/*-abi3-*.whl\n\t$(PYTHON) -m twine check --strict dist/*.whl\n\ncheck-dist:  ## Run all sanity checks re. to the package distribution.\n\t$(MAKE) check-manifest\n\t$(MAKE) check-pyproject\n\t$(MAKE) check-sdist\n\t$(MAKE) check-wheels\n\n# --- release\n\npre-release:  ## Check if we're ready to produce a new release.\n\t$(MAKE) clean\n\t$(MAKE) create-dist\n\t$(MAKE) check-dist\n\t$(MAKE) install\n\t@$(PYTHON) -c \\\n\t\t\"import requests, sys; \\\n\t\tfrom packaging.version import parse; \\\n\t\tfrom pyftpdlib import __ver__; \\\n\t\tres = requests.get('https://pypi.org/pypi/pyftpdlib/json', timeout=5); \\\n\t\tversions = sorted(res.json()['releases'], key=parse, reverse=True); \\\n\t\tsys.exit('version %r already exists on PYPI' % __ver__) if __ver__ in versions else 0\"\n\t@$(PYTHON) -c \\\n\t\t\"from pyftpdlib import __ver__ as ver; \\\n\t\thistory = open('HISTORY.rst').read(); \\\n\t\tassert ver in history, '%r not found in HISTORY.rst' % ver; \\\n\t\tassert 'IN DEVELOPMENT' not in history, 'IN DEVELOPMENT found in HISTORY.rst';\"\n\nrelease:  ## Upload a new release.\n\t$(PYTHON) -m twine upload dist/*.tar.gz\n\t$(PYTHON) -m twine upload dist/*.whl\n\t$(MAKE) git-tag-release\n\ngit-tag-release:  ## Git-tag a new release.\n\tgit tag -a release-`$(PYTHON) -c \"import pyftpdlib; print(pyftpdlib.__ver__)\"` -m `git rev-list HEAD --count`:`git rev-parse --short HEAD`\n\tgit push --follow-tags\n\nprint-announce:  ## Print announce of new release.\n\t@$(PYTHON) scripts/internal/print_announce.py\n\n# ===================================================================\n# Misc\n# ===================================================================\n\ngrep-todos:  ## Look for TODOs in source files.\n\tgit grep -EIn \"TODO|FIXME|XXX\"\n\ncheck-broken-links:  ## Look for broken links in source files.\n\tgit ls-files | xargs $(PYTHON) -Wa scripts/internal/check_broken_links.py\n\nhelp: ## Display callable targets.\n\t@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = \":.*?## \"}; {printf \"\\033[36m%-20s\\033[0m %s\\n\", $$1, $$2}'\n","numLines":255,"startLine":1,"totalLines":255}}}
