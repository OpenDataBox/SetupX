{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_950691672dd24ffaa95cb2f0","type":"tool_result","content":"1\timport json\n2\timport os\n3\t\n4\t\n5\tdef get_auto_db_vendor():\n6\t    \"\"\"Auto-detect database vendor by trying Django connections.\"\"\"\n7\t    # Try PostgreSQL first\n8\t    postgres_config = {\n9\t        \"ENGINE\": \"django.db.backends.postgresql\",\n10\t        \"NAME\": os.environ.get(\"DJSTRIPE_TEST_DB_NAME\", \"djstripe\"),\n11\t        \"USER\": os.environ.get(\"DJSTRIPE_TEST_DB_USER\", \"postgres\"),\n12\t        \"PASSWORD\": os.environ.get(\"DJSTRIPE_TEST_DB_PASS\", \"djstripe\"),\n13\t        \"HOST\": os.environ.get(\"DJSTRIPE_TEST_DB_HOST\", \"localhost\"),\n14\t        \"PORT\": os.environ.get(\"DJSTRIPE_TEST_DB_PORT\", \"5432\"),\n15\t        \"OPTIONS\": {\n16\t            \"connect_timeout\": 3,\n17\t        },\n18\t    }\n19\t\n20\t    # Use Django's database backend to check connectivity\n21\t    try:\n22\t        from django.db.backends.postgresql.base import DatabaseWrapper\n23\t\n24\t        # Try to create a test connection\n25\t        test_conn = DatabaseWrapper(postgres_config, \"test_postgres\")\n26\t        test_conn.ensure_connection()\n27\t        test_conn.close()\n28\t        return \"postgres\"\n29\t    except Exception:\n30\t        # PostgreSQL not available, fall back to SQLite\n31\t        return \"sqlite\"\n32\t\n33\t\n34\t# If DJSTRIPE_TEST_DB_VENDOR is not set, auto-detect\n35\ttest_db_vendor = os.environ.get(\"DJSTRIPE_TEST_DB_VENDOR\")\n36\tif test_db_vendor is None:\n37\t    # Auto-detect: try postgres first, fall back to sqlite\n38\t    test_db_vendor = get_auto_db_vendor()\n39\t    print(f\"Auto-detected database backend: {test_db_vendor}\")\n40\t\n41\ttest_db_name = os.environ.get(\"DJSTRIPE_TEST_DB_NAME\", \"djstripe\")\n42\ttest_db_user = os.environ.get(\"DJSTRIPE_TEST_DB_USER\", test_db_vendor)\n43\ttest_db_pass = os.environ.get(\"DJSTRIPE_TEST_DB_PASS\", \"djstripe\")\n44\ttest_db_port = os.environ.get(\"DJSTRIPE_TEST_DB_PORT\", \"\")\n45\t\n46\tDEBUG = True\n47\tSECRET_KEY = os.environ.get(\"DJSTRIPE_TEST_DJANGO_SECRET_KEY\", \"djstripe\")\n48\tSITE_ID = 1\n49\tTIME_ZONE = \"UTC\"\n50\tUSE_TZ = True\n51\tPROJECT_DIR = os.path.dirname(os.path.abspath(__file__))\n52\tBASE_DIR = os.path.dirname(PROJECT_DIR)\n53\t\n54\tALLOWED_HOSTS = json.loads(os.environ.get(\"DJSTRIPE_TEST_ALLOWED_HOSTS_JSON\", '[\"*\"]'))\n55\t\n56\tif test_db_vendor == \"postgres\":\n57\t    DATABASES = {\n58\t        \"default\": {\n59\t            \"ENGINE\": \"django.db.backends.postgresql\",\n60\t            \"NAME\": test_db_name,\n61\t            \"USER\": test_db_user,\n62\t            \"PASSWORD\": test_db_pass,\n63\t            \"HOST\": os.environ.get(\"DJSTRIPE_TEST_DB_HOST\", \"localhost\"),\n64\t            \"PORT\": test_db_port,\n65\t        }\n66\t    }\n67\telif test_db_vendor == \"mysql\":\n68\t    DATABASES = {\n69\t        \"default\": {\n70\t            \"ENGINE\": \"django.db.backends.mysql\",\n71\t            \"NAME\": test_db_name,\n72\t            \"USER\": os.environ.get(\"DJSTRIPE_TEST_DB_USER\", \"root\"),\n73\t            \"PASSWORD\": test_db_pass,\n74\t            \"HOST\": os.environ.get(\"DJSTRIPE_TEST_DB_HOST\", \"127.0.0.1\"),\n75\t            \"PORT\": test_db_port,\n76\t        }\n77\t    }\n78\telif test_db_vendor == \"sqlite\":\n79\t    # sqlite is not officially supported, but useful for quick testing.\n80\t    # may be dropped if we can't maintain compatibility.\n81\t    DATABASES = {\n82\t        \"default\": {\n83\t            \"ENGINE\": \"django.db.backends.sqlite3\",\n84\t            \"NAME\": os.path.join(BASE_DIR, \"db.sqlite3\"),\n85\t            # use a on-disk db for test so --reuse-db can be used\n86\t            \"TEST\": {\"NAME\": os.path.join(BASE_DIR, \"test_db.sqlite3\")},\n87\t        }\n88\t    }\n89\telse:\n90\t    raise NotImplementedError(f\"DJSTRIPE_TEST_DB_VENDOR = {test_db_vendor}\")\n91\t\n92\t\n93\tTE