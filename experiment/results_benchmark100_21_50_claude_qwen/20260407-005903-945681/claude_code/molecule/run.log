t  \"W1406\",  # redundant-u-string-prefix / ruff UP025\n379\t  \"W1501\",  # bad-open-mode / ruff PLW1501\n380\t  \"W1508\",  # invalid-envvar-default / ruff PLW1508\n381\t  \"W1509\",  # subprocess-popen-preexec-fn / ruff PLW1509\n382\t  \"W1510\",  # subprocess-run-check / ruff PLW1510\n383\t  \"W1514\",  # unspecified-encoding / ruff PLW1514\n384\t  \"W1515\",  # forgotten-debug-statement / ruff T100\n385\t  \"W1518\",  # method-cache-max-size-none / ruff B019\n386\t  \"W1641\",  # eq-without-hash / ruff PLW1641\n387\t  \"W2101\",  # useless-with-lock / ruff PLW2101\n388\t  \"W2402\",  # non-ascii-file-name / ruff N999\n389\t  \"W2901\",  # redefined-loop-name / ruff PLW2901\n390\t  \"W3201\",  # bad-dunder-name / ruff PLW3201\n391\t  \"W3301\",  # nested-min-max / ruff PLW3301\n392\t  \"duplicate-code\",\n393\t  \"too-few-public-methods\",\n394\t  \"too-many-instance-attributes\",\n395\t]\n396\tenable = [\"useless-suppression\"]\n397\tfail-on = [\"useless-suppression\"]\n398\t\n399\t[tool.pytest]\n400\taddopts = [\"--durations=10\", \"--showlocals\", \"-ra\"]\n401\tcache_dir = \"./.cache/.pytest\"\n402\tjunit_family = \"xunit2\"\n403\tmarkers = [\n404\t  \"extensive: marks tests that we want to skip by default, as they are indirectly covered by other tests\",\n405\t  \"serial: Run this test serially via filelock.\",\n406\t]\n407\tnorecursedirs = [\".ansible\", \"scenarios\"]\n408\ttestpaths = [\"tests\"]\n409\tverbosity_assertions = 2\n410\t\n411\t[tool.ruff]\n412\tbuiltins = [\"__\"]\n413\tcache-dir = \"./.cache/.ruff\"\n414\tfix = true\n415\tline-length = 100\n416\trequired-version = \">=0.7.1\"\n417\ttarget-version = \"py310\"\n418\t\n419\t[tool.ruff.lint]\n420\texternal = [\n421\t  \"DOC\",  # pydoclint\n422\t]\n423\tignore = [\n424\t  \"COM812\",  # conflicts with ISC001 on format\n425\t  \"E501\",  # line-too-long / rely on black\n426\t  \"ISC001\",  # conflicts with COM812 on format\n427\t  \"S603\",  # subprocess\n428\t  \"S607\",  # subprocess\n429\t]\n430\tselect = [\"ALL\"]\n431\t\n432\t[tool.ruff.lint.flake8-pytest-style]\n433\tparametrize-values-type = \"tuple\"\n434\t\n435\t[tool.ruff.lint.isort]\n436\tknown-first-party = [\"src\"]\n437\tlines-after-imports = 2  # Ensures consistency for cases when there's variable vs function/class definitions after imports\n438\tlines-between-types = 1  # Separate import/from with 1 line\n439\trequired-imports = [\"from __future__ import annotations\"]\n440\t\n441\t[tool.ruff.lint.per-file-ignores]\n442\t\"_version.py\" = [\"SIM108\"]\n443\t\"tests/**\" = [\"SLF001\", \"S101\", \"S602\", \"T201\", \"D417\", \"ARG001\", \"ANN001\"]\n444\t\n445\t[tool.ruff.lint.pydocstyle]\n446\tconvention = \"google\"\n447\t\n448\t[tool.setuptools_scm]\n449\t# To prevent accidental pick of mobile version tags such 'v6'\n450\tgit_describe_command = [\n451\t  \"git\",\n452\t  \"describe\",\n453\t  \"--dirty\",\n454\t  \"--long\",\n455\t  \"--tags\",\n456\t  \"--match\",\n457\t  \"v*.*\",\n458\t]\n459\tlocal_scheme = \"no-local-version\"\n460\ttag_regex = \"^(?P<prefix>v)?(?P<version>\\\\d+[^\\\\+]*)(?P<suffix>.*)?$\"\n461\tversion_file = \"src/molecule/_version.py\"\n462\t\n463\t[tool.tomlsort]\n464\tin_place = true\n465\tsort_inline_tables = true\n466\tsort_table_keys = true\n467\t\n468\t[tool.tox]\n469\tenv_list = [\n470\t  \"py\",\n471\t  \"collection\",\n472\t  \"deps\",\n473\t  \"docs\",\n474\t  \"lint\",\n475\t  \"milestone\",\n476\t  \"pkg\",\n477\t  \"eco\",\n478\t]\n479\trequires = [\"tox>=4.46.0\", \"tox-extra>=2.2.0\", \"tox-uv>=1.32.1\"]\n480\tskip_missing_interpreters = true\n481\t\n482\t[tool.tox.env.collection]\n483\tcommands = [[\"tox\", \"--ansible\", \"-c\", \"community.molecule/tox-ansible.ini\"]]\n484\tcommands_post = []\n485\tcommands_pre = []\n486\tdependency_groups = [\"collection\"]\n487\tdescription = \"Test community.molecule collection\"\n488\t\n489\t[tool.tox.env.deps]\n490\tcommands = [\n491\t  [\n492\t    \"prek\",\n493\t    \"run\",\n494\t    \"--all-files\",\n495\t    \"--show-diff-on-failure\",\n496\t    \"--hook-stage\",\n497\t    \"manual\",\n498\t    \"deps\",\n499\t  ],\n500\t  [\"prek\", \"autoupdate\"],\n501\t  [\"tox\", \"-e\", \"lint\"],\n502\t]\n503\tcommands_pre = []\n504\tdependency_groups = [\"lint\"]\n505\tdescription = \"Bump all test dependencies\"\n506\tenv_dir = \"{work_dir}/lint\"\n507\trunner = \"uv-venv-runner\"\n508\tskip_install = true\n509\t\n510\t[tool.tox.env.devel]\n511\tdependency_groups = [\"dev\"]\n512\tdeps = [\"ansible-core @ git+https://github.com/ansible/ansible.git\"]\n513\tdescription = \"Run the tests with newest dependencies (no lock and allowing prereleases)\"\n514\trunner = \"uv-venv-runner\"\n515\tuv_sync_flags = [\"--upgrade\", \"--prerelease=allow\"]\n516\tuv_sync_locked = false\n517\t\n518\t[tool.tox.env.docs]\n519\tcommands = [\n520\t  [\n521\t    \"mkdocs\",\n522\t    { default = [\"build\", \"--strict\", \"--site-dir=_readthedocs/html/\"], extend = true, replace = \"posargs\" },\n523\t  ],\n524\t]\n525\tcommands_post = []\n526\tcommands_pre = []\n527\tdependency_groups = [\"docs\"]\n528\tdescription = \"Builds docs\"\n529\tskip_install = false\n530\tset_env.DYLD_FALLBACK_LIBRARY_PATH = \"/opt/homebrew/lib:{env:LD_LIBRARY_PATH}\"\n531\tset_env.NO_COLOR = \"1\"\n532\tset_env.TERM = \"dump\"\n533\t\n534\t[tool.tox.env.eco]\n535\tcommands = [\n536\t  [\"uv\", \"pip\", \"check\"],\n537\t  [\"uv\", \"pip\", \"tree\", \"--invert\"],\n538\t  [\"molecule\", \"--version\"],\n539\t  [\"molecule\", \"drivers\"],\n540\t]\n541\tdeps = [\n542\t  \"molecule-plugins[azure,containers,docker,ec2,gce,podman,vagrant]>=23\",\n543\t  \"tox-ansible>=26.2.1\",\n544\t  \"uv\",\n545\t]\n546\tdescription = \"Smoketest of combining all known to be maintained plugins (ecosystem)\"\n547\tpip_pre = true\n548\t\n549\t[tool.tox.env.lint]\n550\tcommands = [[\"prek\", \"run\", \"--all-files\", \"--show-diff-on-failure\"]]\n551\tcommands_pre = []\n552\tdependency_groups = [\"lint\"]\n553\tdescription = \"Run all linters\"\n554\tskip_install = true\n555\t\n556\t[tool.tox.env.lower]\n557\tbase_python = [\"python3.10\"]\n558\tdependency_groups = [\"dev\"]\n559\tdescription = \"Install using lowest constraints possible.\"\n560\trunner = \"uv-venv-runner\"\n561\tuv_resolution = \"lowest\"\n562\t\n563\t[tool.tox.env.milestone]\n564\tdependency_groups = [\"dev\"]\n565\tdeps = [\n566\t  \"ansible-core@ https://github.com/ansible/ansible/archive/milestone.tar.gz\",\n567\t]\n568\tdescription = \"Run tests with ansible-core milestone branch and without dependencies constraints\"\n569\trunner = \"uv-venv-runner\"\n570\tuv_sync_locked = false\n571\t\n572\t[tool.tox.env.pkg]\n573\tcommands = [\n574\t  [\"rm\", \"-rf\", \"{tox_root}/dist/\"],\n575\t  [\n576\t    \"python\",\n577\t    \"-m\",\n578\t    \"build\",\n579\t    \"--outdir\",\n580\t    \"{tox_root}/dist/\",\n581\t    \"{tox_root}\",\n582\t  ],\n583\t  [\"sh\", \"-c\", \"python -m twine check --strict {tox_root}/dist/*\"],\n584\t]\n585\tcommands_post = []\n586\tcommands_pre = []\n587\tdependency_groups = [\"pkg\"]\n588\tdescription = \"\"\"\n589\tBuild package, verify metadata, install package and assert behavior when ansible is missing.\n590\t\"\"\"\n591\tskip_install = true\n592\t\n593\t[tool.tox.env_run_base]\n594\tallowlist_externals = [\"./tools/report-coverage\", \"rm\", \"sh\"]\n595\tcommands = [\n596\t  [\n597\t    \"python\",\n598\t    \"-c\",\n599\t    \"import pathlib; pathlib.Path(\\\"{env_site_packages_dir}/cov.pth\\\").write_text(\\\"import coverage; coverage.process_startup()\\\")\",\n600\t  ],\n601\t  [\n602\t    \"python\",\n603\t    \"-m\",\n604\t    \"coverage\",\n605\t    \"run\",\n606\t    \"-m\",\n607\t    \"pytest\",\n608\t    { default = [\n609\t      \"-ra\",\n610\t      \"-n\",\n611\t      \"auto\",\n612\t      \"--showlocals\",\n613\t      \"--doctest-modules\",\n614\t      \"--durations=10\",\n615\t      \"--junitxml=./junit.xml\",\n616\t    ], extend = true, replace = \"posargs\" },\n617\t  ],\n618\t