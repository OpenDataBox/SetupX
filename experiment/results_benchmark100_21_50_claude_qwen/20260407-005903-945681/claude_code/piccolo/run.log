{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_fb574e2f745546abb8ac2b38","type":"tool_result","content":"1\tname: Test Suite\n2\t\n3\ton:\n4\t    push:\n5\t        branches: [\"master\", \"v1\"]\n6\t        paths-ignore:\n7\t            - \"docs/**\"\n8\t    pull_request:\n9\t        branches: [\"master\", \"v1\"]\n10\t        paths-ignore:\n11\t            - \"docs/**\"\n12\t\n13\tjobs:\n14\t    linters:\n15\t        runs-on: ubuntu-latest\n16\t        timeout-minutes: 60\n17\t        strategy:\n18\t            matrix:\n19\t                python-version: [\"3.10\", \"3.11\", \"3.12\", \"3.13\", \"3.14\"]\n20\t\n21\t        steps:\n22\t            - uses: actions/checkout@v3\n23\t            - name: Set up Python ${{ matrix.python-version }}\n24\t              uses: actions/setup-python@v5\n25\t              with:\n26\t                  python-version: ${{ matrix.python-version }}\n27\t            - name: Install dependencies\n28\t              run: |\n29\t                  python -m pip install --upgrade pip\n30\t                  pip install -r requirements/requirements.txt\n31\t                  pip install -r requirements/dev-requirements.txt\n32\t                  pip install -r requirements/test-requirements.txt\n33\t            - name: Lint\n34\t              run: ./scripts/lint.sh\n35\t\n36\t    integration:\n37\t        runs-on: ubuntu-latest\n38\t        timeout-minutes: 60\n39\t        strategy:\n40\t            matrix:\n41\t                # These tests are slow, so we only run on the latest Python\n42\t                # version.\n43\t                python-version: [\"3.13\"]\n44\t                postgres-version: [17]\n45\t        services:\n46\t            postgres:\n47\t                image: postgres:${{ matrix.postgres-version }}\n48\t                env:\n49\t                    POSTGRES_PASSWORD: postgres\n50\t                options: >-\n51\t                    --health-cmd pg_isready\n52\t                    --health-interval 10s\n53\t                    --health-timeout 5s\n54\t                    --health-retries 5\n55\t                ports:\n56\t                    - 5432:5432\n57\t        steps:\n58\t            - uses: actions/checkout@v3\n59\t            - name: Set up Python ${{ matrix.python-version }}\n60\t              uses: actions/setup-python@v5\n61\t              with:\n62\t                  python-version: ${{ matrix.python-version }}\n63\t            - name: Install dependencies\n64\t              run: |\n65\t                  python -m pip install --upgrade pip\n66\t                  pip install -r requirements/requirements.txt\n67\t                  pip install -r requirements/test-requirements.txt\n68\t                  pip install -r requirements/extras/postgres.txt\n69\t            - name: Setup postgres\n70\t              run: |\n71\t                  export PGPASSWORD=postgres\n72\t                  psql -h localhost -c 'CREATE DATABASE piccolo;' -U postgres\n73\t                  psql -h localhost -c \"CREATE USER piccolo PASSWORD 'piccolo';\" -U postgres\n74\t                  psql -h localhost -c \"GRANT ALL PRIVILEGES ON DATABASE piccolo TO piccolo;\" -U postgres\n75\t                  psql -h localhost -c \"CREATE EXTENSION IF NOT EXISTS \\\"uuid-ossp\\\";\" -d piccolo -U postgres\n76\t            - name: Run integration tests\n77\t              run: ./scripts/test-integration.sh\n78\t              env:\n79\t                  PG_HOST: localhost\n80\t                  PG_DATABASE: piccolo\n81\t                  PG_PASSWORD: postgres\n82\t\n83\t    postgres:\n84\t        runs-on: ubuntu-latest\n85\t        timeout-minutes: 60\n86\t        strategy:\n87\t            matrix:\n88\t                python-version: [\"3.10\", \"3.11\", \"3.12\", \"3.13\", \"3.14\"]\n89\t                postgres-version: [13, 14, 15, 16, 17, 18]\n90\t\n91\t        # Service containers to run with `container-job`\n92\t        services:\n93\t            # Label used to access the service container\n94\t            postgres:\n95\t                # Docker Hub image\n96\t                image: postgres:${{ matrix.postgres-version }}\n97\t                # Provide the password for postgres\n98\t                env:\n99\t                    POSTGRES_PASSWORD: postgres\n100\t                # Set health checks to wait until postgres has started\n101\t                options: >-\n102\t                    --health-cmd pg_isready\n103\t                    --health-interval 10s\n104\t                    --health-timeout 5s\n105\t                    --health-retries 5\n106\t                ports:\n107\t                    - 5432:5432\n108\t\n109\t        steps:\n110\t            - uses: actions/checkout@v3\n111\t            - name: Set up Python ${{ matrix.python-version }}\n112\t              uses: actions/setup-python@v5\n113\t              with:\n114\t                  python-version: ${{ matrix.python-version }}\n115\t            - name: Install dependencies\n116\t              run: |\n117\t                  python -m pip install --upgrade pip\n118\t                  pip install -r requirements/requirements.txt\n119\t                  pip install -r requirements/test-requirements.txt\n120\t                  pip install -r requirements/extras/postgres.txt\n121\t            - name: Setup postgres\n122\t              run: |\n123\t                  export PGPASSWORD=postgres\n124\t                  psql -h localhost -c 'CREATE DATABASE piccolo;' -U postgres\n125\t                  psql -h localhost -c \"CREATE USER piccolo PASSWORD 'piccolo';\" -U postgres\n126\t                  psql -h localhost -c \"GRANT ALL PRIVILEGES ON DATABASE piccolo TO piccolo;\" -U postgres\n127\t                  psql -h localhost -c \"CREATE EXTENSION IF NOT EXISTS \\\"uuid-ossp\\\";\" -d piccolo -U postgres\n128\t\n129\t            - name: Test with pytest, Postgres\n130\t              run: ./scripts/test-postgres.sh\n131\t              env:\n132\t                  PG_