{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_aa90df476fd346b8add135f0","type":"tool_result","content":"1\t#!/usr/bin/env python\n2\t# -*- coding: utf-8 -*-\n3\t\n4\timport itertools\n5\timport os\n6\t\n7\tfrom setuptools import find_packages, setup\n8\t\n9\tfrom piccolo import __VERSION__ as VERSION\n10\t\n11\tdirectory = os.path.abspath(os.path.dirname(__file__))\n12\t\n13\textras = [\"orjson\", \"playground\", \"postgres\", \"sqlite\", \"uvloop\"]\n14\t\n15\t\n16\twith open(os.path.join(directory, \"README.md\")) as f:\n17\t    LONG_DESCRIPTION = f.read()\n18\t\n19\t\n20\tdef parse_requirement(req_path: str) -> list[str]:\n21\t    \"\"\"\n22\t    Parse requirement file.\n23\t    Example:\n24\t        parse_requirement('requirements.txt')       # requirements/requirements.txt\n25\t        parse_requirement('extras/playground.txt')  # requirements/extras/playground.txt\n26\t    Returns:\n27\t        List[str]: list of requirements specified in the file.\n28\t    \"\"\"  # noqa: E501\n29\t    with open(os.path.join(directory, \"requirements\", req_path)) as f:\n30\t        contents = f.read()\n31\t        return [i.strip() for i in contents.strip().split(\"\\n\")]\n32\t\n33\t\n34\tdef extras_require() -> dict[str, list[str]]:\n35\t    \"\"\"\n36\t    Parse requirements in requirements/extras directory\n37\t    \"\"\"\n38\t    extra_requirements = {\n39\t        extra: parse_requirement(os.path.join(\"extras\", f\"{extra}.txt\"))\n40\t        for extra in extras\n41\t    }\n42\t\n43\t    extra_requirements[\"all\"] = list(\n44\t        itertools.chain.from_iterable(extra_requirements.values())\n45\t    )\n46\t\n47\t    return extra_requirements\n48\t\n49\t\n50\tsetup(\n51\t    name=\"piccolo\",\n52\t    version=VERSION,\n53\t    description=(\n54\t        \"A fast, user friendly ORM and query builder which supports asyncio.\"\n55\t    ),\n56\t    long_description=LONG_DESCRIPTION,\n57\t    long_description_content_type=\"text/markdown\",\n58\t    author=\"Daniel Townsend\",\n59\t    author_email=\"dan@dantownsend.co.uk\",\n60\t    python_requires=\">=3.10.0\",\n61\t    url=\"https://github.com/piccolo-orm/piccolo\",\n62\t    packages=find_packages(exclude=(\"tests\",)),\n63\t    package_data={\n64\t        \"\": [\n65\t            \"templates/*\",\n66\t            \"templates/**/*\",\n67\t            \"templates/**/**/*\",\n68\t            \"templates/**/**/**/*\",\n69\t        ],\n70\t        \"piccolo\": [\"py.typed\"],\n71\t    },\n72\t    project_urls={\n73\t        \"Documentation\": (\n74\t            \"https://piccolo-orm.readthedocs.io/en/latest/index.html\"\n75\t        ),\n76\t        \"Source\": \"https://github.com/piccolo-orm/piccolo\",\n77\t        \"Tracker\": \"https://github.com/piccolo-orm/piccolo/issues\",\n78\t    },\n79\t    install_requires=parse_requirement(\"requirements.txt\"),\n80\t    extras_require=extras_require(),\n81\t    license=\"MIT\",\n82\t    classifiers=[\n83\t        \"License :: OSI Approved :: MIT License\",\n84\t        \"Programming Language :: Python\",\n85\t        \"Programming Language :: Python :: 3\",\n86\t        \"Programming Language :: Python :: 3.10\",\n87\t        \"Programming Language :: Python :: 3.11\",\n88\t        \"Programming Language :: Python :: 3.12\",\n89\t        \"Programming Language :: Python :: 3.13\",\n90\t        \"Programming Language :: Python :: 3.14\",\n91\t        \"Programming Language :: Python :: Implementation :: CPython\",\n92\t        \"Framework :: AsyncIO\",\n93\t        \"Typing :: Typed\",\n94\t        \"Topic :: Database\",\n95\t    ],\n96\t    entry_points={\"console_scripts\": [\"piccolo = piccolo.main:main\"]},\n97\t)\n98\t"}]},"parent_tool_use_id":null,"session_id":"d7965ee4-3d89-4542-b2ab-eb6bdf35cf61","uuid":"7eb0f384-fc64-440b-893e-fd6574f69c10","timestamp":"2026-04-06T23:57:37.745Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/setup.py","content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\nimport itertools\nimport os\n\nfrom setuptools import find_packages, setup\n\nfrom piccolo import __VERSION__ as VERSION\n\ndirectory = os.path.abspath(os.path.dirname(__file__))\n\nextras = [\"orjson\", \"playground\", \"postgres\", \"sqlite\", \"uvloop\"]\n\n\nwith open(os.path.join(directory, \"README.md\")) as f:\n    LONG_DESCRIPTION = f.read()\n\n\ndef parse_requirement(req_path: str) -> list[str]:\n    \"\"\"\n    Parse requirement file.\n    Example:\n        parse_requirement('requirements.txt')       # requirements/requirements.txt\n        parse_requirement('extras/playground.txt')  # requirements/extras/playground.txt\n    Returns:\n        List[str]: list of requirements specified in the file.\n    \"\"\"  # noqa: E501\n    with open(os.path.join(directory, \"requirements\", req_path)) as f:\n        contents = f.read()\n        return [i.strip() for i in contents.strip().split(\"\\n\")]\n\n\ndef extras_require() -> dict[str, list[str]]:\n    \"\"\"\n    Parse requirements in requirements/extras directory\n    \"\"\"\n    extra_requirements = {\n        extra: parse_requirement(os.path.join(\"extras\", f\"{extra}.txt\"))\n        for extra in extras\n    }\n\n    extra_requirements[\"all\"] = list(\n        itertools.chain.from_iterable(extra_requirements.values())\n    )\n\n    return extra_requirements\n\n\nsetup(\n    name=\"piccolo\",\n    version=VERSION,\n    description=(\n        \"A fast, user friendly ORM and query builder which supports asyncio.\"\n    ),\n    long_description=LONG_DESCRIPTION,\n    long_description_content_type=\"text/markdown\",\n    author=\"Daniel Townsend\",\n    author_email=\"dan@dantownsend.co.uk\",\n    python_requires=\">=3.10.0\",\n    url=\"https://github.com/piccolo-orm/piccolo\",\n    packages=find_packages(exclude=(\"tests\",)),\n    package_data={\n        \"\": [\n            \"templates/*\",\n            \"templates/**/*\",\n            \"templates/**/**/*\",\n            \"templates/**/**/**/*\",\