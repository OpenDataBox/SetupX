{"type":"user","uuid":"2ed1d84a-3848-48d1-ac8e-1ad51387c708","session_id":"1a0e28d3-691f-41b9-80b1-e4a04bd1fb82","parent_tool_use_id":null,"message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5c2100127cfe43a498357fbc","is_error":false,"content":"---\nci:\n  # We rely on renovate to update it but there is no way to fully disable it\n  # https://github.com/pre-commit-ci/issues/issues/83\n  autoupdate_schedule: quarterly\n  skip:\n    - codecov\n    - codespell # missing uv\n    - cspell\n    - md # missing uv\n    - mypy # missing uv\n    - ruff # missing uv\n    - shellcheck # missing uv\n    - toml # missing uv\n    - yamllint # missing uv\n\ndefault_language_version:\n  # minimal version we support officially as this will impact mypy, pylint\n  # minimal version determined by minimal version required by ansible-core, but\n  # we might keep a backwards compatibility version for older ones\n  python: \"3.11\"\nrepos:\n  - repo: meta\n    hooks:\n      - id: check-useless-excludes\n  - repo: https://github.com/ansible/actions\n    rev: v0.5.1\n    hooks:\n      - id: toml\n        priority: 0\n      - id: mypy\n        priority: 1\n      - id: ruff\n        priority: 0\n      - id: codespell\n        priority: 1\n      - id: cspell\n        priority: 0\n      - id: yamllint\n        priority: 0\n      - id: md\n        priority: 0\n      - id: codecov\n        priority: 0\n      - id: shellcheck\n        priority: 0\n  - repo: https://github.com/astral-sh/uv-pre-commit\n    rev: 0.10.7\n\n    hooks:\n      - id: uv-sync\n      - id: uv-lock\n      - id: uv-lock\n        name: \"deps: upgrade via uv sync --upgrade\"\n        alias: deps\n        args: [\"--upgrade\"]\n        stages: [manual]\n  - repo: https://github.com/biomejs/pre-commit\n    rev: \"v2.4.4\"\n    hooks:\n      - id: biome-check\n        name: biome\n        alias: biome\n        args: [--unsafe]\n        priority: 0\n  - repo: https://github.com/pre-commit/pre-commit-hooks.git\n    rev: v6.0.0\n    hooks:\n      - id: check-added-large-files\n      - id: check-merge-conflict\n      - id: check-symlinks\n      - id: debug-statements\n      - id: detect-private-key\n      - id: end-of-file-fixer\n      - id: trailing-whitespace\n\n  - repo: https://github.com/rhysd/actionlint\n    rev: v1.7.11\n    hooks:\n      - id: actionlint\n        priority: 0\n\n  - repo: https://github.com/jsh9/pydoclint\n    rev: \"0.8.3\"\n    hooks:\n      - id: pydoclint\n        # This allows automatic reduction of the baseline file when needed.\n        entry: sh -ec \"pydoclint . && pydoclint --generate-baseline=1 .\"\n        pass_filenames: false\n        priority: 1\n\n  - repo: https://github.com/pycqa/pylint.git\n    rev: v4.0.5\n    hooks:\n      - id: pylint\n        priority: 1\n        args:\n          - --output-format=colorized\n        additional_dependencies:\n          - ansible-compat>=25.1.4\n          - click\n          - click-help-colors\n          - enrich>=1.2.7\n          - filelock\n          - jsonschema\n          - pexpect\n          - pytest-mock\n          - pytest-testinfra\n          - wcmatch\n\n  - repo: https://github.com/ansible/ansible-lint\n    rev: v26.2.0\n    hooks:\n      - id: ansible-lint\n        stages: [manual]\n  - repo: https://github.com/ansible/team-devtools\n    rev: v26.2.0\n    hooks:\n      - id: check-platform-constraints\n"}]}}
